[Comment]
// Проводник караванов Хэл
20+ квест - Бракованная партия винтовок

[Dialog]
Speech 1 # Predialogue installations
  Answer 2 # в НКР или Реддинге
    Demand Script Caravan::d_CaravanEndedOrNotStarted
