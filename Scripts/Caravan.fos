///@ Property Critter Server uint8 NcrCrvResetCounter Mutable Persistent Max = 5
///@ Property Critter Server uint8 BHCrvResetCounter Mutable Persistent Max = 5
///@ Property Critter Server uint8 ArroyoCrvResetCounter Mutable Persistent Max = 15
