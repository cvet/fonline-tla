namespace NcrMichael
{

#if SERVER

// Майкл хочет пройти внутрь города, игроки ему помогают
// после того, как диалогом вызывается соотвествующая функция, майrл отправляется к воротам, происходит небольшая сценка с охраной и он проходит внутрь
// движение нужно начинать не сразу, а через некоторое время
// Для квеста "Пропуск"

///@ Property Critter Server int32 NcrMichealMessageNum Mutable Persistent
///@ Property Map Server ident NcrMichaelCritterId Mutable Persistent

const hstring HEX_EXIT_GRID = ("" + 17).hstr();      // гекс перехода базар/центр города
const int NPC_ROLE_PRIVATE = 317;                    // рядовой на воротах (юг)
const int NPC_ROLE_MAIN = 318;                       // командир охраны на воротах (север)
const int MSG_NUM_INCOMING_MIKE = 317;               // номер сообщения - Майк приближается.
const int MSG_NUM_INCOMING_MIKE_GUARD = 318;         // номер сообщения - Майк приближается.
const hstring HEX_NEW_MIKE_HOME = ("" + 171).hstr(); // номер гекса новой домашней позиции майка

const int MSG_NUM_START_MOVE = 2910; // {2910}{}{Посмотрим, что изменилось в Республике...}
const int MSG_NUM_SEE_MIKE = 2911;   // {2911}{}{Бог ты мой, это же Майкл! Майкл, какими судьбами?}
const int MSG_NUM_SHOUT = 2912;      // {2912}{}{Отставить базар! Ему разрешено пройти.}

// вызов из диалога - начало движения
[[DialogResult]]
void PrepareComing(Critter player, Critter npc, any val)
{
    // движение начинаем через 3 игровые минуты
    NpcPlanes::AddMiscPlane(npc, 2, Game.SynchronizedTime + Time::GameMinutes(3), NcrMichael::StartMichaelMove);

    npc.NcrMichealMessageNum = MSG_NUM_INCOMING_MIKE;
    npc.OnNpcPlaneEnd.Subscribe(MichaelPlaneEnd);
}

// начало движения
void StartMichaelMove(Critter npc)
{
    // сообщаем миру о начале движения
    Messaging::SayOnHead(npc, TextPackKey(TextPackName::Text, "" + (MSG_NUM_START_MOVE))); // "Посмотрим, что изменилось в Республике...");
    // координаты гекса, до которого должен дойти майкл
    auto hex = npc.Hex;
    Map? map = npc.GetMap();
    if (map == null) {
        return;
    }

    // не найден гекс, идти некуда
    if (!Entrance::GetNearEntry(map, HEX_EXIT_GRID, hex)) {
        return;
    }

    // при установке новой домащней позиции, Майкл туда проследует, когда закончит все текущие планы
    npc.HomeHex = hex;
    npc.HomeDir = HDIR_Random.value;
}

// завершение выполнения некоего плана
[[Event]]
EventResult MichaelPlaneEnd(Critter npc, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(npc, planeId);

    // Messaging::SayOnHead(npc, "Plane end. ID: " + plane.Identifier + " reason: " + reason);
    // завершен план следования к экзит гриду
    if (npc.NcrMichealMessageNum == MSG_NUM_INCOMING_MIKE && npc.MapId == npc.HomeMapId && npc.Hex.x == npc.HomeHex.x && npc.Hex.y == npc.HomeHex.y) {
        npc.NcrMichealMessageNum = 0;
        // майкл отправляет сообщение "Я пришел" для охранников на входе города
        SendMessage::ToWhoSeesMe(npc, MSG_NUM_INCOMING_MIKE, 0);
        // телепорт майкла в центр города. Будет торчать в баре Дасти
        Map? map = Game.GetMap(Content::Map::ncr_downtown);
        Map? map_bazaar = npc.GetMap();
        if (map == null) {
            Game.Log("Michael teleport map not found error");
            return EventResult::StopChain;
        }

        if (map_bazaar == null) {
            return EventResult::StopChain;
        }

        // транзит
        if (!Entrance::CritterTransferToMapEntry(npc, map.Id, HEX_NEW_MIKE_HOME)) {
            return EventResult::StopChain;
        }

        npc.HomeMapId = map.Id;
        npc.HomeHex = npc.Hex;
        npc.HomeDir = npc.Dir.hex.value;

        // если будет очищена карта центра города, прощаемся с Майком, он свою роль уже выполнил
        // а вот если будет очищена карта Базара, а Майкл уже телепортирован в центр города, копию в центре городу нужно удалить, иначе будет существовать два
        // майкла
        map_bazaar.NcrMichaelCritterId = npc.Id;
        map_bazaar.OnFinish.Subscribe(EOnFinishMap);
    }

    return EventResult::StopChain;
}

// для рядового охранника, слева у входа стоит
void PrivateGuardInit(Critter npc, bool firstTime)
{
    if (firstTime) {
        npc.NpcRole = NPC_ROLE_PRIVATE;
        npc.OnMessage.Subscribe(NpcOnMessage);
    }
}

// для главного охранника (справа у входа в город)
void MainGuardInit(Critter npc, bool firstTime)
{
    if (firstTime) {
        npc.NpcRole = NPC_ROLE_MAIN;
        npc.OnMessage.Subscribe(NpcOnMessage);
    }
}

// обработка сообщения от майкла "я пришел"
[[Event]]
void NpcOnMessage(Critter npcB, Critter npcA, int num, any val)
{
    // сначала говорит рядовой
    if (num == MSG_NUM_INCOMING_MIKE && npcB.NpcRole == NPC_ROLE_PRIVATE) {
        Messaging::SayOnHead(
            npcB,
            TextPackKey(TextPackName::Text, "" + (MSG_NUM_SEE_MIKE))); // Say(SAY_NORM_ON_HEAD,"Бог ты мой, это же Майкл! Майкл, какими судьбами?");
        SendMessage::ToWhoSeesMe(npcB, MSG_NUM_INCOMING_MIKE_GUARD, 0);
    }

    // ему отвечает сержант
    if (num == MSG_NUM_INCOMING_MIKE_GUARD && npcB.NpcRole == NPC_ROLE_MAIN) {
        // отвечает не мгновенно, иначе непонятно. кто первым прокомментировал появление Майкла
        NpcPlanes::AddMiscPlane(npcB, 2, Game.SynchronizedTime + Time::GameMinutes(1), NcrMichael::MainGuardAnswer);
    }
}

// ответ Сержанта у ворот
void MainGuardAnswer(Critter npc)
{
    Messaging::SayShoutOnHead(npc,
                              TextPackKey(TextPackName::Text, "" + (MSG_NUM_SHOUT))); // npc.Say(SAY_SHOUT_ON_HEAD,"Отставить базар! Ему разрешено пройти.");
}

// при очистке карты базара, если Майкл уже там нужно удалить его копию
// иначе будет существовать два Майкла одновременно
[[Event]]
void EOnFinishMap(Map map)
{
    Map? map_downtown = Game.GetMap(Content::Map::ncr_downtown);
    if (map_downtown == null) {
        return;
    }

    Critter? npc = map_downtown.GetCritter(map.NcrMichaelCritterId);
    if (npc == null) {
        return;
    }

    Game.DestroyCritter(npc);
}

#endif

}
