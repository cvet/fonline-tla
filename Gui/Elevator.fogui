{
    {
        {
            // Data[ 3 ]  -  main pic
            if (params.length() == 0) {
                return;
            }
            Type = params["ElevatorType"];
            if (!Elevator::get_elevator(Type, Data)) {
                return;
            }

            SetBackgroundImage(hstring(Data[3]));
        }
    }
}
