//               "OnLMouseClick":
{
    {
        {
            Gui::HideScreen();

            CritterProperty Prop = cast<SkillsPanel>(Parent).Prop;
            if (TargetCritterId == ZERO_IDENT && TargetItemId == ZERO_IDENT) {
                if (Prop == CritterProperty::SkillSneak) {
                    ChosenActions::SetChosenActions({Tla::ChosenUseSklOnCritter, int(CritterProperty::SkillSneak), 0, 0, 0, 0, 0});
                }
                else {
                    Settings.Cursor = CursorType::UseSkill;
                    Settings.CursorData = int(Prop);
                }
            }
            else {
                if (TargetCritterId != ZERO_IDENT) {
                    Critter @cr = Game.GetCritter(TargetCritterId);
                    if (cr !is null) {
                        ChosenActions::SetChosenActions({Tla::ChosenUseSklOnCritter, int(Prop), TargetCritterId, 0, 0, 0, 0});
                    }
                }
                else {
                    Item @item = Game.GetItem(TargetItemId);
                    if (item !is null) {
                        if (item.Type != ItemType::Generic && item.Type != ItemType::Grid) {
                            ChosenActions::SetChosenActions({Tla::ChosenUseSklOnItem, int(Prop), TargetItemId, IsInventory ? 1 : 0, 0, 0, 0});
                        }
                        else {
                            ChosenActions::SetChosenActions({Tla::ChosenUseSklOnScen, int(Prop), item.ProtoId.hash, item.Hex.x, item.Hex.y, 0, 0});
                        }
                    }
                }
            }
        }
    }
}
