        },
        {
            "name": "Launch TLA_Server + FOS Attach",
            "configurations": [
                "Launch TLA_Server",
                "FOS: Attach"
            ]
        },
        {
            "name": "Launch TLA_ServerHeadless (Linux) + FOS Attach",
            "configurations": [
                "Launch TLA_ServerHeadless (Linux)",
                "FOS: Attach"
            ]
        },
        {
            "name": "Launch TLA_Server (Linux) + FOS Attach",
            "configurations": [
                "Launch TLA_Server (Linux)",
