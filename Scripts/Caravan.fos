// вспомогательный класс для задания позиции нпц на карте
// сохраняет координаты нпц (прототип карты, позиция по Х или Y)
// умеет себя копировать
class NpcPosition
{
    // конструктор
    NpcPosition(hstring locPid, hstring mapPid, mpos hex)
    {
        MapProtoId = mapPid;
        Hex = hex;
        LocPid = locPid;
    }

    hstring LocPid;     //
    hstring MapProtoId; // код прототипа карты
    mpos Hex;           // позиция нпц на карте

    NpcPosition Copy()
    {
        return NpcPosition(LocPid, MapProtoId, Hex);
    }

    Map? GetMap()
    {
        return Game.GetMap(MapProtoId);
    }
};

// обмен значениями между двумя экземплярами класса
void SwitchNpcPosition(NpcPosition posA, NpcPosition posB)
{
    NpcPosition pos = posA.Copy();

    posA.LocPid = posB.LocPid;
    posA.MapProtoId = posB.MapProtoId;
    posA.Hex = posB.Hex;

    posB.LocPid = pos.LocPid;
    posB.MapProtoId = pos.MapProtoId;
    posB.Hex = pos.Hex;
    ;
}

// проводник каравана
// если он погибнет, миссия по охране караванов провалена
class CaravanLeaderInfo
{
    CaravanLeaderInfo()
    {
        Virtue = MODEL_CRVNR_COWARD; // других моделей поведения пока не реализовано
    }

    int CaravanId; // код каравана, который ведет проводник

    NpcPosition StartPos; // начальные координаты лидера
    NpcPosition EndPos;   // конечные координаты лидера

    // описание НПЦ
    hstring DialogId; // диалог
    hstring NpcPid;   // прототип нпц
    int BagId;        // инвентарь
    int TeamId;       // команда
    int AiPack;       // пакет ии
    ident CritterId;  // код криттера, получается уже после того, как караванщик создан
    int Level;        // уровень проводника
    int Virtue;       // поведение

    bool CheckLeaderInPos(bool startPos)
    {
        NpcPosition pos = (startPos ? StartPos.Copy() : EndPos.Copy());

        Critter? leader = GetLeader();
        if (leader == null) {
            return false;
        }

        Map? map = leader.GetMap();
        if (map == null) {
            return false;
        }

        DebugLog("map invalid mappid" + pos.MapProtoId);
        if (map.ProtoId != pos.MapProtoId) {
            return false;
        }

        // проверяем насколько далеко проводник от контрольных координат
        return (Game.GetDistance(leader.Hex, pos.Hex) <= LEADER_SEARCH_RADIUS);
    }

    bool TransferToPos(bool startPos)
    {
        Map? map = (startPos ? StartPos.GetMap() : EndPos.GetMap());
        if (map == null) {
            return false;
        }

        Critter? leader = GetLeader();
        if (leader == null) {
            return false;
        }

        leader.TransferToMap(map, (startPos ? StartPos.Hex : EndPos.Hex), HDIR_Random);
        return true;
    }

    Critter? GetLeader()
    {
        return Game.GetCritter(CritterId);
    }

    // установка лидера на указанную позицию
    bool PlaceLeaderCritterToPos(NpcPosition pos)
    {
        Map? map = pos.GetMap();
        if (map == null) {
            return false;
        }

        mpos hex = pos.Hex;
        if (!Entrance::GetFreeHex(map, 2, hex)) {
            return false;
        }

        int[] props = {CritterProperty::DialogId,
                       DialogId.hash,
                       CritterProperty::TeamId,
                       TeamId,
                       CritterProperty::AiId,
                       AiPack,
                       CritterProperty::BagId,
                       BagId,
                       CritterProperty::Level,
                       Level};
        Critter leader = map.AddCritter(NpcPid, hex, HDIR_Random, Tla::GetCritPropsDict(props));

        leader.CaravanCrvId = CaravanId;
        CritterId = leader.Id;
        DebugLog("leader level " + leader.Level + "caravan level " + Level);
        return true;
    }

    // присваивание статуса проводника существующему криттеру
    void SetLeaderCritter(Critter leader)
    {
        DebugLog("leader critter set called/ CaravanInfo=" + CaravanId);
        CritterId = leader.Id;
        leader.TeamId = TeamId;
        leader.BagId = BagId;
        leader.DialogId = DialogId;
        leader.AiId = AiPack;
        leader.Level = Level;

        leader.CaravanCrvId = CaravanId;
        CritterId = leader.Id;
    }
};

// вспомогательный класс, предмет для караванной повозки
class CaravanLootItem
{
    hstring ItemPid;          // код прототипа итема
    int ItemMinAmount;        // минимальное количество итемов
    int ItemMaxAmount;        // максимальное количество итемов
    int ItemAppearChance;     // шанс появления итема, в процентах, 100% = всегда появляется
    bool IsReversedRouteItem; // признак - итем появится только на обратном пути

    // текущее число итемов
    int Amount()
    {
        if (ItemMinAmount == ItemMaxAmount) {
            return ItemMaxAmount;
        }

        return ItemMinAmount < ItemMaxAmount ? Game.Random(ItemMinAmount, ItemMaxAmount) : Game.Random(ItemMaxAmount, ItemMinAmount);
    }

    // признак, появилось или нет в этот раз
    bool IsAppear()
    {
        return Game.Random(1, 100) < int(ItemAppearChance);
    }
};

// караванная повозка, расписывается содержимое ящиков
class CaravanCabInfo
{
    CaravanLootItem[] CabItems = {}; // вещи в повозке
    hstring CabPid;                  // прототип повозки

    CaravanCabInfo()
    {
        CabPid = Game.Random(0, 1) == 0 ? Content::Item::wagon_red : Content::Item::wagon_grey;
    }

    CaravanCabInfo(hstring cabPid)
    {
        CabPid = cabPid;
    }

    // добавление итема в повозку
    void AddLoot(hstring itemPid, int minNum, int maxNum, int chanceAppear, bool isReversLoot)
    {
        CaravanLootItem li = CaravanLootItem();
        li.ItemPid = itemPid;
        li.ItemMinAmount = minNum;
        li.ItemMaxAmount = maxNum;
        li.ItemAppearChance = chanceAppear;
        li.IsReversedRouteItem = isReversLoot;

        CabItems.insertLast(li);
        DebugLog("cab items:" + CabItems.length());
    }

    // размещение повозки с лутом на энкаунтере
    Item? PlaceCabOnMap(Map map, mpos hex, bool isReveresed)
    {
        DebugLog("trying place cab");
        Item cab = map.AddItem(hex, CabPid, 1);
        cab.NoBlock = false;
        DebugLog("try place brahmins");
        // брамины: 1ый х=х0 у=у+1, второй ч х = х-1 у= у-3? dir=1
        if (map.IsHexMovable(mpos(hex.x, hex.y + 1))) {
            map.AddCritter(Content::Critter::Brahmin, mpos(hex.x, hex.y + 1), 1);
        }

        if (map.IsHexMovable(mpos(hex.x - 1, hex.y - 3))) {
            map.AddCritter(Content::Critter::Brahmin, mpos(hex.x - 1, hex.y - 3), 1);
        }

        int num = 0;
        DebugLog("cab items:" + CabItems.length());
        for (int i = 0; i < CabItems.length(); i++) {
            DebugLog("try item appear");
            if (CabItems[i].IsReversedRouteItem == isReveresed) {
                num = CabItems[i].Amount();
                if (CabItems[i].IsAppear() && num > 0) {
                    DebugLog("Adding loot to cab");
                    cab.AddItem(CabItems[i].ItemPid, num, Tla::RootContainerStack());
                }
            }
        }

        return cab;
    }
};

// вспомогательный класс для хранения координат
class GlobalPoint
{
    int X;
    int Y;

    GlobalPoint(int x, int y)
    {
        X = x;
        Y = y;
    }
};

// маршрут следования каравана - ломаная линия
class GlobalRouteCurve
{
    // массив координат узлов ломанного маршрута
    // должен включать и начальную с конечной точкой
    GlobalPoint[] Points = {};
    int nextPoint;

    // добавление нового узла в маршрут
    void AddPoint(GlobalPoint point)
    {
        Points.insertLast(point);
    }

    bool RouteEnded()
    {
        return (nextPoint == -1);
    }

    // если караван достиг узла ломаной маршрута, меняем координаты точки назначения на следующую в маршруте
    void SetRouteDir(int x, int y, float toX, float toY)
    {
        // нет ни одной точки в маршруте
        if (Points.length() == 0) {
            nextPoint = -1;
            return;
        }

        // маршрут закончен
        if (nextPoint == -1) {
            return;
        }

        // достигнут один из узлов маршрута
        if (x == Points[nextPoint].X && y == Points[nextPoint].Y) {
            // если это последняя точка маршрута, меня ничего не нужно
            if (nextPoint == (-1 + int(Points.length()))) {
                nextPoint = -1;
                return;
            }
            else {
                nextPoint++;
            }
        }

        toX = float(Points[nextPoint].X);
        toY = float(Points[nextPoint].Y);
    }

    // преобразование марщрута в обратный
    void ReverseRouteCurve()
    {
        GlobalPoint[] Points2 = array<GlobalPoint>(Points.length());

        for (int i = 0; i < Points.length(); i++) {
            DebugLog("try copy point");
            // TODO: проверить, что это копирование сработает
            Points2[i] = Points[i];
        }

        Points.clear();
        for (int j = (Points2.length() - 1); j >= 0; j--) {
            DebugLog("try copy point - 2/j=" + j + "Points2.length()-1 = " + (Points2.length() - 1));
            AddPoint(Points2[j]);
            if (j == 0) {
                return;
            }
        }

        DebugLog("Reverse route success");
    }
};

// вспомогательный класс - описания охранников каравана
class CaravanGuardInfo
{
    int CaravanId;                         // код каравана
    hstring Pid;                           // код прототипа криттера
    hstring DialogId;                      // диалог
    callback_void_Critter_bool InitScript; // скрипт
    int AiPack;                            // ИИ
    int BagId;                             // инвентарь
    int TeamId;                            // команда
    int Level;                             // уровень
    int ReactionNum;                       // реакция - условный параметр, показывающий, как быстро реагирует нпц на смену обстановки
    int IsNervous;                         // признак - нервный, будет часто жаловаться
    int ChanceToJoin;                      // шанс присутствия в охране, в процентах
    bool IsUnique;                         // признак, уникальный в рамках одного похода караванов

    CaravanGuardInfo(int idCaravan, hstring pid, hstring dialogId, callback_void_Critter_bool initScript, int aiPack, int bagId, int teamId, int level,
                     int reaction, int isNervous, int chanceJoin, bool isUnique)
    {
        CaravanId = idCaravan;
        Pid = pid;
        DialogId = dialogId;
        InitScript = initScript;
        AiPack = aiPack;
        BagId = bagId;
        TeamId = teamId;
        Level = level;
        ReactionNum = reaction;
        IsNervous = isNervous;
        ChanceToJoin = Math::Clamp(chanceJoin, 0, 100);
        IsUnique = isUnique;
    }

    // пытается поставить охранника с определенной долей вероятности.
    // если не удалось, возвращает  null
    // leader - проводник каравана
    Critter? GetCritterGuard(Map map, Critter leader)
    {
        if (Game.Random(1, 100) > int(ChanceToJoin)) {
            return null;
        }

        mpos hex = leader.Hex;
        if (!Entrance::GetFreeHex(map, 4, hex)) {
            return null;
        }

        int[] props = {CritterProperty::DialogId,
                       DialogId.hash,
                       CritterProperty::TeamId,
                       TeamId,
                       CritterProperty::AiId,
                       AiPack,
                       CritterProperty::BagId,
                       BagId,
                       CritterProperty::Level,
                       Level,
                       CritterProperty::CaravanReaction,
                       ReactionNum,
                       CritterProperty::CaravanNervosityLvl,
                       IsNervous};
        Critter guard = map.AddCritter(Pid, hex, HDIR_Random, Tla::GetCritPropsDict(props));
        guard.SetupScript(InitScript);
        // если охранник помечен уникальным - отмечаем его присоединившимся и криттер больше не будет генериться данным методом
        if (IsUnique) {
            ChanceToJoin = 0;
        }

        guard.CaravanCrvId = CaravanId;

        return guard;
    }
};

// вспомогательный класс для описания нпц в составе каравана, которые не отображаются в составе группы на глобале. Например, брамины при перегонке нкр-реддинг
// появляются только на энкаунтере
class CaravanNpcFollowerInfo
{
    int CaravanId;    // код каравана
    hstring Pid;      // код прототипа криттера
    hstring DialogId; // диалог
    int TeamId;       // команда
    int BagId;        // команда

    CaravanNpcFollowerInfo()
    {
    }

    // добавление нпц рядом с итемом
    bool AddNpcNearItem(Map map, Item item, int dist)
    {
        mpos hex = item.Hex;
        if (!Entrance::GetFreeHex(map, dist, hex)) {
            return false;
        }

        int[] props = {CritterProperty::DialogId, DialogId.hash};
        map.AddCritter(Pid, hex, HDIR_Random, Tla::GetCritPropsDict(props));
        return true;
    }

    Critter? AddNpcNearCritter(Map map, Critter cr, int dist)
    {
        mpos hex = cr.Hex;
        if (!Entrance::GetFreeHex(map, dist, hex)) {
            return null;
        }

        int[] props = {CritterProperty::DialogId, DialogId.hash};
        return map.AddCritter(Pid, hex, HDIR_Random, Tla::GetCritPropsDict(props));
    }
};

// основное описание караванов
class CaravanInfo
{
    CaravanInfo()
    {
        MaxPlayers = 5;
        MaxGroup = 10;
        IsReversed = false;
        CaravanStatus = 0;
    }

    int CaravanId;               // код каравана
    int Type;                    // тип каравана, односторонний или двусторонний
    int CaravanStatus;           // текущее состояние каравана
    int GlobalSpeedMultiplayer;  // множитель скорости движения по глобальной карте
    CritterProperty QuestVarNum; // номер квестовой переменной для данного каравана
    int MaxPlayers;              // максимальное число игроков в составе каравана. Пока поставлено 5 для всех караванов.
    int MaxGroup;                // максимальное число нпц/игроков в группе, включая проводника
    bool IsReversed;             // признак - караван идет по обратному маршруту
    // описания
    CaravanLeaderInfo Leader;                // проводник каравана
    CaravanCabInfo[] Cabs = {};              // повозки
    GlobalRouteCurve CaravanRoute;           // маршрут следования каравана
    CaravanGuardInfo[] CaravanGuards = {};   // массив описаний охранников
    CaravanNpcFollowerInfo[] Followers = {}; // массив описаний спутников каравана (брамины, нейтральные персонажи итд)

    // игроки/нпц охранники
    ident[] PlayersRequested = {}; // массив Id игроков, подавших заявку на участие
    ident[] Caravaneers = {};      // массив Id игроков и нпц-караванщиков в составе каравана

    void TerminateCaravan()
    {
        CaravanStatus = CRV_STATUS_END;
        Critter? leader = Leader.GetLeader();
        if (leader != null) {
            DebugLog("Leader deleted");
            Game.DestroyCritter(leader);
            Leader.CritterId = ZERO_IDENT;
        }

        for (int i = 0, l = Caravaneers.length(); i < l; i++) {
            Critter? guard = Game.GetCritter(Caravaneers[i]);
            if (guard != null) {
                if (!guard.ControlledByPlayer) {
                    Game.DestroyCritter(guard);
                    continue;
                }
            }
        }

        SetQuestState(this, CARAVAN_FAILURE_PLAYER_ABANDONED);
        CaravanReset();
    }

    void CaravanReset()
    {
        PlayersRequested.clear();
        // внимание! нет удаления нпц, поскольку они могут быть и на глобале и удаление сломается
        // удалением необходимо управлять в другом месте
        Caravaneers.clear();
        CaravanStatus = CRV_STATUS_BEFORE_START;
        CaravanRoute.nextPoint = 0;
    }

    // удаление охранника из списка охранников каравана
    // id - Id криттера
    bool RemoveGuard(ident id)
    {
        DebugLog("RemoveGuard start/ Player Id = " + id);
        for (int i = 0; i < Caravaneers.length(); i++) {
            if (id == Caravaneers[i]) {
                Caravaneers.removeAt(i);
                return true;
            }
        }

        for (int i = 0; i < PlayersRequested.length(); i++) {
            if (id == PlayersRequested[i]) {
                PlayersRequested.removeAt(i);
                return true;
            }
        }

        return false;
    }

    // проверка, игрок является охранником данного каравана?
    bool PlayerIsGuard(ident playerId)
    {
        for (int i = 0; i < Caravaneers.length(); i++) {
            if (playerId == Caravaneers[i]) {
                return true;
            }
        }

        return false;
    }

    // перенос игрока в список охранников
    // id - код игрока
    // внимание! нет проверки, что криттер найден. Проверять нужно в другом месте перед вызовом метода
    void RequstedToGuard(ident id)
    {
        for (int i = 0; i < Caravaneers.length(); i++) {
            // уже есть в списках
            if (id == Caravaneers[i]) {
                return;
            }
        }

        Caravaneers.insertLast(id);
    }

    CaravanCabInfo? GetCab(int idx)
    {
        DebugLog("Getting cab info");
        if (Cabs.length() == 0) {
            return null;
        }

        DebugLog("cabs found");
        if (idx < 0) {
            return Cabs[Game.Random(0, Cabs.length() - 1)];
        }
        else {
            if (Cabs.length() <= idx) {
                return Cabs[0];
            }

            return Cabs[idx];
        }
    }

    // добавление точки в маршрут
    void AddRoutePoint(int x, int y)
    {
        CaravanRoute.AddPoint(GlobalPoint(x, y));
        CaravanRoute.nextPoint = 0;
    }
};

/* ******************************** вспомогательные функции ******************************** */

// ищет на указанной карте криттера с нужным диалогом и прототипом
// ищет только нпц
Critter[] GetCrittersByDialogId(Map? map, hstring dialog, hstring pid)
{
    Critter[] critters = {};

    if (map == null) {
        return critters;
    }

    if (dialog == EMPTY_HSTRING) {
        return critters;
    }

    Critter[] foundCrits = map.GetCritters(pid, CritterFindType::Npc);
    for (int i = 0; i < foundCrits.length(); i++) {
        if (foundCrits[i].DialogId == dialog) {
            critters.insertLast(foundCrits[i]);
        }
    }

    return critters;
}

///@ Property Critter Server uint8 VCDeadPatrollers Mutable Persistent Max = 10

const int MESSAGE_CARAVANEER_GOTO_HOME = 212; // проводник отправит это сообщение, если двигает к домашней позиции
const int NPC_ROLE_CARAVAN_BOSS = 117;        // босс каравана
const int NPC_ROLE_CARAVAN_GUIDE = 118;       // проводник
const int NPC_ROLE_CARAVAN_GUARD = 119;       // охранник каравана(НПЦ)

// типовые фразы

const int PHRASE_BORING = 2;       // охранник заскучал
const int PHRASE_ATTACKED = 5;     // фраза если охранник атакован
const int PHRASE_LOW_HP = 6;       // фраза если у охранника осталось мало хп
const int PHRASE_KILL_SOMEONE = 7; // фраза при убийстве охранником кого-либо
// задачи

const int PLANE_GOTO_HOME = 405;        // гвард идет на новое место дислокации
const int MSG_WHERE_IS_DA_LEADER = 211; // номер сообщения, которое отправляет охранник, когда хочет приблизиться к караванщику

/*---------------------- получение нескольких нпц-охранников ----------------------*/
// пытается сказать фразу в кассу к происходящему событию
// с учетом уровня "нервозности" гарда
// чем выше уровень нервозности, тем выше шанс
// guard - охранник
// msgId - номер строки в диалоге охранника
// boost - увеличивает вероятность
// если фраза сказана - функция вернет true, иначе false
bool SayNervous(Critter guard, int msgID, int boost)
{
    DebugLogVerbose("try say nrv" + MsgStr::DialogTextId(guard.DialogId, msgID));
    if (Game.Random(guard.CaravanNervosityLvl + boost, 6) >= 5) {
        Messaging::SayOnHead(guard, MsgStr::DialogTextKey(guard.DialogId, msgID));
        return true;
    }

    return false;
}

// охранник подходит к проводнику
void MoveToCaravanLeader(Critter guard, Critter leader, int radius)
{
    auto hex = leader.Hex;
    Map? map = guard.GetMap();
    if (map == null) {
        return;
    }

    if (Entrance::GetFreeHex(map, radius, hex)) {
        bool run = false;
        if ((Game.Random(1, 3)) == 1) {
            run = true;
        }

        NpcPlanes::AddWalkPlane(guard, NpcPlanes::AI_PLANE_WALK_PRIORITY, PLANE_GOTO_HOME, 0, hex, Game.Random(1, 5), run, 1);
    }
}

/*-------------------- -----обработка------   -------------------*/
// Охранник на локации, и ничего особенного не делает GuardIdle
// иногда говорит случайную фразу из диалога
void GuardIdleImpl(Critter guard)
{
    CaravanInfo? ci = GetCaravan(guard.CaravanCrvId);
    // Удаление охранника, если он непонятно где завис
    // Охранники должны существовать только в момент движения или остановки каравана на энке
    if (ci != null) {
        if (ci.CaravanStatus == CRV_STATUS_BEFORE_START || ci.CaravanStatus == CRV_STATUS_PREPARE || ci.CaravanStatus == CRV_STATUS_END) {
            DebugLog("kill caravan guard");
            Game.DestroyCritter(guard);
            return;
        }
    }

    if (guard.GetMap() != null) {
        if (guard.CaravanIdleCount >= 20) {
            DebugLogVerbose("NextPhrase");
            if (SayNervous(guard, PHRASE_BORING, 3)) {
                guard.CaravanIdleCount = 0;
                SendMessage::ToAllOnMap(guard, MSG_WHERE_IS_DA_LEADER, guard.Id);

                return;
            }
        }

        guard.CaravanIdleCount += guard.CaravanNervosityLvl;
        guard.CaravanIdleCount += 1;
        return;
    }
    else {
        if (guard.CaravanIdleCount > 0) {
            guard.CaravanIdleCount = 0;
        }
    }
}

[[TimeEvent]] [[Async]]
void GuardIdle(Critter guard)
{
    if (!Sync::LockCritterWithMap(guard)) {
        return;
    }

    GuardIdleImpl(guard);
}

// Пришло сообщение отправленное с помощью Critter::SendMessage.
[[Event]]
void GuardOnMessage(Critter guard, Critter fromCr, int message, any value)
{
    if (message == MESSAGE_CARAVANEER_GOTO_HOME) {
        if (fromCr.NpcRole == NPC_ROLE_CARAVAN_GUIDE && fromCr.CaravanCrvId == guard.CaravanCrvId) {
            guard.CaravanIdleCount = 0;
            NpcPlanes::AddMiscPlane(guard, NpcPlanes::AI_PLANE_MISC_PRIORITY, Time::GameMinutes(guard.CaravanReaction), Caravan::MiscGoHomePos);
        }
    }
}

// завершение выполнения некоего плана охранником
[[Event]]
EventResult GuardPlaneEnd(Critter guard, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(guard, planeId);
    if (plane == null) {
        return EventResult::StopChain;
    }

    // нпц без проблем дошел до домашней позиции
    if (plane.Identifier == PLANE_GOTO_HOME && reason == NpcPlanes::REASON_SUCCESS) {
        guard.HomeHex = guard.Hex;
        guard.HomeDir = Game.Random(1, 5);
    }

    // Messaging::SayOnHead(guard, "reason = " +reason);
    // у нпц проблемы - не может дойти до домашней позиции
    else if (plane.Identifier == PLANE_GOTO_HOME) {
        if (reason == NpcPlanes::REASON_HEX_TOO_FAR || reason == NpcPlanes::REASON_HEX_BUSY || reason == NpcPlanes::REASON_HEX_BUSY_RING ||
            reason == NpcPlanes::REASON_DEADLOCK || reason == NpcPlanes::REASON_TRACE_FAIL || reason == NpcPlanes::REASON_POSITION_NOT_FOUND ||
            reason == NpcPlanes::REASON_FIND_PATH_ERROR) {
            NpcPlanes::AddMiscPlane(guard, NpcPlanes::AI_PLANE_MISC_PRIORITY, Time::GameMinutes(guard.CaravanReaction), Caravan::MiscGoHomePos);
        }
    }

    return EventResult::StopChain;
}

// убит ктото
[[Event]]
void SomeCritterDead(Critter guard, Critter fromCrit, Critter? killer)
{
    if (killer == null) {
        return;
    }

    if (killer.Id == guard.Id) {
        Messaging::SayOnHead(guard, MsgStr::DialogTextKey(guard.DialogId, PHRASE_KILL_SOMEONE));
    }
}

// атакован кем-то
[[Event]]
EventResult GuardAttacked(Critter guard, Critter attacker)
{
    if (guard.CurrentHp * 3 < guard.MaxLife) {
        SayNervous(guard, PHRASE_LOW_HP, 3);
    }
    else {
        SayNervous(guard, PHRASE_ATTACKED, 0);
    }

    return EventResult::StopChain;
}

// охранник обворован
[[Event]]
void GuardStealing(Critter cr, Critter thief, Item item, int count)
{
    // if( success && thief.ControlledByPlayer )
    if (thief.ControlledByPlayer) {
        NpcPlanes::AddAttackPlane(cr, 0, thief);
        if (!EnemyStack::CheckEnemyInStack(cr, thief.Id)) {
            EnemyStack::AddEnemyToStack(cr, thief.Id);
        }
    }
}

// убит патрульный ГУ
[[Event]]
void VcPatrolDead(Critter cr, Critter killer)
{
    CaravanInfo? ci = GetCaravan(cr.CaravanCrvId);
    if (ci == null || ci.CaravanStatus != CRV_STATUS_ON_ENCOUNTER) {
        return;
    }

    for (int i = 0, l = ci.Caravaneers.length(); i < l; i++) {
        Critter? player = Game.GetCritter(ci.Caravaneers[i]);
        if (player != null && player.ControlledByPlayer) {
            player.VCDeadPatrollers += 1;
        }
    }
}

/*-------------------------специфические обработки-------------------------*/
// Находчивый Василий нервно шарится по округе гораздо чаще, чем остальные
[[TimeEvent]] [[Async]]
void VasyaIdle(Critter guard)
{
    if (!Sync::LockCritterWithMap(guard)) {
        return;
    }

    if (NpcPlanes::IsNoPlanes(guard)) {
        if (guard.CaravanIdleCount % 3 == 1 && CritterState::IsFree(guard)) {
            SendMessage::ToAllOnMap(guard, MSG_WHERE_IS_DA_LEADER, guard.Id);
        }
    }

    GuardIdleImpl(guard);
}

/*-------------------------планы---------------------------------*/
// охранник подходит ближе к проводнику, если у него нет других целей
void MiscGoHomePos(Critter guard)
{
    SendMessage::ToAllOnMap(guard, MSG_WHERE_IS_DA_LEADER, guard.Id);
}

/*-------------------------инициализация-------------------------*/
void DefaultGuardInit(Critter guard, bool firstTime)
{
    if (guard.IsDead()) {
        Game.DestroyCritter(guard);
        return;
    }

    if (!firstTime) {
        if (guard.GetMap() == null) {
            Game.DestroyCritter(guard);
            return;
        }
    }

    // void _FuncName(Critter cr, Critter fromCr, int message, any value)
    guard.OnMessage.Subscribe(GuardOnMessage);
    guard.OnNpcPlaneEnd.Subscribe(GuardPlaneEnd);
    guard.OnSomeCritterDead.Subscribe(SomeCritterDead);
    guard.OnAttacked.Subscribe(GuardAttacked);
    guard.StartTimeEvent(Time::Asap(), Time::Seconds(1), GuardIdle);
    guard.OnDead.Subscribe(GuardDead);

    // охранников не ограбить
    guard.IsNoSteal = true;
    // торговать они не будут
    guard.IsNoBarter = true;
    guard.IsNoLoot = false;
    // из мертвых не встанут
    guard.ReplicationTime = -1;
}

[[Event]]
void GuardDead(Critter cr, Critter killer)
{
    if (!cr.ControlledByPlayer) {
        cr.StartTimeEvent(Time::Minutes(5), DeleteCaravanGuard);
    }
}

[[TimeEvent]] [[Async]]
void DeleteCaravanGuard(Critter cr)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    if (!cr.ControlledByPlayer) {
        Game.DestroyCritter(cr);
    }

    return;
}

// тоже, но бесконечные патроны
void DefaultGuardInitUnlimAmmo(Critter guard, bool firstTime)
{
    guard.IsUnlimitedAmmo = true;
    DefaultGuardInit(guard, firstTime);
}

void VcPatrolInit(Critter guard, bool firstTime)
{
    guard.IsUnlimitedAmmo = true;
    DefaultGuardInit(guard, firstTime);
    guard.OnDead.Subscribe(VcPatrolDead);
}

// Патрульные для квеста Патруль Рейнджеров

void NcrRangerPatrolInit(Critter guard, bool firstTime)
{
    guard.NcrHatePatrol = 2;

    guard.MaxLifeBase = Game.Random(150, 250);
    guard.CurrentHp = guard.MaxLife;
    guard.ExplodeResistanceBase = Game.Random(50, 90);
    guard.NormalResistanceBase = Game.Random(20, 50);
    guard.IsUnlimitedAmmo = true;
    DefaultGuardInit(guard, firstTime);
}

