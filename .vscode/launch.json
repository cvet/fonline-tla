        {
            "name": "Launch TLA_ServerHeadless",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "Prepare TLA_ServerHeadless",
            "program": "${workspaceFolder}/Binaries/Server-Windows-win64/TLA_ServerHeadless.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Launch TLA_Server",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "Prepare TLA_Server",
            "program": "${workspaceFolder}/Binaries/Server-Windows-win64/TLA_Server.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Launch TLA_UnitTests",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "Prepare TLA_UnitTests",
            "program": "${workspaceFolder}/Binaries/Tests-Windows-win64/TLA_UnitTests.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Launch TLA_ServerHeadless (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "Prepare TLA_ServerHeadless",
