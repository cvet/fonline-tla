{
    {
        int RadioChannel;
        void SetChannel(int channel)
        {
            RadioChannel = channel;
            SetText("" + channel, FONT_DEFAULT, FT_CENTERX | FT_CENTERY);
            SetTextColor(COLOR_GREEN);
        }
    }
}
