// clang-format on

const int ENTRY_ITEM = 0;    // Гекс для расположения итема
const int TABLE_COLUMNS = 6; // число колонок в таблице

// Всего определений итемов в таблице (число строк).
int ItemTableCount()
{
    return items_table.length() / TABLE_COLUMNS;
}

const int MAX_TRIES = ETYPE_DEFAULT; // максимальное число попыток найти подходящую по типу энкаунтера строку в таблице итемов
const int MIN_ITEMS = 0;             // минимальное число итемов на энке
const int MAX_ITEMS = 8;             // максимальное

// Доступ к колонкам строки таблицы по индексу строки idx.
int GetItemType(int idx)
{
    return int(items_table[TABLE_COLUMNS * (0 + int(idx)) + 1]);
}

hstring GetItemPid(int idx)
{
    return hstring(items_table[TABLE_COLUMNS * (0 + int(idx)) + 0]);
}

int GetItemQuantity(int idx)
{
    return Game.Random(int(items_table[TABLE_COLUMNS * (0 + int(idx)) + 2]), int(items_table[TABLE_COLUMNS * (0 + int(idx)) + 3]));
}

int GetItemChance(int idx)
{
    return int(items_table[TABLE_COLUMNS * (0 + int(idx)) + 4]);
}

hstring GetItemHex(int idx)
{
    return ("" + int(items_table[TABLE_COLUMNS * (0 + int(idx)) + 5])).hstr();
}

// Карта является внутренностью пещеры (используется для определения типа энкаунтера).
bool IsCaveMap(hstring mapPid)
{
    return mapPid == Content::Map::e_cave0_in || mapPid == Content::Map::e_cave1_in || mapPid == Content::Map::e_cave2_in ||
           mapPid == Content::Map::e_cave3_in || mapPid == Content::Map::e_cave4_in || mapPid == Content::Map::e_cave5_in ||
           mapPid == Content::Map::e_coast5_cave;
}

// Фильтр таблицы по типу энка и гексу
int[] GetItemsInfo(int eType, hstring hex)
{
    int[] infos = {};
    for (int i = 0; i < ItemTableCount(); i++) {
        if ((GetItemType(i) == eType || GetItemType(i) == ETYPE_ANY) && GetItemHex(i) == hex) {
            // отладочный лог совпадений (оставлено как breadcrumb диагностики таблицы)
            // Game.Log("eType:"+eType+"GetItemType:"+GetItemType(i));
            infos.insertLast(i);
        }
    }

    return infos;
}

// Определяет тип энкаунтера по карте: сначала по прото пещеры, иначе по группе локации.
int GetEncounterType(Map map)
{
    if (IsCaveMap(map.ProtoId)) {
        return ETYPE_CAVERN;
    }

    Location loc = map.GetLocation();
    if (PidsGroups::Pids_MapDeserts.find(loc.ProtoId) != -1) {
        return ETYPE_DESERT;
    }

    if (PidsGroups::Pids_MapMountains.find(loc.ProtoId) != -1) {
        return ETYPE_MOUNTAINS;
    }

    if (PidsGroups::Pids_MapCaverns.find(loc.ProtoId) != -1) {
        return ETYPE_MOUNTAINS;
    }

    if (PidsGroups::Pids_MapCities.find(loc.ProtoId) != -1) {
        return ETYPE_CITY;
    }

    if (PidsGroups::Pids_MapCoasts.find(loc.ProtoId) != -1) {
        return ETYPE_COAST;
    }

    if (PidsGroups::Pids_MapOceans.find(loc.ProtoId) != -1) {
        return ETYPE_OCEAN;
    }

    return ETYPE_DEFAULT;
}

// Главная точка: спавнит лут на энкаунтере. Количество предметов зависит от минимальной
// Удачи в группе; гексы под предметы выбираются случайно среди распарсенных входов карты.
void GenerateItems(Map map, Critter[] grp)
{
    // Берём минимальную Удачу по группе как множитель щедрости лута.
    int minLuck = 8;
    for (int i = 0, l = grp.length() - 1; i < l; i++) {
        Critter cr = grp[i];
        if (minLuck > cr.Luck) {
            minLuck = cr.Luck;
        }
    }

    int itemz = Game.Random(MIN_ITEMS, Math::Clamp(minLuck, 3, MAX_ITEMS));
    int mapType = GetEncounterType(map);

    // Собираем все гексы-входы карты, подходящие под типы из таблицы гексов.
    Entrance::Entry[] entries = {};
    for (int i = 0, l = gex_table.length(); i < l; i++) {
        entries.insertLast(Entrance::ParseEntries(map, gex_table[i]));
    }

    int len = entries.length();
    if (len == 0) {
        return;
    }

    // Случайно набираем уникальные индексы гексов под предметы (не больше itemz).
    int tries = 30;
    int[] foundedEntries = {};
    int cur = 0;
    int idx = 0;
    while (tries > 0) {
        cur = Game.Random(0, len - 1);
        if (foundedEntries.find(cur) == -1) {
            foundedEntries.insertLast(cur);
        }

        if (foundedEntries.length() > itemz) {
            break;
        }

        tries--;
    }

    // По выбранным гексам бросаем шанс и кладём предмет: в контейнер рядом или прямо на гекс.
    bool found = false;
    for (int i = 0, l = foundedEntries.length(); i < l; i++) {
        Entrance::Entry hex = entries[foundedEntries[i]];
        int[] rows = GetItemsInfo(mapType, hex.Name);
        if (rows.length() == 0) {
            continue;
        }

        idx = rows[Game.Random(0, rows.length() - 1)];
        if (idx < 0) {
            continue;
        }

        if (Game.Random(1, 99) < int(GetItemChance(idx))) {
            Item? item = map.GetItemInRadius(hex.Hex, 2, ItemProperty::Type, ItemType::Container);
            if (item != null) {
                int qty = GetItemQuantity(idx);
                if (qty > 0) {
                    item.AddItem(GetItemPid(idx), qty, Tla::RootContainerStack());
                }

                found = true;
                break;
            }

            if (!found) {
                map.AddItem(hex.Hex, GetItemPid(idx), GetItemQuantity(idx));
            }
        }
    }
}

#endif

}
