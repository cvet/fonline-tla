//       "Expanded": true,
//       "Selected": false,
//       "Active": true,
//       "Name": "MapEntraceaGrid",
//       "Position": "0, 0",
//       "Size": "0, 0",
//       "Anchor": "None",
//       "Dock": "None",
//       "IsDraggable": false,
