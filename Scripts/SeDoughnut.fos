namespace SeDoughnut
{

#if SERVER

// Autor: Dagnir

const int STR_USE_MONUMENT = 70060;

[[ItemStatic]]
bool s_Monument(Critter cr, StaticItem terminal, Item? item, any skill)
{
    if (skill == CritterProperty::SpecialSkillPickOnGround && item == null) {
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_USE_MONUMENT)));
    }

    return false;
}

#endif

