namespace MsgStr
{

int DialogTextId(hstring dialogId, int strNum)
{
    return (dialogId.uhash) + (12000 + (strNum));
}
int LocationTextId(hstring locPid, int strNum)
{
    return (locPid.uhash) + (strNum);
}
int ItemTextId(hstring itemPid, int strNum)
{
    return (itemPid.uhash) + (strNum);
}
int CritterTextId(hstring crPid, int strNum)
{
    return (crPid.uhash) + (strNum);
}

int MakePropHashForMsg(CritterProperty prop)
{
    string str = "CritterProperty::" + Game.EnumToString(prop);
    if (str.endsWith("Base")) {
        return str.substr(0, str.length() - 4).hstr().uhash;
    }

    return str.hstr().uhash;
}

// Two-token text key prefix for a CritterProperty: "CritterProperty::<Value>",
// stripping a trailing "Base" so e.g. StrengthBase shares text with Strength.
string PropPrefix(CritterProperty prop)
{
    string str = "CritterProperty::" + Game.EnumToString(prop);
    if (str.endsWith("Base")) {
        return str.substr(0, str.length() - 4);
    }

    return str;
}

int Get(string strName)
{
    return strName.hstr().uhash;
}

