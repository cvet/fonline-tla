// CritterTypes — реестр типов криттеров из CritterTypes.json. Ключевые обязанности:
// парсинг описаний типов (анимации, времена/кадры движения, флаги), поиск типа по
// id/имени/криттеру, геттер алиаса типа для игроков.
// Сторона: MIXED (SERVER OnInit, CLIENT OnStart, геттер для !MAPPER).
// Связи: Json, Game ресурсы.
namespace CritterTypes
{

// Точка входа модуля: загрузка реестра типов запускается и на сервере (OnInit), и
// на клиенте (OnStart) — обеим сторонам нужны описания типов криттеров.
[[ModuleInit]]
void InitCritterTypes()
{
#if SERVER
    Game.OnInit.Subscribe(init);
#endif

#if CLIENT
    Game.OnStart.Subscribe(start);
#endif
}

// Серверная инициализация реестра: читаем CritterTypes.json и разбираем каждый тип.
[[Event]]
void init()
{
    verify(Game.IsResourcePresent("CritterTypes.json"), "Assertion failed");
    Json::JSON info = Json::JSONParse(Game.ReadResource("CritterTypes.json"));
    info.forEach(ReadCritterTypeInfo);
}

// Клиентская инициализация реестра: тот же разбор CritterTypes.json при старте клиента.
[[Event]]
void start()
{
    verify(Game.IsResourcePresent("CritterTypes.json"), "Assertion failed");
    Json::JSON info = Json::JSONParse(Game.ReadResource("CritterTypes.json"));
    info.forEach(ReadCritterTypeInfo);
}

// Разбор одного описания типа криттера из JSON: добавляем новый CritterType в реестр
// и заполняем его поля (id/имя/прото, флаги возможностей, времена и кадры движения,
// набор анимаций). Шаги ходьбы дочитываются отдельным обходом массива.
void ReadCritterTypeInfo(Json::JSON crInfo, int index)
{
    CritterType ct = CritterType();
    string value;
    AllCritterTypes.insertLast(ct);
    crInfo["CritterTypeId"] >> ct.CritterTypeId;
    crInfo["CritterTypeId"] >> ct.CritterTypeId;
    crInfo["AnimationType"] >> ct.AnimType;
    crInfo["AliasTypeId"] >> ct.Alias;
    crInfo["CritterTypeName"] >> ct.Name;
    crInfo["CritterTypeName"] >> value;
    ct.Proto = value.hstr();

    // Ручная инициализация хешей, которые не видит клиент
    hstring hashA = ("art/critters/" + value + "aa.frm").hstr();

    crInfo["CanWalk"] >> ct.CanWalk;
    crInfo["CanRun"] >> ct.CanRun;
    crInfo["CanAim"] >> ct.CanAim;
    crInfo["CanChangeArmor"] >> ct.CanChangeArmor;
    crInfo["CanRotate"] >> ct.CanRotate;
    crInfo["WalkTime"] >> ct.WalkTime;
    crInfo["RunTime"] >> ct.RunTime;
    crInfo["MoveWalkFrames"] >> ct.MoveWalkFrames;
    crInfo["MoveRunFrames"] >> ct.MoveRunFrames;
    crInfo["Animations"] >> ct.Animations;
    ct.WalkSteps = array<int>(4);
    crInfo["WalkSteps"].forEach(ReadWalkStepInfo);
}

// Дочитывает один шаг ходьбы в WalkSteps типа, разбираемого прямо сейчас (последний в
// реестре). Вызывается из forEach по массиву WalkSteps внутри ReadCritterTypeInfo.
void ReadWalkStepInfo(Json::JSON wsInfo, int index)
{
    CritterType ct = AllCritterTypes.last();
    wsInfo >> ct.WalkSteps[index];
}

// Начинается с #, поскольку перечисление CritterStateAnim начинается с 1, не с 0.
const string AnimationsAll = "#ABCDEFGHIJKLMNOPQRSTUVWXYZ";

enum AnimationType
{
    Fallout = 0,
    VanBuren3d = 1,
    Tactics = 2,
    Arcanum = 3,
};

// Поиск типа по числовому id. Возвращает null, если тип с таким id не зарегистрирован.
CritterType? GetCritterType(int typeId)
{
    for (int i = 0; i < AllCritterTypes.length(); i++) {
        if (typeId == AllCritterTypes[i].CritterTypeId) {
            return AllCritterTypes[i];
        }
    }

    return null;
}

// Поиск типа по имени. Возвращает null, если тип с таким именем не найден.
CritterType? GetCritterType(string name)
{
    for (int i = 0; i < AllCritterTypes.length(); i++) {
        if (name == AllCritterTypes[i].Name) {
            return AllCritterTypes[i];
        }
    }

    return null;
}

// Поиск типа по криттеру: имя типа извлекается из пути модели (art/critters/<имя>...),
// затем ищется в реестре по имени. Возвращает null, если совпадение не найдено.
CritterType? GetCritterType(Critter cr)
{
    string name = cr.ModelName;

    if (name.substr(0, 13) == "art/critters/") {
        name = name.substr(13, 6);
    }

    for (int i = 0; i < AllCritterTypes.length(); i++) {
        if (name == AllCritterTypes[i].Name) {
            return AllCritterTypes[i];
        }
    }

    return null;
}

// Описание одного типа криттера: статические характеристики анимаций и движения,
// прочитанные из CritterTypes.json. Экземпляры живут в реестре AllCritterTypes.
class CritterType
{
    int CritterTypeId;
    int AnimType;
    string Name;
    hstring Proto;
    int Alias;
    int Multihex;
    bool CanWalk;
    bool CanRun;
    bool CanAim;
    bool CanChangeArmor;
    bool CanRotate;
    // Время ходьбы в миллисекундах.
    int WalkTime;
    // Время бега в миллисекундах.
    int RunTime;
    // Шаги ходьбы (специфика Fallout) — кадров на гекс при ходьбе, для бега используются
    // диапазоны 1-2, 3-4, 5-7, 8-конец.
    // Пример: 4  9 11  0
    // 4 - № кадра анимации, который завершает переход из первого гекса во второй
    // 9 - № кадра анимации, который завершает переход из второго гекса в третий
    // 11 - № кадра анимации, который завершает переход из третьего гекса во четвертый
    // 0 - № кадра анимации, который завершает переход из четвертого гекса в пятый
    int[] WalkSteps;
    // Движение (специфика пользовательских типов) — первое значение: кадров на гекс при
    // ходьбе, второе: кадров на гекс при беге; если ноль, берутся значения по умолчанию
    // 5 (ходьба) и 2 (бег).
    int MoveWalkFrames;
    int MoveRunFrames;
    // Доступные для типа криттера анимации. Склеены в строку.
    // Таблица первичных анимаций (буква = код анимации в строке Animations):
    /*
     # Primary animations
     # 1  A Unarmed
     # 4  D Knife
     # 5  E Club
     # 6  F Hammer
     # 7  G Spear
     # 8  H Pistol
     # 9  I SMG
     # 10 J Shootgun
     # 11 K Heavy Rifle
     # 12 L Minigun
     # 13 M Rocket Launcher
     # 14 N Flamer
     # 15 O Rifle
     # 16 P Sword
     # 17 Q Long Sword
     # 18 R Axe
     # 19 S Bow
       // enum CritterStateAnim Unarmed = 1 совпадает с индексом анимаций
     */
    string Animations;

    // Есть ли у типа анимация для заданного оружия: сравниваем буквы из строки Animations
    // с буквой-кодом этого оружия из общего алфавита AnimationsAll.
    bool HasAnim(int weaponAnim)
    {
        for (int i = 0, l = Animations.length(); i < l; i++) {
            if (Animations[i] == AnimationsAll[weaponAnim]) {
                return true;
            }
        }

        return false;
    }

    // Тип-алиас (по полю Alias) — тип, под который данный маскируется (например, для игроков).
    CritterType? AliasType()
    {
        return GetCritterType(Alias);
    }
}

// Реестр всех типов криттеров, заполняется при инициализации модуля.
CritterType[] AllCritterTypes = {};

#if !MAPPER

// Геттер алиаса типа криттера: для управляемых игроком криттеров отдаём алиас из их типа
// (если он задан), иначе — базовое значение CrTypeAliasBase.
[[PropertyGetter]]
int CritterGetCrTypeAlias(Critter cr)
{
    if (cr.ControlledByPlayer) {
        auto crType = GetCritterType(cr);
        if (crType != null && crType.Alias > 0) {
            return crType.Alias;
        }
    }

    return cr.CrTypeAliasBase;
}

#endif

}
