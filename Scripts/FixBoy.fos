namespace FixBoy
{

///@ RemoteCall Server Rpc_CraftItem(int32 state, int32 craftId, int32 p2)
///@ RemoteCall Client ShowFixBoy(int32 craftId, int32 strNum, int32 p2, any[] data)

#if SERVER

///@ Property Critter Server int32 FixboyPowerArmor Mutable Persistent Max = 1
///@ Property Critter Server int32 ModLourenceVenomedratRecipe Mutable Persistent Max = 1
///@ Property Critter Server int32 ModLourenceTNTRatRecipe Mutable Persistent Max = 1
///@ Property Critter Server int32 NavEmpRocketRecipe Mutable Persistent Max = 1
///@ Property Critter Server int32 FixboyDefault Mutable Persistent Max = 1
///@ Property Critter Server int32 SFRecipeSsupersledge Mutable Persistent Max = 1
///@ Property Critter Server int32 SFRecipePlasmagrenades Mutable Persistent Max = 1
///@ Property Critter Server int32 Fixboy700NitroExpress Mutable Persistent Max = 1
///@ Property Critter Server int32 FixboyAmmoPressOperator Mutable Persistent Max = 1

const int FIX_SUCCESS = Tla::FIXBOY_DEFAULT;
const int FIX_FAIL = Tla::FIXBOY_DEFAULT ^ Tla::FIXBOY_ALLOW_CRAFT;

funcdef int MainCraftScript(Critter cr, int state, MainCraft craft);

MainCraft[] CraftList = {};

class MainCraft
{
    int Id;
    any[] OutItems = {};
    int Experience;
    MainCraftScript? Script;
    any[] NeedResources = {};
    any[] NeedTools = {};
    int[] OnView = {};
    int[] OnCraft = {};

    MainCraft(int id, hstring pid, int count, int exp = 50)
    {
        Id = id;
        OutItems = {pid, any(count)};
        Experience = exp;
    }

    MainCraft AddMoreOutItems(hstring pid, int count)
    {
        OutItems.insertLast(pid);
        OutItems.insertLast(any(count));
        return this;
    }

    MainCraft AddNeedResources(any[] arr)
    {
        NeedResources = arr;
        return this;
    }

    MainCraft AddNeedTools(any[] arr)
    {
        NeedTools = arr;
        return this;
    }

    MainCraft AddCheckOnView(int[] arr)
    {
        OnView = arr;
        return this;
    }

    MainCraft AddCheckOnCraft(int[] arr)
    {
        OnCraft = arr;
        return this;
    }

    MainCraft SetScript(MainCraftScript script)
    {
        Script = script;
        return this;
    }

    bool CheckOnView(Critter cr)
    {
        int i = 0;
        while (i < OnView.length()) {
            CritterProperty prop = CritterProperty(OnView[i++]);
            int value = OnView[i++];
            int valCr = cr.GetAsInt(prop);
            if (valCr < value) {
                return false;
            }
        }

        if (Script != null && Script(cr, Tla::FixboyList, this) == FIX_FAIL) {
            return false;
        }

        return true;
    }

    bool CheckOnCraft(Critter cr)
    {
        int i = 0;
        while (i < OnCraft.length()) {
            CritterProperty prop = CritterProperty(OnCraft[i++]);
            int value = OnCraft[i++];
            int valCr = cr.GetAsInt(prop);
            if (valCr < value) {
                return false;
            }
        }

        i = 0;
        while (i < NeedResources.length()) {
            hstring pid = hstring(NeedResources[i++]);
            int count = int(NeedResources[i++]);
            bool ors = int(NeedResources[i++]) == 1;
            if (!ors) {
                if (cr.CountItem(pid) < count) {
                    return false;
                }
            }
            else {
                hstring[] pids = {pid};
                int[] counts = {count};

                while (i < NeedResources.length()) {
                    pids.insertLast(hstring(NeedResources[i++]));
                    counts.insertLast(int(NeedResources[i++]));
                    if (int(NeedResources[i++]) != 1) {
                        break;
                    }
                }

                for (int j = 0; j < pids.length(); j++) {
                    if (cr.CountItem(pids[j]) < counts[j]) {
                        return false;
                    }
                }
            }
        }

        i = 0;
        while (i < NeedTools.length()) {
            hstring pid = hstring(NeedTools[i++]);
            int count = int(NeedTools[i++]);
            bool ors = int(NeedTools[i++]) == 1;
            if (!ors) {
                if (cr.CountItem(pid) < count) {
                    return false;
                }
            }
            else {
                hstring[] pids = {pid};
                int[] counts = {count};

                while (i < NeedTools.length()) {
                    pids.insertLast(hstring(NeedTools[i++]));
                    counts.insertLast(int(NeedTools[i++]));
                    if (int(NeedTools[i++]) != 1) {
                        break;
                    }
                }

                for (int j = 0; j < pids.length(); j++) {
                    if (cr.CountItem(pids[j]) < counts[j]) {
                        return false;
                    }
                    else {
                        break;
                    }
                }
            }
        }

        if (Script != null && Script(cr, Tla::FixboyButton, this) == FIX_FAIL) {
            return false;
        }

        return true;
    }

    bool CraftedItem(Critter cr)
    {
        if (!CheckOnCraft(cr)) {
            return false;
        }

        if (Script != null && Script(cr, Tla::FixboyCraft, this) == FIX_FAIL) {
            return false;
        }

        int i = 0;
        while (i < NeedResources.length()) {
            hstring pid = hstring(NeedResources[i++]);
            int count = int(NeedResources[i++]);
            bool ors = int(NeedResources[i++]) == 1;
            if (!ors) {
                cr.DestroyItem(pid, count);
            }
            else {
                bool orIsDelet = false;
                while (i < NeedResources.length()) {
                    if (!orIsDelet) {
                        if (cr.CountItem(pid) > count) {
                            cr.DestroyItem(pid, count);
                            orIsDelet = true;
                        }
                    }

                    pid = hstring(NeedResources[i++]);
                    count = int(NeedResources[i++]);
                    ors = int(NeedResources[i++]) == 1;
                    if (!ors) {
                        break;
                    }
                }
            }
        }

        i = 0;
        while (i < OutItems.length()) {
            hstring pid = hstring(OutItems[i++]);
            int count = int(OutItems[i++]);
            cr.AddItem(pid, count);
        }

        cr.Experience += Experience;
        return true;
    }
};

MainCraft? GetCraft(int id)
{
    for (int i = 0; i < CraftList.length(); i++) {
        if (CraftList[i].Id == id) {
            return CraftList[i];
        }
    }

    return null;
}

