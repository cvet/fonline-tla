            if (!Active) {
                SetText("");
                return;
            }
            auto fix = cast<FixBoy>(GuiScreensExt::NeedScreen(Screen));
            if (fix.StrNum == 0) {
                SetText("");
            }
            else {
                SetText(MsgStr::GetGameText(fix.StrNum));
            }
        }
    }
