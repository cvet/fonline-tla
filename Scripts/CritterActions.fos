namespace CritterActions
{

#if SERVER

bool ProcessAp(Critter cr, int ap)
{
    if (cr.CurrentAp / AP_DIVIDER < int(ap)) {
        int apRegeneration = cr.ApRegenerationTime;
        if (apRegeneration == 0) {
            apRegeneration = Settings.Combat.ApRegeneration;
        }

        CritterState::Wait(cr, apRegeneration / cr.ActionPoints * (ap - cr.CurrentAp / AP_DIVIDER));
        return false;
    }

    cr.CurrentAp = (cr.CurrentAp / AP_DIVIDER - ap) * AP_DIVIDER;
    cr.ApRegenerationTick = Game.FrameTime + Time::Milliseconds(Settings.Movement.Breaktime);
    CritterState::Wait(cr, Settings.Movement.Breaktime);

    return true;
}

void PickCritter(Critter cr, Critter pickCr)
{
    // Spend ap
    if (!ProcessAp(cr, Settings.Movement.RtApCostPickCritter)) {
        return;
    }

    if (!cr.IsAlive()) {
        throw("Critter is not alive", cr);
    }

    if (!pickCr.IsDead()) {
        throw("Pick critter is not dead", pickCr);
    }

    if (pickCr.IsNoLoot) {
        return;
    }

    if (Game.GetDistance(cr.Hex, pickCr.Hex) > 1 + cr.Multihex) {
        throw("Target too far", cr, cr.Hex.x, cr.Hex.y, pickCr.Hex.x, pickCr.Hex.y);
    }

    Map? map = cr.GetMap();
    if (map == null) {
        throw("Critter is on global map", cr);
    }

    Map? mapPick = pickCr.GetMap();
    if (mapPick == null) {
        throw("Pick critter is on global map", pickCr);
    }

    cr.Action(CritterAction::PickCritter, 0, null);
    (Game.OnCritterUseSkill.Fire(cr, CritterProperty::SpecialSkillLootCritter, pickCr, null, null) == EventResult::ContinueChain);
}

void PickItem(Critter cr, mpos hex, hstring pid)
{
    // Spend ap
    if (!ProcessAp(cr, Settings.Movement.RtApCostPickItem)) {
        return;
    }

    if (!cr.IsAlive()) {
        throw("Critter is not alive", cr);
    }

    if (Game.GetDistance(cr.Hex, hex) > 1 + cr.Multihex) {
        throw("Target too far", cr, cr.Hex.x, cr.Hex.y, hex.x, hex.y);
    }

    Map? map = cr.GetMap();
    if (map == null) {
        throw("Critter is on global map", cr);
    }

    if (hex.x >= map.Size.width || hex.y >= map.Size.height) {
        throw("Invalid hex position", cr, hex.x, hex.y);
    }

    if (!Game.CheckProtoItem(pid)) {
        throw("Invalid pid", cr, pid);
    }

    ProtoItem proto = Game.GetProtoItem(pid);

    if (!proto.IsScenery && !proto.IsWall) {
        Item? item = map.GetItemOnHex(hex, pid);
        if (item == null) {
            throw("Item not found", cr, hex.x, hex.y, pid);
        }

        cr.Action(CritterAction::PickItem, 0, item);
        (Game.OnCritterUseSkill.Fire(cr, CritterProperty::SpecialSkillPickOnGround, null, item, null) == EventResult::ContinueChain);
    }
    else if (proto.IsScenery) {
        StaticItem? scenery = map.GetStaticItemOnHex(hex, pid);
        if (scenery == null) {
            throw("Scenery not found", cr, hex.x, hex.y, pid);
        }

        cr.Action(CritterAction::PickItem, 0, scenery);
        (Game.OnCritterUseSkill.Fire(cr, CritterProperty::SpecialSkillPickOnGround, null, null, scenery) == EventResult::ContinueChain);
    }
    else if (proto.IsWall) {
        Messaging::Info(cr, TextPackKey(TextPackName::Game, "" + (MsgStr::Get("StrUseNothing"))));
    }
    else {
        Messaging::Info(cr, TextPackKey(TextPackName::Game, "" + (MsgStr::Get("StrUseNothing"))));
    }
}

void DropInvItem(Critter cr, ident itemId, int count)
{
    // Spend ap
    if (!ProcessAp(cr, Settings.Movement.RtApCostDropItem)) {
        return;
    }

    // Critter checks
    if (!cr.IsAlive()) {
        throw("Critter is not alive", cr);
    }

    // Get item
    Item? item = cr.GetItem(itemId);
    if (item == null) {
        throw("Item not found", cr, itemId);
    }

    if (count == 0) {
        count = item.Count;
    }

    if (count > item.Count) {
        throw("Invalid count", cr, item, count);
    }

    // Animation
    cr.Action(CritterAction::DropItem, -1, item);

    // Drop
    Map? map = cr.GetMap();
    if (map != null) {
        ItemMovement::MoveItem(item, count, map, cr.Hex);
    }
    else if (count < item.Count) {
        item.Count -= count;
    }
    else {
        Game.DestroyItem(item);
    }
}

void UseSkill(Critter cr, CritterProperty skill, ident targetCrId, ident targetItemId, hstring sceneryPid, int hx, int hy)
{
    if (!cr.IsAlive()) {
        throw("Client is not alive", cr);
    }

    // Spend ap
    int ap = Settings.Movement.RtApCostUseSkill;
    if (!ProcessAp(cr, ap)) {
        return;
    }

    Critter? targetCr;
    Item? targetItem;
    StaticItem? targetScen;
    int useDist = 3 + cr.Multihex;

    if (targetCrId != ZERO_IDENT) {
        if (cr.Id != targetCrId) {
            if (cr.GetMap() != null) {
                targetCr = Game.GetCritter(targetCrId);
                if (targetCr == null) {
                    throw("Target critter not found", cr, targetCrId);
                }

                if (!cr.IsSee(targetCr)) {
                    throw("Critter doesn't see target critter", cr, targetCr);
                }

                if (Game.GetDistance(cr.Hex, targetCr.Hex) > useDist + targetCr.Multihex) {
                    throw("Target critter too far", cr, targetCr);
                }
            }
            else {
                // need realization
                throw("Target critter not found in global group", cr, targetCrId);
            }
        }
        else {
            targetCr = cr;
        }
    }
    else if (targetItemId != ZERO_IDENT || sceneryPid != EMPTY_HSTRING) {
        Map? map = cr.GetMap();
        if (map == null) {
            throw("Critter on global map", cr);
        }

        if (sceneryPid == EMPTY_HSTRING) {
            targetItem = map.GetItem(targetItemId);
            if (targetItem == null) {
                throw("Target item not found on map", cr, map, targetItemId);
            }

            if (targetItem.Hidden) {
                throw("Target item is hidden", cr, map, targetItem);
            }

            if (Game.GetDistance(cr.Hex, targetItem.Hex) > useDist) {
                throw("Target item too far", cr, targetItem);
            }
        }
        else {
            if (!Game.CheckProtoItem(sceneryPid)) {
                throw("Proto item not found", cr, sceneryPid);
            }

            ProtoItem proto = Game.GetProtoItem(sceneryPid);

            if (Game.GetDistance(cr.Hex, mpos(hx, hy)) > useDist) {
                throw("Target scenery too far", cr, hx, hy, sceneryPid);
            }

            targetScen = map.GetStaticItemOnHex(mpos(hx, hy), sceneryPid);
            if (targetScen == null) {
                throw("Scenery not found", cr, hx, hy, sceneryPid);
            }
        }
    }

    // Send action
    cr.Action(CritterAction::UseSkill, 0, null);

    (Game.OnCritterUseSkill.Fire(cr, skill, targetCr, targetItem, targetScen) == EventResult::ContinueChain);
}

void MoveInvItem(Critter cr, ident itemId, CritterItemSlot slot)
{
    // Get item
    Item? item = cr.GetItem(itemId);
    if (item == null) {
        throw("Item not found", cr, itemId);
    }

    // Calculate move cost
    int apCost = Settings.Movement.RtApCostMoveItemInventory;
    if ((item.CritterSlot == CritterItemSlot::Main && slot == CritterItemSlot::Secondary) ||
        (item.CritterSlot == CritterItemSlot::Secondary && slot == CritterItemSlot::Main)) {
        apCost = 0;
    }

    // Spend ap
    if (!ProcessAp(cr, apCost)) {
        return;
    }

    // Critter checks
    if (!cr.IsAlive()) {
        throw("Critter is not alive", cr);
    }

    // Move
    cr.ChangeItemSlot(item.Id, slot);
}

void OperateContainer(Critter cr, bool take, bool all, ident itemId, int itemCount)
{
    if (!cr.IsAlive()) {
        throw("Critter is not alive", cr);
    }

    CritterState::Wait(cr, Settings.Movement.Breaktime);

    TransferTypes transferType = cr.TransferType;
    if (transferType == TransferTypes::Close) {
        throw("Transfer is closed", cr);
    }

    Map? map = cr.GetMap();
    if (map == null && (transferType != TransferTypes::CritSteal && transferType != TransferTypes::FarCont && transferType != TransferTypes::FarCrit &&
                        transferType != TransferTypes::CritBarter && transferType != TransferTypes::SelfCont)) {
        throw("Invalid transfer type for global map", cr, transferType);
    }

    if (all && transferType == TransferTypes::CritSteal) {
        throw("Can't operate with stealing with all items", cr);
    }

    // Get container
    Item? itemCont;
    Critter? crCont;
    if (transferType == TransferTypes::HexContUp || transferType == TransferTypes::HexContDown || transferType == TransferTypes::SelfCont ||
        transferType == TransferTypes::FarCont) {
        if (transferType == TransferTypes::HexContUp || transferType == TransferTypes::HexContDown) {
            itemCont = Game.GetItem(cr.TransferContainerId);
            if (itemCont == null) {
                throw("Hex container not found", cr, cr.TransferContainerId);
            }

            if (itemCont.Type != ItemType::Container) {
                throw("Hex container is not container type", cr, itemCont);
            }

            if (itemCont.Ownership != ItemOwnership::MapHex) {
                throw("Hex container not on map", cr, itemCont);
            }

            verify(map != null, "Hex container transfer requires critter map", cr);
            if (itemCont.MapId != map.Id) {
                throw("Hex container not on cr map", cr, itemCont);
            }

            if (Game.GetDistance(cr.Hex, itemCont.Hex) > 1 + cr.Multihex) {
                throw("Hex container too far", cr, itemCont);
            }
        }
        else if (transferType == TransferTypes::FarCont) {
            itemCont = Game.GetItem(cr.TransferContainerId);
            if (itemCont == null) {
                throw("Hex container not found", cr, cr.TransferContainerId);
            }

            if (itemCont.Type != ItemType::Container) {
                throw("Hex container is not container type", cr, itemCont);
            }
        }
        else {
            itemCont = cr.GetItem(cr.TransferContainerId);
            if (itemCont == null) {
                throw("Hex container not found", cr, cr.TransferContainerId);
            }

            if (itemCont.Type != ItemType::Container) {
                throw("Hex container is not container type", cr, itemCont);
            }
        }
    }
    else if (transferType == TransferTypes::CritLoot || transferType == TransferTypes::CritSteal || transferType == TransferTypes::CritBarter ||
             transferType == TransferTypes::FarCrit) {
        crCont = Game.GetCritter(cr.TransferContainerId);
        if (crCont == null) {
            throw("Critter container not found", cr, cr.TransferContainerId);
        }

        if (transferType != TransferTypes::FarCrit && !cr.IsSee(crCont)) {
            throw("Critter container is not seen by cr", cr, crCont);
        }

        if (transferType != TransferTypes::FarCrit && Game.GetDistance(cr.Hex, crCont.Hex) > 1 + cr.Multihex + crCont.Multihex) {
            throw("Critter container is too far", cr, crCont);
        }

        if (cr.Id == cr.TransferContainerId) {
            throw("Critter container id is same as cr id", cr, crCont);
        }

        if (transferType == TransferTypes::CritSteal && crCont.IsNoSteal) {
            throw("Critter container marked as NoSteal", cr, crCont);
        }

        //     if( transferType == TransferTypes::CritSteal && !crCont.ControlledByPlayer && Ai::IsAttacking( crCont ) )
        //         throw( "Critter container is in battle", cr, crCont );
        if (transferType == TransferTypes::CritLoot && !crCont.IsDead()) {
            throw("Critter container loot is not dead", cr, crCont);
        }
    }
    else {
        verify(false, "Assertion failed");
    }

    // Get item(s)
    Item[] items;
    if (take) {
        if (itemCont != null) {
            if (!all) {
                Item? item = Game.GetItem(itemId);
                if (item == null) {
                    throw("Hex container item not found", cr, itemId);
                }

                if (item.Ownership != ItemOwnership::ItemContainer || item.ContainerId != itemCont.Id) {
                    throw("Item not in hex container", cr, item, itemCont);
                }

                if (item.ContainerStack != any()) {
                    throw("Item hex container stack is not zero", cr, item, itemCont);
                }

                if (itemCount > item.Count) {
                    throw("Hex container item invalid count", cr, item, itemCount);
                }

                items = {item};
            }
            else {
                items = itemCont.GetItems(ROOT_CONTAINER_STACK);
            }
        }
        else {
            verify(crCont != null, "Critter container must be resolved", cr);
            Critter critterContainer = crCont;
            if (!all) {
                Item? item = critterContainer.GetItem(itemId);
                if (item == null) {
                    throw("Critter container item not found", cr, itemId);
                }

                if (item.Ownership != ItemOwnership::CritterInventory || item.CritterId != critterContainer.Id) {
                    throw("Item not in critter container", cr, item, critterContainer);
                }

                if (item.CritterSlot != CritterItemSlot::Inventory) {
                    throw("Item critter container slot is not innventory", cr, item, critterContainer);
                }

                if (itemCount > item.Count) {
                    throw("Critter container item invalid count", cr, item, itemCount);
                }

                items = {item};
            }
            else {
                items = critterContainer.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
            }
        }
    }
    else {
        if (!all) {
            Item? item = cr.GetItem(itemId);
            if (item == null) {
                throw("Client item not found", cr, itemId);
            }

            if (itemCount > item.Count) {
                throw("Client item invalid count", cr, item, itemCount);
            }

            items = {item};
        }
        else {
            items = cr.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
        }
    }

    // Filter
    if (take && (transferType == TransferTypes::CritLoot || transferType == TransferTypes::CritSteal)) {
        for (int i = 0; i < items.length();) {
            if ((transferType == TransferTypes::CritLoot && items[i].IsNoLoot) || (transferType == TransferTypes::CritSteal && items[i].IsNoSteal)) {
                items.removeAt(i);
            }
            else {
                i++;
            }
        }
    }

    if (items.length() == 0) {
        return;
    }

    // Check ability
    int weight = 0;
    for (int i = 0; i < items.length(); i++) {
        weight += items[i].Weight * (all ? items[i].Count : itemCount);
    }

    if (itemCont == null) {
        Critter? target = take ? cr : crCont;
        verify(target != null, "Critter container must be resolved", cr);
        if (target.CarryWeight < target.ItemsWeight + weight) {
            throw("Critter is overweight", target);
        }
    }

    // Animation
    cr.Action(CritterAction::OperateContainer, transferType, !all ? items[0] : null);

    // Moving
    if (transferType == TransferTypes::CritSteal) {
        if ((Game.OnCritterStealing.Fire(crCont, cr, items[0], itemCount) == EventResult::ContinueChain)) {
            ItemMovement::MoveItem(items[0], itemCount, cr);
        }
        else {
            items.clear();
            cr.TransferType = TransferTypes::Close;
            cr.TransferContainerId = ZERO_IDENT;
            cr.SendItems(items);
            return;
        }
    }
    else {
        if (take) {
            if (!all) {
                ItemMovement::MoveItem(items[0], itemCount, cr);
            }
            else {
                ItemMovement::MoveItems(items, cr);
            }
        }
        else {
            if (itemCont != null) {
                if (!all) {
                    ItemMovement::MoveItem(items[0], itemCount, itemCont, ROOT_CONTAINER_STACK);
                }
                else {
                    ItemMovement::MoveItems(items, itemCont, ROOT_CONTAINER_STACK);
                }
            }
            else {
                if (!all) {
                    ItemMovement::MoveItem(items[0], itemCount, crCont);
                }
                else {
                    ItemMovement::MoveItems(items, crCont);
                }
            }
        }
    }

    // Events
    Entity cont = (itemCont != null ? cast<Entity>(itemCont) : cast<Entity>(crCont));
    for (int i = 0; i < items.length(); i++) {
        (Game.OnClientOperateContainer.Fire(cr, cont, items[i], take) == EventResult::ContinueChain);
    }

    // Refresh container info
    Item[] curItems;
    if (itemCont != null) {
        curItems = itemCont.GetItems(ROOT_CONTAINER_STACK);
    }
    else {
        verify(crCont != null, "Critter container must be resolved", cr);
        Critter critterContainer = crCont;
        curItems = critterContainer.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
    }

    cr.SendItems(curItems, false, false, 1);
}

void ReloadWeapon(Critter cr, ident weaponId, ident ammoId)
{
    if (!cr.IsAlive()) {
        throw("Client is not alive", cr);
    }

    // Get weapon
    Item? weapon = cr.GetItem(weaponId);
    if (weapon == null) {
        throw("Unable to find weapon", cr, weaponId);
    }

    if (weapon.Type != ItemType::Weapon) {
        throw("Invalid type of weapon", cr, weapon);
    }

    if (weapon.Weapon_Caliber == 0) {
        throw("Weapon doesn't have caliber", cr, weapon);
    }

    if (weapon.Weapon_MaxAmmoCount == 0) {
        throw("Weapon doesn't have ammo holder", cr, weapon);
    }

    // Spend ap
    int ap = Settings.Movement.RtApCostReloadWeapon;
    if (!ProcessAp(cr, ap)) {
        return;
    }

    // Get ammo
    Item? ammo = (ammoId != ZERO_IDENT ? cr.GetItem(ammoId) : null);
    if (ammoId != ZERO_IDENT && ammo == null) {
        throw("Ammo not found", cr, weapon, ammoId);
    }

    if (ammo != null && weapon.AmmoPid == ammo.ProtoId && weapon.AmmoCount >= weapon.Weapon_MaxAmmoCount) {
        throw("Weapon is full", cr, weapon, ammo);
    }

    // Unload
    if (ammo == null || (weapon.AmmoCount > 0 && weapon.AmmoPid != ammo.ProtoId)) {
        if (weapon.AmmoPid != EMPTY_HSTRING) {
            Item? existAmmo = cr.GetItem(weapon.AmmoPid);
            if (existAmmo == null) {
                cr.AddItem(weapon.AmmoPid, weapon.AmmoCount);
            }
            else {
                existAmmo.Count += weapon.AmmoCount;
            }
        }

        weapon.AmmoCount = 0;
    }

    // Load
    if (ammo != null) {
        int count = Math::Min(ammo.Count, weapon.Weapon_MaxAmmoCount - weapon.AmmoCount);
        weapon.AmmoCount += count;
        weapon.AmmoPid = ammo.ProtoId;

        if (ammo.Count > count) {
            ammo.Count -= count;
        }
        else {
            Game.DestroyItem(ammo);
        }
    }

    cr.Action(CritterAction::ReloadWeapon, 0, weapon);
}

void Attack(Critter cr, ident targetId, int mode)
{
    Critter? target = Game.GetCritter(targetId);

    int use = mode & 0xF;
    int aim = mode >> 4;

    AbstractItem weapon = CritterItem::GetActive(cr);
    if (weapon.Type != ItemType::Weapon) {
        throw("Critter item is not weapon", cr, weapon);
    }

    if (weapon.Weapon_IsTwoHanded && (cr.IsDamagedLeftArm || cr.IsDamagedRightArm)) {
        throw("Critter is damaged arm for two handed weapon", cr, weapon);
    }

    if (cast<Item?>(weapon) == null && cr.IsDamagedLeftArm && cr.IsDamagedRightArm) {
        throw("Critter is damaged two arms for armed attack", cr, weapon);
    }

    if (weapon.Weapon_ActiveUses <= use) {
        throw("Weapon use is not allowed", cr, weapon, use);
    }

    if (aim != HitLocations::LocationNone) {
        if (cr.IsNoAim) {
            throw("Critter try aim when mode IsNoAim", cr, weapon, aim);
        }

        if (!_WeaponAim(weapon, use)) {
            throw("Critter try aim when weapon no aim for use", cr, weapon, aim, use);
        }
    }

    // Spend ap
    int ap = Parameters::GetItemUseApCost(cr, weapon, mode);
    if (!ProcessAp(cr, ap)) {
        return;
    }

    if (target != null && cr.Id == target.Id) {
        throw("Critter tried attack himself", cr);
    }

    Map? map = cr.GetMap();
    if (map == null) {
        throw("Critter on global map", cr);
    }

    if (target != null) {
        if (!cr.IsSee(target)) {
            throw("Critter don't sees target", cr, target);
        }

        if (target.IsDead()) {
            throw("Target critter is dead", cr, target);
        }
    }
    else {
        // TODO: hex attack
        throw("Target == null for critter", cr);
    }

    Critter attackTarget = target;
    mpos targetHex = attackTarget.Hex;
    mpos hex = cr.Hex;

    int maxDist = Parameters::GetCritterAttackDistance(cr, weapon, mode);
    if (maxDist == 0) {
        throw("Invalid weapon range", cr, weapon, use, targetHex.x, targetHex.y);
    }

    int dist = Game.GetDistance(hex, targetHex);
    if (dist - attackTarget.Multihex > maxDist) {
        throw("Target too far", cr, weapon, use, targetHex.x, targetHex.y);
    }

    mpos tracedHex = targetHex;
    map.GetHexInPath(hex, tracedHex, 0.0f, dist);
    if (targetHex != tracedHex) {
        throw("Target blocked", cr, weapon, use, targetHex.x, targetHex.y);
    }

    // Ammo
    ProtoItem? ammo = null;

    if (weapon.Weapon_Caliber != 0 && weapon.Weapon_MaxAmmoCount > 0) {
        if (Game.CheckProtoItem(weapon.AmmoPid)) {
            ammo = Game.GetProtoItem(weapon.AmmoPid);
        }
        else if (Game.CheckProtoItem(weapon.Weapon_DefaultAmmoPid)) {
            ammo = Game.GetProtoItem(weapon.Weapon_DefaultAmmoPid);
        }

        if (ammo == null) {
            throw("Weapon ammo not found", cr, weapon);
        }

        if (ammo.Type != ItemType::Ammo) {
            throw("Weapon ammo item isn't have ammo type", cr, weapon, ammo);
        }

        if (!cr.IsUnlimitedAmmo && weapon.AmmoCount == 0) {
            throw("Weapon ammo count is zero", cr, weapon, ammo);
        }
    }

    // Raise attack event
    cr.TimeoutAggressor = Game.SynchronizedTime + Time::Minutes(1);
    Combat::CombatAttack(cr, attackTarget, weapon, mode, ammo);
}

void UseItemOn(Critter cr, ident usedItemId, ident targetCrId, ident targetItemId, hstring sceneryPid, int hx, int hy, int timer)
{
    if (!cr.IsAlive()) {
        throw("Client is not alive", cr);
    }

    if (usedItemId == ZERO_IDENT) {
        throw("Critter used zero ident item", cr);
    }

    Item? usedItem = Game.GetItem(usedItemId);
    if (usedItem == null) {
        throw("Critter used item not found", cr, usedItemId);
    }

    int ap = Settings.Movement.RtApCostUseItem;
    if (!ProcessAp(cr, ap)) {
        return;
    }

    Critter? targetCr;
    Item? targetItem;
    StaticItem? targetScen;
    int useDist = 1 + cr.Multihex;

    if (targetCrId != ZERO_IDENT) {
        if (cr.Id != targetCrId) {
            if (cr.GetMap() != null) {
                targetCr = Game.GetCritter(targetCrId);
                if (targetCr == null) {
                    throw("Target critter not found", cr, targetCrId);
                }

                if (!cr.IsSee(targetCr)) {
                    throw("Critter doesn't see target critter", cr, targetCr);
                }

                if (Game.GetDistance(cr.Hex, targetCr.Hex) > useDist + targetCr.Multihex) {
                    throw("Target critter too far", cr, targetCr);
                }
            }
            else {
                // need realization
                throw("Target critter not found in global group", cr, targetCrId);
            }
        }
    }
    else if (targetItemId != ZERO_IDENT || sceneryPid != EMPTY_HSTRING) {
        Map? map = cr.GetMap();
        if (map == null) {
            throw("Critter on global map", cr);
        }

        if (sceneryPid == EMPTY_HSTRING) {
            targetItem = map.GetItem(targetItemId);
            if (targetItem == null) {
                throw("Target item not found on map", cr, map, targetItemId);
            }

            if (targetItem.Hidden) {
                throw("Target item is hidden", cr, map, targetItem);
            }

            if (Game.GetDistance(cr.Hex, targetItem.Hex) > useDist) {
                throw("Target item too far", cr, targetItem);
            }
        }
        else {
            if (!Game.CheckProtoItem(sceneryPid)) {
                throw("Proto item not found", cr, sceneryPid);
            }

            ProtoItem proto = Game.GetProtoItem(sceneryPid);

            if (Game.GetDistance(cr.Hex, mpos(hx, hy)) > useDist) {
                throw("Target scenery too far", cr, hx, hy, sceneryPid);
            }

            targetScen = map.GetStaticItemOnHex(mpos(hx, hy), sceneryPid);
            if (targetScen == null) {
                throw("Scenery not found", cr, hx, hy, sceneryPid);
            }
        }
    }

    // Send action
    cr.Action(CritterAction::UseItem, 0, null);
    (Game.OnCritterUseItemOn.Fire(cr, usedItem, targetCr, targetItem, targetScen, timer) == EventResult::ContinueChain);
}

#endif

}
