// Elevators
int ElevatorPosition(int elevator, int current_level)
{
    return (int((current_level) & 0xFFFF) << 16) | (elevator) & 0xFFFF;
}
int ElevatorBos1234(int current_level)
{
    return ElevatorPosition(0, current_level);
}
int ElevatorBos01(int current_level)
{
    return ElevatorPosition(1, current_level);
}
int ElevatorMaster123(int current_level)
{
    return ElevatorPosition(2, current_level);
}
int ElevatorMaster34(int current_level)
{
    return ElevatorPosition(3, current_level);
}
int ElevatorMilitary123(int current_level)
{
    return ElevatorPosition(4, current_level);
}
int ElevatorMilitary34(int current_level)
{
    return ElevatorPosition(5, current_level);
}
int ElevatorMilitary346(int current_level)
{
    return ElevatorPosition(6, current_level);
}
int ElevatorMilitary456(int current_level)
{
    return ElevatorPosition(7, current_level);
}
int ElevatorVault123(int current_level)
{
    return ElevatorPosition(8, current_level);
}

