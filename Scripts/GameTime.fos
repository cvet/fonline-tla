{
    int year = 0, month = 0, day = 0, hour = 0, minute = 0, second = 0, milisecond = 0;
    Game.UnpackSynchronizedTime(Game.SynchronizedTime, year, month, day, hour, minute, second, milisecond);
    return hour;
}

