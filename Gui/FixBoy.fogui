{
    {
        {
            if (!Active) {
                return;
            }

            any[] needTools = cast<FixBoy>(GuiScreensExt::NeedScreen(Screen)).NeedTools;
            string text = MsgStr::GetGameText(MsgStr::StrFixTools) + "\\n";
            int index = 0;
            while (index < needTools.length()) {
                if (index != 0) {
                    text += needTools[index + 2] == 1 ? "или " : "и ";
                }
                text += Game.GetText(MsgStr::ProtoItemNameKey(hstring(needTools[index])));
                text += ", " + needTools[index + 1] + "\\n";
                index += 3;
            }
            int tw = 0, th = 0, lines = 0;
            Game.GetTextInfo(text, isize(Size.width, 1000), TextFormat(FontType(int(TextFont)), FontFlag(TextFlags), 0), isize(tw, th), lines);
            SetText(text);
            SetSize(Size.width, th);
        }
    }
