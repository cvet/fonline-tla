[Dialog]
Speech 1 # Преддиалоговые установки
  Answer 2 # не знаком
    Demand Script Dialog::IsNotNameMemNpcPlayer
    Result Script Dialog::SetNameMemNpcPlayer true
  Answer 3 # знаком
    Demand Script Dialog::IsNameMemNpcPlayer

Speech 2 # Привет. Я Фред, занимаюсь продажей всяких вещей...
  Answer 4 # Меня прислал Джеймс за деньгами.
    Demand Property Player DenJaneDolg == 1
    Demand Property Player DenJaneTraderFred == 0
    Result Property Player DenJaneTraderFred = 1
    Result Item Player bottle_caps += 500
  Answer Barter # Давай посмотрим, что у тебя есть.
  Answer Exit # Мне пора.

Speech 3 # Снова ты. Чем могу помочь на этот раз?
  Answer 4 # Меня прислал Джеймс за деньгами.
    Demand Property Player DenJaneDolg == 1
    Demand Property Player DenJaneTraderFred == 0
    Result Property Player DenJaneTraderFred = 1
    Result Item Player bottle_caps += 500
  Answer 7 # У тебя стимпаки есть?
    Demand Item Npc stimpak < 1
    Demand Script Dialog::d_NotTimeoutCheck
  Answer 9 # У тебя стимпаки есть?
    Demand Item Npc stimpak < 1
    Demand Script Dialog::d_TimeoutCheck
  Answer 8 # У тебя стимпаки есть?
    Demand Item Npc stimpak > 0
  Answer 10 # У меня есть несколько стимпаков для тебя.
    Demand Item Player stimpak > 2
    Demand Property Player DenFredStim == 1
    Result Script Dialog::r_TimeoutSet 4
    Result Item Player stimpak -= 3
    Result Property Player Experience += 200
    Result Property Player DenFredStim = 2
    Result Item Player bottle_caps += 300
  Answer Barter # Давай торговаться.
  Answer Exit # Спасибо, пока ничего.

Speech 4 # Да верно, вот держи.

Speech 5 # В данное время у меня нет денег, чтобы выплатит...

Speech 7 # Нет, закончились... Зайди попозже.
  Answer Barter # Покажи тогда другой товар.
  Answer Exit # Окей.

Speech 8 # Должно быть, осталось немного. Желаешь купить?
  Answer Barter # Давай. [Бартер]
  Answer Exit # Мне уже хватит.

Speech 9 # Нет, закончились. Может ты принесешь мне хоть 3...
  Answer Exit # По рукам!
    Result Property Player DenFredStim = 1
  Answer Exit* # Нет, не хочу тратить время.

Speech 10 # Отлично. Вот твои деньги. [Он дает вам 300 долл...
  Answer Exit # [Выход]

[Text russ]
{Name}{}{Фред}
{DescAliveShort}{}{Вы видите Фреда.}
{DescAliveFull}{}{Фред, похоже, очень доволен своим элегантным костюмом.}
{Speech 1}{}{Преддиалоговые установки}
{Speech 1 Answer 2}{}{не знаком}
{Speech 1 Answer 3}{}{знаком}
{Speech 2}{}{Привет. Я Фред, занимаюсь продажей всяких вещей. Чем обязан?}
{Speech 2 Answer 4}{}{Меня прислал Джеймс за деньгами.}
{Speech 2 Answer Barter}{}{Давай посмотрим, что у тебя есть.}
{Speech 2 Answer Exit}{}{Мне пора.}
{Speech 3}{}{Снова ты. Чем могу помочь на этот раз?}
{Speech 3 Answer 4}{}{Меня прислал Джеймс за деньгами.}
{Speech 3 Answer 7}{}{У тебя стимпаки есть?}
{Speech 3 Answer 9}{}{У тебя стимпаки есть?}
{Speech 3 Answer 8}{}{У тебя стимпаки есть?}
{Speech 3 Answer 10}{}{У меня есть несколько стимпаков для тебя.}
{Speech 3 Answer Barter}{}{Давай торговаться.}
{Speech 3 Answer Exit}{}{Спасибо, пока ничего.}
{Speech 4}{}{Да верно, вот держи.}
{Speech 5}{}{В данное время у меня нет денег, чтобы выплатить долг. Зайди попозже.}
{Speech 7}{}{Нет, закончились... Зайди попозже.}
{Speech 7 Answer Barter}{}{Покажи тогда другой товар.}
{Speech 7 Answer Exit}{}{Окей.}
{Speech 8}{}{Должно быть, осталось немного. Желаешь купить?}
{Speech 8 Answer Barter}{}{Давай. [Бартер]}
{Speech 8 Answer Exit}{}{Мне уже хватит.}
{Speech 9}{}{Нет, закончились. Может ты принесешь мне хоть 3 штуки? Я заплачу тебе по 100 баксов за каждый.}
{Speech 9 Answer Exit}{}{По рукам!}
{Speech 9 Answer Exit*}{}{Нет, не хочу тратить время.}
{Speech 10}{}{Отлично. Вот твои деньги. [Он дает вам 300 долларов]}
{Speech 10 Answer Exit}{}{[Выход]}

