{
    {
        {
            Dialog @dialog = cast<Dialog>(Screen);
            string text;
            if (dialog.TalkTime != ZERO_TIMESPAN) {
                nanotime curTick = Game.FrameTime;
                nanotime endTick = dialog.TalkStartTick + dialog.TalkTime;
                text += (curTick < endTick ? (endTick - curTick) : ZERO_TIMESPAN).seconds;
            }

            SetText(text);
        }
    }
}
