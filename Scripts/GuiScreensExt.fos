// GuiScreensExt — ручная (негенерируемая) логика поверх сгенерированного GuiScreens.fos.
// Отвечает за переключение экранов интерфейса по событиям клиента (старт, загрузка/выгрузка
// карты, подключение/отключение), за обработку выхода/отмены (TryExit), смену курсора
// и за хелперы-гарды доступа к GUI-объектам (бросают исключение вместо тихого null).
// CLIENT: вся работа с экранами, курсором и пинг-клиент.
// SERVER: только серверная часть пинга (обработка GuiPingRequest).
// Парный модуль к генерируемому GuiScreens.fos; источник GUI — Gui/*.fogui.
namespace GuiScreensExt
{

// Todo: ввести рисование подсветки гекса при курсоре передвижения, см. CurMap.SetCursorPos

///@ Setting Client bool Gui.HideCursor
///@ RemoteCall Server GuiPingRequest()
///@ RemoteCall Client GuiPingAnswer()

#if CLIENT

// Точка входа модуля: подписываемся на клиентские события для переключения экранов.
[[ModuleInit]]
void InitGuiScreensExt()
{
    Game.OnStart.Subscribe(OnStart, EventPriority::Lowest);
    Game.OnConnectingFailed.Subscribe(OnConnectingFailed);
    Game.OnMapLoaded.Subscribe(OnMapLoaded);
    Game.OnMapUnload.Subscribe(OnMapUnload);
    Game.OnConnecting.Subscribe(OnConnecting);
    Game.OnDisconnected.Subscribe(OnDisconnected);
}

// При старте клиента показываем экран логина (без автоподключения к серверу).
[[Event]]
void OnStart()
{
    // отключено: ранее клиент подключался к серверу сразу при старте
    //Game.Connect();
    Gui::ShowScreen(GuiScreen::Login);
    ScreenFadeOut();
}

// Карта загружена — переходим к игровому экрану и ставим курсор перемещения.
[[Event]]
void OnMapLoaded()
{
    Gui::HideAllScreens();
    Gui::ShowScreen(GuiScreen::Game);
    Gui::Cursor = CursorType::Move;
    ScreenFadeOut();
}

// Карта выгружается — убираем все экраны.
[[Event]]
void OnMapUnload()
{
    Gui::HideAllScreens();
}

// Идёт подключение — показываем экран ожидания (если он ещё не активен).
[[Event]]
void OnConnecting()
{
    if (!Gui::IsScreenActive(GuiScreen::Wait)) {
        Gui::HideAllScreens();
        Gui::ShowScreen(GuiScreen::Wait);
    }
}

// Подключение не удалось — возвращаемся на экран логина.
[[Event]]
void OnConnectingFailed()
{
    if (Gui::IsScreenActive(GuiScreen::Wait)) {
        Gui::HideAllScreens();
        Gui::ShowScreen(GuiScreen::Login);
        ScreenFadeOut();
    }
}

// Соединение разорвано — возвращаемся на экран логина.
[[Event]]
void OnDisconnected()
{
    if (!Gui::IsScreenActive(GuiScreen::Login)) {
        Gui::HideAllScreens();
        Gui::ShowScreen(GuiScreen::Login);
        ScreenFadeOut();
    }
}

// Плавное затемнение экрана из чёрного (общий переход между экранами).
void ScreenFadeOut()
{
    Effects::FadeScreen(Color::Black, ZERO_UCOLOR, Time::Milliseconds(1000));
}

// Хелперы-гарды доступа к GUI-объектам: сужают nullable-хендл и громко падают, если объект
// отсутствует, вместо тихого возврата null. Используются вызывающим кодом GUI, где элемент
// обязан существовать по контракту экрана.
Gui::Object NeedObject(Gui::Object? obj)
{
    if (obj == null) {
        throw("GUI object not found");
    }

    return obj;
}

Gui::Screen NeedScreen(Gui::Screen? screen)
{
    if (screen == null) {
        throw("GUI screen not found");
    }

    return screen;
}

Gui::Text NeedText(Gui::Text? text)
{
    if (text == null) {
        throw("GUI text not found");
    }

    return text;
}

Gui::Panel NeedPanel(Gui::Panel? panel)
{
    if (panel == null) {
        throw("GUI panel not found");
    }

    return panel;
}

Gui::Button NeedButton(Gui::Button? button)
{
    if (button == null) {
        throw("GUI button not found");
    }

    return button;
}

Gui::ItemView NeedItemView(Gui::ItemView? itemView)
{
    if (itemView == null) {
        throw("GUI item view not found");
    }

    return itemView;
}

Sprite::Sprite NeedSprite(Sprite::Sprite? sprite)
{
    if (sprite == null) {
        throw("GUI sprite not found");
    }

    return sprite;
}

// Реакция на запрос «выйти/отмена» (обычно Esc): поведение зависит от активного экрана —
// выход из игры на логине, шаг назад в регистрации, разрыв соединения на ожидании, сброс
// активного курсора или открытие меню в игре, скрытие неосновного экрана по умолчанию.
void TryExit()
{
    Gui::Screen? screen = Gui::GetActiveScreen();
    if (screen == null) {
        return;
    }

    switch (screen.Num) {
    case GuiScreen::None:
        break;

    case GuiScreen::Login:
        Game.RequestQuit();
        break;
    case GuiScreen::Registration:
        Gui::ShowScreen(GuiScreen::Login);
        break;
    case GuiScreen::Wait:
        Game.Disconnect();
        break;
    case GuiScreen::GlobalMap:
    case GuiScreen::Game:
        if (Gui::Cursor == CursorType::UseItem || Gui::Cursor == CursorType::UseWeapon || Gui::Cursor == CursorType::UseSkill) {
            Gui::Cursor = CursorType::Default;
        }
        else {
            Gui::ShowScreen(GuiScreen::Menu);
        }

        break;

    default:
        if (!IsMainScreen(screen)) {
            Gui::HideScreen(screen);
        }

        break;
    }
}

// Является ли экран «основным» (его нельзя просто скрыть по отмене, в отличие от диалогов/панелей).
bool IsMainScreen(Gui::Screen screen)
{
    GuiScreen num = screen.Num;
    return num == GuiScreen::Login || num == GuiScreen::Registration || num == GuiScreen::Game || num == GuiScreen::GlobalMap || num == GuiScreen::Wait;
}

// Циклическое переключение типа курсора (по умолчанию -> перемещение -> применение оружия и т.д.).
// Курсор оружия доступен только при наличии Chosen, вне таймаута боя и с активным оружием в руках.
void NextCursor()
{
    switch (Gui::Cursor) {
    case CursorType::Default:
        Gui::Cursor = CursorType::Move;
        break;
    case CursorType::Move: {
        if (HasChosen && !Time::IsTimeoutActive(Chosen.TimeoutBattle) && CritterItem::GetActive(Chosen).Type == ItemType::Weapon) {
            Gui::Cursor = CursorType::UseWeapon;
        }
        else {
            Gui::Cursor = CursorType::Default;
        }
    } break;
    case CursorType::UseItem:
        Gui::Cursor = CursorType::Default;
        break;
    case CursorType::UseWeapon:
        Gui::Cursor = CursorType::Default;
        break;
    case CursorType::UseSkill:
        Gui::Cursor = CursorType::Move;
        break;
    default:
        Gui::Cursor = CursorType::Default;
        break;
    }
}

#endif

// Пинг сервера: клиент шлёт запрос и ждёт ответа, флаг отражает «запрос в процессе».
// Используется для проверки/индикации связи с сервером.

#if CLIENT

bool _PingInProgress = false;

// Отправить запрос пинга на сервер и пометить, что ответ ожидается.
void Ping()
{
    _PingInProgress = true;
    CurPlayer.ServerCall.GuiPingRequest();
}

bool IsPingInProgress()
{
    return _PingInProgress;
}

// сторона вызова закомментирована как breadcrumb парного контракта (см. GuiPingRequest на сервере)
// [[ServerRemoteCall]]
[[ClientRemoteCall]]
void GuiPingAnswer()
{
    _PingInProgress = false;
}

#endif

#if SERVER

// сторона вызова закомментирована как breadcrumb парного контракта (см. GuiPingAnswer на клиенте)
// [[ClientRemoteCall]]
[[ServerRemoteCall]]
void GuiPingRequest(Player player)
{
    player.ClientCall.GuiPingAnswer();
}

#endif
}
