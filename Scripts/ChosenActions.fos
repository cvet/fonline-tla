bool IsBusy(Critter cr)
{
    return Game.FrameTime < cr.WaitEndTick;
}

bool IsFree(Critter cr)
{
    return !IsBusy(cr);
}

#endif

#if SERVER

[[ServerRemoteCall]]
void PickCritter(Player player, ident crId)
{
    CritterActions::PickCritter(player.GetControlledCritter(), Game.GetCritter(crId));
}

[[ServerRemoteCall]]
void PickItem(Player player, mpos hex, hstring pid)
{
    CritterActions::PickItem(player.GetControlledCritter(), hex, pid);
}

[[ServerRemoteCall]]
void DropInvItem(Player player, ident itemId, int count)
{
    CritterActions::DropInvItem(player.GetControlledCritter(), itemId, count);
}

[[ServerRemoteCall]]
void UseSkill(Player player, CritterProperty skill, ident targetCrId, ident targetItemId, hstring sceneryPid, mpos hex)
{
    CritterActions::UseSkill(player.GetControlledCritter(), skill, targetCrId, targetItemId, sceneryPid, hex.x, hex.y);
}

[[ServerRemoteCall]]
void MoveInvItem(Player player, ident itemId, CritterItemSlot slot)
{
    CritterActions::MoveInvItem(player.GetControlledCritter(), itemId, slot);
}

[[ServerRemoteCall]]
void OperateContainer(Player player, bool take, bool all, ident itemId, int itemCount)
{
    CritterActions::OperateContainer(player.GetControlledCritter(), take, all, itemId, itemCount);
}

[[ServerRemoteCall]]
void ReloadWeapon(Player player, ident weaponId, ident ammoId)
{
    CritterActions::ReloadWeapon(player.GetControlledCritter(), weaponId, ammoId);
}

[[ServerRemoteCall]]
void Attack(Player player, ident targetId, int mode)
{
    CritterActions::Attack(player.GetControlledCritter(), targetId, mode);
}

[[ServerRemoteCall]]
void UseItemOn(Player player, ident usedItemId, ident targetCrId, ident targetItemId, hstring sceneryPid, mpos hex, int timer)
{
    CritterActions::UseItemOn(player.GetControlledCritter(), usedItemId, targetCrId, targetItemId, sceneryPid, hex.x, hex.y, timer);
}

#endif

