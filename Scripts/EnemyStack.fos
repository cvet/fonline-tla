// EnemyStack — управление персональным стеком врагов криттера (свойство EnemyStack: ident[]).
// Ключевые обязанности: добавить/проверить/удалить/очистить врага, поднять врага в конец стека (LRU), найти видимого врага из стека.
// Сторона: SERVER. Связи: Game.GetCritter, Critter.GetCritters.
namespace EnemyStack
{

#if SERVER

///@ Property Critter Server ident[] EnemyStack Mutable Persistent
///@ Property Critter Common bool IsNoEnemyStack Mutable PublicSync Persistent

// Ищет в стеке первого врага, которого криттер сейчас видит на карте (для выбора цели).
Critter? ScanEnemyStack(Critter cr)
{
    if (cr.MapId != ZERO_IDENT) {
        Critter[] critters = cr.GetCritters(CritterSeeType::WhoISee, CritterFindType::NonDead);
        if (critters.length() > 0) {
            for (int i = 0, l = critters.length(); i < l; i++) {
                if (CheckEnemyInStack(cr, critters[i].Id)) {
                    return critters[i];
                }
            }
        }
    }

    return null;
}

// Добавляет врага в стек; если он уже есть, поднимает его в конец (LRU — самый свежий в хвосте).
void AddEnemyToStack(Critter? cr, ident enemyId)
{
    if (cr != null && enemyId != ZERO_IDENT) {
        ident[] enemies = cr.EnemyStack.clone();
        for (int i = 0, l = enemies.length(); i < l; i++) {
            if (enemies[i] == enemyId) {
                if (i < l - 1) {
                    enemies.removeAt(i);
                    enemies.insertLast(enemyId);
                    cr.EnemyStack = enemies;
                }

                return;
            }
        }

        enemies.insertLast(enemyId);
        cr.EnemyStack = enemies;
    }
}

// Проверяет, числится ли указанный криттер во вражеском стеке.
bool CheckEnemyInStack(Critter? cr, ident enemyId)
{
    if (cr != null && enemyId != ZERO_IDENT) {
        auto enemies = cr.EnemyStack;
        for (int i = 0, l = enemies.length(); i < l; i++) {
            if (enemies[i] == enemyId) {
                return true;
            }
        }
    }

    return false;
}

// Удаляет конкретного врага из стека (если он там есть).
void EraseEnemyFromStack(Critter? cr, ident enemyId)
{
    if (cr != null && enemyId != ZERO_IDENT) {
        ident[] enemies = cr.EnemyStack.clone();
        for (int i = 0, l = enemies.length(); i < l; i++) {
            if (enemies[i] == enemyId) {
                enemies.removeAt(i);
                cr.EnemyStack = enemies;
                return;
            }
        }
    }
}

// Полностью очищает стек врагов.
void ClearEnemyStack(Critter? cr)
{
    if (cr != null) {
        cr.EnemyStack = array<ident>();
    }
}

// Убирает из стека всех NPC, оставляя только врагов-игроков.
void ClearEnemyStackNpc(Critter? cr)
{
    if (cr != null) {
        ident[] enemies = cr.EnemyStack.clone();
        for (int i = 0; i < enemies.length();) {
            Critter? npc = Game.GetCritter(enemies[i]);
            if (npc != null && !npc.ControlledByPlayer) {
                enemies.removeAt(i);
            }
            else {
                i++;
            }
        }

        cr.EnemyStack = enemies;
    }
}

#endif

}
