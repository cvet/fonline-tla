{
    {
        {
            TargetCritterId = ZERO_IDENT;
            TargetItemId = ZERO_IDENT;
            IsInventory = false;
            if (params !is null && params.length() == 3) {
                TargetCritterId = params["TargetCritterId"];
                TargetItemId = params["TargetItemId"];
                IsInventory = params["IsInventory"] == "true";
            }
        }
    }
}
