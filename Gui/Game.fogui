//                       "Size": "17, 12",
//                       "Anchor": "Top, Right",
//                       "Dock": "None",
//                       "IsDraggable": false,
//                       "IsNotHittable": true,
//                       "CheckTransparentOnHit": false,
//                       "GlobalScope": null,
