///@ RemoteCall Client SetCurrentLocationEntrances(hstring locPid, hstring[] mapEntrances)
///@ RemoteCall Server ProcessGlobalMapCommand(int32 command, any param1, any param2)

// GM Rule command
const int GM_CMD_SETMOVE = 1;     // +r-a*x,y
const int GM_CMD_STOP = 2;        // +r-a
const int GM_CMD_TOLOCAL = 3;     // +r-a*num_city,num_map
const int GM_CMD_KICKCRIT = 4;    // +r-a*cr_id
const int GM_CMD_FOLLOW_CRIT = 5; // +r+a*cr_id
const int GM_CMD_FOLLOW = 6;
const int GM_CMD_GIVE_RULE = 7;
const int GM_CMD_ANSWER = 8;
const int GM_CMD_ENTRANCES = 9;
const int GM_CMD_VIEW_MAP = 10;

#if CLIENT

[[ModuleInit]]
void InitGlobalmapGroup()
{
    Game.OnLoop.Subscribe(OnLoop);
}

[[Event]]
void OnLoop()
{
    auto group = GetCurrentGroup();
    if (group.IsMoving) {
        if (!HasChosen || HasCurMap) {
            group.IsMoving = false;
            return;
        }

        group.StepCount++;
        if (group.StepCount % 167 == 1) {
            group.Points.insertLast({int(group.CurX), int(group.CurY), int(Color::Red.value)});
        }
    }
    else if (group.StepCount > 0) {
        group.Stop();
    }
}

class GlobalMapGroupClientInfo
{
    int CurX, CurY;
    int ToX, ToY;
    bool IsMoving;
    bool IsEncounter;
    int StepCount;
    int[] Points;

    GlobalMapGroupClientInfo()
    {
        Points = array<int>();
        StepCount = 0;
        Clear();
    }

    void Stop()
    {
        Points.clear();
        StepCount = 0;
    }

    void Clear()
    {
        CurX = CurY = ToX = ToY = 0;
        IsMoving = false;
        IsEncounter = false;
    }

    void Load(Serializator::Serializator load)
    {
        Clear();
        load.Get(CurX);
        load.Get(CurY);
        load.Get(ToX);
        load.Get(ToY);
        load.Get(IsMoving);
        load.Get(IsEncounter);
    }
}

GlobalMapGroupClientInfo CurrentGroup = GlobalMapGroupClientInfo();

GlobalMapGroupClientInfo GetCurrentGroup()
{
    return CurrentGroup;
}

void RuleGlobalCommand(int command, any param1, any param2)
{
    CurPlayer.ServerCall.ProcessGlobalMapCommand(command, param1, param2);
}

[[ClientRemoteCall]]
void SetCurrentLocationEntrances(hstring locPid, hstring[] mapEntrances)
{
}

void LoadGlobalMapGroupData(Serializator::Serializator load)
{
    CurrentGroup.Load(load);
}

