// FOGUI V2
// {
//   "$type": "Screen",
//   "IsModal": false,
//   "IsMultiinstance": false,
//   "IsCloseOnMiss": false,
//   "AvailableCursors": null,
//   "IsCanMove": true,
//   "IsMoveIgnoreBorders": false,
//   "BackgroundImage": null,
//   "BackgroundImageLayout": "None",
//   "CropContent": false,
//   "IsVerticalScroll": false,
//   "IsHorizontalScroll": false,
//   "Expanded": true,
//   "Selected": true,
//   "Active": true,
//   "Name": "Screen",
//   "Position": "82, 41",
//   "Size": "800, 600",
//   "Anchor": "None",
//   "Dock": "Fill",
//   "IsDraggable": false,
//   "IsNotHittable": true,
//   "CheckTransparentOnHit": false,
//   "GlobalScope":
{
    string FormatXXX(int value)
    {
        string result = "";
        int offs = 0;
        if (value >= 0) {
            result += Game.EncodeUtf8('9' + 4);
        }
        else {
            offs = 0x20;
            result += Game.EncodeUtf8('9' + offs + 3);
            value = -value;
        }

        value = CLAMP(value, 0, 999);

        result += Game.EncodeUtf8('0' + offs + value / 100);
        result += Game.EncodeUtf8('0' + offs + value / 10 % 10);
        result += Game.EncodeUtf8('0' + offs + value % 10);

        return result;
    }

    void GameLMouseDown()
    {
        Critter @chosen = Game.GetChosen();
        if (chosen is null) {
            return;
        }

        int cursor = Settings.Cursor;
        if (cursor == CursorType::Move) {
            any[] actions = {};
            ChosenActions::GetChosenActions(actions);
            bool isMoveAction = (actions.length() > 0 && actions[0] == Tla::ChosenMove);
            int milliseconds = (actions.length() > 6 ? int(actions[6]) : 0);
            if (isMoveAction &&
                (Game.FrameTime - (milliseconds == 0 ? ZERO_TIMESPAN : Time::Milliseconds(milliseconds))).milliseconds < Settings.DoubleClickTime) {
                actions[3] = (Settings.AlwaysRun ? 0 : 1);
                actions[5] = 0;
                ChosenActions::SetChosenActions(actions);
            }
            else {
                mpos hex;
                if (Game.CurMap.GetHexAtScreenPos(Game.MousePos, hex)) {
                    int dist = Game.GetDistance(chosen.Hex, hex);
                    bool isRun = (Input::IsShiftDown() ? !Settings.AlwaysRun : Settings.AlwaysRun && dist >= Settings.AlwaysRunMoveDist);
                    ChosenActions::SetChosenActions({Tla::ChosenMove, hex.x, hex.y, isRun ? 1 : 0, 0, isMoveAction ? 0 : 1, Game.FrameTime});
                }
            }
        }
        else if (cursor == CursorType::UseSkill && Settings.CursorData != 0) {
            Critter @cr = Game.CurMap.GetCritterAtScreenPos(ipos(Game.MousePos.x, Game.MousePos.y));
            Entity @entity = Game.CurMap.GetEntityAtScreenPos(Game.MousePos);
            Item @item = cast<Item>(entity);
            CritterProperty skill = CritterProperty(int(Settings.CursorData));
            if (cr != null) {
                ChosenActions::SetChosenActions({Tla::ChosenUseSklOnCritter, int(skill), cr.Id, 0, 0, 0, 0});
                GuiScreensExt::NextCursor();
                Settings.CursorData = 0;
            }
            else {
                if (item !is null) {
                    if (item.Type != ItemType::Generic && item.Type != ItemType::Grid) {
                        ChosenActions::SetChosenActions({Tla::ChosenUseSklOnItem, int(skill), item.Id, 0, 0, 0, 0});
                    }
                    else {
                        ChosenActions::SetChosenActions({Tla::ChosenUseSklOnScen, int(skill), item.ProtoId.hash, item.Hex.x, item.Hex.y, 0, 0});
                    }
                    GuiScreensExt::NextCursor();
                    Settings.CursorData = 0;
                }
            }
        }
        else if (cursor == CursorType::UseItem || cursor == CursorType::UseWeapon) {
            bool isAttack = (cursor == CursorType::UseWeapon);
            Item @useItem = (!isAttack && Settings.CursorData != 0 ? chosen.GetItem(ident(Settings.CursorData)) :
                                                                     chosen.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main));
            ProtoItem proto = CritterItem::GetSlotItemProto(chosen);
            if (useItem !is null || (isAttack && proto != null)) {
                Entity @entity = null;
                if (isAttack) {
                    @entity = Game.CurMap.GetEntityAtScreenPos(Game.MousePos);
                }
                else {
                    @entity = Game.CurMap.GetEntityAtScreenPos(Game.MousePos);
                }

                Critter @cr = cast<Critter>(entity);
                Item @item = cast<Item>(entity);
                Item realWeapon = chosen.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main);
                int mode = (valid(realWeapon) ? useItem.Mode : chosen.HandsItemMode);
                if (cr !is null) {
                    if (isAttack && _WeaponModeAim(mode) != 0) {
                        //IsCritterCanAim( chosen.ModelName ) &&
                        if (!chosen.IsNoAim) {
                            dict<string, any> dict = {};
                            dict["TargetCritterId"] = "" + cr.Id;
                            Gui::ShowScreen(GuiScreen::Aim, dict);
                        }
                    }
                    else {
                        ChosenActions::SetChosenActions(
                            {Tla::ChosenUseItem, valid(useItem) ? useItem.Id : ZERO_IDENT, 0, TARGET_CRITTER, cr.Id, isAttack ? mode : USE_USE, 0});
                    }
                }
                else if (item !is null && useItem !is null) {
                    ChosenActions::SetChosenActions({Tla::ChosenUseItem, useItem.Id, 0, TARGET_ITEM, item.Id, USE_USE, 0});
                }
            }
        }
    }

    void GameLMouseUp()
    {
    }
}
