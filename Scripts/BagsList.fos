// Спец-сумки AiPattern (снайперы/медики/терминаторы). Исходные id сохранены как breadcrumb миграции —
// не удалять: при возврате 'продвинутых' сумок алиасы ниже надо вернуть к этим оригинальным значениям.
/*
   #define Bags::Sniper1                                (270) // AiPattern special bags. >>
   #define BAG_Sniper2                                (271)
   #define BAG_Sniper3                                (272)
   #define BAG_Sniper4                                (273) // Gauss Rifle
   #define BAG_Medic1                                 (274)
   #define BAG_Medic2                                 (275) // Plasma pistol
   #define Bags::Term1                                  (276)
   #define BAG_Term2                                  (277)
   #define BAG_Term3                                  (278)
   #define BAG_Term4                                  (279) // Vindicator/Bozar

   на время теста отключил продвинутые сумки.
   в исходной сумке добавил монет
 */
///@ Enum Bags Sniper1 = 270        // спец-сумки AiPattern. >>
///@ Enum Bags Sniper2 = 271
// Sniper3/Sniper4 временно ссылаются на сумку Sniper2 (продвинутые отключены).
const int BAG_Sniper3 = Bags::Sniper2;
const int BAG_Sniper4 = BAG_Sniper3; // Gauss Rifle
///@ Enum Bags Medic1 = 274
///@ Enum Bags Medic2 = 275         // плазменный пистолет
///@ Enum Bags Term1 = 276
// Term2/Term3/Term4 временно ссылаются на сумку Term1 (продвинутые отключены).
const int BAG_Term2 = Bags::Term1;
const int BAG_Term3 = Bags::Term1;
const int BAG_Term4 = Bags::Term1;
// без изменений — спец-сумки слэйеров AiPattern.
