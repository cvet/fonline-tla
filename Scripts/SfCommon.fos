///@ Property Critter Common uint8 SFAhs7HubJudgement Mutable OwnerSync Persistent Group = Quests Quest = 4430 Max = 8
///@ Property Critter Server int32 SFLoPanBlackmailSum Mutable Persistent Max = 2000
///@ Property Critter Server ident SFHububJudgementLocId Mutable Persistent
///@ Property Critter Server uint8 SFHubJudgementKills Mutable Persistent Max = 4
///@ Property Critter Server ident SfMercMaster Mutable Persistent
///@ Property Critter Server int32 SFCommonOneWeekInvokeId Mutable Persistent
///@ Property Critter Server ident SFCommonFightPlayerId Mutable Persistent
///@ Property Critter Server ident=>int32 ClickCounter Mutable Persistent

///@ Property Game Server uint8 SFZax366StatusGlobal Mutable Persistent
///@ Property Game Server bool SFDevinHired Mutable Persistent

void BosEvaInit(Critter eva, bool firstTime)
{
    // Сброс глобального статуса для квеста "Чокнутый компьютер"
    eva.OnFinish.Subscribe(EvaFinish);
    if (firstTime) {
        eva.SFCommonOneWeekInvokeId = Game.StartTimeEvent(Time::GameDays(7), OneWeek, eva.Id); //SavedDeferredCall
    }
}

[[Event]]
void EvaFinish(Critter eva)
{
    Game.StopTimeEvent(eva.SFCommonOneWeekInvokeId);
}

[[TimeEvent]]
void OneWeek(any value)
{
    Game.SFZax366StatusGlobal = 0;

    Critter? eva = Game.GetCritter(value);
    if (eva != null) {
        eva.SFCommonOneWeekInvokeId = Game.StartTimeEvent(Time::GameDays(7), OneWeek, value); //SavedDeferredCall
    }
}

// * Квест "Сбор дани для Ло Пэна                         *//

const int DEAD_SHOE_CAPS = 200; // Сумма денег, добавляемой нпц, если его убил человек, выполняющий квест Сбор дани для Ло Пэна
const int STR_KILL_SHOE = 4;    // Строка диалога, которую игрок прочитает в чате после убийства горожанина.
const int STR_GET_MONEY = 5;    // Строка из диалога крестьянина, которая пишется игроку в чат, когда он получает очередную сумму

// Функция пишет в чат игроку сумму, набранную для Ло Пэна
void ShowBlackmailSumImpl(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    string textArgs = "|money: " + player.SFLoPanBlackmailSum;
    Messaging::Info(player, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(npc.DialogId, STR_GET_MONEY))), textArgs);
}

[[DialogResult]]
void ShowBlackmailSum(Critter player, Critter npc)
{
    ShowBlackmailSumImpl(player, npc);
}

// Функция вызывается из диалога, если крестьянин вступил в бой с игроком. При смерти крестьянина, если его убил тот самый игрок
// у него в инвентаре генерится 200 монет, и у игрока переключается счетчик собранной дани
[[DialogResult]]
void BeginFight(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    npc.SFCommonFightPlayerId = player.Id;
    npc.OnDead.Subscribe(CitizenDead);
}

[[Event]]
void CitizenDead(Critter npc, Critter? killer)
{
    if (killer != null) {
        // Убить должен тот, кто пришел от Ло Пэна
        if (killer.ControlledByPlayer && npc.SFCommonFightPlayerId == killer.Id) {
            npc.AddItem(Content::Item::bottle_caps, DEAD_SHOE_CAPS);
            // Для упрощения задачи, деньги начисляем сразу, несмотря на то, что игрок может их и не подобрать
            Messaging::Info(killer, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(npc.DialogId, STR_KILL_SHOE))));
            killer.SFLoPanBlackmailSum += DEAD_SHOE_CAPS;
            // Сообщение новой суммы игроку
            ShowBlackmailSumImpl(killer, npc);
        }
    }

    // Сброс запоминания игрока
    npc.SFCommonFightPlayerId = ZERO_IDENT;
    npc.OnDead.Unsubscribe(CitizenDead);
}

// * Телохранители Ло Пэна

const int CONTRACT_TIME = 6 * 30 * 24 * 60 * 60; // полгода

void SfMercInit(Critter merc, bool firstTime)
{
    Merc::MercInit(merc, firstTime);
    merc.OnRespawn.Subscribe(SfMercRespawn);
    merc.OnDead.Subscribe(SfMercDead);
}

[[Event]]
void SfMercDead(Critter merc, Critter killer)
{
    Merc::MercDeadImpl(merc, killer);
    merc.ReplicationTime = 0;
    merc.IsGeck = true; // Чтобы мерк не пропал на энкаунтере
    CancelContract(merc);
}

// Отправление мерка домой.
void SFMercToHome(Critter merc)
{
    auto map = Game.GetMap(merc.HomeMapId);
    if (map != null) {
        merc.TransferToMap(map, merc.HomeHex, hdir(merc.HomeDir));
    }

    merc.IsGeck = false;
    merc.OnRespawn.Unsubscribe(SfMercRespawn);
    merc.OnDead.Unsubscribe(SfMercDead);
}

[[Event]]
void SfMercRespawn(Critter cr)
{
    SFMercToHome(cr);
}

[[DialogResult]]
void SfMerc2Player(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    if (Merc::IsMerc(npc)) {
        return;
    }

    any[] values = {npc.Id, player.Id};
    Game.StartTimeEvent(GameTime::GameSeconds(CONTRACT_TIME), DoCancelContract, values); // Окончание контракта через полгода//SavedDeferredCall

    Merc::Merc2Player(player, npc, true, false, 0, Merc::MMDistMedium, Merc::MercGuardDefault, true, false, GameTime::GameSeconds(CONTRACT_TIME));
    npc.SetupScript(SfMercInit);
}

[[TimeEvent]]
void DoCancelContract(any[] values)
{
    Critter? merc = Game.GetCritter(values[0]);
    ident masterId;
    if (values.length() > 0) {
        masterId = values[1];
    }

    if (merc != null) {
        if (masterId == ZERO_IDENT) {
            CancelContract(merc);
        }
        else {
            if (masterId == merc.SfMercMaster) { // Хозяин уже мог смениться
                CancelContract(merc);
            }
        }
    }
}

void CancelContract(Critter merc)
{
    Critter? cr = Game.GetCritter(merc.SfMercMaster);
    if (cr != null) {
        cr.SfMercMaster = ZERO_IDENT;
    }

    merc.SfMercMaster = ZERO_IDENT;
}

