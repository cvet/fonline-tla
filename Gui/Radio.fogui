      "GlobalScope": null,
      "ClassFields": "int BroadCastType = 0;\r\n\r\nvoid SwitchBroadCast(bool reverse)\r\n{\r\n    if(reverse)\r\n    {\r\n        BroadCastType--;\r\n        if(BroadCastType < 0)\r\n            BroadCastType = 4;\r\n    }\r\n    else\r\n    {\r\n        BroadCastType++;\r\n        \r\n        if(BroadCastType > 4)\r\n            BroadCastType = 0;\r\n    }\r\n    SetBackgroundImage(\"art/intrface/Radio/radio_dial\" + BroadCastType + \".png\");\r\n    Radio::ChangeRadioBroadcastType(cast<Radio>(Parent).RadioId, BroadCastType);\r\n}",
