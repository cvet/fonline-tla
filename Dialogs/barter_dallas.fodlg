[Dialog]
Speech 1 # Преддиалоговые установки
  Answer 2 # -
    Result Script Dialog::SetNameMemPlayerNpc false

Speech 2 # Привет! Капитан Том Даллас, оружие и боеприпасы...
  Answer Barter # Давай посмотрим, что у тебя есть.
    Demand Script Dialog::IsNotNameMemPlayerNpc
    Result Script Dialog::SetNameMemPlayerNpc true
  Answer 3 # Эй, а ты какой армии капитан?
    Demand Script Dialog::IsNotNameMemPlayerNpc
  Answer 3* # Ничем, спасибо.
    Demand Script Dialog::IsNotNameMemPlayerNpc
  Answer Barter* # Покажи ещё раз товар.
    Demand Script Dialog::IsNameMemPlayerNpc
  Answer Exit # Это всё.
    Demand Script Dialog::IsNameMemPlayerNpc

Speech 3 # Я капитан охраны караванов, расслабься. Это ней...
  Answer Barter # Ну, давай посмотрим, что у тебя есть.
    Demand Script Dialog::IsNotNameMemPlayerNpc
    Result Script Dialog::SetNameMemPlayerNpc true
  Answer Exit # Ладно, я всё равно пока не буду торговать.
    Demand Script Dialog::IsNotNameMemPlayerNpc
  Answer Barter* # Покажи ещё раз товар.
    Demand Script Dialog::IsNameMemPlayerNpc
  Answer Exit* # Это всё.
    Demand Script Dialog::IsNameMemPlayerNpc

[Text russ]
{Name}{}{Капитан Даллас}
{DescAliveShort}{}{Вы видите: Капитан Даллас}
{DescAliveFull}{}{Крепкий темноволосый бородач в боевой броне.}
{Speech 1}{}{Преддиалоговые установки}
{Speech 1 Answer 2}{}{-}
{Speech 2}{}{Привет! Капитан Том Даллас, оружие и боеприпасы по выгодным ценам без пошлин! Чем могу помочь?}
{Speech 2 Answer Barter}{}{Давай посмотрим, что у тебя есть.}
{Speech 2 Answer 3}{}{Эй, а ты какой армии капитан?}
{Speech 2 Answer 3*}{}{Ничем, спасибо.}
{Speech 2 Answer Barter*}{}{Покажи ещё раз товар.}
{Speech 2 Answer Exit}{}{Это всё.}
{Speech 3}{}{Я капитан охраны караванов, расслабься. Это нейтральная территория, тут нет никаких армий.}
{Speech 3 Answer Barter}{}{Ну, давай посмотрим, что у тебя есть.}
{Speech 3 Answer Exit}{}{Ладно, я всё равно пока не буду торговать.}
{Speech 3 Answer Barter*}{}{Покажи ещё раз товар.}
{Speech 3 Answer Exit*}{}{Это всё.}

[Text engl]
{Name}{}{Captain Dallas}
{DescAliveShort}{}{You see: Captain Dallas}
{DescAliveFull}{}{Fit beared dark-haired man in combat armor.}
{Speech 1}{}{Преддиалоговые установки}
{Speech 1 Answer 2}{}{-}
{Speech 2}{}{Hi, Captain Dallas, Guns and Bullets for generous prices without custom taxes! How may I hepl you?}
{Speech 2 Answer Barter}{}{Let's see what you have here.}
{Speech 2 Answer 3}{}{Captain? What army do you belong to?}
{Speech 2 Answer 3*}{}{I'm fine, thanks.}
{Speech 2 Answer Barter*}{}{Show me your stuff again.}
{Speech 2 Answer Exit}{}{That's it.}
{Speech 3}{}{I'm captain of caravan guards. It's a neutral territory, no armies here, relax.}
{Speech 3 Answer Barter}{}{Okay, show me what you've got.}
{Speech 3 Answer Exit}{}{I don't to barter anyway.}
{Speech 3 Answer Barter*}{}{Show me your stuff again.}
{Speech 3 Answer Exit*}{}{That's it.}
