//       "OnLMouseClick":
{
    {
        {
            string inputText = Screen.FindText("MainSayText").Text;
            auto screen = cast<SayExtended>(Parent);
            if (screen.FromScenery) {
                Game.CurPlayer.ServerCall.ProcessSayExtendedFromScenery(inputText, screen.ProtoID, mpos(screen.HexX, screen.HexY));
            }
            else {
                Game.CurPlayer.ServerCall.Rpc_ProcessSayExtended(inputText);
            }
            Gui::HideScreen();
        }
    }
}
