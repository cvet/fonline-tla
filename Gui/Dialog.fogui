{
    {
        {
            Dialog @dialog = cast<Dialog>(Screen);
            Text = dialog.Text;
            int lines = 0;
            isize box;
            Game.GetTextInfo(dialog.Text, isize(Size.width, 1000), TextFont, TextFlags, box, lines);
            SetSize(Parent.Size.width, Math::Max(box.height, Parent.Size.height));
            SetText(dialog.Text);
        }
    }
}
