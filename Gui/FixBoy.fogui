{
    {
        void ChangedTargetItem()
        {
            if (!HasChosen) {
                return;
            }
            auto fixBoy = cast<FixBoy>(GuiScreensExt::NeedScreen(Screen));

            string result = MsgStr::GetGameText(MsgStr::StrFixParams) + "\\n";
            any[] needParams = cast<FixBoy>(GuiScreensExt::NeedScreen(Screen)).NeedParams;
            int index = 0;
            while (index < needParams.length()) {
                CritterProperty prop = CritterProperty(needParams[index++]);
                string text = MsgStr::GetGameText(MsgStr::StrFixYouhave);
                text = Game.ReplaceText(text, "%NAME", MsgStr::GetParamNameText(prop));
                text = Game.ReplaceText(text, "%VALUE1", needParams[index++]);
                text = Game.ReplaceText(text, "%VALUE2", Chosen.GetAsInt(prop));
                result += text + "\\n";
            }
            int tw = 0, th = 0, lines = 0;
            Game.GetTextInfo(result, isize(Size.width, 1000), TextFormat(FontType(int(TextFont)), FontFlag(TextFlags), 0), isize(tw, th), lines);
            SetText(result);
            SetSize(Size.width, th);
        }
    }
}
