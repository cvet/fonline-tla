// Called to check interface hit.
bool CheckInterfaceHit(int x, int y)
{
    return Gui::CheckHit(ipos(x, y));
}

// Called to check current container item under mouse.
bool GetContItem(ident& itemId, bool& isEnemy)
{
    Gui::Screen? screen = Gui::GetActiveScreen(GuiScreen::Inventory);
    if (screen == null) {
        return false;
    }

    if (Gui::Cursor == CursorType::Default) {
        Gui::Object? hitObj = screen.FindMouseHit();
        if (hitObj != null && hitObj.Grid != null) {
            Gui::ItemView? itemView = cast<Gui::ItemView?>(hitObj.Grid);
            if (itemView != null) {
                Item? item = itemView.GetItem(hitObj.CellIndex);
                if (item != null) {
                    itemId = item.Id;
                    isEnemy = (itemView.UserDataExt == ClientDefines::ITEMS_BARTER_OPPONENT ||
                               itemView.UserDataExt == ClientDefines::ITEMS_BARTER_OPPONENT_OFFER || itemView.UserDataExt == ClientDefines::ITEMS_PICKUP_FROM);
                }
            }
        }
    }

    return true;
}

// Items and drop handler.
bool ItemsDragAndDropHandler(Gui::Object obj, Gui::Object? target)
{
    if (obj.Grid == null) {
        return false;
    }

    // Destination
    Gui::ItemView? targetItemView = null;
    Item? targetItem;
    if (target != null) {
        if (target.Grid != null) {
            targetItemView = cast<Gui::ItemView?>(target.Grid);
            if (targetItemView == null) {
                return false;
            }

            targetItem = targetItemView.GetItem(target.CellIndex);
        }
        else {
            targetItemView = cast<Gui::ItemView?>(target);
            if (targetItemView == null) {
                return false;
            }
        }
    }

    // Source
    Gui::ItemView? objItemView = cast<Gui::ItemView?>(obj.Grid);
    if (objItemView == null) {
        return false;
    }

    Item? objItem = objItemView.GetItem(obj.CellIndex);
    if (objItem == null) {
        return false;
    }

    // Drop item
    if (targetItemView == null) {
        if (objItem.Stackable && objItem.Count > 1) {
            Gui::ShowScreen(GuiScreen::Split, dict<string, any> = {{"TargetItemId", objItem.Id}, {"ItemsCollection", ClientDefines::ITEMS_CHOSEN_ALL}});
        }
        else {
            ChosenActions::SetChosenActions({Tla::ChosenMoveItem, objItem.Id, objItem.Count, CritterItemSlot::Outside, 0, 0, 0});
        }

        return true;
    }

    // Barter
    if ((objItemView.UserDataExt == ClientDefines::ITEMS_BARTER && targetItemView.UserDataExt == ClientDefines::ITEMS_BARTER_OFFER) ||
        (objItemView.UserDataExt == ClientDefines::ITEMS_BARTER_OPPONENT && targetItemView.UserDataExt == ClientDefines::ITEMS_BARTER_OPPONENT_OFFER) ||
        (objItemView.UserDataExt == ClientDefines::ITEMS_BARTER_OFFER && targetItemView.UserDataExt == ClientDefines::ITEMS_BARTER) ||
        (objItemView.UserDataExt == ClientDefines::ITEMS_BARTER_OPPONENT_OFFER && targetItemView.UserDataExt == ClientDefines::ITEMS_BARTER_OPPONENT)) {
        if (objItem.Stackable && objItem.Count > 1) {
            // Game.CustomCall( "SplitItem " + objItem.Id + " " + objItemView.UserDataExt );
            Gui::ShowScreen(GuiScreen::Split, dict<string, any> = {{"TargetItemId", objItem.Id}, {"ItemsCollection", objItemView.UserDataExt}});
        }
        else {
            ClientItems::BarterTransfer(objItem.Id, objItemView.UserDataExt, objItem.Count);
            //Game.CustomCall("BarterMoveItem " + objItem.Id + " " + objItemView.UserDataExt + " " + objItem.Count);
        }

        return true;
    }

    // Loot
    if ((objItemView.UserDataExt == ClientDefines::ITEMS_PICKUP && targetItemView.UserDataExt == ClientDefines::ITEMS_PICKUP_FROM) ||
        (objItemView.UserDataExt == ClientDefines::ITEMS_PICKUP_FROM && targetItemView.UserDataExt == ClientDefines::ITEMS_PICKUP)) {
        if (objItem.Stackable && objItem.Count > 1) {
            Gui::ShowScreen(GuiScreen::Split, dict<string, any> = {{"TargetItemId", objItem.Id}, {"ItemsCollection", objItemView.UserDataExt}});
        }
        else {
            any[] actions = {};
            ChosenActions::GetChosenActions(actions);
            any[] useItemAction = {Tla::ChosenMoveItemCont, objItem.Id, objItemView.UserDataExt, objItem.Count, 0, 0, 0};
            for (int i = 0; i < useItemAction.length(); i++) {
                actions.insertLast(useItemAction[i]);
            }

            ChosenActions::SetChosenActions(actions);
        }

        return true;
    }

    // Load ammo
    if ((objItemView.UserDataExt == ClientDefines::ITEMS_INVENTORY || objItemView.UserDataExt == ClientDefines::ITEMS_CHOSEN_ALL) && targetItem != null &&
        objItem.Type == ItemType::Ammo && targetItem.Type == ItemType::Weapon) {
        if (objItem.Ammo_Caliber == targetItem.Weapon_Caliber &&
            (targetItem.AmmoCount < targetItem.Weapon_MaxAmmoCount || targetItem.AmmoPid != objItem.ProtoId)) {
            any[] actions = {};
            ChosenActions::GetChosenActions(actions);
            any[] useItemAction = {Tla::ChosenUseItem, targetItem.Id, 0, ClientDefines::TARGET_SELF_ITEM, objItem.Id, WeaponHelpers::USE_RELOAD, 0};
            for (int i = 0; i < useItemAction.length(); i++) {
                actions.insertLast(useItemAction[i]);
            }

            ChosenActions::SetChosenActions(actions);
            return true;
        }
    }

    // Transfer between slots
    int objSlot = objItemView.UserData;
    int targetSlot = targetItemView.UserData;
    if (objSlot != targetSlot) {
        any[] actions = {};
        ChosenActions::GetChosenActions(actions);
        any[] useItemAction = {Tla::ChosenMoveItem, objItem.Id, objItem.Count, targetSlot, 0, 0, 0};
        for (int i = 0; i < useItemAction.length(); i++) {
            actions.insertLast(useItemAction[i]);
        }

        ChosenActions::SetChosenActions(actions);
        return true;
    }

    return true;
}

