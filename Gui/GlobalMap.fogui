{
    {
        GlobalMapLocations::LocationData Location;

        void SetLocPosition(float zoom)
        {
            if (Location == null) {
                return;
            }
            int radius = int(Location.Radius * 2 * zoom);
            SetPosition(int(Location.LocWx * zoom) - radius / 2, int(Location.LocWy * zoom) - radius / 2);
            SetSize(radius, radius);
        }
    }
}
//                   "OnInit": null,
//                   "OnShow":
{
    {
        {
            SetLocPosition(1.0f);
            if (Location != null && Location.Color != ucolor(0)) {
                SetColor(Location.Color);
            }
            else {
                SetColor(COLOR_GREEN);
            }
        }
    }
}
