// Combat results.
[[ClientRemoteCall]] [[Async]]
void CombatResult(any[] data)
{
    int datalen = data.length();
    if (datalen == 0) {
        return;
    }

    if (data[0] != datalen) {
        return;
    }

    int current = 1;

    while (current < datalen) {
        int damage = -1;
        int effect = 0;
        int loc = 0;
        int message = -1;

        int mode = data[current++];
        ident who = data[current++];
        ident who2;
        Critter? originalTarget;

        Critter? cr = Game.GetCritter(who);
        Critter? trueTarget = null;
        if (cr == null) {
            continue;
        }

        bool self = HasChosen && (who == Chosen.Id);

        string name = "error0";
        if (!self) {
            name = cr.Name;
        }
        else {
            name = Game.GetText(TextPackKey(TextPackName::Combat, "" + (Chosen.Gender == GenderType::Male ? 506 : 556)));
        }

        int offset;
        if (self) {
            if (cr.Gender == GenderType::Male) {
                offset = 506;
            }
            else {
                offset = 556;
            }
        }
        else {
            if (cr.Gender == GenderType::Male) {
                offset = 606;
            }
            else {
                offset = 706;
            }
        }

        string result;

        // reading and preparing the data:
        switch (mode) {
        case MessageSpecifications::CritMiss:
            effect = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 8)));
            result = Game.ReplaceText(result, "%s", name);
            break;
        case MessageSpecifications::CritMissDamage:
            effect = data[current++];
            damage = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 28 : 27))));
            result = Game.ReplaceText(result, "%s", name);
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::Hit:
        case MessageSpecifications::HitDead:
            damage = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 7 : (damage != 0 ? 17 : 21)))));
            result = Game.ReplaceText(result, "%s", name);
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::AimedHit:
        case MessageSpecifications::AimedHitDead:
            loc = data[current++];
            damage = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 6 : (damage != 0 ? 16 : 20)))));
            result = Game.ReplaceText(result, "%s", name);
            result = Game.ReplaceText(result, "%s", Game.GetText(TextPackKey(TextPackName::Combat, "" + (1000 + cr.CrTypeAlias * 10 + loc - 1))));
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::CritHit:
            damage = data[current++];
            effect = data[current++];
            message = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 14 : (damage != 0 ? 18 : 22)))));
            result = Game.ReplaceText(result, "%s", name);
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::CritAimedHit:
            loc = data[current++];
            damage = data[current++];
            effect = data[current++];
            message = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 5 : (damage != 0 ? 15 : 19)))));
            result = Game.ReplaceText(result, "%s", name);
            result = Game.ReplaceText(result, "%s", Game.GetText(TextPackKey(TextPackName::Combat, "" + (1000 + cr.CrTypeAlias * 10 + loc - 1))));
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::CritHitDead:
            damage = data[current++];
            message = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 14 : (damage != 0 ? 18 : 22)))));
            result = Game.ReplaceText(result, "%s", name);
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::CritAimedHitDead:
            loc = data[current++];
            damage = data[current++];
            message = data[current++];
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + (damage > 1 ? 5 : (damage != 0 ? 15 : 19)))));
            result = Game.ReplaceText(result, "%s", name);
            result = Game.ReplaceText(result, "%s", Game.GetText(TextPackKey(TextPackName::Combat, "" + (1000 + cr.CrTypeAlias * 10 + loc - 1))));
            if (damage > 1) {
                result = Game.ReplaceText(result, "%d", damage);
            }

            break;
        case MessageSpecifications::Oops:
            who2 = data[current++]; // who2 was hit instead of who
            // +2 "... was hit instead of you!"
            // +3 "... was hit instead of ...!"
            trueTarget = Game.GetCritter(who2);
            if (self) {
                // It was original target
                result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (cr.Gender == GenderType::Male ? 608 : 708)));
                string nameTrue = "error1";
                if (trueTarget != null) {
                    nameTrue = trueTarget.Name;
                }

                result = Game.ReplaceText(result, "%s", nameTrue);
            }
            else {
                // It was not original target
                result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 3)));
                if (HasChosen && who2 == Chosen.Id) {
                    result =
                        Game.ReplaceText(result, "%s", Game.GetText(TextPackKey(TextPackName::Combat, "" + (Chosen.Gender == GenderType::Male ? 506 : 556))));
                }
                else {
                    string nameTrue = "error1";
                    if (trueTarget != null) {
                        nameTrue = trueTarget.Name;
                    }

                    result = Game.ReplaceText(result, "%s", nameTrue);
                }

                result = Game.ReplaceText(result, "%s", name);
            }

            break;
        case MessageSpecifications::Miss:
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 9)));
            result = Game.ReplaceText(result, "%s", name);
            break;
        case MessageSpecifications::HitRandomly:
            result = Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 9)));
            result = Game.ReplaceText(result, "%s", name);
            result += Game.GetText(TextPackKey(TextPackName::Combat, "" + (108))) + Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset - 306 + 20)));
        default:
            break;
        }

        bool isVerbose = (Settings.Combat.CombatMessagesType == 0);
        string[] ext = {};

        if (message != -1 && isVerbose) // Must be critical hit
        {
            result += Game.GetText(TextPackKey(TextPackName::Combat, "" + (message)));
        }
        else if (effect != 0) {
            offset -= 306;
            if (mode > MessageSpecifications::CritMissDamage) // Hit flags
            {
                if (Flags::HasFlag(effect, Flags::HF_KNOCKOUT)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 0))));
                }

                if (Flags::HasFlag(effect, Flags::HF_KNOCKDOWN)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 1))));
                }

                if (Flags::HasFlag(effect, Flags::HF_CRIPPLED_LEFT_LEG)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 2))));
                }

                if (Flags::HasFlag(effect, Flags::HF_CRIPPLED_RIGHT_LEG)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 3))));
                }

                if (Flags::HasFlag(effect, Flags::HF_CRIPPLED_LEFT_ARM)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 4))));
                }

                if (Flags::HasFlag(effect, Flags::HF_CRIPPLED_RIGHT_ARM)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 5))));
                }

                if (Flags::HasFlag(effect, Flags::HF_BLINDED)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 6))));
                }

                // if(HasFlag(effect, HF_DEATH))              ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset)))); // This is handled elsewhere
                // if(HasFlag(effect, HF_ON_FIRE))            ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 10)))); // Not used
                if (Flags::HasFlag(effect, Flags::HF_BYPASS_ARMOR)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 11))));
                }

                if (Flags::HasFlag(effect, Flags::HF_DROPPED_WEAPON)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 14))));
                }

                if (Flags::HasFlag(effect, Flags::HF_LOST_NEXT_TURN)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 15))));
                }

                if (Flags::HasFlag(effect, Flags::HF_RANDOM)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 21))));
                }
            }
            else {
                if (Flags::HasFlag(effect, Flags::MF_KNOCKED_DOWN)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 1))));
                }

                // if(HasFlag(effect, MF_ON_FIRE))              ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 10)))); // Not used
                if (Flags::HasFlag(effect, Flags::MF_WEAPON_EXPLODED)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 12))));
                }

                if (Flags::HasFlag(effect, Flags::MF_WEAPON_DESTROYED)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 13))));
                }

                if (Flags::HasFlag(effect, Flags::MF_WEAPON_DROPPED)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 14))));
                }

                if (Flags::HasFlag(effect, Flags::MF_LOST_NEXT_TURN)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 15))));
                }

                if (Flags::HasFlag(effect, Flags::MF_HIT_SELF)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 16))));
                }

                if (Flags::HasFlag(effect, Flags::MF_LOST_REST_OF_AMMO)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 17))));
                }

                if (Flags::HasFlag(effect, Flags::MF_FIRED_DUD_SHOT)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 18))));
                }

                if (Flags::HasFlag(effect, Flags::MF_HURT_SELF)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 19))));
                }

                // if(HasFlag(effect, MF_HIT_RANDOMLY))         ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 20)))); // This is handled elsewhere
                if (Flags::HasFlag(effect, Flags::MF_CRIPPLED_RANDOM_LIMB)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 21))));
                }

                if (Flags::HasFlag(effect, Flags::MF_WAS_KILLED)) {
                    ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 7))));
                }
            }

            offset += 306;
        }

        if (8 <= mode && mode <= 11 && (!isVerbose || message == -1)) {
            ext.insertLast(Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 7 - 306))));
        }

        for (int m = 0, n = ext.length(); m < n; m++) {
            if (m == n - 1) {
                result += Game.GetText(TextPackKey(TextPackName::Combat, "" + (108)));
            }
            else {
                result += ", ";
            }

            result += ext[m];
        }

        result += ".";

        Messaging::Info(MessageBoxType::Combat, result);

        if (8 <= mode && mode <= 11 && isVerbose && message != -1) {
            Messaging::Info(MessageBoxType::Combat, name + " " + Game.GetText(TextPackKey(TextPackName::Combat, "" + (offset + 7 - 306))) + ".");
        }

        // On head indication
        if (Settings.Combat.DamageHitDelay > 0 && damage > 0) {
            mpos hex = cr.Hex;
            Yield(Settings.Combat.DamageHitDelay);
            MapText::AddFlyingText(hex, 0xFFC80000, "-" + damage);
        }
    }
}

// Generic description. Descriptions type look in _client_defines.fos, Generic descriptions types.
// int& offsX, int& offsY - offsets of text, by default is zero.
string GenericDescription(int descType, int& offsX, int& offsY)
{
    if (!HasChosen) {
        return "";
    }

    Critter chosen = Chosen;
    string result;

    if (descType == GenericDescriptionsTypes::InventoryMain) {
        result += chosen.Name + "\n";
        result += "---------------------\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Strength)))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Perception)))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Endurance)))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Charisma)))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Intellect)))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Agility)))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::InvShortSpecialTextId(CritterProperty::Luck)))) + "\n";
        result += "---------------------\n";

        AbstractItem weaponMain = CritterItem::GetActive(chosen);
        int use = WeaponHelpers::WeaponModeUse(weaponMain.Mode);
        if (use > 2) {
            use = 0;
        }

        result += Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(weaponMain)))) + "\n";

        if (weaponMain.Type == ItemType::Weapon) {
            result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvDmg))) + " ";
            result += WeaponHelpers::WeaponDamageMin(weaponMain, use) + "-";
            int wpnMaxDmg = WeaponHelpers::WeaponDamageMax(weaponMain, use);
            if (WeaponHelpers::IsWeaponHthAttack(weaponMain, use)) {
                wpnMaxDmg += chosen.MeleeDamage;
            }

            result += wpnMaxDmg;

            if (WeaponHelpers::WeaponMaxDistance(weaponMain, use) > 1) {
                result += " " + Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvDist))) + " ";
                int wpnMaxDist = WeaponHelpers::WeaponMaxDistance(weaponMain, use);
                if (WeaponHelpers::WeaponSkill(weaponMain, use) == CritterProperty::SkillThrowing) {
                    wpnMaxDist = Math::Min(wpnMaxDist, 3 * Math::Min(int(10), chosen.Strength + 2 * chosen.PerkHeaveHo));
                }

                result += wpnMaxDist;
            }

            result += "\n";

            if (weaponMain.Weapon_MaxAmmoCount > 0) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvAmmo))) + " ";
                result += weaponMain.AmmoCount + "/";
                result += weaponMain.Weapon_MaxAmmoCount + " ";
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CaliberTextId(weaponMain.Weapon_Caliber))));
            }

            result += "\n";
        }
        else {
            result += "\n\n";
        }

        result += "---------------------\n";

        AbstractItem weaponExt = CritterItem::GetActive(chosen, CritterItemSlot::Secondary);
        use = WeaponHelpers::WeaponModeUse(weaponExt.Mode);
        if (use > 2) {
            use = 0;
        }

        result += Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(weaponExt)))) + "\n";

        if (weaponExt.Type == ItemType::Weapon) {
            result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvDmg))) + " ";
            result += WeaponHelpers::WeaponDamageMin(weaponExt, use) + "-";
            int wpnMaxDmg = WeaponHelpers::WeaponDamageMax(weaponExt, use);
            if (WeaponHelpers::IsWeaponHthAttack(weaponExt, use)) {
                wpnMaxDmg += chosen.MeleeDamage;
            }

            result += wpnMaxDmg;
            if (WeaponHelpers::WeaponMaxDistance(weaponExt, use) > 1) {
                result += " " + Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvDist))) + " ";
                int wpnMaxDist = WeaponHelpers::WeaponMaxDistance(weaponExt, use);
                if (WeaponHelpers::WeaponSkill(weaponExt, use) == CritterProperty::SkillThrowing) {
                    wpnMaxDist = Math::Min(wpnMaxDist, 3 * Math::Min(int(10), chosen.Strength + 2 * chosen.PerkHeaveHo));
                }

                result += wpnMaxDist;
            }

            result += "\n";

            if (weaponExt.Weapon_MaxAmmoCount > 0) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvAmmo))) + " ";
                result += weaponExt.AmmoCount + "/";
                result += weaponExt.Weapon_MaxAmmoCount + " ";
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CaliberTextId(weaponExt.Weapon_Caliber))));
            }

            result += "\n";
        }
        else {
            result += "\n\n";
        }

        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvTotalWeight))) + " ";
        result += (chosen.ItemsWeight / 1000) + "/";
        result += (chosen.CarryWeight / 1000) + ".";
    }
    else if (descType == GenericDescriptionsTypes::InventorySpecial) {
        offsX = 23;
        result += "\n\n";
        result += chosen.Strength + "\n";
        result += chosen.Perception + "\n";
        result += chosen.Endurance + "\n";
        result += chosen.Charisma + "\n";
        result += chosen.Intellect + "\n";
        result += chosen.Agility + "\n";
        result += chosen.Luck;
    }
    else if (descType == GenericDescriptionsTypes::InventoryStats) {
        offsX = 39;
        result += "\n\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvHp))) + " ";
        result += chosen.CurrentHp + "/" + chosen.MaxLife + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvAc))) + " ";
        result += chosen.ArmorClass + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvNormal))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvLaser))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvFire))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvPlasma))) + "\n";
        result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvExplode)));
    }
    else if (descType == GenericDescriptionsTypes::InventoryResist) {
        offsX = 103;
        result += "\n\n\n\n";
        int[] threshold = array<int>(chosen.DamageThreshold);
        int[] resistance = array<int>(chosen.DamageResistance);
        result += threshold[DamageTypes::Normal] + "/" + resistance[DamageTypes::Normal] + "%\n";
        result += threshold[DamageTypes::Laser] + "/" + resistance[DamageTypes::Laser] + "%\n";
        result += threshold[DamageTypes::Fire] + "/" + resistance[DamageTypes::Fire] + "%\n";
        result += threshold[DamageTypes::Plasma] + "/" + resistance[DamageTypes::Plasma] + "%\n";
        result += threshold[DamageTypes::Explode] + "/" + resistance[DamageTypes::Explode] + "%";
    }

    return result;
}

// Item description. Look types look in _client_defines.fos, Item look types.
string ItemDescription(Item item, ItemLookTypes lookType)
{
    // Default error text
    if (not Game.IsTextPresent(
            TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(item) + (lookType != ItemLookTypes::OnlyName ? "Desc".hstr().uhash : 0))))) {
        return Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrItemLookNothing)));
    }

    string result;

    // Car on world map
    if (lookType == ItemLookTypes::WmCar) {
        string fuel = Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvCarFuel)));
        fuel = Game.ReplaceText(fuel, "VALUE", item.Charge / 100);
        fuel = Game.ReplaceText(fuel, "MAXVAL", item.Car_TankVolume / 100);
        string deterioration = Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvCarDeterioration)));
        deterioration = Game.ReplaceText(deterioration, "VALUE", item.Deterioration * 100 / item.Car_MaxDeterioration);
        result = fuel + "\n" + deterioration;
    }

    // Short info
    else if (lookType == ItemLookTypes::OnlyName) {
        result += Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrItemLook))),
                                   "NAME",
                                   Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(item)))));
    }

    // Full info
    else {
        if (lookType == ItemLookTypes::Inventory) {
            result += Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(item)))) + "\n";
        }

        if (item.ProtoId == Content::Item::holodisk && item.HolodiskNum != 0) {
            result += Game.GetText(TextPackKey(TextPackName::Holo, "" + (MsgStr::HoloInfoNameTextId(item.HolodiskNum))));
        }
        else {
            result += Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemInfoTextId(item))));
        }

        if (lookType != ItemLookTypes::Map) {
            // Weight
            result += "\n" + Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrItemWeightGramm))),
                                              "VALUE",
                                              item.Weight * (item.Stackable ? item.Count : 1));

            // Ammo load
            if (item.Type == ItemType::Weapon && item.Weapon_MaxAmmoCount > 0) {
                result += "\n";
                string str = Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvHasShots)));
                str = Game.ReplaceText(str, "VALUE", item.AmmoCount);
                str = Game.ReplaceText(str, "MAXVAL", item.Weapon_MaxAmmoCount);
                str = Game.ReplaceText(str, "AMMO", Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CaliberTextId(item.Weapon_Caliber)))));
                result += str;
            }

            // Deterioration
            if (item.Deteriorable) {
                int brokenCount = item.BrokenCount;
                int deterioration = item.Deterioration;

                // Broken level, procent
                result += "\n";
                if (item.BrokenNotresc) {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationNoResc)));
                }
                else if (item.BrokenLowBroken) {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationBrokenLow)));
                }
                else if (item.BrokenNormBroken) {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationBrokenNorm)));
                }
                else if (item.BrokenHighBroken) {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationBrokenHigh)));
                }
                else {
                    result += Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationProcent))),
                                               "VALUE",
                                               deterioration * 100 / Tla::MaxDeterioration);
                }

                // Service
                if (item.BrokenService) {
                    result += "\n" + Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationService)));
                }

                // Service ext
                if (item.BrokenServiceExt) {
                    result += "\n" + Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationServiceExt)));
                }

                // Broken count
                if (HasChosen && Chosen.PerkMrFixit != 0) {
                    result += "\n" +
                              Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrDeteriorationBrokenCount))), "VALUE", brokenCount);
                }
            }

            // Key id
            if (item.Type == ItemType::Key) {
                result += "\n" + Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrInvKeyNumber))), "KEY_ID", item.LockerId);
            }
        }
    }

    // Format tags
    if (item.TextArgs != "") {
        return Game.FormatTags(result, item.TextArgs);
    }

    return result;
}

int GetTextNumUpperCompat(TextPackName textPack, uint strNum)
{
    for (uint cur = strNum; cur != 0; cur--) {
        if (Game.IsTextPresent(TextPackKey(textPack, "" + (cur)))) {
            return cur;
        }
    }

    return 0;
}

// Critter description. Look types look in _client_defines.fos, Critter look types.
string CritterDescription(Critter& cr, CritterLookTypes lookType)
{
    string result;
    int gender = cr.Gender;

    // Player
    if (cr.ControlledByPlayer) {
        // Only name
        if (lookType == CritterLookTypes::OnlyName) {
            result = cr.Name; // No change
        }

        // Short info
        else if (lookType == CritterLookTypes::LookShort) {
            result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLook1TextId(gender))));
            result += cr.Name;
            result += ".";
        }

        // Full info
        else {
            result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLook1TextId(gender))));

            // Age
            int ageStr = GetTextNumUpperCompat(TextPackName::Game, MsgStr::CritLookAgeTextId(gender, cr.Age));
            if (ageStr != 0) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (ageStr)));
            }
            else {
                result += cr.Name;
            }

            result += ".";
        }
    }

    // Npc
    else {
        hstring dlgId = cr.DialogId;
        hstring npcPid = cr.ProtoId;
        bool defaultText = false;

        if (lookType == CritterLookTypes::OnlyName) {
            result = MsgStr::NpcName(dlgId, npcPid);
        }

        // Short info
        else if (lookType == CritterLookTypes::LookShort) {
            if (cr.IsAlive() && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcInfoLifeTextId(dlgId, npcPid))))) {
                result += MsgStr::NpcDesc(dlgId, npcPid);
            }
            else if (cr.IsKnockout() && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcInfoKoTextId(dlgId, npcPid))))) {
                result += Game.GetText(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcInfoKoTextId(dlgId, npcPid))));
            }
            else if (cr.IsDead() && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcInfoDeadTextId(dlgId, npcPid))))) {
                result += Game.GetText(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcInfoDeadTextId(dlgId, npcPid))));
            }
            else {
                defaultText = true;
            }
        }

        // Full info
        else {
            if (cr.IsAlive()) {
                result += MsgStr::NpcDesc(dlgId, npcPid);
            }
            else if (cr.IsKnockout() && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcFullInfoKoTextId(dlgId, npcPid))))) {
                result += Game.GetText(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcFullInfoKoTextId(dlgId, npcPid))));
            }
            else if (cr.IsDead() && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcFullInfoDeadTextId(dlgId, npcPid))))) {
                result += Game.GetText(TextPackKey(TextPackName::Dialogs, "" + (MsgStr::NpcFullInfoDeadTextId(dlgId, npcPid))));
            }
            else {
                defaultText = true;
            }
        }

        if (defaultText) {
            // Check standart text
            if (MsgStr::NpcName(dlgId, npcPid) != "") {
                if (cr.IsAlive()) {
                    result +=
                        Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookLife))), "NAME", MsgStr::NpcName(dlgId, npcPid));
                }
                else if (cr.IsKnockout()) {
                    result +=
                        Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookKo))), "NAME", MsgStr::NpcName(dlgId, npcPid));
                }
                else if (cr.IsDead()) {
                    result +=
                        Game.ReplaceText(Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookDead))), "NAME", MsgStr::NpcName(dlgId, npcPid));
                }
            }

            // Set default text
            else {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookNothing)));
            }
        }
    }

    // Additional description
    if (lookType == CritterLookTypes::LookFull) {
        if (result.length() > 0 && result[result.length() - 1] != ".") {
            result += ".";
        }

        result += " ";

        if (HasChosen && Chosen.PerkAwareness != 0) // Awareness
        {
            result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookHpTextId(gender))));
            result = Game.ReplaceText(result, "CUR", cr.CurrentHp);
            result = Game.ReplaceText(result, "Max", cr.MaxLife);

            AbstractItem item = CritterItem::GetActive(cr);
            if (Tla::IsCritterInjured(cr)) {
                result += ", ";
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookLimbsTextId(gender, false))));
            }

            if (item.Type == ItemType::Weapon) {
                if (item.Weapon_MaxAmmoCount == 0) {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookWeap)));
                    result = Game.ReplaceText(result, "WEAPON", Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(item)))));
                }
                else {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookWeapAmmo)));
                    result = Game.ReplaceText(result, "WEAPON", Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(item)))));
                    result = Game.ReplaceText(result, "CUR", item.AmmoCount);
                    result = Game.ReplaceText(result, "Max", item.Weapon_MaxAmmoCount);
                    result = Game.ReplaceText(result, "AMMO", Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CaliberTextId(item.Weapon_Caliber)))));
                }
            }
            else {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritLookMisc)));
                result = Game.ReplaceText(result, "MISC", Game.GetText(TextPackKey(TextPackName::Items, "" + (MsgStr::ItemNameTextId(item)))));
            }
        }
        else // Simple
        {
            result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookWhoTextId(gender))));

            int hp_proc = cr.CurrentHp * 100 / cr.MaxLife;
            if (cr.IsDead()) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookStateTextId(0))));
            }
            else if (hp_proc < 34) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookStateTextId(1))));
            }
            else if (hp_proc < 67) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookStateTextId(2))));
            }
            else if (hp_proc < 100) {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookStateTextId(3))));
            }
            else {
                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookStateTextId(4))));
            }

            if (Tla::IsCritterInjured(cr)) {
                if (hp_proc < 90) {
                    result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::StrAnd)));
                }

                result += Game.GetText(TextPackKey(TextPackName::Game, "" + (MsgStr::CritLookLimbsTextId(gender, hp_proc >= 90))));
            }
        }

        result += ".";
    }

    // Format tags
    if (cr.TextArgs != "") {
        return Game.FormatTags(result, cr.TextArgs);
    }

    return result;
}

// Call to determine available timeouts.
void GetAvailableTimeouts(CritterProperty[] & timeouts)
{
    for (int i = 0; i < CritterPropertyGroup::Timeouts.length(); i++) {
        timeouts.insertLast(CritterPropertyGroup::Timeouts[i]);
    }
}

// Call on some critter action.
[[Event]]
void CritterAction(bool localCall, Critter cr, CritterAction action, int actionExt, AbstractItem? item)
{
    // Not process locally called actions
    if (cr.IsChosen && not localCall) {
        switch (action) {
        case CritterAction::MoveItem:
        case CritterAction::SwapItems:
        case CritterAction::UseItem:
        case CritterAction::DropItem:
        case CritterAction::UseWeapon:
        case CritterAction::ReloadWeapon:
        case CritterAction::UseSkill:
        // case CritterAction::PickItem:
        case CritterAction::PickCritter:
        case CritterAction::OperateContainer:
            return; // Skip processing
        default:
            break; // Processing
        }
    }

    AbstractItem proto = (item != null ? item : CritterItem::GetActive(cr));
    if ((action >= CritterAction::MoveItem && action <= CritterAction::OperateContainer) || action == CritterAction::StandUp) {
        CurPlayer.ServerCall.Rpc_Wait(Settings.Movement.Breaktime);
    }

    switch (action) {
    case CritterAction::MoveItem:
        if (cr.IsAlive()) {
            verify(item != null, "Move item action requires item", cr);
            CritterItemSlot fromSlot = CritterItemSlot(actionExt);
            CritterItemSlot toSlot = item.CritterSlot;

            if (toSlot == CritterItemSlot::Main) {
                if (proto.Type == ItemType::Weapon) {
                    cr.Animate(proto.Weapon_StateAnim, CritterActionAnim::ShowWeapon, item);
                }
                else {
                    cr.Animate(CritterStateAnim::None, CritterActionAnim::ShowWeapon, item);
                }
            }
            else if (fromSlot == CritterItemSlot::Main) {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::HideWeapon, item);
            }
            else {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::SwitchItems);
            }
        }

        break;
    case CritterAction::SwapItems:
        break;
    case CritterAction::UseItem:
        if (cr.IsAlive()) {
            if (proto.Type == ItemType::Weapon && cr.IsAnimAvailable(proto.Weapon_StateAnim, proto.Weapon_ActionAnim_0)) {
                cr.Animate(proto.Weapon_StateAnim, proto.Weapon_ActionAnim_0, item);
            }
            else {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::Use, item);
            }
        }

        break;
    case CritterAction::DropItem:
        if (cr.IsAlive()) {
            cr.Animate(CritterStateAnim::None, CritterActionAnim::PickUp);
        }

        break;
    case CritterAction::UseWeapon:
        if (cr.IsAlive()) {
            int use = (actionExt & 0xF);
            int aim = ((actionExt >> 4) & 0xF);
            bool fail = (((actionExt >> 8) & 1) != 0);

            cr.Animate(CritterStateAnim::None, CritterActionAnim::PrepareWeapon);

            Effects::PlayWeaponSound(WeaponHelpers::SOUND_WEAPON_USE, WeaponHelpers::WeaponSoundId(proto, use), use != 1 ? '1' : '2');
            cr.Animate(CritterStateAnim::None, WeaponHelpers::WeaponActionAnim(proto, use), item, true);

            if (fail) {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::DamageFront, item);
            }
            else {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::TurnOffWeapon, item, true);
            }
        }

        break;
    case CritterAction::ReloadWeapon:
        if (cr.IsAlive()) {
            Effects::PlayWeaponSound(WeaponHelpers::SOUND_WEAPON_RELOAD, proto.Weapon_SoundId_0, '1');
            cr.Animate(proto.Weapon_StateAnim, CritterActionAnim::Reload, item);
        }

        break;
    case CritterAction::UseSkill:
        if (cr.IsAlive() && actionExt != CritterProperty::SkillSneak) {
            cr.Animate(CritterStateAnim::None, CritterActionAnim::Use);
        }

        break;
    case CritterAction::PickItem:
        if (cr.IsAlive()) {
            cr.Animate(CritterStateAnim::None, proto.GroundLevel ? CritterActionAnim::PickUp : CritterActionAnim::Use);
        }

        break;
    case CritterAction::PickCritter:
        if (cr.IsAlive()) {
            switch (actionExt) // 0 - loot, 1 - steal, 2 - push
            {
            case 0:
                cr.Animate(CritterStateAnim::None, CritterActionAnim::Loot);
                break;
            case 1:
                cr.Animate(CritterStateAnim::None, CritterActionAnim::Steal);
                break;
            case 2:
                cr.Animate(CritterStateAnim::None, CritterActionAnim::Push);
                break;
            default:
                break;
            }
        }

        break;
    case CritterAction::OperateContainer:
        if (cr.IsAlive()) {
            int transferType = actionExt / 10;
            int directionType = actionExt % 10;

            if (transferType == TransferTypes::HexContDown || transferType == TransferTypes::CritLoot) {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::PickUp);
            }
            else {
                cr.Animate(CritterStateAnim::None, CritterActionAnim::Use);
            }
        }

        break;
    case CritterAction::Dodge:
        if (not cr.IsAnimPlaying() && cr.IsAlive()) {
            cr.Animate(CritterStateAnim::None, actionExt == 0 ? CritterActionAnim::DodgeFront : CritterActionAnim::DodgeBack);
        }

        break;
    case CritterAction::Damage:
        if (not cr.IsAnimPlaying()) {
            if (cr.IsAlive()) {
                cr.Animate(CritterStateAnim::None, actionExt == 0 ? CritterActionAnim::DamageFront : CritterActionAnim::DamageBack);
            }
            else if (cr.IsKnockout()) {
                cr.Animate(CritterStateAnim::None, actionExt == 0 ? CritterActionAnim::DamageProneFront : CritterActionAnim::DamageProneBack);
            }
        }
        else {
            // Todo:
            // CritterActionAnim::Walk_DAMAGE_FRONT
            // CritterActionAnim::Walk_DAMAGE_BACK
            // CritterActionAnim::Limp_DAMAGE_FRONT
            // CritterActionAnim::Limp_DAMAGE_BACK
            // CritterActionAnim::Run_DAMAGE_FRONT
            // CritterActionAnim::Run_DAMAGE_BACK
        }

        break;
    case CritterAction::DamageForce:
        if (cr.IsAlive()) {
            cr.Animate(CritterStateAnim::None, actionExt == 0 ? CritterActionAnim::DamageFront : CritterActionAnim::DamageBack);
        }
        else if (cr.IsKnockout()) {
            cr.Animate(CritterStateAnim::None, actionExt == 0 ? CritterActionAnim::DamageProneFront : CritterActionAnim::DamageProneBack);
        }

        break;
    case CritterAction::Knockout:
        if (not cr.IsKnockout()) {
            cr.Animate(CritterStateAnim::None, CritterActionAnim(actionExt));
        }

        break;
    case CritterAction::StandUp:
        if (cr.IsKnockout()) {
            cr.Animate(CritterStateAnim::None, CritterActionAnim(actionExt));
        }

        break;
    case CritterAction::Fidget:
        if (cr.IsAlive() && not cr.IsAnimPlaying()) {
            cr.Animate(CritterStateAnim::None, CritterActionAnim::Fidget);
        }

        break;
    case CritterAction::Dead:
        if (not cr.IsDead()) {
            cr.Animate(CritterStateAnim::None, CritterActionAnim(actionExt));
        }

        break;
    case CritterAction::Connect:
        break;
    case CritterAction::Disconnect:
        break;
    case CritterAction::Respawn:
        break;
    case CritterAction::Refresh:
        break;
    default:
        break;
    }
}

