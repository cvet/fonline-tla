[Dialog]
Speech 1 # Преддиалоговые установки
  Answer 6 # знаком
    Demand Script Dialog::IsNameMemNpcPlayer
  Answer 2 # -

Speech 2 # Приветствую путник. Тебя привел сюда запах еды?
  Answer 3 # Здравствуй. Ты кто?

Speech 3 # Я местный повар. Стряпаю братьям обеды и ужины.
  Answer 4 # Значит я на кухне?

Speech 4 # Да. Ты находишься на кухне. Здесь идет сложнейш...
  Answer 5 # Удачи в приготовлении.
  Answer 7 # Говорят, вы готовите еду из еретиков и грешников?
  Answer 8 # Мне бы еды или напитков.

Speech 5 # Спасибо на добром слове путник. Вот возьми вита...
  Answer Exit # Спасибо.
    Result Script Dialog::SetNameMemNpcPlayer true
    Result Item Player mutated_fruit += 1

Speech 6 # Снова здравствуй. Извини, я сейчас занят.
  Answer Exit # Пока.@@Тогда пока.@@Удачной стряпни.
  Answer 8 # Мне бы еды или напитков.

Speech 7 # Ха-ха-ха. Точно. И ты сегодня главное блюдо. Ид...
  Answer Exit # Пока.
    Result Script Dialog::SetNameMemNpcPlayer true

Speech 8 # Могу продать тебе пивка, самогончика, фруктов, ...
  Answer 9 # Давай пивка.
  Answer 10 # Попробую самогончика.
  Answer 11 # Возьму фрукт.
  Answer 12 # Перекушу игуаной на палочке.
  Answer 13 # Проверим, какой из меня эстет. Гамму.
  Answer Exit # Я лучше позже зайду.

Speech 9 # Отличное холодное пивко для бодрости духа. Всег...
  Answer Exit # Держи.
    Demand Item Player bottle_caps >= 5
    Result Item Player bottle_caps -= 5
    Result Item Player beer += 1
  Answer Exit* # Наверное, я передумаю.

Speech 10 # Местный самогончик тройной очистки. Не самогон,...
  Answer Exit # Держи
    Demand Item Player bottle_caps >= 20
    Result Item Player bottle_caps -= 20
    Result Item Player booze += 1
  Answer Exit* # Тогда не надо.

Speech 11 # Витамины - это наша жизнь. А 5 монет - полная е...
  Answer Exit # Держи.
    Demand Item Player bottle_caps >= 5
    Result Item Player bottle_caps -= 5
    Result Item Player mutated_fruit += 1
  Answer Exit* # Тогда не надо.

Speech 12 # Сия прекрасная ящерка на шампуре будет стоить в...
  Answer Exit # Держи.
    Demand Item Player bottle_caps >= 15
    Result Item Player bottle_caps -= 15
    Result Item Player iguana_on_a_stick += 1
  Answer Exit* # Тогда не надо.

Speech 13 # О! Это лучший выбор! За 10 монет абсолютно новы...
  Answer Exit # Держи.
    Demand Item Player bottle_caps >= 10
    Result Item Player bottle_caps -= 10
    Result Item Player gamma_gulp_beer += 1
  Answer Exit* # Тогда не надо.

[Text russ]
{Name}{}{Повар}
{DescAliveShort}{}{Перед вами повар.}
{Speech 1}{}{Преддиалоговые установки}
{Speech 1 Answer 6}{}{знаком}
{Speech 1 Answer 2}{}{-}
{Speech 2}{}{Приветствую путник. Тебя привел сюда запах еды?}
{Speech 2 Answer 3}{}{Здравствуй. Ты кто?}
{Speech 3}{}{Я местный повар. Стряпаю братьям обеды и ужины.}
{Speech 3 Answer 4}{}{Значит я на кухне?}
{Speech 4}{}{Да. Ты находишься на кухне. Здесь идет сложнейший процесс превращения разной всячины во вкусную еду.}
{Speech 4 Answer 5}{}{Удачи в приготовлении.}
{Speech 4 Answer 7}{}{Говорят, вы готовите еду из еретиков и грешников?}
{Speech 4 Answer 8}{}{Мне бы еды или напитков.}
{Speech 5}{}{Спасибо на добром слове путник. Вот возьми витаминов.}
{Speech 5 Answer Exit}{}{Спасибо.}
{Speech 6}{}{Снова здравствуй. Извини, я сейчас занят.}
{Speech 6 Answer Exit}{}{Пока.@@Тогда пока.@@Удачной стряпни.}
{Speech 6 Answer 8}{}{Мне бы еды или напитков.}
{Speech 7}{}{Ха-ха-ха. Точно. И ты сегодня главное блюдо. Иди давай, не мешай, некогда мне глупости слушать.}
{Speech 7 Answer Exit}{}{Пока.}
{Speech 8}{}{Могу продать тебе пивка, самогончика, фруктов, игуану и оригинальное пиво для эстетов гамма-глоток.}
{Speech 8 Answer 9}{}{Давай пивка.}
{Speech 8 Answer 10}{}{Попробую самогончика.}
{Speech 8 Answer 11}{}{Возьму фрукт.}
{Speech 8 Answer 12}{}{Перекушу игуаной на палочке.}
{Speech 8 Answer 13}{}{Проверим, какой из меня эстет. Гамму.}
{Speech 8 Answer Exit}{}{Я лучше позже зайду.}
{Speech 9}{}{Отличное холодное пивко для бодрости духа. Всего за 5 монет.}
{Speech 9 Answer Exit}{}{Держи.}
{Speech 9 Answer Exit*}{}{Наверное, я передумаю.}
{Speech 10}{}{Местный самогончик тройной очистки. Не самогон, а вино. И всего за 20 монет.}
{Speech 10 Answer Exit}{}{Держи}
{Speech 10 Answer Exit*}{}{Тогда не надо.}
{Speech 11}{}{Витамины - это наша жизнь. А 5 монет - полная ерунда.}
{Speech 11 Answer Exit}{}{Держи.}
{Speech 11 Answer Exit*}{}{Тогда не надо.}
{Speech 12}{}{Сия прекрасная ящерка на шампуре будет стоить всего 15 монет.}
{Speech 12 Answer Exit}{}{Держи.}
{Speech 12 Answer Exit*}{}{Тогда не надо.}
{Speech 13}{}{О! Это лучший выбор! За 10 монет абсолютно новые и непередаваемые ощущения.}
{Speech 13 Answer Exit}{}{Держи.}
{Speech 13 Answer Exit*}{}{Тогда не надо.}
