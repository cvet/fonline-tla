    craft = MainCraft(id++, Content::Item::throwing_knife, 1, 70)
                .AddCheckOnView({CritterProperty::SkillThrowing, 40})
                .AddCheckOnCraft({CritterProperty::SkillThrowing, 50, CritterProperty::SkillRepair, 30})
                .AddNeedResources({Content::Item::knife, 1, 0})
                .AddNeedTools({Content::Item::multi_tool, 1, 0});
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::shovel, 1, 50)
                .AddCheckOnCraft({CritterProperty::SkillOutdoorsman, 30})
                .AddNeedResources({Content::Item::metal_trash, 1, 0, Content::Item::sharpened_pole, 1, 0});
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::axe, 1, 70)
                .AddCheckOnCraft({CritterProperty::SkillOutdoorsman, 30})
                .AddNeedResources({Content::Item::metal_trash, 1, 0});
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::sandbag_empty, 1, 60)
                .AddCheckOnCraft({CritterProperty::SkillOutdoorsman, 20})
                .AddNeedResources({Content::Item::rags, 4, 0, Content::Item::pocket_lint, 1, 0})
                .AddNeedTools({Content::Item::shiv, 1, 0});
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::sandbag_1, 1, 10).AddNeedResources({Content::Item::sandbag_empty, 1, 0}).AddNeedTools({Content::Item::shovel, 1, 0});
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::elephant_gun, 1, 500)
                .AddCheckOnView({CritterProperty::SkillScience, 40, CritterProperty::SkillRepair, 50})
                .AddCheckOnCraft({CritterProperty::SkillSmallGuns, 80, CritterProperty::SkillScience, 60, CritterProperty::SkillRepair, 100})
                .AddNeedResources({Content::Item::tube,
                                   1,
                                   0,
                                   Content::Item::plank,
                                   1,
                                   0,
                                   Content::Item::firewood,
                                   1,
                                   0,
                                   Content::Item::metal_trash,
                                   4,
                                   0,
                                   Content::Item::pump_parts,
                                   2,
                                   0})
                .AddNeedTools({Content::Item::super_tool_kit, 1, 0, Content::Item::welding, 1, 0, Content::Item::guns_and_bullets, 1, 0})
                .SetScript(NitroExpress);
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::multi_barrel_gun, 1, 350)
                .AddCheckOnView({CritterProperty::SkillScience, 60, CritterProperty::SkillRepair, 60})
                .AddCheckOnCraft({CritterProperty::SkillSmallGuns, 80, CritterProperty::SkillScience, 100, CritterProperty::SkillRepair, 80})
                .AddNeedResources({Content::Item::tube,
                                   6,
                                   0,
                                   Content::Item::firewood,
                                   2,
                                   0,
                                   Content::Item::metal_trash,
                                   4,
                                   0,
                                   Content::Item::pump_parts,
                                   2,
                                   0,
                                   Content::Item::small_energy_cell,
                                   40,
                                   0,
                                   Content::Item::v15_computer_part,
                                   7,
                                   0})
                .AddNeedTools({Content::Item::welding, 1, 0, Content::Item::guns_and_bullets, 1, 0})
                .SetScript(AnyStuff);
    CraftList.insertLast(craft);

    craft = MainCraft(id++, Content::Item::metal_storm, 1, 500)
                .AddCheckOnView({CritterProperty::SkillScience, 80, CritterProperty::SkillRepair, 80})
                .AddCheckOnCraft({CritterProperty::SkillSmallGuns, 80, CritterProperty::SkillScience, 120, CritterProperty::SkillRepair, 100})
                .AddNeedResources({Content::Item::hk_g11e,
                                   7,
                                   0,
                                   Content::Item::metal_trash,
                                   8,
                                   0,
                                   Content::Item::pump_parts,
                                   5,
                                   0,
                                   Content::Item::micro_fusion_cell,
                                   50,
                                   0,
                                   Content::Item::v15_computer_part,
                                   15,
                                   0,
                                   Content::Item::oil_can,
                                   2,
                                   0})
                .AddNeedTools({Content::Item::super_tool_kit, 1, 0, Content::Item::welding, 2, 0, Content::Item::guns_and_bullets, 1, 0})
                .SetScript(AnyStuff);
    CraftList.insertLast(craft);
}

int PowerArmor(Critter player, int state, MainCraft craft)
{
    if (player.FixboyPowerArmor == 0) {
        return FIX_FAIL;
