// HellMineMining — добыча ресурсов в локации "адская шахта" по нажатию на статичный объект.
// SERVER: обработчики добычи (золото/уран) с проверкой инструмента, броском на успех,
// выдачей предмета и таймаутом-передышкой между попытками.
// Связи: Messaging (сообщения игроку), Effects (анимация удара), Content (прото-id предметов),
// Time (расчёт таймаута), тексты — через TextPackName::Text.
namespace HellMineMining
{

#if SERVER

///@ Property Critter Server synctime HellMineTimeoutEnd Mutable Persistent

// время в реальных секундах
const int BASE_TIMEOUT = 11;

const int STR_NEED_REST = 2201;
const int STR_MINE_URANIUM = 3035;
const int STR_MINE_STONE = 3036;
const int STR_MINE_GOLD = 3037;

bool MineGold(Critter cr, StaticItem sc, Item item, any skill)
{
    return MgImpl(cr, sc, item, skill);
}

bool MgImpl(Critter cr, StaticItem sc, Item item, any skill)
{
    if (not IsMiningTool(item)) {
        return false;
    }

    if (not IsTimeoutExpired(cr)) {
        // криттеру нужна передышка
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_NEED_REST)));
        return true;
    }
    else {
        Effects::Animate(cr, CritterStateAnim::Hammer, CritterActionAnim::Swing1H);
    }

    int successChance = (cr.Endurance + cr.Strength * 4);
    successChance = Math::Clamp(successChance, 10, 95);
    int roll = Game.Random(1, 100);

    if (roll <= successChance) {
        cr.AddItem(Content::Item::gold_nugget, 1);
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_MINE_GOLD)));
    }
    else {
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_MINE_STONE)));
        cr.AddItem(Content::Item::rock, 1);
    }

    SetTimeout(cr);
    return true;
}

// добыча золота (Mine Gold), точка входа по нажатию на статичный объект
[[ItemStatic]]
bool Mg(Critter cr, StaticItem sc, Item item, any skill)
{
    return MgImpl(cr, sc, item, skill);
}

bool Mine(Critter cr, StaticItem sc, Item item, any skill)
{
    if (not IsMiningTool(item)) {
        return false;
    }

    if (not IsTimeoutExpired(cr)) {
        // криттеру нужна передышка
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_NEED_REST)));

        // breadcrumb миграции: прежний вызов анимации простоя, оставлен до домиграции API
        // cr.Animate(0xFF, STATE_ANIM_EMPTY, 0, 0xFF, 0, true, true, true);

        return true;
    }
    else {
        Effects::Animate(cr, CritterStateAnim::Hammer, CritterActionAnim::Swing1H);
    }

    int successChance = (cr.Luck) * 10;
    successChance = Math::Clamp(successChance, 10, 95);
    int roll = Game.Random(1, 100);

    // успех — выдаём урановую руду, провал — простой камень
    if (roll <= successChance) {
        cr.AddItem(Content::Item::uranium_ore, 1);
        // breadcrumb отладки: вывод броска и шанса
        // Messaging::Info(cr, "Success. Roll/Chance = " + roll + "/" + successChance);
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_MINE_URANIUM)));
    }
    else {
        // breadcrumb отладки: вывод броска и шанса
        // Messaging::Info(cr, "Fail. Roll/Chance = " + roll + "/" + successChance);
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_MINE_STONE)));
        // r17 091228>
        // добавление камня всегда, если не досталось урановой руды
        cr.AddItem(Content::Item::rock, 1);
        // <r17
    }

    SetTimeout(cr);
    return true;
}

// Подходит ли предмет в качестве инструмента для добычи (кувалда / супер-кувалда).
bool IsMiningTool(Item? item)
{
    if (item == null) {
        return false;
    }

    hstring pid = item.ProtoId;
    return pid == Content::Item::sledgehammer || pid == Content::Item::super_sledge;
}

// Истёк ли таймаут-передышка после прошлой добычи; иначе шлёт игроку остаток времени.
bool IsTimeoutExpired(Critter cr)
{
    if (Game.SynchronizedTime >= cr.HellMineTimeoutEnd) {
        return true;
    }

    Messaging::Info(cr, "Remaining time, seconds: " + (cr.HellMineTimeoutEnd - Game.SynchronizedTime).seconds);
    return false;
}

// Устанавливает таймаут до следующей добычи: чем выше выносливость, тем короче передышка.
void SetTimeout(Critter cr)
{
    // базовая формула длительности таймаута в реальных секундах
    int timeoutTime = (BASE_TIMEOUT - cr.Endurance);
    // запоминаем момент окончания таймаута
    cr.HellMineTimeoutEnd = Game.SynchronizedTime + Time::Seconds(timeoutTime);
    Messaging::Info(cr, "Setting timeout, seconds: " + (cr.HellMineTimeoutEnd - Game.SynchronizedTime).seconds);
}

#endif

}
