// DialogBarman — механика 'бармен ищет игрока по имени'.
// Ключевые обязанности: перехват введённого в диалоге текста, поиск игрока, формирование лексем (пол, место, статус онлайн).
// Сторона: SERVER. Связи: Dialog, PlayerRegistration, Maps, Replication, MsgStr, Tla.
namespace DialogBarman
{

#if SERVER

const int DialogNone = 0;
// Номера веток и номера дополнительных строк стандартные для любых НПЦ, должны присутствовать в самом диалоге.
const int DialogCheckPlayerExists = 200;
const int DialogFoundPlayerOnline = 202;

// Карта относится к репликациям (по списку прото-id из модуля Replication).
bool IsReplicationMap(hstring mapPid)
{
    return Replication::ReplicatorsMapPids.find(mapPid) != -1;
}

// Точка входа модуля: подписка на ввод игроком текста в диалоге.
[[ModuleInit]]
void InitDialogBarman()
{
    Game.OnPlayerSaidText.Subscribe(OnPlayerSaidText);
}

// Маршрутизация введённого текста в нужный шаг по текущему номеру диалога бармена.
[[Event]]
void OnPlayerSaidText(Critter? critter, string text, bool fromDialog, ident talkerId, bool isNpc)
{
    if (critter != null && critter.ControlledByPlayer && isNpc && fromDialog && !text.isEmpty() && text.length() > 1) {
        auto npc = Game.GetCritter(talkerId);
        if (npc == null) {
            return;
        }

        int curDialog = Dialog::GetCurrentDialogNumber(critter, npc);
        switch (curDialog) {
        case DialogNone:
            break;
        case DialogCheckPlayerExists:
            TryFoundPlayer(critter, npc, text);
            break;
        case DialogFoundPlayerOnline:
            FoundOnline(critter, npc, text);
            break;
        default:
            Game.Log("Wrond dialog number: " + curDialog + "; npc: " + npc.ProtoId);
            break;
        }
    }
}

// Подготовка шага «проверить, существует ли игрок»: разрешаем ввод имени или завершаем диалог.
void CheckPlayerExists(Critter player, Critter? barman, string& lex)
{
    if (barman == null) {
        player.CanSendSay = false;
        return;
    }

    if (Tla::IsDialogEnd(lex)) {
        Dialog::SetCurrentDialogNumber(player, barman, DialogNone);
        player.CanSendSay = false;
        return;
    }

    player.CanSendSay = true;
    Dialog::SetCurrentDialogNumber(player, barman, DialogCheckPlayerExists);
}

// Подготовка шага «найти игрока онлайн»: разрешаем ввод имени или завершаем диалог.
void FindPlayerOnline(Critter player, Critter? barman, string& lex)
{
    if (barman == null) {
        player.CanSendSay = false;
        return;
    }

    if (Tla::IsDialogEnd(lex)) {
        Dialog::SetCurrentDialogNumber(player, barman, DialogNone);
        player.CanSendSay = false;
        return;
    }

    player.CanSendSay = true;
    Dialog::SetCurrentDialogNumber(player, barman, DialogFoundPlayerOnline);
}

// Шаг проверки существования: ищем игрока по имени и формируем лексемы пола (бармен + найденный криттер).
void TryFoundPlayer(Critter player, Critter barman, string playerName)
{
    if (playerName.length() <= 1) {
        return;
    }

    hstring BankerDialog = barman.DialogId;
    int DlgStr = 200;

    // Имя запрашиваемого криттера и инициализация переменной с лексемами.
    string textArgs = "|Victim: " + playerName;

    // Пол бармена.
    if (barman.Gender == GenderType::Female) {
        textArgs += "|BarmanGen: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 10) + "@";
    }
    else {
        textArgs += "|BarmanGen: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 9) + "@";
    }

    // Игрок не найден.
    Player? foundPlayer = PlayerRegistration::GetPlayerByName(playerName);
    if (foundPlayer == null) {
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 0), textArgs);
        return;
    }

    Critter? cr = foundPlayer.GetControlledCritter();

    if (cr != null) {
        // Пол запрашиваемого криттера.
        if (cr.Gender == GenderType::Female) {
            textArgs += "|Gender: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 8) + "@";
        }
        else {
            textArgs += "|Gender: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 7) + "@";
        }
    }

    player.CanSendSay = false;
    // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 11), textArgs);
}

// Шаг поиска онлайн: проверяем статус игрока и его местоположение, формируем лексемы (пол, место) и выдаём подсказку.
void FoundOnline(Critter player, Critter? barman, string playerName)
{
    if (barman == null) {
        return;
    }

    if (playerName.length() <= 1) {
        return;
    }

    hstring BankerDialog = barman.DialogId;
    int DlgStr = 200;

    // Имя запрашиваемого криттера и инициализация переменной с лексемами.
    string textArgs = "|Victim: " + playerName;

    // Пол бармена.
    if (barman.Gender == GenderType::Female) {
        textArgs += "|BarmanGen: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 10) + "@";
    }
    else {
        textArgs += "|BarmanGen: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 9) + "@";
    }

    // Игрок не найден.
    Player? foundPlayer = PlayerRegistration::GetPlayerByName(playerName);
    if (foundPlayer == null) {
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 0), textArgs);
        return;
    }

    Critter? cr = foundPlayer.GetControlledCritter();
    // Игрок оффлайн.
    if (cr == null) {
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 2), textArgs);
        return;
    }

    // Пол запрашиваемого криттера.
    if (cr.Gender == GenderType::Female) {
        textArgs += "|Gender: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 8) + "@";
    }
    else {
        textArgs += "|Gender: text Dialogs " + MsgStr::DialogTextId(BankerDialog, DlgStr + 7) + "@";
    }

    // Игрок спрашивает о самом себе.
    if (player.Id == cr.Id) {
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 1));
        return;
    }

    // Криттер на глобале.
    Map? map = cr.GetMap();
    if (map == null) {
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 2), textArgs);
        return;
    }

    // Локация, где находится криттер. Диапазоны PID: до 150 и 210-235. Города и репликации.
    Location loc = map.GetLocation();
    if (Maps::IsCityLocation(loc.ProtoId) || IsReplicationMap(map.ProtoId)) {
        textArgs += "|Place: text Locations " + MsgStr::LocNameTextId(loc.ProtoId) + "@";
        // Криттер находится в той же локации, что и игрок.
        Map? barmanMap = barman.GetMap();
        if (barmanMap == null) {
            return;
        }

        if (barmanMap.GetLocation().Id == loc.Id) {
            // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 3), textArgs);
            return;
        }

        // Криттер найден, лексемы сформированы - даем информацию.
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 4 + Game.Random(0, 2)), textArgs);
    }
    else {
        // Todo: player.SayMsg(SAY_DIALOG, TextPackName::Dialogs, DialogTextId(BankerDialog, DlgStr + 2), textArgs);
    }

    player.CanSendSay = false;
    Dialog::SetCurrentDialogNumber(player, barman, DialogNone);
}

#endif

}
