// To-hit chance.
int ToHit(Critter chosen, Critter target, ProtoItem? weapon, int weaponMode)
{
    ProtoItem resolvedWeapon = Game.GetProtoItem(Content::Item::default_weapon);
    if (weapon != null) {
        resolvedWeapon = weapon;
    }

    int use = WeaponHelpers::WeaponModeUse(weaponMode);
    int hitLocation = WeaponHelpers::WeaponModeAim(weaponMode);
    if (use > 2) {
        return 0;
    }

    if (target.IsDead()) {
        return 0;
    }

    if (!chosen.IsAlive()) {
        return 0;
    }

    ProtoItem? ammo = null;

    if (WeaponHelpers::WeaponRounds(resolvedWeapon, use) > 0) {
        ammo = Game.GetProtoItem(resolvedWeapon.AmmoPid);
    }

    CritterProperty skill = CritterProperty::SkillUnarmed;
    skill = WeaponHelpers::WeaponSkill(resolvedWeapon, use);
    int wpnMaxDist = WeaponHelpers::WeaponMaxDistance(resolvedWeapon, use);
    if (skill == CritterProperty::SkillThrowing) {
        wpnMaxDist = Math::Min(wpnMaxDist, 3 * Math::Min(int(10), chosen.Strength + 2 * chosen.PerkHeaveHo));
    }

    int dist = Game.GetDistance(chosen, target);
    if (dist > wpnMaxDist) {
        return 0;
    }

    int toHit = int(chosen.GetAsInt(skill));
    int weaponPerk = resolvedWeapon.Weapon_Perk;
    int blockers = 0;

    if (skill != CritterProperty::SkillUnarmed && skill != CritterProperty::SkillMeleeWeapons) {
        // Ranged attack modifiers
        int distmod1 = 2; // Used for initial weapon bonus
        int distmod2 = 0; // Minimal distance
        if (weaponPerk == ItemPerks::LongRange) {
            distmod1 = 4;
        }
        else if (weaponPerk == ItemPerks::ScopeRange) {
            distmod1 = 5;
            distmod2 = 8;
        }

        int perception = chosen.Perception;
        int acc = dist;

        if (dist < distmod2) {
            acc += distmod2;
        }
        else {
            if (chosen.ControlledByPlayer) {
                acc -= (perception - 2) * distmod1; // we want to keep it, because fo2238 might use it to display NPCs chance (via possessing)
            }
            else {
                acc -= perception * distmod1;
            }
        }

        if (-2 * perception > acc) {
            acc = -2 * perception;
        }

        acc -= 2 * chosen.PerkSharpshooter;

        if (acc >= 0) {
            if (chosen.IsDamagedEye) {
                acc *= -12;
            }
            else {
                acc *= -4;
            }
        }
        else {
            acc *= -4;
        }

        toHit += acc;

        verify(HasCurMap, "To-hit calculation requires an active map", chosen);
        blockers = CurMap.GetCrittersInPath(chosen.Hex, target.Hex, 0.0f, dist, CritterFindType::NonDead).length();
        if (!target.IsKnockout()) {
            blockers--;
        }

        toHit -= 10 * blockers;
    } // End range modifiers

    if (!resolvedWeapon.Weapon_IsUnarmed && chosen.IsTraitOneHander) {
        toHit += (resolvedWeapon.Weapon_IsTwoHanded ? -40 : 20);
    }

    int handlingStrength = chosen.Strength;
    int reqStrength = resolvedWeapon.Weapon_MinStrength;
    if (chosen.PerkWeaponHandling != 0) {
        handlingStrength += 3;
    }

    if (handlingStrength < reqStrength) {
        toHit -= (reqStrength - handlingStrength) * 20;
    }

    if (weaponPerk == ItemPerks::Accurate) {
        toHit += 20;
    }

    int acmod = target.ArmorClass;
    if (ammo != null) {
        acmod += ammo.Ammo_AcMod;
    }

    if (acmod > 0) {
        toHit -= acmod;
    }

    // TODO: tohit += 15 if target is multihex
    // TODO: light penalty

    if (chosen.IsDamagedEye) {
        toHit -= 25;
    }

    if (chosen.PerkVampireAccuracy != 0 && GameTime::IsNight(GameTime::GetHour())) {
        toHit += 13;
    }

    if (target.IsKnockout()) {
        toHit += 40;
    }

    toHit += target.Multihex * 15;

    int hitMod = GetHitAim(hitLocation);
    if (skill == CritterProperty::SkillMeleeWeapons || skill == CritterProperty::SkillUnarmed) {
        hitMod /= 2;
    }

    toHit -= hitMod;
    toHit = Math::Clamp(toHit, 5, 95);

    return toHit;
}

int GetHitAim(int hitLocation)
{
    switch (hitLocation) {
    case HitLocations::LocationNone:
        break;
    case HitLocations::LocationUncalled:
        break;
    case HitLocations::LocationTorso:
        return Settings.Combat.HitAimTorso;
    case HitLocations::LocationEyes:
        return Settings.Combat.HitAimEyes;
    case HitLocations::LocationHead:
        return Settings.Combat.HitAimHead;
    case HitLocations::LocationLeftArm:
    case HitLocations::LocationRightArm:
        return Settings.Combat.HitAimArms;
    case HitLocations::LocationGroin:
        return Settings.Combat.HitAimGroin;
    case HitLocations::LocationRightLeg:
    case HitLocations::LocationLeftLeg:
        return Settings.Combat.HitAimLegs;
    default:
        break;
    }

    return 0;
}

