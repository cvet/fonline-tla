// Two-token Game text accessors. The bake stores stat/property/karma/reputation strings
// as `{<Enum>::<Value>}{<Field>}{<text>}`; before #144 hashes those keys were addressed
// by summing two `.hstr().uhash` values into a single int, but the new hash function
// no longer produces matching numbers, so we now go through the actual two-key lookup.
string GetParamNameText(CritterProperty prop)
{
    return Game.GetText(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "Name"));
}
string GetParamDescText(CritterProperty prop)
{
    return Game.GetText(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "Desc"));
}
string GetParamShortNameText(CritterProperty prop)
{
    return Game.GetText(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "ShortName"));
}
string GetParamPicText(CritterProperty prop)
{
    return Game.GetText(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "Pic"));
}
string GetInventoryShortSpecialText(CritterProperty prop)
{
    return Game.GetText(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "Inv"));
}
bool HasParamNameText(CritterProperty prop)
{
    return Game.IsTextPresent(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "Name"));
}
bool HasParamDescText(CritterProperty prop)
{
    return Game.IsTextPresent(TextPackKey(TextPackName::Game, MsgStr::PropPrefix(prop), "Desc"));
}

string GetKarmaLevelNameText(KarmaLevel num)
{
    return Game.GetText(TextPackKey(TextPackName::Game, "KarmaLevel::" + Game.EnumToString(num), "Name"));
}
string GetKarmaLevelValueText(KarmaLevel num)
{
    return Game.GetText(TextPackKey(TextPackName::Game, "KarmaLevel::" + Game.EnumToString(num), "MinValue"));
}
string GetKarmaLevelSkilldexText(KarmaLevel num)
{
    return Game.GetText(TextPackKey(TextPackName::Game, "KarmaLevel::" + Game.EnumToString(num), "Pic"));
}

string GetReputationLevelNameText(ReputationLevel num)
{
    return Game.GetText(TextPackKey(TextPackName::Game, "ReputationLevel::" + Game.EnumToString(num), "Name"));
}
string GetReputationLevelDescText(ReputationLevel num)
{
    return Game.GetText(TextPackKey(TextPackName::Game, "ReputationLevel::" + Game.EnumToString(num), "Desc"));
}
string GetReputationLevelSkilldexText(ReputationLevel num)
{
    return Game.GetText(TextPackKey(TextPackName::Game, "ReputationLevel::" + Game.EnumToString(num), "Pic"));
}

