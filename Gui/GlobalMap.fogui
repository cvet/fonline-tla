//           "OnLMousePressed":
{
    {
        {
            Game.CurPlayer.ServerCall.ProcessGlobalMapCommand(1,
                                                              NormalX2(Game.MousePos.x - Pos.x - Parent.AbsolutePos.x),
                                                              NormalY2(Game.MousePos.y - Pos.y - Parent.AbsolutePos.y));
        }
    }
}
//           "OnRMousePressed":
{
    {
        {
            LastX = Game.MousePos.x;
            LastY = Game.MousePos.y;
        }
    }
}
//           "OnMouseClick": null,
//           "OnLMouseClick": null,
//           "OnRMouseClick": null,
//           "OnMouseMove":
{
    {
        {
            if (!Input::IsMousePressed(MouseButton::Right)) {
                return;
            }

            int NewPosX = Pos.x + (Game.MousePos.x - LastX);
            int NewPosY = Pos.y + (Game.MousePos.y - LastY);

            NewPosX = Math::Clamp(NewPosX, Parent.Size.width - Size.width, 0);
            NewPosY = Math::Clamp(NewPosY, Parent.Size.height - Size.height, 0);

            SetPosition(NewPosX, NewPosY);

            LastX = Game.MousePos.x;
            LastY = Game.MousePos.y;
        }
    }
}
//           "OnGlobalMouseDown":
{
    {
        {
            if (button == MouseButton::WheelDown) {
                ChangeGMZoom(-0.02);
            }
            else if (button == MouseButton::WheelUp) {
                ChangeGMZoom(0.04);
            }
            else if (button == MouseButton::Middle) {
                ChangeGMZoom(0);
            }
        }
    }
}
