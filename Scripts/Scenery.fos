namespace Scenery
{

#if SERVER

[[ModuleInit]]
void InitScenery()
{
    Game.OnStaticItemWalk.Subscribe(OnMapExit);
}

[[Event]]
void OnMapExit(StaticItem item, Critter cr, bool isIn, mdir moveDir)
{
    if (!isIn) {
        return;
    }

    if (item.Type != ItemType::Grid) {
        return;
    }

    if (!cr.ControlledByPlayer) {
        return;
    }

    if (Time::IsTimeoutActive(cr.TimeoutBattle) || Time::IsTimeoutActive(cr.TimeoutTransfer)) {
        return;
    }

    hstring mapProto = item.Grid_ToMap;
    if (mapProto != EMPTY_HSTRING) {
        Map? currentMap = cr.GetMap();
        if (currentMap == null) {
            return;
        }

        Map? map = currentMap.GetLocation().GetMap(mapProto);
        if (map == null) {
            throw("Invalid exit map.", cr, mapProto);
        }

        if (!map.GetLocation().Hidden) {
            auto knownLocations = cr.KnownLocations.clone();
            if (knownLocations.find(map.GetLocation().Id) == -1) {
                knownLocations.insertLast(map.GetLocation().Id);
                cr.KnownLocations = knownLocations;
            }
        }

        Entrance::CritterTransferToMapEntry(cr, map.Id, item.Grid_ToMapEntry);
    }
    else {
        cr.TransferToGlobal();
    }
}

[[ItemStatic]]
bool Dialog(Critter player, StaticItem scenery, Item? item, any skill) // 691 revision CritterProperty skill )
{
    // Запускаем диалог, если игрок не применял к сценери скилл или итем
    if (skill == CritterProperty::SpecialSkillPickOnGround && item == null) {
        hstring dialogId = scenery.SceneryParams[0];
        Dialogs::RunDialog(player, dialogId, false);
        return true;
    }

    return false;
}

[[ItemStatic]]
bool DoorControl(Critter player, StaticItem scenery, Item item, any skill)
{
    auto params = scenery.SceneryParams;
    hstring entryNum = params[0];
    int toOpen = params[1].uhash;

    if (toOpen == 1) {
        Stdlib::DoorControl(player, entryNum, true);
    }
    else {
        Stdlib::DoorControl(player, entryNum, false);
    }

    return true;
}

[[ItemStatic]]
bool TransferToMap(Critter player, StaticItem scenery, Item item, any skill)
{
    auto params = scenery.SceneryParams;
    hstring locPid = params[0];
    int mapIndex = params[1].uhash;
    int entry = params[2].uhash;
    return Stdlib::TransferToMap(player, locPid, mapIndex, entry);
}

#endif

}
