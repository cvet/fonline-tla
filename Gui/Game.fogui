//           "Columns": 10,
//           "Padding": "9, 0",
//           "BackgroundImage": null,
//           "BackgroundImageLayout": "None",
//           "CropContent": false,
//           "IsVerticalScroll": false,
//           "IsHorizontalScroll": false,
//           "Expanded": true,
//           "Selected": false,
//           "Active": true,
//           "Name": "ActionPoints",
//           "Position": "475, 40",
//           "Size": "0, 0",
//           "Anchor": "None",
//           "Dock": "None",
//           "IsDraggable": false,
//           "IsNotHittable": false,
//           "CheckTransparentOnHit": false,
//           "GlobalScope": null,
//           "ClassFields": null,
//           "OnInit": null,
//           "OnShow": null,
//           "OnHide": null,
//           "OnAppear": null,
//           "OnDisappear": null,
//           "OnDraw":
{
    {
        {
            Critter @chosen = Game.GetChosen();
            int ap = (chosen !is null ? chosen.CurrentAp / AP_DIVIDER : 0);
            int moveAp = 0; //( IsTurnBased() && chosen !is null ? chosen.MoveAp : 0 );
            for (int i = 0; i < Cells.length(); i++) {
                int absAp = int(ABS(ap));
                bool active = (i < absAp + moveAp);
                Cells[i].SetActive(active);
                if (active) {
                    Cells[i].GetChild(0).SetActive(ap >= 0 && i < absAp); // Green
                    Cells[i].GetChild(1).SetActive(ap < 0 && i < absAp);  // Red
                    Cells[i].GetChild(2).SetActive(i >= absAp);           // Yellow
                }
            }
        }
    }
}
