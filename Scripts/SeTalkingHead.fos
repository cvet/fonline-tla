namespace SeTalkingHead
{

#if SERVER

// Talking head special encounter scripts

///@ Property Critter Server int32 SETalkingHeadStringNum Mutable Persistent

const int STR_FIRST = 70002;
const int STR_LAST = 70027;
const int STR_STEALING_WTF = 70029;

void HeadInit(Item head, bool firstTime)
{
    head.OnCritterUseSkill.Subscribe(Head);
}

[[Event]]
EventResult Head(Item head, Critter cr, CritterProperty skill)
{
    if (skill == CritterProperty::SpecialSkillPickOnGround) {
        cr.SETalkingHeadStringNum = STR_FIRST;
        Game.StartTimeEvent(ZERO_TIMESPAN, StartDialog, cr.Id);
    }

    if (skill == CritterProperty::SkillSteal) {
        if (cr.SkillSteal + cr.LuckBase * 5 >= Game.Random(200, 351)) {
            cr.AddItem(Content::Item::monument_chunck, 3);
        }
        else {
            CritterState::ToDead(cr, CritterActionAnim::DeadFront, null);
            Map? map = cr.GetMap();
            if (map == null) {
                return EventResult::StopChain;
            }

            MapText::AddText(map, mpos(85, 94), Color::Red, TextPackKey(TextPackName::Text, "" + (STR_STEALING_WTF)));
        }
    }

    return EventResult::StopChain;
}

[[TimeEvent]]
void StartDialog(any value)
{
    Critter? cr = Game.GetCritter(value);
    if (cr == null) {
        return;
    }

    Map? map = cr.GetMap();
    if (map == null) {
        return;
    }

    if (cr.SETalkingHeadStringNum <= STR_LAST) {
        if (cr.SETalkingHeadStringNum == 70006 || cr.SETalkingHeadStringNum == 70011 || cr.SETalkingHeadStringNum == 70013 ||
            cr.SETalkingHeadStringNum == 70015 || cr.SETalkingHeadStringNum == 70017 || cr.SETalkingHeadStringNum == 70019 ||
            cr.SETalkingHeadStringNum == 70025) {
            Messaging::SayOnHead(cr, TextPackKey(TextPackName::Text, "" + (cr.SETalkingHeadStringNum)));
        }
        else {
            if (cr.SETalkingHeadStringNum == 70023) {
                cr.AddItem(Content::Item::monument_chunck, 1);
            }

            MapText::AddText(map, mpos(85, 94), (ucolor(0xF8, 0xF9, 0x93)), TextPackKey(TextPackName::Text, "" + (cr.SETalkingHeadStringNum)));
        }

        cr.SETalkingHeadStringNum += 1;
        Game.StartTimeEvent(GameTime::GameSeconds(2 * 60), StartDialog, cr.Id);
        CritterState::Wait(cr, 3 * 60 * 1000);
    }
    else {
        CritterState::Wait(cr, 1);
    }
}

void Test(Critter cr, int p0, int p1, int p2)
{
    Location loc = Location::CreateLocation(Content::Location::vault_dwellers_head, ipos(cr.WorldPos.x, cr.WorldPos.y), null);
    Map map = loc.GetMapByIndex(0);
    Entrance::CritterTransferToMapEntry(cr, map.Id, Tla::EntryHash(0));
}

// ~run se_talking_head Test 1 1 1

#endif

}
