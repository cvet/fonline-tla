{
    {
        ident LocId;
        hstring LocPid;
        int[] IndexMaps = {};
    }
}
//   "OnInit": null,
//   "OnShow":
{
    {
        {
            if (params !is null) {
                LocId = params["LocationId"];
                LocPid = hstring(params["LocationPid"]);
                IndexMaps = Stdlib::StrToIntArr(string(params["IndexMaps"]));
                string picName = MSG_LOCATION(STR_LOC_PIC(LocPid));
                SetBackgroundImage(picName);
            }
        }
    }
}
