namespace PatternSlayer
{

#if SERVER

/*
   Рукопашник/боец с холоднмы оружием

   PE_BETTER_CRITICALS
   PE_SILENT_DEATH
   PE_SILENT_RUNNING
   PE_SLAYER

   ---------------------------|-------------|-------------|-------------|-------------|
   Уровень         0          |  1          |  2          |  3          |  4          |
   ---------------------------|-------------|-------------|-------------|-------------|
   ХО/РБ           120..150   |  150..180   |  160..200   |  200..250   |  240..300   |
   Скрытность      150..200   |  200..240   |  220..260   |  220..290   |  250..300   |
   MeleeDmg        8          |  12         |  16         |  22         |  25         |
   HP              120        |  150        |  190        |  220        |  260        |
   Resist          30..50     |  40..55     |  40..60     |  50..60     |  50..80     |
   AP              10         |  12         |  16         |  20         |  22         |
   ---------------------------|-------------|-------------|-------------|-------------|
*/

// clang-format off

const int[] slayerStats_ =
{
//  MeleeMin,    MeleeMax,   SnMin,   SnMax,   MDmg,   HP,    ResMin,   ResMax, AP
    160,         190,        190,     220,     12,     220,   30,       40,     10,
    180,         200,        200,     240,     14,     250,   40,       55,     12,
    190,         220,        220,     260,     16,     290,   40,       60,     13,
    200,         250,        220,     290,     22,     320,   45,       60,     15,
    240,         300,        250,     300,     25,     360,   45,       80,     18
};

// clang-format on

const int LvlCount = 5;
const int ColumnsCount = 9; // Индекс первой колонки=0
int SlayerStatCell(int lvl, int column)
{
    return slayerStats_[(lvl < LvlCount ? lvl : 0) * ColumnsCount + (column < ColumnsCount ? column : 0)];
}
int SlayerMeleeSkill(int lvl)
{
    return Game.Random(SlayerStatCell(lvl, 0), SlayerStatCell(lvl, 1));
}
int SlayerSneakSkill(int lvl)
{
    return Game.Random(SlayerStatCell(lvl, 2), SlayerStatCell(lvl, 3));
}
int SlayerMeleeDamage(int lvl)
{
    return SlayerStatCell(lvl, 4);
}
int SlayerHitPoints(int lvl)
{
    return SlayerStatCell(lvl, 5);
}
int SlayerResistance(int lvl)
{
    return Game.Random(SlayerStatCell(lvl, 6), SlayerStatCell(lvl, 7));
}
int SlayerActionPoints(int lvl)
{
    return SlayerStatCell(lvl, 8);
}
const int ATTACK_DIST = 10;

void CritterInit(Critter cr, bool firstTime)
{
    pattern.SetEvents(cr);
}

class SlayerPattern : PatternCommon::CommonPattern
{
    // При начале любого плана нпц уходит в бег, если нет таймаута битвы
    // Также включает сник, если позволяет таймаут сника
    bool PlaneBegin(Critter cr, int planeId, int reason, Critter someCr, Item someItem)
    {
        NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(cr, planeId);
        if (plane == null) {
            return true;
        }

        SetRun(plane, cr);
        SetSneak(cr);

        if (plane.Type == NpcPlanes::AI_PLANE_ATTACK) {
            Game.StartTimeEvent(GameTime::SneakTimeout(cr) - Game.SynchronizedTime, SneakWhileAttack, cr.Id);
        }

        return true;
    }

    void SetSneak(Critter cr)
    {
        if (!Time::IsTimeoutActive(cr.TimeoutSneak) && !cr.InSneakMode) {
            cr.InSneakMode = true;
        }
    }

    void SetRun(NpcPlanes::NpcPlane plane, Critter cr)
    {
        if (!Time::IsTimeoutActive(cr.TimeoutBattle)) {
            plane.Run = true;
        }
        else {
            plane.Run = Settings.Movement.RunOnCombat;
        }
    }

    // Если позволяет таймаут, при выполнении любого плана слеер стремится уйти в сник
    bool PlaneRun(Critter cr, int planeId, int reason, any& result0, any& result1, any& result2)
    {
        NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(cr, planeId);
        if (plane == null) {
            return true;
        }

        SetRun(plane, cr);
        SetSneak(cr);
        return true;
    }

    void Idle(Critter cr)
    {
        SetSneak(cr);

        Map? map = cr.GetMap();
        if (map == null) {
            return;
        }

        Critter[] critters = map.GetCrittersInRadius(cr.Hex, ATTACK_DIST, CritterFindType::NonDeadPlayers);
        for (int i = 0; i < critters.length(); i++) {
            Critter player = critters[i];
            if (cr.IsSee(player)) {
                NpcPlanes::AddAttackPlane(cr, 0, player);
                break;
            }
        }
    }

    bool Attack(Critter cr, Critter target)
    {
        if (!target.ControlledByPlayer) {
            return false;
        }

        NpcPlanes::NpcPlane? plane = NpcPlanes::GetCurPlane(cr);
        if (plane != null) {
            SetRun(plane, cr);
        }

        if (target.IsKnockout()) {
            return false;
        }

        AbstractItem weapon = CritterItem::GetActive(cr);
        if (weapon.Type != ItemType::Weapon) {
            return false;
        }

        if (weapon.Weapon_Skill_0 != CritterProperty::SkillMeleeWeapons && weapon.Weapon_Skill_0 != CritterProperty::SkillUnarmed) {
            return false;
        }

        Item? weaponInHands = Tla::GetCritterHandItem(cr);
        if (weaponInHands == null) {
            return false;
        }

        ProtoItem ammo = Game.GetProtoItem(weaponInHands.AmmoPid);

        // Скопировано из основного обработчика
        cr.TimeoutAggressor = Game.SynchronizedTime + Time::Minutes(1);
        Combat::CombatAttack(cr, target, weapon, WeaponHelpers::MakeWeaponMode(0, HitLocations::LocationEyes), ammo);
        return true;
    }

    void SetEvents(Critter cr)
    {
        cr.OnAttack.Subscribe(SlayerAttack);
        cr.OnNpcPlaneRun.Subscribe(SlayerPlaneRun);
        cr.OnNpcPlaneBegin.Subscribe(SlayerPlaneBegin);
        cr.OnAttacked.Subscribe(SlayerAttacked);
        cr.StartTimeEvent(Time::Asap(), Time::Seconds(1), SlayerIdle);
        cr.OnDead.Subscribe(SlayerDead);
    }
}

#ifndef _NoBaseInstance
SlayerPattern pattern; // Для наследников нужно определить _NoBaseInstance
#endif

[[Event]]
void SlayerDead(Critter cr, Critter killer)
{
    pattern.Dead(cr, killer);
}

void SlayerInit(Critter cr, bool firstTime)
{
    CritterInit(cr, firstTime);
}

void SetSlayerStats(Critter cr, int lvl)
{
    lvl = Math::Clamp(lvl, 0, LvlCount - 1);
    if (lvl < 1) {
        return;
    }

    if (lvl > 2) {
        cr.PerkBetterCriticals = 1;
    }

    cr.PerkSilentDeath = 1;
    if (lvl > 2) {
        cr.PerkSlayer = 1;
    }

    cr.PerkSilentRunning = 1;

    cr.MeleeDamageBase = SlayerMeleeDamage(lvl);
    cr.StrengthBase = 10;
    cr.MaxLifeBase = SlayerHitPoints(lvl);
    cr.CurrentHp = cr.MaxLife;
    cr.ActionPointsBase = SlayerActionPoints(lvl);

    for (int i = 0; i < CritterPropertyGroup::ResistsBase.length(); i++) {
        if (CritterPropertyGroup::ResistsBase[i] != CritterProperty::EmpResistanceBase) {
            cr.SetAsInt(CritterPropertyGroup::ResistsBase[i], SlayerResistance(lvl));
        }
    }

    cr.SkillMeleeWeapons = SlayerMeleeSkill(lvl);
    cr.SkillUnarmed = SlayerMeleeSkill(lvl);
    cr.SkillSneak = SlayerSneakSkill(lvl);
}

// При начале любого плана нпц уходит в бег, если нет таймаута битвы
// Также включает сник, если позволяет таймаут сника
[[Event]]
EventResult SlayerPlaneBegin(Critter cr, int planeId, int reason, Critter someCr, Item someItem)
{
    return (pattern.PlaneBegin(cr, planeId, reason, someCr, someItem)) ? EventResult::StopChain : EventResult::ContinueChain;
}

// регулярные попытки уйти в сник
[[TimeEvent]]
void SneakWhileAttack(any value)
{
    Critter? cr = Game.GetCritter(value);
    if (cr == null) {
        return;
    }

    pattern.SetSneak(cr);
    if (NpcPlanes::IsCurPlane(cr, NpcPlanes::AI_PLANE_ATTACK)) {
        Game.StartTimeEvent(GameTime::SneakTimeout(cr) - Game.SynchronizedTime, SneakWhileAttack, value);
    }
}

// Если позволяет таймаут, при выполнении любого плана слеер стремится уйти в сник
[[Event]]
EventResult SlayerPlaneRun(Critter cr, int planeId, int reason, any& result0, any& result1, any& result2)
{
    return (pattern.PlaneRun(cr, planeId, reason, result0, result1, result2)) ? EventResult::ContinueChain : EventResult::StopChain;
}

// Снайпер атакован
[[Event]]
EventResult SlayerAttacked(Critter sniper, Critter attacker)
{
    return (pattern.Attacked(sniper, attacker)) ? EventResult::ContinueChain : EventResult::StopChain;
}

[[TimeEvent]]
void SlayerIdle(Critter cr)
{
    pattern.Idle(cr);
}

[[Event]]
EventResult SlayerAttack(Critter cr, Critter target, Item weapon, int weaponMode, ProtoItem ammo)
{
    return (pattern.Attack(cr, target)) ? EventResult::StopChain : EventResult::ContinueChain;
}

void testSlayer(Critter cr, int lvl, int team, int bag)
{
    // ~run PatternSlayer testSlayer 0 0 0
    // ~run test SetStat 1 72 10000
    int[] props = {CritterProperty::BagId, bag, CritterProperty::TeamId, team};
    Map? map = cr.GetMap();
    if (map == null) {
        return;
    }

    Critter npc = map.AddCritter(Content::Critter::VaultCityPatrolMale, mpos(cr.Hex.x - 5, cr.Hex.y - 5), 0, Tla::GetCritPropsDict(props));
    npc.SetupScript(CritterInit);
    SetSlayerStats(npc, lvl);
}

#endif

}
