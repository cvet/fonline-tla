int TownrepRatioNameTextId(int val)
{
    return 6500 + ((val) >= Settings.Reputation.ReputationLoved ?
                       0 :
                       ((val) >= Settings.Reputation.ReputationLiked ?
                            1 :
                            ((val) >= Settings.Reputation.ReputationAccepted ?
                                 2 :
                                 ((val) >= Settings.Reputation.ReputationNeutral ?
                                      3 :
                                      ((val) >= Settings.Reputation.ReputationAntipathy ? 4 : ((val) >= Settings.Reputation.ReputationHated ? 5 : 6))))));
}
int TownrepRatioDescTextId(int val)
{
    return 6550 + ((val) >= Settings.Reputation.ReputationLoved ?
                       0 :
                       ((val) >= Settings.Reputation.ReputationLiked ?
                            1 :
                            ((val) >= Settings.Reputation.ReputationAccepted ?
                                 2 :
                                 ((val) >= Settings.Reputation.ReputationNeutral ?
                                      3 :
                                      ((val) >= Settings.Reputation.ReputationAntipathy ? 4 : ((val) >= Settings.Reputation.ReputationHated ? 5 : 6))))));
}

