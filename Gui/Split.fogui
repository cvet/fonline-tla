{
    {
        {
            int result = 0;
            int count = 0;
            if (text.tryToInt(result)) {
                count = SplitCount * 10;
                count += result;
                if (count > 99999) {
                    count = count % 100000;
                }
                SplitCount = count;
            }
        }
    }
}
