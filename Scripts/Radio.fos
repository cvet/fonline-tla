namespace Radio
{

///@ Setting Common int32 Radio.RadioBroadcastZones1
///@ Setting Common int32 Radio.RadioBroadcastZones2

///@ Enum RadioBroadcastType World = 0
///@ Enum RadioBroadcastType Zone // Distance set in Radio.BroadcastZones
///@ Enum RadioBroadcastType Location
///@ Enum RadioBroadcastType Map

///@ Property Item Common bool Radio Component
///@ Property Item Common int32 Radio.Channel Mutable OwnerSync Persistent
///@ Property Item Common bool Radio.DisableSend Mutable OwnerSync Persistent
///@ Property Item Common bool Radio.DisableRecv Mutable OwnerSync Persistent
///@ Property Item Common RadioBroadcastType Radio.Broadcast Mutable OwnerSync Persistent
///@ Property Item Common int8 Radio.BroadcastZones Mutable OwnerSync Persistent
///@ Property Item Common bool Radio.FixedChannel Mutable OwnerSync Persistent
///@ Property Item Common bool Radio.FixedBroadcast Mutable OwnerSync Persistent

///@ RemoteCall Client ShowEditScreen(ident itemId)
///@ RemoteCall Server SendRadioMessage(string text)
///@ RemoteCall Server ChangeActivity(ident radioId, bool isSend, bool enable)
///@ RemoteCall Server ChangeChannel(ident radioId, int32 radioChannel)
///@ RemoteCall Server ChangeBroadcast(ident radioId, RadioBroadcastType broadcast, int32 broadcastZones)

#if SERVER

Item[] RadioItems = {};

[[ModuleInit]]
void InitRadio()
{
    // Todo: use OnCritterUseItem event instead direct call of EditRadioSettings
    // Game.OnCritterUseItem.Subscribe(OnCritterUseItem);
    Game.OnItemInit.Subscribe(OnItemInit);
    Game.OnItemFinish.Subscribe(OnItemFinish);
}

[[Event]]
void OnItemInit(Item item, bool firstTime)
{
    if (item.HasRadio) {
        RadioItems.insertLast(item);
    }
}

[[Event]]
void OnItemFinish(Item item)
{
    if (item.HasRadio) {
        //RadioItems.remove(item);
        for (int i = 0; i < RadioItems.length(); i++) {
            if (RadioItems[i].Id == item.Id) {
                RadioItems.removeAt(i);
            }
        }
    }
}

void AddRadioSyncEntity(Entity[] & entities, Entity entity)
{
    if (entity.IsDestroyed) {
        return;
    }

    for (int i = 0; i < entities.length(); i++) {
        if (entities[i] is entity) {
            return;
        }
    }

    entities.insertLast(entity);
}

[[Async]]
bool LockRadioMessageEntities(Entity[] baseEntities, Critter? sourceCr)
{
    Entity[] entities = {};
    for (int i = 0; i < baseEntities.length(); i++) {
        AddRadioSyncEntity(entities, baseEntities[i]);
    }

    if (sourceCr != null) {
        AddRadioSyncEntity(entities, sourceCr);
    }

    for (int i = 0; i < RadioItems.length(); i++) {
        AddRadioSyncEntity(entities, RadioItems[i]);
    }

    if (!Sync::Lock(entities)) {
        return false;
    }

    if (sourceCr != null) {
        Map? sourceMap = sourceCr.GetMap();
        if (sourceMap != null) {
            AddRadioSyncEntity(entities, sourceMap);
        }
    }

    for (int i = 0; i < RadioItems.length(); i++) {
        Item item = RadioItems[i];
        if (item.IsDestroyed) {
            continue;
        }

        Critter? itemCr = item.GetCritter();
        if (itemCr != null) {
            AddRadioSyncEntity(entities, itemCr);
        }

        Map? itemMap = item.GetMap();
        if (itemMap != null) {
            AddRadioSyncEntity(entities, itemMap);
        }

        mpos hex;
        Map? posMap = item.GetMapPosition(hex);
        if (posMap != null) {
            AddRadioSyncEntity(entities, posMap);
        }
    }

    if (!Sync::Lock(entities)) {
        return false;
    }

    if (sourceCr != null) {
        Map? sourceMap = sourceCr.GetMap();
        if (sourceMap != null) {
            AddRadioSyncEntity(entities, sourceMap.GetLocation());
        }
    }

    for (int i = 0; i < RadioItems.length(); i++) {
        Item item = RadioItems[i];
        if (item.IsDestroyed) {
            continue;
        }

        Critter? itemCr = item.GetCritter();
        if (itemCr != null) {
            Map? crMap = itemCr.GetMap();
            if (crMap != null) {
                AddRadioSyncEntity(entities, crMap);
                AddRadioSyncEntity(entities, crMap.GetLocation());
            }
        }

        Map? itemMap = item.GetMap();
        if (itemMap != null) {
            AddRadioSyncEntity(entities, itemMap.GetLocation());
        }

        mpos hex;
        Map? posMap = item.GetMapPosition(hex);
        if (posMap != null) {
            AddRadioSyncEntity(entities, posMap.GetLocation());
        }
    }

    return Sync::Lock(entities);
}

void EditRadioSettings(Critter cr, Item item)
{
    cr.PlayerClientCall.ShowEditScreen(item.Id);
}

// [[Event]]
void OnCritterUseItem(Critter cr, Item item)
{
    if (item.HasRadio) {
        cr.PlayerClientCall.ShowEditScreen(item.Id);
    }
}

[[ServerRemoteCall]] [[Async]]
void SendRadioMessage(Player player, string text)
{
    Critter? cr = player.GetControlledCritter();
    if (cr == null) {
        return;
    }

    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    Item[] items = cr.GetItems();
    bool hasActiveRadio = false;

    for (int i = 0; i < items.length(); i++) {
        if (items[i].HasRadio && !items[i].Radio.DisableSend) {
            hasActiveRadio = true;
            break;
        }
    }

    verify(hasActiveRadio, "Assertion failed");

    text = text.trim();
    verify(!text.isEmpty(), "Assertion failed");

    SendRadioMessage(cr, text);
}

[[ServerRemoteCall]]
void ChangeActivity(Player player, ident radioId, bool isSend, bool disable)
{
    Critter? cr = player.GetControlledCritter();
    if (cr == null) {
        return;
    }

    Item? item = cr.GetItem(radioId);

    verify(item != null, "Assertion failed");
    verify(item.HasRadio, "Assertion failed");

    if (isSend) {
        item.Radio.DisableSend = disable;
    }
    else {
        item.Radio.DisableRecv = disable;
    }
}

[[ServerRemoteCall]]
void ChangeChannel(Player player, ident radioId, int radioChannel)
{
    Critter? cr = player.GetControlledCritter();
    if (cr == null) {
        return;
    }

    Item? item = cr.GetItem(radioId);

    verify(item != null, "Assertion failed");
    verify(item.HasRadio, "Assertion failed");
    verify(!item.Radio.FixedChannel, "Assertion failed");
    verify(radioChannel >= 0 && radioChannel <= 0xFFFF, "Assertion failed");

    item.Radio.Channel = radioChannel;
}

[[ServerRemoteCall]]
void ChangeBroadcast(Player player, ident radioId, RadioBroadcastType broadcast, int broadcastZones)
{
    Critter? cr = player.GetControlledCritter();
    if (cr == null) {
        return;
    }

    Item? item = cr.GetItem(radioId);

    verify(item != null, "Assertion failed");
    verify(item.HasRadio, "Assertion failed");
    verify(!item.Radio.FixedBroadcast, "Assertion failed");

    item.Radio.Broadcast = broadcast;
    item.Radio.BroadcastZones = broadcastZones == 1 ? Settings.Radio.RadioBroadcastZones1 : Settings.Radio.RadioBroadcastZones2;
}

[[Async]]
void SendRadioMessage(Critter cr, string text)
{
    Entity[] syncCover = Sync::Snapshot();
    if (!LockRadioMessageEntities(syncCover, cr)) {
        Sync::Restore(syncCover);
        return;
    }

    Messaging::SayWhisper(cr, text);

    Item[] items = cr.GetItems();

    for (int i = 0; i < items.length(); i++) {
        Item sendItem = items[i];

        if (sendItem.HasRadio && !sendItem.Radio.DisableSend) {
            SendRadioMessage(sendItem, text);
        }
    }

    Sync::Restore(syncCover);
}

void SendRadioMessage(Item sendItem, string text)
{
    Map? sendMap = sendItem.GetMap();
    Critter? sendCr = sendItem.GetCritter();
    ipos sendWorldPos;
    if (sendCr != null) {
        sendWorldPos = sendCr.WorldPos;
    }
    else {
        if (sendMap == null) {
            return;
        }

        sendWorldPos = sendMap.GetLocation().WorldPos;
    }

    RadioBroadcastType sendBroadcast = sendItem.Radio.Broadcast;

    for (int i = 0; i < RadioItems.length(); i++) {
        Item recvItem = RadioItems[i];

        if (recvItem.Radio.DisableRecv) {
            continue;
        }

        if (sendItem.Id == recvItem.Id && sendCr == null) {
            continue;
        }

        if (recvItem.Radio.Channel != sendItem.Radio.Channel) {
            continue;
        }

        RadioBroadcastType broadcast;
        int broadcastZones = 0;

        if (sendBroadcast == RadioBroadcastType::Map || recvItem.Radio.Broadcast == RadioBroadcastType::Map) {
            broadcast = RadioBroadcastType::Map;
        }
        else if (sendBroadcast == RadioBroadcastType::Location || recvItem.Radio.Broadcast == RadioBroadcastType::Location) {
            broadcast = RadioBroadcastType::Location;
        }
        else if (sendBroadcast == RadioBroadcastType::Zone || recvItem.Radio.Broadcast == RadioBroadcastType::Zone) {
            broadcast = RadioBroadcastType::Zone;
            broadcastZones = Math::Min(sendItem.Radio.BroadcastZones, recvItem.Radio.BroadcastZones);
        }
        else if (sendBroadcast == RadioBroadcastType::World || recvItem.Radio.Broadcast == RadioBroadcastType::World) {
            broadcast = RadioBroadcastType::World;
        }

        mpos hex;
        Map? recvMap = recvItem.GetMapPosition(hex);
        Critter? recvCr = recvItem.GetCritter();
        ipos recvWorldPos;
        if (recvCr != null) {
            recvWorldPos = recvCr.WorldPos;
        }
        else {
            if (recvMap == null) {
                continue;
            }

            recvWorldPos = recvMap.GetLocation().WorldPos;
        }

        if (broadcast == RadioBroadcastType::Zone) {
            if (Math::Distance(sendWorldPos, recvWorldPos) > broadcastZones * Settings.GlobalMap.GlobalMapZoneLength) {
                continue;
            }
        }
        else if (broadcast == RadioBroadcastType::Location) {
            if (sendMap == null || recvMap == null || sendMap.GetLocation().Id != recvMap.GetLocation().Id) {
                continue;
            }
        }
        else if (broadcast == RadioBroadcastType::Map) {
            if (sendMap == null || recvMap == null || sendMap.Id != recvMap.Id) {
                continue;
            }
        }

        if (recvCr != null) {
            Messaging::Info(recvCr, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_MBRADIO)), "|channel:" + recvItem.Radio.Channel + "|text:" + text);
        }
        else {
            MapText::AddText(recvMap, hex, Color::White, text);
        }
    }
}

void SendChannelRadioMessage(int channel, string text)
{
    any[] values = {channel, text};
    Game.StartTimeEvent(Time::Asap(), SendChannelRadioMessageText, values);
}

[[TimeEvent]] [[Async]]
void SendChannelRadioMessageText(any[] values)
{
    int channel = int(values[0]);
    string text = string(values[1]);
    Entity[] syncCover = Sync::Snapshot();
    Critter? sourceCr = null;
    if (!LockRadioMessageEntities(syncCover, sourceCr)) {
        Sync::Restore(syncCover);
        return;
    }

    SendChannelRadioMessageLocked(channel, text);
    Sync::Restore(syncCover);
}

void SendChannelRadioMessageLocked(int channel, string text)
{
    for (int i = 0; i < RadioItems.length(); i++) {
        Item recvItem = RadioItems[i];

        if (recvItem.Radio.DisableRecv) {
            continue;
        }

        if (int(recvItem.Radio.Channel) != channel) {
            continue;
        }

        Critter? recvCr = recvItem.GetCritter();

        if (recvCr != null) {
            Messaging::Info(recvCr, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_MBRADIO)), "|channel:" + channel + "|text:" + text);
        }
        else {
            mpos hex;
            Map? recvMap = recvItem.GetMapPosition(hex);
            MapText::AddText(recvMap, hex, Color::White, text);
        }
    }
}

void SendChannelRadioMessage(int channel, TextPackKey textKey, string textArgs = "")
{
    any[] values = {channel, textKey, textArgs};
    Game.StartTimeEvent(Time::Asap(), SendChannelRadioMessageTextKey, values);
}

[[TimeEvent]] [[Async]]
void SendChannelRadioMessageTextKey(any[] values)
{
    int channel = int(values[0]);
    TextPackKey textKey = TextPackKey(values[1]);
    string textArgs = string(values[2]);
    Entity[] syncCover = Sync::Snapshot();
    Critter? sourceCr = null;
    if (!LockRadioMessageEntities(syncCover, sourceCr)) {
        Sync::Restore(syncCover);
        return;
    }

    SendChannelRadioMessageLocked(channel, textKey, textArgs);
    Sync::Restore(syncCover);
}

void SendChannelRadioMessageLocked(int channel, TextPackKey textKey, string textArgs = "")
{
    for (int i = 0; i < RadioItems.length(); i++) {
        Item recvItem = RadioItems[i];

        if (recvItem.Radio.DisableRecv) {
            continue;
        }

        if (int(recvItem.Radio.Channel) != channel) {
            continue;
        }

        Critter? recvCr = recvItem.GetCritter();

        if (recvCr != null) {
            MapText::AddText(recvCr, Color::White, textKey);
        }
        else {
            mpos hex;
            Map? recvMap = recvItem.GetMapPosition(hex);
            if (recvMap == null) {
                continue;
            }

            MapText::AddText(recvMap, hex, Color::White, textKey, textArgs);
        }
    }
}

#endif

#if CLIENT

void SendRadioMessage(string text)
{
    bool hasActiveRadio = false;
    Item[] items = Chosen.GetItems();

    for (int i = 0; i < items.length(); i++) {
        if (items[i].HasRadio && !items[i].Radio.DisableSend) {
            hasActiveRadio = true;
            break;
        }
    }

    if (hasActiveRadio) {
        CurPlayer.ServerCall.SendRadioMessage(text);
    }
    else {
        Messaging::Info(TextPackKey(TextPackName::Game, "" + (MsgStr::Get("RadioCantSendMessage"))));
    }
}

Item? GetItemRadio(ident radioId)
{
    Item? item = Chosen.GetItem(radioId);

    if (item == null) {
        return null;
    }

    if (!item.HasRadio) {
        return null;
    }

    return item;
}

bool GetRadioActivity(ident radioId, bool isSend)
{
    Item? item = GetItemRadio(radioId);
    if (item == null) {
        return false;
    }

    bool disableFlag = isSend ? item.Radio.DisableSend : item.Radio.DisableRecv;
    return disableFlag;
}

bool ChangeRadioActivity(ident radioId, bool isSend)
{
    Item? item = GetItemRadio(radioId);
    if (item == null) {
        return false;
    }

    bool disableFlag = isSend ? item.Radio.DisableSend : item.Radio.DisableRecv;
    int beginStr = isSend ? MsgStr::Get("RadioBroadcastSendBegin") : MsgStr::Get("RadioBroadcastRecvBegin");
    int endStr = isSend ? MsgStr::Get("RadioBroadcastSendEnd") : MsgStr::Get("RadioBroadcastRecvEnd");

    disableFlag = !disableFlag;
    CurPlayer.ServerCall.ChangeActivity(radioId, isSend, disableFlag);

    if (!disableFlag) {
        Messaging::Info(TextPackKey(TextPackName::Game, "" + (beginStr)));
    }
    else {
        Messaging::Info(TextPackKey(TextPackName::Game, "" + (endStr)));
    }

    return disableFlag;
}

void ChangeRadioChannel(ident radioId, int channel)
{
    Item? item = GetItemRadio(radioId);
    if (item == null) {
        return;
    }

    verify(!item.Radio.FixedChannel, "Assertion failed");

    if (int(item.Radio.Channel) == channel) {
        return;
    }

    CurPlayer.ServerCall.ChangeChannel(radioId, channel);
    Messaging::Info(TextPackKey(TextPackName::Game, "" + (MsgStr::Get("RadioChannelChanged"))));
}

void ChangeRadioBroadcastType(ident radioId, int type)
{
    Item? item = GetItemRadio(radioId);
    if (item == null) {
        return;
    }

    if (item.Radio.FixedBroadcast) {
        Messaging::Info(TextPackKey(TextPackName::Game, "" + (MsgStr::Get("RadioCantShiftBcSend"))));
        return;
    }

    RadioBroadcastType newBroadcast = RadioBroadcastType::World;
    int newBroadcastZones = 0;

    if (type == 1) {
        newBroadcast = RadioBroadcastType::Zone;
        newBroadcastZones = 1;
    }
    else if (type == 2) {
        newBroadcast = RadioBroadcastType::Zone;
        newBroadcastZones = 2;
    }
    else if (type == 3) {
        newBroadcast = RadioBroadcastType::Location;
    }
    else if (type == 4) {
        newBroadcast = RadioBroadcastType::Map;
    }

    if (item.Radio.Broadcast == newBroadcast) {
        if (item.Radio.Broadcast == RadioBroadcastType::Zone) {
            if (item.Radio.BroadcastZones == (newBroadcastZones == 1 ? Settings.Radio.RadioBroadcastZones1 : Settings.Radio.RadioBroadcastZones2)) {
                return;
            }
        }
        else {
            return;
        }
    }

    CurPlayer.ServerCall.ChangeBroadcast(radioId, newBroadcast, newBroadcastZones);
    Messaging::Info(TextPackKey(TextPackName::Game, "" + (MsgStr::Get("RadioBroadcastSendChange"))));
}

[[ClientRemoteCall]]
void ShowEditScreen(ident itemId)
{
    Item? item = Chosen.GetItem(itemId);

    if (item != null) {
        dict<string, any> params = {{"ItemId", item.Id}};
        Gui::ShowScreen(GuiScreen::Radio, params);
    }
}
#endif

}
