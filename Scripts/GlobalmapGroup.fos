// Global map
int GlobalMapMaxX()
{
    return Settings.GlobalMap.GlobalMapWidth * Settings.GlobalMap.GlobalMapZoneLength;
}
int GlobalMapMaxY()
{
    return Settings.GlobalMap.GlobalMapHeight * Settings.GlobalMap.GlobalMapZoneLength;
}
int GlobalMapZoneLength()
{
    return Settings.GlobalMap.GlobalMapZoneLength;
} // Can be multiple to GlobalMapMaxX and GlobalMapMaxY

const int GM_MAX_GROUP_COUNT = 6;
const timespan GM_ANSWER_WAIT_TIME = Time::Seconds(20);
const timespan GM_LIGHT_TIME = Time::Seconds(5);
int GlobalMapZone(int x)
{
    return (x) / GlobalMapZoneLength();
}
const timespan GM_ENTRANCES_SEND_TIME = Time::Seconds(5);
const timespan GM_TRACE_TIME = Time::Seconds(1);

// Follow
const int FOLLOW_DIST = 10;
const int FOLLOW_FORCE = 1;
const int FOLLOW_PREP = 2;

// Global process types
const int GLOBAL_PROCESS_MOVE = 0;
const int GLOBAL_PROCESS_ENTER = 1;
const int GLOBAL_PROCESS_START_FAST = 2;
const int GLOBAL_PROCESS_START = 3;
const int GLOBAL_PROCESS_SET_MOVE = 4;
const int GLOBAL_PROCESS_STOPPED = 5;
const int GLOBAL_PROCESS_NPC_IDLE = 6;
