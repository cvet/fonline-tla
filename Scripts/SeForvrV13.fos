namespace SeForvrV13 // Sort 2
{

#if SERVER

// Autor: Cracker
// Guardian of Forever special encounter scripts

const int STR_COMPUTER_MESSAGE = 70000;
const int STR_COMPUTER_BEEP = 70001;
const int MESSAGE_HEX_X = 74;
const int MESSAGE_HEX_Y = 127;
const ucolor MESSAGE_COLOR = ucolor(0xFF, 0, 0xFF);

void _TranInit(Item item, bool firstTime)
{
    item.OnCritterWalk.Subscribe(_Transit);
}

[[ItemTrigger]]
void t_Zizz(Critter cr, StaticItem trigger, bool entered, mdir dir)
{
    Game.StartTimeEvent(ZERO_TIMESPAN, Zizz, cr.MapId);
}

[[TimeEvent]]
void Zizz(any value)
{
    Map? map = Game.GetMap(ident(value));
    if (map == null) {
        return;
    }

    MapText::AddText(map, mpos(MESSAGE_HEX_X, MESSAGE_HEX_Y), MESSAGE_COLOR, TextPackKey(TextPackName::Text, "" + (STR_COMPUTER_BEEP)));
    Game.StartTimeEvent(Time::GameMinutes(1), Zizz, value);
}

[[Event]]
void _Transit(Item item, Critter cr, bool entered, mdir dir)
{
    if (not entered || not cr.ControlledByPlayer) {
        return;
    }

    Map? curMap = cr.GetMap();
    if (curMap == null) {
        return;
    }

    Map map = curMap.GetLocation().GetMapByIndex(1);
    Entrance::CritterTransferToMapEntry(cr, map.Id, Tla::EntryHash(0));
    Game.DestroyItem(item);
}

[[ItemStatic]]
bool s_Terminal(Critter cr, StaticItem terminal, Item? item, any skill)
{
    if (CritterProperty(int(skill)) == CritterProperty::SpecialSkillPickOnGround && item == null) {
        Map? curMap = cr.GetMap();
        if (curMap == null) {
            return false;
        }

        Map map = curMap.GetLocation().GetMapByIndex(0);
        Entrance::CritterTransferToMapEntry(cr, map.Id, Tla::EntryHash(0));
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_COMPUTER_MESSAGE)));
        cr.Experience += 1000;
        return true;
    }

    return false;
}

void Test(Critter cr, int mapIndex, int, int)
{
    Location loc = Location::CreateLocation(Content::Location::guardian_of_forever, ipos(cr.WorldPos.x, cr.WorldPos.y), null);
    Map map = loc.GetMapByIndex(mapIndex);
    Entrance::CritterTransferToMapEntry(cr, map.Id, Tla::EntryHash(0));
}

#endif

}
