{
    {
        {
            auto critters = cast<GlobalGroupGrid>(Parent).CrittersIds;
            auto critter = Game.GetCritter(critters[cellIndex]);
            if (critter != null) {
                CritterId = critter.Id;
                FindText("CritterName").Text = critter.Name;
                FindText("CritterCond").Text = (critter.IsOffline() ? "offline" : "online");
            }
        }
    }
}
