// DappoLostCRobot — квест 'Потерянный караван Даппо'.
// Ключевые обязанности: ИИ робота-патруля, копирование записи на голодиск, мёртвые караванщики, диалоговые demand/result по наличию голодиска.
// Сторона: SERVER. Связи: NpcPlanes, Entrance, Messaging, CritterState, Tla, Content.
namespace DappoLostCRobot
{

#if SERVER

// Encounter-моб квеста 'Потерянный караван Даппо' — боевой робот.

///@ Property Critter Server uint8 NcrBusterLostCStatus Mutable Persistent Max = 4
///@ Property Critter Server uint8 QDappoLostRobotHexNum Mutable Persistent

const int ENT_HEX_NUM1 = 17; // первый гекс маршрута патрулирования
const int ENT_HEX_NUM2 = 18; // второй гекс маршрута патрулирования
const int ENT_HEX_NUM3 = 19; // третий гекс маршрута патрулирования
const int ENT_HEX_NUM4 = 20; // четвертый гекс маршрута патрулирования
const int HOLO_MSG_ID = 51;  // номер текста голодиска

const int STR_NUM_WRONG_ITEM = 2800;
const int STR_NUM_RIGHT_ITEM = 2801;
const int STR_NUM_ENEMY_SPOT = 2802;
const int STR_NUM_ENEMY_KILL = 2803;
const int STR_NUM_PT_REACHED = 2804;
const int STR_NUM_NEXT_POINT = 2805;
const int STR_NUM_MAP_ENTER = 2806;
const int STR_NUM_MAP_LEAVE = 2807;
/*
   {2800}{}{Бесполезно. Не работает. Нужно придумать что-то еще.}
   {2801}{}{Ухты! У меня получилось скопировать запись с видеокамеры робота.}
   {2802}{}{Цель обнаружена. Атака.}
   {2803}{}{Цель уничтожена.}
   {2804}{}{Контрольная точка достигнута.}
   {2805}{}{Продолжаю патрулирование.}
   {2806}{}{От каравана Даппо мало что осталось. Пресловутым ..
   {2807}{}{Очевидно, что робот случайно активировался,...
*/
// Инициализация робота: подписки на события восприятия/атаки и запуск патрулирования.
void RoboInit(Critter robo, bool firstTime)
{
    // robo.OnNpcPlaneEnd.Subscribe(NpcPlaneEnd);
    // робот увидел кого-то
    robo.OnCritterAppeared.Subscribe(RoboShowCritter);
    // заскучал
    robo.StartTimeEvent(Time::Asap(), Time::Seconds(1), RoboCritterIdle);
    // кто-то что-то применил в пределах видимости
    robo.OnSomeUseItemOnMe.Subscribe(RoboSmthUseItemOnMe);
    // робот кого-то убил
    robo.OnSomeCritterDead.Subscribe(RoboSmthDead);
    // начало патрулирования
    robo.QDappoLostRobotHexNum = ENT_HEX_NUM4;
    // если робота убьют, реплицироваться он не должен
    robo.ReplicationTime = -1;
    // робот пошёл патрулировать
    RoboPatrolNextMove(robo);
}

// Применение предмета на робота: запись копируется на голодиск только когда робот мёртв и предмет — голодиск.
[[Event]]
void RoboSmthUseItemOnMe(Critter robo, Critter whoUse, Item item, int param)
{
    if (robo.CurrentHp > 0) {
        return;
    }

    if (item.ProtoId != Content::Item::holodisk) {
        Messaging::SayOnHead(whoUse, TextPackKey(TextPackName::Text, "" + (STR_NUM_WRONG_ITEM))); // "Бесполезно. Не работает. Нужно придумать что-то ещё."
        return;
    }

    Messaging::SayOnHead(whoUse, TextPackKey(TextPackName::Text, "" + (STR_NUM_RIGHT_ITEM))); // "Получилось скопировать запись с видеокамеры робота."
    item.HolodiskNum = HOLO_MSG_ID;

    whoUse.NcrBusterLostCStatus = 2;
}

// Шаг патрулирования: робот ходит по кругу из 4 контрольных точек.
void RoboPatrolNextMove(Critter robo)
{
    mpos hex;
    // координаты следующего гекса маршрута (гексы заданы в маппере)
    Entrance::GetNearEntry(robo.GetMap(), robo.QDappoLostRobotHexNum, hex);

    // отправляем робота на следующий пункт маршрута
    NpcPlanes::AddWalkPlane(robo, 2, hex, HDIR_Random, false, Game.Random(0, 1));

    // переходим к следующей точке: после последней замыкаемся на первую
    if (robo.QDappoLostRobotHexNum == ENT_HEX_NUM4) {
        robo.QDappoLostRobotHexNum = ENT_HEX_NUM1;
    }
    else {
        robo.QDappoLostRobotHexNum += 1;
    }
}

// Робот заметил кого-то (showCrit, как правило игрок) — бросаем все атакующие планы и атакуем цель.
[[Event]]
void RoboShowCritter(Critter robo, Critter showCrit)
{
    Messaging::SayOnHead(robo, TextPackKey(TextPackName::Text, "" + (STR_NUM_ENEMY_SPOT))); // "Цель обнаружена. Атака."

    Tla::EraseNpcAllAttackPlanes(robo);
    NpcPlanes::AddAttackPlane(robo, 0, showCrit.Id);
}

// Робот убил кого-то рядом — реплика об уничтожении цели.
[[Event]]
void RoboSmthDead(Critter robo, Critter fromCrit, Critter killer)
{
    Messaging::SayOnHead(robo, TextPackKey(TextPackName::Text, "" + (STR_NUM_ENEMY_KILL))); // "Цель уничтожена."
}

// Робот достиг контрольной точки — пауза на 3 игровых минуты перед движением к следующей.
[[TimeEvent]] [[Async]]
void RoboCritterIdle(Critter robo)
{
    if (!Sync::LockCritterWithMap(robo)) {
        return;
    }

    Messaging::SayOnHead(robo, TextPackKey(TextPackName::Text, "" + (STR_NUM_PT_REACHED))); // "Контрольная точка достигнута."
    // робот останавливается на каждой контрольной точке на 3 игровых минуты
    NpcPlanes::AddMiscPlane(robo, 2, Game.SynchronizedTime + Time::GameMinutes(3), DappoLostCRobot::PatrolMoveNext);
}

// Завершение паузы на контрольной точке — продолжаем патрулирование к следующему пункту.
void PatrolMoveNext(Critter robo)
{
    Messaging::SayOnHead(robo, TextPackKey(TextPackName::Text, "" + (STR_NUM_NEXT_POINT))); // "Продолжаю патрулирование."
    // после передышки робот снова идёт на следующую контрольную точку
    RoboPatrolNextMove(robo);
}

// Мёртвые караванщики.

// Инициализация караванщиков: гарантируем мёртвое состояние и навешиваем диалог по телу.
void DeadMenInit(Critter npc, bool firstTime)
{
    // караванщики должны быть мертвы
    if (not npc.IsDead()) {
        CritterState::ToDead(npc, CritterActionAnim::DeadBurst, null);
    }

    npc.ReplicationTime = -1;
    npc.DialogId = Content::Dialog::all_q_dappo_deadmen;
}

// Работа с голодиском в диалогах.

// Удаление голодиска с нужной записью из инвентаря игрока. Если такого голодиска нет — ничего не происходит.
// val — номер записи голодиска в FOHOLO.MSG.
[[DialogResult]]
void RemoveHolodisk(Critter player, Critter npc, any val)
{
    Item[] items = player.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
    // у игрока может быть несколько разных голодисков — ищем именно с нужной записью
    for (int i = 0; i < items.length(); i++) {
        if (ItemIsHolodisk(items[i].ProtoId)) {
            // приводим val к int, чтобы не было warning'а несоответствия типов
            if (items[i].HolodiskNum == int(val)) {
                Game.DestroyItem(items[i], 1);
                return;
            }
        }
    }
}

// Все прото-id предметов, считающихся голодиском (для проверки типа предмета в инвентаре).
hstring[] HolodiskPids = {Content::Item::holodisk,
                          Content::Item::brotherhood_tape,
                          Content::Item::disk_fev,
                          Content::Item::disk_security,
                          Content::Item::disk_alpha_experiment,
                          Content::Item::disk_alpha_experiment,
                          Content::Item::disk_vrees_experiment,
                          Content::Item::disk_mutant_transmissions,
                          Content::Item::disk_brotherhood_history,
                          Content::Item::disk_maxson_history,
                          Content::Item::disk_maxson_journal,
                          Content::Item::disk_vault_records,
                          Content::Item::disk_military_base_sec_code,
                          Content::Item::disk_regulator_transmissions,
                          Content::Item::holodisk_fake_v13,
                          Content::Item::gecko_data_disk,
                          Content::Item::reactor_data_disk,
                          Content::Item::lynette_holo,
                          Content::Item::westin_holo,
                          Content::Item::westin_holo,
                          Content::Item::spy_holo,
                          Content::Item::bishops_holodisk,
                          Content::Item::enclave_holodisk_5,
                          Content::Item::enclave_holodisk_1,
                          Content::Item::enclave_holodisk_2,
                          Content::Item::enclave_holodisk_3,
                          Content::Item::enclave_holodisk_4,
                          Content::Item::evacuation_holodisk,
                          Content::Item::experiment_holodisk,
                          Content::Item::medical_holodisk,
                          Content::Item::password_holodisk,
                          Content::Item::elron_member_holo,
                          Content::Item::broadcast_holodisk,
                          Content::Item::sierra_mission_holodisk,
                          Content::Item::ncr_history_holodisk,
                          Content::Item::elron_teach_holo};

// Является ли предмет с данным прото-id голодиском.
bool ItemIsHolodisk(hstring pid)
{
    for (int i = 0, l = HolodiskPids.length(); i < l; i++) {
        if (pid == HolodiskPids[i]) {
            return true;
        }
    }

    return false;
}

// Есть ли у игрока в инвентаре голодиск с нужной записью.
// Подходит любой голодиск, важна именно запись. Для квеста 'Потерянный караван Даппо' val = 51.
// val — номер записи голодиска в FOHOLO.MSG.
bool HasHolodiskImpl(Critter player, Critter npc, int val)
{
    // breadcrumb прежнего жёсткого значения записи: val = HOLO_MSG_ID;
    Item[] items = player.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
    // у игрока может быть несколько разных голодисков — ищем именно с нужной записью
    for (int i = 0; i < items.length(); i++) {
        if (ItemIsHolodisk(items[i].ProtoId)) {
            // приводим val к int, чтобы не было warning'а несоответствия типов
            if (items[i].HolodiskNum == int(val)) {
                return true;
            }
        }
    }

    // нужный голодиск не найден (или голодисков нет вовсе)
    return false;
}

// Диалоговый demand: у игрока есть нужный голодиск.
[[DialogDemand]]
bool HasHolodisk(Critter player, Critter npc, any val)
{
    return HasHolodiskImpl(player, npc, val);
}

// Диалоговый demand: у игрока нет нужного голодиска.
[[DialogDemand]]
bool NoHolodisk(Critter player, Critter npc, any val)
{
    return !HasHolodiskImpl(player, npc, val);
}

// Карта: события входа игрока на карту и выхода с неё.

// Инициализация карты: подписки на вход/выход криттеров для подсказок в окне состояния.
void MapInit(Map map, bool firstTime)
{
    map.OnCritterIn.Subscribe(LostCEncInCritter);
    map.OnCritterOut.Subscribe(LostCEncOutCritter);
}

// Игрок вошёл в локацию — показываем вводное описание сцены.
[[Event]]
void LostCEncInCritter(Map map, Critter player)
{
    if (player.ControlledByPlayer) {
        Messaging::Info(
            player,
            TextPackKey(
                TextPackName::Text,
                "" +
                    (STR_NUM_MAP_ENTER))); // "От каравана Даппо мало что осталось. Пресловутым грузом оказался боевой робот в заводской упаковке. Робот случайно
                                           // активировался, выбрался на свободу и уничтожил караван."
    }
}

// Игрок вышел из локации — итоговая подсказка по квесту.
[[Event]]
void LostCEncOutCritter(Map map, Critter player)
{
    if (player.ControlledByPlayer) {
        Messaging::Info(
            player,
            TextPackKey(TextPackName::Text, "" + (STR_NUM_MAP_LEAVE))); // "Даппо должен узнать, что произошло с его караваном. Робот не пожалел никого."
    }
}

#endif

}
