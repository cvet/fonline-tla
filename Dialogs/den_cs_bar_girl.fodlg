[Dialog]
Speech 1 # Преддиалоговые установки
  Answer 2 # Сразу говорим, если игрок не тупой
    Demand Property Player Intellect > 4
  Answer 5 # Если игрок тупой

Speech 2 # Привет @sex@ |дядя||тетя|.
  Answer 3 # Привет, девочка.
    Demand Item Npc flower > 0
  Answer Exit # Привет, девочка.

Speech 3 # Хочешь цветочек?
  Answer 4 # Давай!
    Result Item Player flower += 1
    Result Item Npc flower -= 1
  Answer Exit # В другой раз. [Уходите]

Speech 4 # Держи. [Передает вам цветок]
  Answer Exit # Спасибо!

Speech 5 # Привет, как дела?
  Answer 6 # У моя дела хорошо, гыгы!

Speech 6 # Фу, ты глупый!
  Answer Exit # [Выход] Ыгык!

