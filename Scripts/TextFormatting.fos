namespace TextFormatting
{

///@ Property Item Common string TextArgs Mutable PublicSync Persistent
///@ Property Critter Common string TextArgs Mutable PublicSync Persistent

string TextArg(string name, string value)
{
    return name + ":" + value;
}

string TextArg(string name, int value)
{
    return TextArg(name, "" + value);
}

}
