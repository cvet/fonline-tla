// InputHandler — клиентская обработка ввода с клавиатуры (горячие клавиши и удержание клавиш).
// CLIENT: подписывается на колбэки нажатия/отпускания клавиш в InitInputHandler и решает,
//  является ли клавиша игровой горячей клавишей.
// Обязанности: открытие/закрытие экранов интерфейса (Character/Inventory/PipBoy и т.д.),
//  переключение настроек отображения и громкости, выбор курсора навыков/оружия, прокрутка карты
//  удержанием стрелок и зум. Опирается на Gui::, Settings, GameTime::, ChosenActions::,
//  GuiScreensExt:: и другие модули клиента.
namespace InputHandler
{

#if CLIENT

// Точка входа модуля: регистрирует колбэки ввода при старте клиента.
[[ModuleInit]]
void InitInputHandler()
{
    Input::AddKeyDownCallback(OnKeyDown);
    Input::AddKeyUpCallback(OnKeyUp);
}

// Колбэк нажатия клавиши: обновляет состояние удерживаемых клавиш и,
// если это не ввод текста, пытается обработать клавишу как горячую.
bool OnKeyDown(KeyCode key, string text)
{
    HandlePressedKeys();
    if (key != KeyCode::Text) {
        return HandleHotkeys(key);
    }

    return false;
}

// Колбэк отпускания клавиши: переоценивает состояние удерживаемых клавиш.
void OnKeyUp(KeyCode key)
{
    HandlePressedKeys();
}

// Разбор горячих клавиш: возвращает true, если клавиша была обработана как хоткей.
bool HandleHotkeys(KeyCode key)
{
    // Пример эффекта, временный код
    if (Input::IsAltDown() && key == KeyCode::Q) {
        Game.SetEffect(EffectType::FlushMap, 0, "");
    }

    if (Input::IsAltDown() && key == KeyCode::W) {
        Game.SetEffect(EffectType::FlushMap, 0, "Effects/Flush_Map_BlackWhite.fofx");
    }

    // Хоткеи: считаем фокус ввода (консоль или активное текстовое поле),
    // чтобы при наборе текста не перехватывать обычные клавиши
    bool isHotkey = true;
    bool inputFocused = Gui::IsConsoleActive();

    if (!inputFocused) {
        Gui::Object[] focusedObjects = Gui::GetFocusedObjects();
        for (int i = 0; i < focusedObjects.length() && !inputFocused; i++) {
            inputFocused = cast<Gui::TextInput?>(focusedObjects[i]) != null;
        }
    }

    if (!Input::IsCtrlDown() && !Input::IsAltDown() && !Input::IsShiftDown()) {
        switch (key) {
        case KeyCode::F1:
            Settings.Client.HelpInfo = !Settings.Client.HelpInfo;
            break;

        case KeyCode::F2:
            // breadcrumb: сохранение лога в файл, ждёт восстановления API
            // if( Game.SaveText( filePath, text ) )
            //    Messaging::Info( GetGameText( MsgStr::StrLogSaved ) );
            // else
            //    Messaging::Info( GetGameText( MsgStr::StrLogNotSaved ) );
            break;
        case KeyCode::F3:
            // breadcrumb: сохранение скриншота, ждёт восстановления API
            // if( Game.SaveScreenshot( filePath ) )
            //    Messaging::Info( GetGameText( MsgStr::StrScreenshotSaved ) );
            // else
            //    Messaging::Info( GetGameText( MsgStr::StrScreenshotNotSaved ) );
            break;

        case KeyCode::F6:
            break;
        case KeyCode::F7:
            break;

        case KeyCode::F8:
            if (Settings.Render.Fullscreen) {
                Settings.Hex.FullscreenMouseScroll = !Settings.Hex.FullscreenMouseScroll;
            }
            else {
                Settings.Hex.WindowedMouseScroll = !Settings.Hex.WindowedMouseScroll;
            }

            Settings.Hex.ScrollMouseRight = false;
            Settings.Hex.ScrollMouseLeft = false;
            Settings.Hex.ScrollMouseDown = false;
            Settings.Hex.ScrollMouseUp = false;
            break;

        case KeyCode::F9:
            break;
        case KeyCode::F10:
            break;

        // Полноэкранный режим
        case KeyCode::F11:
            Game.ToggleFullscreen();
            break;
        // Свернуть окно
        case KeyCode::F12:
            Game.MinimizeWindow();
            break;

        // Эмуляция колеса мыши
        case KeyCode::Prior:
            Game.SimulateMouseClick(Game.MousePos, MouseButton::WheelUp);
            break;
        case KeyCode::Next:
            Game.SimulateMouseClick(Game.MousePos, MouseButton::WheelDown);
            break;

        // Переключение текстовых полей ввода
        case KeyCode::Tab:
            Gui::NextTextInput();
            break;

        // Выход
        case KeyCode::Escape:
            GuiScreensExt::TryExit();
            break;

        default:
            break;
        }

        if (!inputFocused) {
            Gui::Screen? screen = Gui::GetActiveScreen();
            if (screen == null) {
                return false;
            }

            // Открытие экрана
            if (key == KeyCode::C && (screen.Num == GuiScreen::Game || screen.Num == GuiScreen::GlobalMap)) {
                Gui::ShowScreen(GuiScreen::Character);
            }
            else if (key == KeyCode::I && (screen.Num == GuiScreen::Game || screen.Num == GuiScreen::GlobalMap)) {
                Gui::ShowScreen(GuiScreen::Inventory);
            }
            else if (key == KeyCode::P && (screen.Num == GuiScreen::Game || screen.Num == GuiScreen::GlobalMap)) {
                Gui::ShowScreen(GuiScreen::PipBoy);
            }
            else if (key == KeyCode::F && (screen.Num == GuiScreen::Game || screen.Num == GuiScreen::GlobalMap)) {
                Gui::ShowScreen(GuiScreen::FixBoy);
            }
            else if (key == KeyCode::O && (screen.Num == GuiScreen::Game || screen.Num == GuiScreen::GlobalMap)) {
                Gui::ShowScreen(GuiScreen::Menu);
            }
            else if (key == KeyCode::S && screen.Num == GuiScreen::Game) {
                Gui::ShowScreen(GuiScreen::SkillBox);
            }
            else if (key == KeyCode::Tab && screen.Num == GuiScreen::Game) {
                // breadcrumb: миникарта ещё не подключена
                //Gui::ShowScreen(GuiScreen::MiniMap);
            }

            // Закрытие открытого экрана (повторное нажатие той же клавиши)
            else if ((key == KeyCode::C && screen.Num == GuiScreen::Character) || (key == KeyCode::I && screen.Num == GuiScreen::Inventory) ||
                     (key == KeyCode::P && screen.Num == GuiScreen::PipBoy) || (key == KeyCode::F && screen.Num == GuiScreen::FixBoy) ||
                     (key == KeyCode::O && screen.Num == GuiScreen::Menu) || (key == KeyCode::S && screen.Num == GuiScreen::SkillBox) /*||
                     (key == KeyCode::Tab && screen.Num == GuiScreen::MiniMap)*/) {
                GuiScreensExt::TryExit();
            }

            // Текущее игровое время
            else if (key == KeyCode::Slash && (screen.Num == GuiScreen::Game || screen.Num == GuiScreen::GlobalMap)) {
                string str = "Time: ";
                str += (GameTime::GetDay() < 10 ? "0" : "") + GameTime::GetDay() + ".";
                str += (GameTime::GetMonth() < 10 ? "0" : "") + GameTime::GetMonth() + ".";
                str += GameTime::GetYear() + " ";
                str += (GameTime::GetHour() < 10 ? "0" : "") + GameTime::GetHour() + ":";
                str += (GameTime::GetMinute() < 10 ? "0" : "") + GameTime::GetMinute() + ":";
                str += (GameTime::GetSecond() < 10 ? "0" : "") + GameTime::GetSecond();
                str += " x" + Settings.WorldTime.Multiplier;
                Messaging::Info(str);
            }

            // Центрирование глобальной карты
            else if (key == KeyCode::Home && screen.Num == GuiScreen::GlobalMap) {
                // (CustomCall удалён) Game.CustomCall("GmapHome");
            }

            // Прочее
            else if (key == KeyCode::Space && Settings.Game.Singleplayer) {
                // (CustomCall удалён) Game.CustomCall("SwitchSingleplayerPause");
            }

            // Горячие клавиши основного игрового экрана
            else if (screen.Num == GuiScreen::Game) {
                isHotkey = true;

                switch (key) {
                case KeyCode::Q:
                    // (CustomCall удалён) Game.CustomCall("SwitchLookBorders");
                    break;
                case KeyCode::W:
                    // (CustomCall удалён) Game.CustomCall("SwitchShootBorders");
                    break;

                case KeyCode::A: {
                    if (!HasChosen) {
                        isHotkey = false;
                        break;
                    }

                    AbstractItem item = CritterItem::GetActive(Chosen);
                    if (item.Type == ItemType::Weapon && (item.Mode & 0xF) < WeaponHelpers::MAX_USES) {
                        Gui::Cursor = CursorType::UseWeapon;
                    }
                    else {
                        isHotkey = false;
                    }
                } break;

                case KeyCode::G:
                    // (CustomCall удалён) Game.CustomCall("TryPickItemOnGround");
                    break;

                case KeyCode::T:
                    Settings.GlobalMap.ShowGroups = !Settings.GlobalMap.ShowGroups;
                    break;

                case KeyCode::B:
                    // (CustomCall удалён) Game.CustomCall("ChangeSlot");
                    break;
                case KeyCode::M:
                    GuiScreensExt::NextCursor();
                    break;
                case KeyCode::N:
                    Parameters::SwitchMainItemMode(true);
                    break;

                case KeyCode::Comma:
                    ChosenActions::SetChosenActions({Tla::ChosenDir, 1 /* по часовой */, 0, 0, 0, 0, 0});
                    break;
                case KeyCode::Period:
                    ChosenActions::SetChosenActions({Tla::ChosenDir, 0 /* против часовой */, 0, 0, 0, 0, 0});
                    break;

                case KeyCode::Home: {
                    if (HasCurMap && HasChosen) {
                        CurMap.MoveScreenToHex(Chosen.Hex, Chosen.HexOffset, 100, true);
                    }
                } break;
                case KeyCode::Scroll: {
                    if (HasCurMap && HasChosen) {
                        CurMap.MoveScreenToHex(Chosen.Hex, Chosen.HexOffset, 20, true);
                    }
                } break;

                case KeyCode::H:
                    ChosenActions::SetChosenActions({Tla::ChosenUseSklOnCritter, int(CritterProperty::SkillSneak), 0, 0, 0, 0, 0});
                    break;

                // Навыки
                case KeyCode::C1:
                    ChosenActions::SetChosenActions({Tla::ChosenUseSklOnCritter, int(CritterProperty::SkillSneak), 0, 0, 0, 0, 0});
                    break;
                case KeyCode::C2: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillLockpick));
                } break;
                case KeyCode::C3: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillSteal));
                } break;
                case KeyCode::C4: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillTraps));
                } break;
                case KeyCode::C5: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillFirstAid));
                } break;
                case KeyCode::C6: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillDoctor));
                } break;
                case KeyCode::C7: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillScience));
                } break;
                case KeyCode::C8: {
                    Gui::Cursor = CursorType::UseSkill;
                    Gui::CursorData = any(int(CritterProperty::SkillRepair));
                } break;

                // Не горячая клавиша
                default:
                    isHotkey = false;
                    break;
                }
            }
            else {
                isHotkey = false;
            }
        }
        else {
            isHotkey = false;
        }
    }
    else {
        switch (key) {
        case KeyCode::F10:
            if (Input::IsShiftDown()) {
                Game.DumpAtlases();
            }

            break;

        // Цифровая клавиатура: регулировка громкости (Ctrl — звук, Shift — музыка)
        case KeyCode::Equals:
        case KeyCode::Add:
            if (!inputFocused) {
                if (Input::IsCtrlDown()) {
                    Settings.Audio.SoundVolume = Math::Clamp(Settings.Audio.SoundVolume + 2, 0, 100);
                }
                else if (Input::IsShiftDown()) {
                    Settings.Audio.MusicVolume = Math::Clamp(Settings.Audio.MusicVolume + 2, 0, 100);
                }
            }

            break;
        case KeyCode::Minus:
        case KeyCode::Subtract:
            if (!inputFocused) {
                if (Input::IsCtrlDown()) {
                    Settings.Audio.SoundVolume = Math::Clamp(Settings.Audio.SoundVolume - 2, 0, 100);
                }
                else if (Input::IsShiftDown()) {
                    Settings.Audio.MusicVolume = Math::Clamp(Settings.Audio.MusicVolume - 2, 0, 100);
                }
            }

            break;

        // Выход (Shift+Escape — завершить игру)
        case KeyCode::Escape:
            if (Input::IsShiftDown()) {
                Game.RequestQuit();
            }

            break;

        default:
            isHotkey = false;
            break;
        }
    }

    return isHotkey;
}

// Обработка удерживаемых клавиш: прокрутка карты стрелками и зум по Z работают только
// на игровом экране без активной консоли.
void HandlePressedKeys()
{
    bool isGameWithoutConsole = (Gui::IsScreenActive(GuiScreen::Game) && !Gui::IsConsoleActive());
    Settings.View.MapZoomInProgress = (isGameWithoutConsole && Input::IsKeyPressed(KeyCode::Z));
    Settings.Hex.ScrollKeybLeft = (isGameWithoutConsole && Input::IsKeyPressed(KeyCode::Left));
    Settings.Hex.ScrollKeybRight = (isGameWithoutConsole && Input::IsKeyPressed(KeyCode::Right));
    Settings.Hex.ScrollKeybUp = (isGameWithoutConsole && Input::IsKeyPressed(KeyCode::Up));
    Settings.Hex.ScrollKeybDown = (isGameWithoutConsole && Input::IsKeyPressed(KeyCode::Down));
}

#endif

}
