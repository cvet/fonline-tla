//           "OnInit": null,
//           "OnShow": null,
//           "OnHide": null,
//           "OnAppear": null,
//           "OnDisappear": null,
//           "OnDraw":
{
    {
        {
            Critter @chosen = Game.GetChosen();
            if (chosen == null) {
                return;
            }
            CrittersIds.clear();
            auto critters = Game.GetCritters(CritterFindType::Any);
            for (int i = 0, l = critters.length(); i < l; i++) {
                CrittersIds.insertLast(critters[i].Id);
            }
            ResizeGrid(CrittersIds.length());
        }
    }
}
