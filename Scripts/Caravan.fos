const int BAG_Stanwell = 24;
const int BAG_Savinelly = 20;
const int BAG_Hal = 20;

// типы караванов
const int CRV_TYPE_ONEWAY = 1;               // односторонний караван, всегда идет из начальной точки в конечную
const int CRV_TYPE_TWOWAY = 2;               // двухсторонний караван, если доходит до точки назначения, в следующий раз пойдет по обратному маршруту
const int CRV_TYPE_ONEWAY_TRANSITLEADER = 3; // односторонний караван, из конечной точки телепортирует начальника караванв в начальную
const int CRV_TYPE_ONEWAY_DELETELEADER = 4;  // односторонний караван, через час после достижения конечной точки удаляет начальника каравана
const int CRV_TYPE_ONEWAY_DELETELEADER_BOTH =
    5; // односторонний караван, через час после достижения конечной точки удаляет начальника каравана. Если никто не пришел к отправлению - удаляет тоже.

// статус каравана
const int CRV_STATUS_BEFORE_START = 0; // караван не начинался
const int CRV_STATUS_PREPARE = 1;      // появился проводник, игроки могут подавать заявки на охрану каравана
const int CRV_STATUS_START_MOVE = 2;   // караван вышел из пункта А
const int CRV_STATUS_ON_GLOBAL = 3;    // караван перемещается по глобалу
const int CRV_STATUS_ON_ENCOUNTER = 4; // караван на случайном энкаунтере
const int CRV_STATUS_END = 5;          // караван добрался до точки назначения в пункт Б

// статус квестовой переменной для игроков, сопровождающих караван
const int CARAVAN_NOQUEST = 0;           // не взят
const int CARAVAN_QUEST_TAKEN = 1;       // взят квест
const int CARAVAN_PLAYER_JOIN_FIRST = 2; // игрок присоединился к каравану и караван начал движение впервые
// провалы. Если будет хоть один провал, по идее игрок больше не сможет охранять этот караван
const int CARAVAN_FAILURE_PLAYER_THIEFT = 3;      // игрок напал на караванщиков или пытался ограбить
const int CARAVAN_FAILURE_PLAYER_ABANDONED = 4;   // игрок покинул караван
const int CARAVAN_FAILURE_PLAYER_DEAD = 5;        // игрок погиб во время каравана
const int CARAVAN_FAILURE_CARAVANLEADER_DEAD = 6; // убит проводник на энкаунтере
const int CARAVAN_FAILURE_PLAYER_KILL_LEADER = 7; // игрок убил проводника на энкаунтере
// первый и последующий успех
const int CARAVAN_SUCCESS_FIRST = 8;    // игрок довел караван до точки назначения впервые
const int CARAVAN_PLAYER_JOIN_NEXT = 9; // игрок присоединился к каравану и караван начал движение в последующие разы
const int CARAVAN_SUCCESS_NEXT = 10;    // игрок довел караван до точки назначения в последующие разы
const int CARAVAN_QUEST_COMPLETE = 11;  // игрок сдал квест

const int LEADER_SEARCH_RADIUS = 8; // радиус, в котором ищем проводника при проверках, в верной ли позиции он находится

const int MODEL_CRVNR_COWARD = 1; // модель поведения проводника: трус - пока других моделей поведения нет

const int MIN_DIST_CABS_DIST = 6; // минимальное расстояние между соседними повозками
const int STR_DONT_TOUCH = 3500;  // строка, которую произносит проводник, если игрок пробует открыть повозки

// время в игрокых минутах, через которое будет телепортирован в начальную точку лидер, если тип каравана = CRV_TYPE_ONEWAY_TRANSITLEADER и караван дошел до пункта назначенния
const int TIME_TO_WAIT_AT_ENDPOINT = 60 * 60 * 2;

// время в игровых минутах, через которое будет удален проводник каравана в конечной точке маршрута, если тип каравана = CRV_TYPE_ONEWAY_DELETELEADER
const int TIME_TO_DELETE_LEADER = 60 * 30;

void SetQuestState(Critter player, int idCaravan, int state)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    player.SetAsInt(ci.QuestVarNum, state);
}

int GetQuestState(Critter player, int idCaravan)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return 0;
    }

    return player.GetAsInt(ci.QuestVarNum);
}

// управление квестовой переменной
void SetPlayerJoinedFirstCaravan(Critter cr, CaravanInfo crv)
{
    if (GetQuestState(cr, crv.CaravanId) == CARAVAN_QUEST_TAKEN) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_PLAYER_JOIN_FIRST);
    }
}
void SetPlayerFirstCaravanSuccess(Critter cr, CaravanInfo crv)
{
    if (GetQuestState(cr, crv.CaravanId) == CARAVAN_PLAYER_JOIN_FIRST) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_SUCCESS_FIRST);
    }
}
void SetPlayerCaravanTheftFailure(Critter cr, CaravanInfo crv)
{
    SetQuestState(cr, crv.CaravanId, CARAVAN_FAILURE_PLAYER_THIEFT);
}
void SetPlayerCaravanAbandonedFailure(Critter cr, CaravanInfo crv)
{
    int q1 = GetQuestState(cr, crv.CaravanId);
    if (q1 == CARAVAN_PLAYER_JOIN_FIRST || q1 == CARAVAN_PLAYER_JOIN_NEXT) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_FAILURE_PLAYER_ABANDONED);
    }
}
void SetPlayerCaravanDeadFailure(Critter cr, CaravanInfo crv)
{
    int q2 = GetQuestState(cr, crv.CaravanId);
    if (q2 == CARAVAN_PLAYER_JOIN_FIRST || q2 == CARAVAN_PLAYER_JOIN_NEXT) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_FAILURE_PLAYER_DEAD);
    }
}
void SetCaravanLeaderDeadFailure(Critter cr, CaravanInfo crv)
{
    int q3 = GetQuestState(cr, crv.CaravanId);
    if (q3 == CARAVAN_PLAYER_JOIN_FIRST || q3 == CARAVAN_PLAYER_JOIN_NEXT) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_FAILURE_CARAVANLEADER_DEAD);
    }
}
void SetPlayerKilledCaravanLeaderFailure(Critter cr, CaravanInfo crv)
{
    SetQuestState(cr, crv.CaravanId, CARAVAN_FAILURE_PLAYER_KILL_LEADER);
}
void SetPlayerJoinedNextCaravan(Critter cr, CaravanInfo crv)
{
    int q4 = GetQuestState(cr, crv.CaravanId);
    if (q4 == CARAVAN_QUEST_COMPLETE) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_PLAYER_JOIN_NEXT);
    }
}
void SetPlayerNextCaravanSuccess(Critter cr, CaravanInfo crv)
{
    int q5 = GetQuestState(cr, crv.CaravanId);
    if (q5 == CARAVAN_PLAYER_JOIN_NEXT) {
        SetQuestState(cr, crv.CaravanId, CARAVAN_SUCCESS_NEXT);
    }
}
void SetPlayerCaravanJoined(Critter cr, CaravanInfo crv)
{
    int q6 = GetQuestState(cr, crv.CaravanId);
    if (q6 == CARAVAN_QUEST_TAKEN) {
        SetPlayerJoinedFirstCaravan(cr, crv);
    }
    if (q6 == CARAVAN_QUEST_COMPLETE) {
        SetPlayerJoinedNextCaravan(cr, crv);
    }
}
bool CanPlayerJoinCaravan(Critter cr, CaravanInfo crv)
{
    int q7 = GetQuestState(cr, crv.CaravanId);
    return (q7 == CARAVAN_QUEST_COMPLETE || q7 == CARAVAN_NOQUEST || q7 == CARAVAN_QUEST_TAKEN);
} // после первого, последующего успеха или при взятом квесте
bool HasPlayerFailedCaravanQuest(Critter cr, CaravanInfo crv)
{
    int q8 = GetQuestState(cr, crv.CaravanId);
    return (q8 >= CARAVAN_FAILURE_PLAYER_THIEFT && q8 <= CARAVAN_FAILURE_PLAYER_KILL_LEADER);
} // игрок завалил ранее квест

