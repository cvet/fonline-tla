namespace Repairer
{

#if SERVER

// Author: rifleman17
// Скрипт для НПЦ, ремонтирующих оружие и броню.
// - Ремонтируемый предмет игрок должен держать в основном слоте
// - Ремонт может либо производиться мгновенно, либо за некий период.
// - Одновременно НПЦ может ремонтировать только один предмет для одного игрока.
// - От навыка ремонта НПЦ зависит скорость ремонта.  Линейная зависимость.
//   При 300 навыка - ремонт мгновенный, при 0 навыка - ремонт = 3 игровых часа для полностью поломанного предмета.
// - От навыка торговли НПЦ и игрока зависит стоимость ремонта. Формула: [Стоимость] = 0.95*[Цена предмета]*[Навык торговли ремонтника]/[Навык торговли игрока]
// для полностью поломанного предмета, но не менее 5% от цены предмета
// - Для НПЦ назначены следующие переменные-флаги (локальная переменная для нпц максимум 1)
// VAR_CAN_REPAIR_WEAPONS - признак, может ремонтировать хоть какое-то оружие
// VAR_CAN_REPAIR_WEAPONS_SPECIAL - признак, может ремонтировать редкое оружие
// VAR_CAN_REPAIR_ARMOUR - признак, может ремонтировать броню
// VAR_CAN_REPAIR_SPECIAL_ARMOUR - признак, может ремонтировать редкую броню
// Для настройки возможностей ремонта НПЦ используйте диалог и установку переменных, либо один из заготовленных скриптов (см. конец файла).

///@ Property Critter Server uint8 CanRepairWeapons Mutable Persistent Max = 1
///@ Property Critter Server uint8 CanRepairWeaponsSpecial Mutable Persistent Max = 1
///@ Property Critter Server uint8 CanRepairArmor Mutable Persistent Max = 1
///@ Property Critter Server uint8 CanRepairArmorSpecial Mutable Persistent Max = 1
///@ Property Critter Server ident=>synctime RepairCompleteTime Mutable Persistent
///@ Property Critter Server ident=>hstring RepairItemPid Mutable Persistent

const int BASE_REPAIR_TIME = 3 * 60 * 60;

double CalcBaseRepairCost(double itemCost, double itemDeterioration, double playerBarter, double npcBarter)
{
    return Tla::Clamp(0.95 * itemCost * npcBarter * itemDeterioration / (playerBarter * 99), 0.05 * itemCost, 0.95 * itemCost);
}
double CalcRepairCost(Item item, Critter player, Critter npc)
{
    return CalcBaseRepairCost((item.Cost == 0 ? item.Cost : item.Cost), Repair::GetDeteriorationProcent(item), player.SkillBarter, npc.SkillBarter);
}
int CalcRepairTime(Item item, Critter npc)
{
    return int((npc.SkillRepair * (-1 * BASE_REPAIR_TIME / 300) + BASE_REPAIR_TIME) * (Repair::GetDeteriorationProcent(item) / 99));
}

// #define DebugLog #(s) (Game.Log(s))
void DebugLog(string s)
{
}

const hstring[] SpecialArmours = {Content::Item::keepbrige_robe,
                                  Content::Item::powered_armor,
                                  Content::Item::hardened_power_armor,
                                  Content::Item::advanced_power_armor,
                                  Content::Item::advanced_power_armor_mk2};
const hstring[] SpecialWeapons = {Content::Item::alien_laser_pistol,
                                  Content::Item::robo_rocket_launcher,
                                  Content::Item::phazer,
                                  Content::Item::deathclaw_claw_1,
                                  Content::Item::deathclaw_claw_2,
                                  Content::Item::fire_gecko_flame_weapon,
                                  Content::Item::special_boxer_weapon,
                                  Content::Item::gun_turret_weapon,
                                  Content::Item::eyeball_fist_1,
                                  Content::Item::eyeball_fist_2,
                                  Content::Item::dual_minigun,
                                  Content::Item::heavy_dual_minigun,
                                  Content::Item::end_boss_kife,
                                  Content::Item::end_boss_plasma_gun,
                                  Content::Item::holy_hand_grenade,
                                  Content::Item::solar_scorcher};

bool CanRepair(Item? item, Critter? npc)
{
    if (item == null || npc == null) {
        return false;
    }

    int type = item.Type;
    hstring pid = item.ProtoId;
    switch (type) {
    case ItemType::Armor:
        if (npc.GetAsInt(SpecialWeapons.exists(pid) ? CritterProperty::CanRepairArmorSpecial : CritterProperty::CanRepairArmor) == 1) {
            return true;
        }

        break;
    case ItemType::Weapon:
        if (npc.GetAsInt(SpecialWeapons.exists(pid) ? CritterProperty::CanRepairWeaponsSpecial : CritterProperty::CanRepairWeapons) == 1) {
            return true;
        }

        break;
    default:
        return false;
    }

    return false;
}

void TakeItemToRepair(Critter? player, Critter? npc, Item? item)
{
    if (player == null || npc == null || item == null) {
        return;
    }

    auto repairCompleteTime = player.RepairCompleteTime.clone();
    auto repairItemPid = player.RepairItemPid.clone();
    repairCompleteTime[npc.Id] = Game.SynchronizedTime + Tla::GameSeconds(CalcRepairTime(item, npc));
    player.RepairCompleteTime = repairCompleteTime;
    repairItemPid[npc.Id] = item.ProtoId;
    player.RepairItemPid = repairItemPid;
    // Удаление предмета, "взят на ремонт".
    Game.DestroyItem(item);
}

bool SomeItemWasRepaired(Critter? player, Critter? npc)
{
    if (player == null || npc == null) {
        return false;
    }

    if (player.RepairItemPid.get(npc.Id, EMPTY_HSTRING) == EMPTY_HSTRING) {
        return false;
    }

    return Game.SynchronizedTime >= player.RepairCompleteTime.get(npc.Id, ZERO_SYNCTIME);
}

bool HasSomeItemToRepair(Critter? player, Critter? npc)
{
    if (player == null || npc == null) {
        return false;
    }

    return player.RepairItemPid.get(npc.Id, EMPTY_HSTRING) != EMPTY_HSTRING;
}

void GetItemFromRepair(Critter? player, Critter? npc)
{
    if (player == null || npc == null) {
        return;
    }

    auto repairItemPid = player.RepairItemPid.clone();
    if (repairItemPid.get(npc.Id, EMPTY_HSTRING) == EMPTY_HSTRING) {
        return;
    }

    Item item = player.AddItem(repairItemPid[npc.Id], 1);
    if (item.Type == ItemType::Weapon) {
        item.AmmoCount = 0;
    }

    repairItemPid[npc.Id] = EMPTY_HSTRING;
    player.RepairItemPid = repairItemPid;
}

int GetRepairCost(Critter? player, Critter? npc, Item? item)
{
    if (player == null || npc == null || item == null) {
        return 0;
    }

    // DebugLog("Repair price:" + CalcRepairCost(item, player, npc) + "item cost: "+item.Cost + "; Proto cost = "+item.Cost);
    return int(CalcRepairCost(item, player, npc));
}

// Диалоги. Условия, результаты, генерация лексем

// Условия
[[DialogDemand]]
bool IsItemInHand(Critter player, Critter npc)
{
    return (Tla::GetCritterHandItem(player) != null);
}

bool CanRepairImpl(Critter player, Critter npc)
{
    Item? item = Tla::GetCritterHandItem(player);
    if (item == null) {
        return false;
    }

    return CanRepair(item, npc);
}

[[DialogDemand]]
bool CanRepair(Critter player, Critter npc)
{
    return CanRepairImpl(player, npc);
}

[[DialogDemand]]
bool CanNotRepair(Critter player, Critter npc)
{
    return (!CanRepairImpl(player, npc));
}

bool HasEnoughMoneyImpl(Critter player, Critter npc)
{
    Item? item = Tla::GetCritterHandItem(player);
    if (item == null || !CanRepair(item, npc)) {
        return false;
    }

    return (GetRepairCost(player, npc, item) <= player.CountItem(Content::Item::bottle_caps));
}

[[DialogDemand]]
bool HasEnoughMoney(Critter player, Critter npc)
{
    return HasEnoughMoneyImpl(player, npc);
}

bool HasNotEnoughMoney(Critter player, Critter npc)
{
    return (!HasEnoughMoneyImpl(player, npc));
}

bool ItemWasRepairedImpl(Critter player, Critter npc)
{
    return SomeItemWasRepaired(player, npc);
}

[[DialogDemand]]
bool ItemWasRepaired(Critter player, Critter npc)
{
    return ItemWasRepairedImpl(player, npc);
}

[[DialogDemand]]
bool NoItemWasRepaired(Critter player, Critter npc)
{
    return (!ItemWasRepairedImpl(player, npc));
}

bool SomeItemIsRepairingImpl(Critter player, Critter npc)
{
    return HasSomeItemToRepair(player, npc);
}

[[DialogDemand]]
bool SomeItemIsRepairing(Critter player, Critter npc)
{
    return SomeItemIsRepairingImpl(player, npc);
}

[[DialogDemand]]
bool NoItemIsRepairing(Critter player, Critter npc)
{
    return (!SomeItemIsRepairingImpl(player, npc));
}

// Диалог
// Имя предмета и цена, который игрок держит в руке будет отображено с помощью лексемы lex item_name lex price
// Функция для сдачи предмета
void CallItemBefore(Critter player, Critter npc, string& textArgs)
{
    if (!Tla::IsDialogGenerated(textArgs)) {
        return;
    }

    textArgs = "|item_name: _";
    Item? item = Tla::GetCritterHandItem(player);
    if (item == null) {
        return;
    }

    textArgs = "|item_name:@text Item " + MsgStr::ItemNameTextId(item) + "@|price:" + GetRepairCost(player, npc, item);
}

// Функция для проверки, отремонтирован ли предмет
void CallItemAfter(Critter player, Critter npc, string& textArgs)
{
    if (!Tla::IsDialogGenerated(textArgs)) {
        return;
    }

    textArgs = "|item_name: _";
    if (player.RepairItemPid.get(npc.Id, EMPTY_HSTRING) == EMPTY_HSTRING) {
        return;
    }

    textArgs = "|item_name:@text Item " + MsgStr::ProtoItemNameTextId(player.RepairItemPid[npc.Id]) + "@";
}

// Время и дата, когда будет отремонтирован предмет для случая, когда предмет уже взят на ремонт
// Время указывается в формате "@arg time@"
void GetRepairTime(Critter player, Critter npc, string& textArgs)
{
    if (!Tla::IsDialogGenerated(textArgs)) {
        return;
    }

    if (player.RepairCompleteTime.get(npc.Id, ZERO_SYNCTIME) == ZERO_SYNCTIME) {
        return;
    }

    int year = 0, month = 0, day = 0, hour = 0, minute = 0, second = 0, milisecond = 0;
    Game.UnpackSynchronizedTime(player.RepairCompleteTime[npc.Id], year, month, day, hour, minute, second, milisecond);
    textArgs = "|time:" + (month > 9 ? ("" + month) : ("0" + month)) + "." + year + " " + (hour > 9 ? ("" + hour) : ("0" + hour)) + ":" +
               (minute > 9 ? ("" + minute) : ("0" + minute));
}

// Результаты
// free - признак, что ремонт бесплатный
// 0 - платный, остальное бесплатный
[[DialogResult]]
void TakeForRepair(Critter player, Critter npc, any free)
{
    Item? item = Tla::GetCritterHandItem(player);
    if (item == null) {
        return;
    }

    if (free == 0) {
        int money = GetRepairCost(player, npc, item);
        Game.DestroyItem(player.GetItem(Content::Item::bottle_caps), money);
    }

    TakeItemToRepair(player, npc, item);
}

// Получение отремонтированного предмета
[[DialogResult]]
void TakeItemFromRepair(Critter player, Critter npc)
{
    GetItemFromRepair(player, npc);
}

#endif

}
