// Dialogs — ядро диалоговой системы (демоды/результаты ответов, контекст разговора).
// SERVER: RunDialog/SpeechAnswer/CloseDialog, проверка демандов (CheckAnswerDemands)
//  и применение результатов (UseAnswerResults), таймаут через ProcessDialog.
// CLIENT: приём контекста и показ экрана Dialog.
// Связи: Barter, Messaging, Gui, движковые DialogPack/DialogSpeech/DialogAnswer.
namespace Dialogs
{

// Todo: ввести в работу MaxTalkers

///@ Setting Common int32 Dialog.TalkDistance
///@ Setting Common int32 Dialog.TalkMaxTime
///@ Setting Common int32 Dialog.MaxTalkers

///@ Property Critter Common hstring DialogId Mutable PublicSync Persistent
///@ Property Critter Common int8 TalkDistance Mutable PublicSync Persistent
///@ Property Critter Server int8 MaxTalkers Mutable Persistent

///@ Property Critter Common bool DialogContext Component
///@ Property Critter Common bool DialogContext.Talking Mutable PublicSync
///@ Property Critter Server hstring DialogContext.DialogId Mutable
///@ Property Critter Server ident DialogContext.TalkerId Mutable
///@ Property Critter Server ident DialogContext.MapId Mutable
///@ Property Critter Server mpos DialogContext.MapHex Mutable
///@ Property Critter Server bool DialogContext.IgnoreDistance Mutable
///@ Property Critter Server int32 DialogContext.CurSpeech Mutable
///@ Property Critter Server int32 DialogContext.PrevSpeech Mutable
///@ Property Critter Server int32[] DialogContext.SpeechAnswers Mutable
///@ Property Critter Server nanotime DialogContext.StartTime Mutable
///@ Property Critter Server timespan DialogContext.Duration Mutable
///@ Property Critter Server string DialogContext.TextArgs Mutable

///@ Event Server Game OnCritterTalk(Critter cr)

///@ Enum DialogAnswerLink Barter = -2
///@ Enum DialogAnswerLink Attack = -3

///@ RemoteCall Server SpeechAnswer(int32 answerIndex)
///@ RemoteCall Client ReceiveDialogContext(hstring dialogId, ident talkerId, hstring textId, hstring[] answerTextIds, string textArgs, timespan duration)

// Подписки на серверные события жизненного цикла криттера: при выходе из строя
// (нокаут/смерть/выход из игры) активный диалог нужно корректно закрыть.
[[ModuleInit]]
void InitDialogs()
{
#if SERVER
    Game.OnCritterSendInitialInfo.Subscribe(OnCritterSendInitialInfo);
    Game.OnCritterKnockout.Subscribe(OnCritterKnockout);
    Game.OnCritterDead.Subscribe(OnCritterDead);
    Game.OnCritterFinish.Subscribe(OnCritterFinish);
#endif
}

#if SERVER

// Запуск диалога с конкретным собеседником: берём его DialogId и проверяем,
// что разговор сейчас вообще возможен (живы, рядом, видят друг друга).
void RunDialog(Critter cr, Critter talker, bool ignoreDistance)
{
    if (talker.DialogId == EMPTY_HSTRING) {
        throw("Critter is not talkable", cr);
    }

    if (!IsCrittersCanTalk(cr, talker)) {
        throw("Critters can't talk now", cr, talker);
    }

    RunDialog(cr, talker.DialogId, talker, ignoreDistance);
}

// Запуск диалога по идентификатору пакета без собеседника (например, скриптовый разговор).
void RunDialog(Critter cr, hstring dialogId, bool ignoreDistance)
{
    RunDialog(cr, dialogId, null, ignoreDistance);
}

// Базовая реализация: проходим стартовую реплику, применяем её результаты,
// затем разворачиваем первую видимую реплику с ответами и собираем контекст диалога.
void RunDialog(Critter cr, hstring dialogId, Critter? talker, bool ignoreDistance)
{
    if (!cr.HasDialogContext) {
        throw("Critter can't start dialog", cr, dialogId);
    }

    DialogPack? dialogPack = Game.GetDialogPack(dialogId);

    if (dialogPack == null) {
        throw("Dialog pack not found", cr, dialogId);
    }

    CloseDialog(cr);

    if (cr.IsMoving()) {
        cr.StopMoving();
    }

    // Определяем первый диалог
    const int initSpeechIndex = 0;
    int[] answerIndices = GetSpeechAnswers(cr, talker, dialogPack, initSpeechIndex, findFirst : true);

    if (answerIndices.isEmpty()) {
        return;
    }

    DialogSpeech initSpeech = dialogPack.GetSpeech(initSpeechIndex);
    DialogAnswer initAnswer = initSpeech.GetAnswer(answerIndices.first());
    int firstSpeechId = UseAnswerResults(cr, talker, initAnswer);
    int firstSpeechIndex = FindSpeech(dialogPack, firstSpeechId);

    if (firstSpeechIndex == -1) {
        throw("First speech not found", cr, dialogId, firstSpeechId);
    }

    int[] firstAnswerIndices = GetSpeechAnswers(cr, talker, dialogPack, firstSpeechIndex);
    DialogSpeech firstSpeech = dialogPack.GetSpeech(firstSpeechIndex);

    // Нет ответов, просто текст над головой
    if (firstAnswerIndices.isEmpty()) {
        if (talker != null) {
            Messaging::Say(talker, TextPackKey(TextPackName::Dialogs, dialogId, firstSpeech.TextId));
        }
        else {
            Messaging::Info(cr, TextPackKey(TextPackName::Dialogs, dialogId, firstSpeech.TextId));
        }

        return;
    }

    string textArgs = Game.RunSpeechScript(firstSpeech, cr, talker);

    if (textArgs == "!") {
        throw("Speech script error", cr, dialogId, firstSpeech.Id);
    }

    // Диалог запустили где-то в скриптовых вызовах GetSpeechAnswers/UseAnswerResults/RunSpeechScript
    if (cr.DialogContext.Talking) {
        return;
    }

    // Контекст диалога готов
    cr.DialogContext.Talking = true;
    cr.DialogContext.DialogId = dialogId;
    cr.DialogContext.TalkerId = talker != null ? talker.Id : ZERO_IDENT;
    cr.DialogContext.MapId = cr.MapId;
    cr.DialogContext.MapHex = cr.Hex;
    cr.DialogContext.IgnoreDistance = ignoreDistance;
    cr.DialogContext.StartTime = Game.FrameTime;
    cr.DialogContext.Duration = Time::Milliseconds(Settings.Dialog.TalkMaxTime);
    cr.DialogContext.PrevSpeech = -1;
    cr.DialogContext.CurSpeech = firstSpeechIndex;
    cr.DialogContext.SpeechAnswers = firstAnswerIndices;
    cr.DialogContext.TextArgs = textArgs;

    cr.StartTimeEvent(Time::Milliseconds(1000), Time::Milliseconds(1000), ProcessDialog);
    SendDialogContext(cr);

    Game.OnCritterTalk.Fire(cr);
}

// Игрок выбрал ответ: валидируем индекс, перепроверяем демоды ответа (анти-чит),
// применяем результаты и переходим к следующей реплике либо закрываем/бартер/атака.
[[ServerRemoteCall]] [[Async]]
void SpeechAnswer(Player player, int answerIndex)
{
    Critter? cr = player.GetControlledCritter();

    if (cr == null || !cr.HasDialogContext || !cr.DialogContext.Talking) {
        throw("SpeechAnswer - Critter is not talking", player);
    }

    Critter? talker = Game.GetCritter(cr.DialogContext.TalkerId);
    if (talker != null && !Sync::Lock(cr, talker)) {
        return;
    }

    // Специальные индексы ответа
    switch (answerIndex) {
    case -1:
    case 0xF1: // Закрыть диалог
        CloseDialog(cr);
        return;
    case -2:
    case 0xF2: // Бартер
        if (talker != null) {
            CloseDialog(cr);
            Barter::StartNpcBarter(cr, talker);
        }

        return;
    default:
        break;
    }

    if (IsDialogMustBeClosed(cr)) {
        CloseDialog(cr);
        return;
    }

    hstring dialogId = cr.DialogContext.DialogId;
    int[] answerIndices = cr.DialogContext.SpeechAnswers;

    if (answerIndex < 0 || answerIndex >= answerIndices.length()) {
        CloseDialog(cr);
        throw("Invalid answer index", cr, dialogId, answerIndex);
    }

    DialogPack? dialogPack = Game.GetDialogPack(dialogId);
    if (dialogPack == null) {
        CloseDialog(cr);
        throw("Dialog pack not found", cr, dialogId);
    }

    int[] recheckedAnswerIndices = GetSpeechAnswers(cr, talker, dialogPack, cr.DialogContext.CurSpeech, recheck : true);

    if (recheckedAnswerIndices.find(answerIndices[answerIndex]) == -1) {
        CloseDialog(cr);
        throw("Answer is not pass second check", cr, dialogId, answerIndex);
    }

    DialogSpeech dialogSpeech = dialogPack.GetSpeech(cr.DialogContext.CurSpeech);
    DialogAnswer dialogAnswer = dialogSpeech.GetAnswer(answerIndices[answerIndex]);

    int nextSpeechId = UseAnswerResults(cr, talker, dialogAnswer);

    // Специальные обработчики
    switch (nextSpeechId) {
    case 0: { // Закрываем
        CloseDialog(cr);
        return;
    }
    case 0xFFE1:
    case -1: { // К предыдущей речи
        if (cr.DialogContext.PrevSpeech < 0) {
            CloseDialog(cr);
            return;
        }

        DialogSpeech prevSpeech = dialogPack.GetSpeech(cr.DialogContext.PrevSpeech);
        nextSpeechId = prevSpeech.Id;
        break;
    }
    case 0xFFE2:
    case -2: { // Бартер
        if (talker != null) {
            CloseDialog(cr);
            Barter::StartNpcBarter(cr, talker);
        }

        return;
    }
    case 0xFFE3:
    case -3: { // Атака
        if (talker != null) {
            // Todo:
        }

        return;
    }
    default: {
        break;
    }
    }

    int nextSpeechIndex = FindSpeech(dialogPack, nextSpeechId);

    if (nextSpeechIndex == -1) {
        CloseDialog(cr);
        throw("Next speech not found", cr, dialogId, dialogAnswer.Link);
    }

    int[] nextAnswerIndices = GetSpeechAnswers(cr, talker, dialogPack, nextSpeechIndex);

    DialogSpeech nextSpeech = dialogPack.GetSpeech(nextSpeechIndex);
    string textArgs = Game.RunSpeechScript(nextSpeech, cr, talker);

    if (textArgs == "!") {
        CloseDialog(cr);
        throw("Speech script error", cr, dialogId, nextSpeech.Id);
    }

    // Диалог изменился в вызовах GetSpeechAnswers/UseAnswerResults/RunSpeechScript
    if (!cr.DialogContext.Talking || cr.DialogContext.DialogId != dialogId) {
        return;
    }

    cr.DialogContext.StartTime = Game.FrameTime;
    cr.DialogContext.PrevSpeech = cr.DialogContext.CurSpeech;
    cr.DialogContext.CurSpeech = nextSpeechIndex;
    cr.DialogContext.SpeechAnswers = nextAnswerIndices;
    cr.DialogContext.TextArgs = textArgs;

    SendDialogContext(cr);
}

// Завершение диалога: снимаем таймер таймаута, сбрасываем флаг разговора
// и шлём клиенту пустой контекст (он скроет экран Dialog).
void CloseDialog(Critter cr)
{
    if (cr.HasDialogContext && cr.DialogContext.Talking) {
        cr.StopTimeEvent(ProcessDialog);
        cr.DialogContext.DialogId = EMPTY_HSTRING;
        cr.DialogContext.Talking = false;
        SendDialogContext(cr);
    }
}

// Продление диалога: сбрасываем отсчёт таймаута, чтобы разговор не оборвался.
void RefreshDialogTime(Critter cr)
{
    if (cr.HasDialogContext && cr.DialogContext.Talking) {
        cr.DialogContext.StartTime = Game.FrameTime;
    }
}

// Занят ли криттер разговором: либо сам ведёт диалог, либо является собеседником
// у кого-то из видимых вокруг криттеров.
bool IsTalking(Critter cr)
{
    if (cr.HasDialogContext && cr.DialogContext.Talking) {
        return true;
    }

    Critter[] otherCritters = cr.GetCritters(CritterSeeType::Any, CritterFindType::Any);

    for (int i = 0; i < otherCritters.length(); i++) {
        Critter otherCr = otherCritters[i];

        if (otherCr.HasDialogContext && otherCr.DialogContext.Talking && otherCr.DialogContext.TalkerId == cr.Id) {
            return true;
        }
    }

    return false;
}

// Периодический таймер диалога: закрывает разговор, когда тот больше не валиден
// (таймаут, уход с дистанции, движение, потеря собеседника).
[[TimeEvent]] [[Async]]
void ProcessDialog(Critter cr)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    if (IsDialogMustBeClosed(cr)) {
        CloseDialog(cr);
    }
}

// Условия, при которых диалог обязан закрыться: нет контекста/не разговаривает,
// криттер двинулся, истёк таймаут, либо (если дистанция учитывается) собеседник
// недоступен или ушёл за пределы дистанции разговора.
[[Async]]
bool IsDialogMustBeClosed(Critter cr)
{
    if (!cr.HasDialogContext || !cr.DialogContext.Talking) {
        return true;
    }

    if (cr.IsMoving()) {
        return true;
    }

    timespan elapsed = Game.FrameTime - cr.DialogContext.StartTime;

    if (elapsed >= Time::Milliseconds(Settings.Dialog.TalkMaxTime)) {
        return true;
    }

    if (!cr.DialogContext.IgnoreDistance) {
        if (cr.DialogContext.TalkerId != ZERO_IDENT) {
            Critter? talker = Game.GetCritter(cr.DialogContext.TalkerId);

            // talker — вторая сущность вне cr+map-набора вызывающего; расширяем sync-набор на неё перед
            // чтением её свойств в IsCrittersCanTalk (Game.Sync ЗАМЕНЯЕТ набор, поэтому включаем и cr, и карту).
            if (talker != null) {
                Map? crMap = cr.GetMap();
                bool locked = crMap != null ? Sync::Lock(cr, crMap, talker) : Sync::Lock(cr, talker);
                if (!locked) {
                    return true;
                }
            }

            if (talker == null || !IsCrittersCanTalk(cr, talker)) {
                return true;
            }
        }
        else {
            int talkDistance = cr.TalkDistance != 0 ? cr.TalkDistance : Settings.Dialog.TalkDistance;

            if (cr.MapId != cr.DialogContext.MapId || Game.GetDistance(cr, cr.DialogContext.MapHex) > talkDistance) {
                return true;
            }
        }
    }

    return false;
}

// Могут ли двое начать/продолжить разговор: оба живы, на одной карте,
// в пределах дистанции разговора и видят друг друга.
bool IsCrittersCanTalk(Critter cr, Critter talker)
{
    if (!cr.IsAlive() || !talker.IsAlive()) {
        return false;
    }

    if (cr.MapId != talker.MapId) {
        return false;
    }

    if (Game.GetDistance(cr, talker) > (cr.TalkDistance != 0 ? cr.TalkDistance : Settings.Dialog.TalkDistance)) {
        return false;
    }

    if (!talker.IsSee(cr) || !cr.IsSee(talker)) {
        return false;
    }

    return true;
}

// Переподключение/реинициализация клиента: если разговор активен, переотправляем
// текущий контекст, чтобы клиент восстановил экран Dialog.
[[Event]]
void OnCritterSendInitialInfo(Critter cr)
{
    if (cr.HasDialogContext && cr.DialogContext.Talking) {
        SendDialogContext(cr);
    }
}

// Выход криттера из строя закрывает активный диалог.
[[Event]]
void OnCritterKnockout(Critter cr)
{
    CloseDialog(cr);
}

[[Event]]
void OnCritterDead(Critter cr, Critter killer)
{
    CloseDialog(cr);
}

[[Event]]
void OnCritterFinish(Critter cr)
{
    CloseDialog(cr);
}

// Отправка текущего состояния диалога клиенту: текст реплики, тексты ответов
// и остаток времени до таймаута. Если диалог не активен — отправляем пустой контекст.
void SendDialogContext(Critter cr)
{
    verify(cr.HasDialogContext, "Assertion failed");

    if (cr.DialogContext.Talking) {
        hstring dialogId = cr.DialogContext.DialogId;
        DialogPack? dialogPack = Game.GetDialogPack(dialogId);
        if (dialogPack == null) {
            CloseDialog(cr);
            return;
        }

        DialogSpeech dialogSpeech = dialogPack.GetSpeech(cr.DialogContext.CurSpeech);

        hstring textId = dialogSpeech.TextId;
        hstring[] answerTextIds = {};
        auto speechAnswers = cr.DialogContext.SpeechAnswers;

        for (int i = 0; i < speechAnswers.length(); i++) {
            DialogAnswer dialogAnswer = dialogSpeech.GetAnswer(speechAnswers[i]);
            answerTextIds.insertLast(dialogAnswer.TextId);
        }

        ident talkerId = cr.DialogContext.TalkerId;
        string textArgs = cr.DialogContext.TextArgs;
        timespan duration = Time::Milliseconds(Settings.Dialog.TalkMaxTime) - (Game.FrameTime - cr.DialogContext.StartTime);

        cr.PlayerClientCall.ReceiveDialogContext(dialogId, talkerId, textId, answerTextIds, textArgs, duration);
    }
    else {
        cr.PlayerClientCall.ReceiveDialogContext(EMPTY_HSTRING, ZERO_IDENT, EMPTY_HSTRING, {}, "", timespan());
    }
}

// Собирает индексы ответов реплики, прошедших проверку демандов. recheck — повторная
// проверка (анти-чит) только демандов с флагом NoRecheck; findFirst — остановиться на первом.
int[] GetSpeechAnswers(Critter cr, Critter? talker, DialogPack dialogPack, int speechIndex, bool recheck = false, bool findFirst = false)
{
    DialogSpeech speech = dialogPack.GetSpeech(speechIndex);

    int[] answerIndices = {};

    for (int i = 0; i < speech.AnswersCount; i++) {
        DialogAnswer answer = speech.GetAnswer(i);

        if (CheckAnswerDemands(cr, talker, answer, recheck)) {
            answerIndices.insertLast(i);

            if (findFirst) {
                break;
            }
        }
    }

    return answerIndices;
}

// Типы демандов/результатов диалога (DR_* — legacy-формат данных диалогов Fallout2):
// над чем проверка/действие (свойство глобала/криттера/предмета/локации/карты, предмет,
// скрипт) и кто адресат (DR_WHO_*). Имена сериализуемые — не переименовывать.
const uint8 DR_NONE = 0;
const uint8 DR_PROP_GLOBAL = 1;
const uint8 DR_PROP_CRITTER = 2;
const uint8 DR_PROP_ITEM = 4;
const uint8 DR_PROP_LOCATION = 5;
const uint8 DR_PROP_MAP = 6;
const uint8 DR_ITEM = 7;
const uint8 DR_SCRIPT = 8;
const uint8 DR_NO_RECHECK = 9;
const uint8 DR_OR = 10;

const uint8 DR_WHO_NONE = 0;
const uint8 DR_WHO_PLAYER = 1;
const uint8 DR_WHO_NPC = 2;

// Проверка всех демандов ответа. Демоды объединяются по И, но группы могут связываться
// через DR_OR: при провале деманда ищем следующий DR_OR — если он есть, провал «прощается»
// (группа ИЛИ), иначе ответ недоступен.
bool CheckAnswerDemands(Critter cr, Critter talker, DialogAnswer answer, bool recheck)
{
    for (int i = 0; i < answer.DemandsCount; i++) {
        DialogAnswerReq demand = answer.GetDemand(i);

        if (recheck && !demand.NoRecheck) {
            continue;
        }

        Critter? master;
        Critter? slave;

        switch (demand.Who) {
        case DR_WHO_PLAYER:
            master = cr;
            slave = talker;
            break;
        case DR_WHO_NPC:
            master = talker;
            slave = cr;
            break;
        default:
            continue;
        }

        if (master == null) {
            continue;
        }

        switch (demand.Type) {
        case DR_PROP_GLOBAL:
        case DR_PROP_CRITTER:
        case DR_PROP_ITEM:
        case DR_PROP_LOCATION:
        case DR_PROP_MAP: {
            int value;

            if (demand.Type == DR_PROP_GLOBAL) {
                value = Game.GetAsInt(GameProperty(demand.ParamIndex));
            }
            else if (demand.Type == DR_PROP_CRITTER) {
                value = master.GetAsInt(CritterProperty(demand.ParamIndex));
            }
            else if (demand.Type == DR_PROP_ITEM) {
                Item? item = master.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main);

                if (item == null) {
                    continue;
                }

                value = item.GetAsInt(ItemProperty(demand.ParamIndex));
            }
            else if (demand.Type == DR_PROP_LOCATION) {
                Map? map = master.GetMap();

                if (map == null) {
                    continue;
                }

                value = map.GetLocation().GetAsInt(LocationProperty(demand.ParamIndex));
            }
            else if (demand.Type == DR_PROP_MAP) {
                Map? map = master.GetMap();

                if (map == null) {
                    continue;
                }

                value = map.GetAsInt(MapProperty(demand.ParamIndex));
            }

            // continue = деманд выполнен (переходим к следующему); провал падает
            // на общую обработку DR_OR ниже по телу цикла.
            switch (demand.Op) {
            case '>':
                if (value > demand.Value) {
                    continue;
                }

                break;
            case '<':
                if (value < demand.Value) {
                    continue;
                }

                break;
            case '=':
                if (value == demand.Value) {
                    continue;
                }

                break;
            case '!':
                if (value != demand.Value) {
                    continue;
                }

                break;
            case '}':
                if (value >= demand.Value) {
                    continue;
                }

                break;
            case '{':
                if (value <= demand.Value) {
                    continue;
                }

                break;
            default:
                break;
            }

            break;
        }
        case DR_ITEM: {
            hstring pid = demand.ParamHash;

            switch (demand.Op) {
            case '>':
                if (master.CountItem(pid) > demand.Value) {
                    continue;
                }

                break;
            case '<':
                if (master.CountItem(pid) < demand.Value) {
                    continue;
                }

                break;
            case '=':
                if (master.CountItem(pid) == demand.Value) {
                    continue;
                }

                break;
            case '!':
                if (master.CountItem(pid) != demand.Value) {
                    continue;
                }

                break;
            case '}':
                if (master.CountItem(pid) >= demand.Value) {
                    continue;
                }

                break;
            case '{':
                if (master.CountItem(pid) <= demand.Value) {
                    continue;
                }

                break;
            default:
                break;
            }
        } break;
        case DR_SCRIPT: {
            if (Game.DialogScriptDemand(demand, master, slave)) {
                continue;
            }

            break;
        }
        case DR_OR: {
            return true;
        }
        default: {
            continue;
        }
        }

        // Деманд провален: если впереди есть DR_OR, провал «прощается» (группа ИЛИ),
        // иначе ответ недоступен.
        bool orMod = false;

        for (; i < answer.DemandsCount; ++i) {
            if (answer.GetDemand(i).Type == DR_OR) {
                orMod = true;
                break;
            }
        }

        if (!orMod) {
            return false;
        }
    }

    return true;
}

// Применение результатов выбранного ответа: меняет свойства/предметы и запускает
// скрипты результата. Возвращает id следующей реплики (ссылка ответа либо
// переопределённая скриптом-результатом через DR_SCRIPT).
int UseAnswerResults(Critter cr, Critter? talker, DialogAnswer answer)
{
    int linkId = answer.Link;

    Critter? master;
    Critter? slave;

    for (int i = 0; i < answer.ResultsCount; i++) {
        DialogAnswerReq result = answer.GetResult(i);

        switch (result.Who) {
        case DR_WHO_PLAYER:
            master = cr;
            slave = talker;
            break;
        case DR_WHO_NPC:
            master = talker;
            slave = cr;
            break;
        default:
            continue;
        }

        if (master == null) {
            continue;
        }

        switch (result.Type) {
        case DR_PROP_GLOBAL:
        case DR_PROP_CRITTER:
        case DR_PROP_ITEM:
        case DR_PROP_LOCATION:
        case DR_PROP_MAP: {
            int value;

            if (result.Type == DR_PROP_GLOBAL) {
                value = Game.GetAsInt(GameProperty(result.ParamIndex));
            }
            else if (result.Type == DR_PROP_CRITTER) {
                value = master.GetAsInt(CritterProperty(result.ParamIndex));
            }
            else if (result.Type == DR_PROP_ITEM) {
                Item? item = master.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main);

                if (item == null) {
                    continue;
                }

                value = item.GetAsInt(ItemProperty(result.ParamIndex));
            }
            else if (result.Type == DR_PROP_LOCATION) {
                Map? map = master.GetMap();

                if (map == null) {
                    continue;
                }

                value = map.GetLocation().GetAsInt(LocationProperty(result.ParamIndex));
            }
            else if (result.Type == DR_PROP_MAP) {
                Map? map = master.GetMap();

                if (map == null) {
                    continue;
                }

                value = map.GetAsInt(MapProperty(result.ParamIndex));
            }

            switch (result.Op) {
            case '+':
                value += int(result.Value);
                break;
            case '-':
                value -= int(result.Value);
                break;
            case '*':
                value *= int(result.Value);
                break;
            case '/':
                value /= int(result.Value);
                break;
            case '=':
                value = int(result.Value);
                break;
            default:
                break;
            }

            if (result.Type == DR_PROP_GLOBAL) {
                Game.SetAsInt(GameProperty(result.ParamIndex), value);
            }
            else if (result.Type == DR_PROP_CRITTER) {
                master.SetAsInt(CritterProperty(result.ParamIndex), value);
            }
            else if (result.Type == DR_PROP_ITEM) {
                Item? item = master.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main);
                if (item == null) {
                    continue;
                }

                item.SetAsInt(ItemProperty(result.ParamIndex), value);
            }
            else if (result.Type == DR_PROP_LOCATION) {
                Map? map = master.GetMap();
                if (map == null) {
                    continue;
                }

                map.GetLocation().SetAsInt(LocationProperty(result.ParamIndex), value);
            }
            else if (result.Type == DR_PROP_MAP) {
                Map? map = master.GetMap();
                if (map == null) {
                    continue;
                }

                map.SetAsInt(MapProperty(result.ParamIndex), value);
            }

            continue;
        }
        case DR_ITEM: {
            hstring pid = result.ParamHash;
            int curCount = master.CountItem(pid);
            int needCount = curCount;

            switch (result.Op) {
            case '+':
                needCount += int(result.Value);
                break;
            case '-':
                needCount -= int(result.Value);
                break;
            case '*':
                needCount *= int(result.Value);
                break;
            case '/':
                needCount /= int(result.Value);
                break;
            case '=':
                needCount = int(result.Value);
                break;
            default:
                continue;
            }

            needCount = Math::Max(needCount, 0);

            if (needCount < curCount) {
                master.DestroyItem(pid, curCount - needCount);
            }
            else {
                master.AddItem(pid, needCount - curCount);
            }

            continue;
        }
        case DR_SCRIPT: {
            int newLinkId = Game.DialogScriptResult(result, master, slave);

            if (newLinkId != 0) {
                linkId = newLinkId;
            }

            continue;
        }
        default: {
            continue;
        }
        }
    }

    return linkId;
}

// Поиск индекса реплики в пакете по её id; -1, если id отрицателен или не найден.
int FindSpeech(DialogPack dialogPack, int speechId)
{
    if (speechId < 0) {
        return -1;
    }

    for (int i = 0; i < dialogPack.SpeechesCount; i++) {
        DialogSpeech speech = dialogPack.GetSpeech(i);

        if (speech.Id == speechId) {
            return i;
        }
    }

    return -1;
}

#endif

#if CLIENT

// Приём контекста диалога с сервера: разворачиваем тексты из текст-пака, подставляем
// теги и показываем экран Dialog. Пустой dialogId означает «диалог закрыт» — прячем экран.
[[ClientRemoteCall]]
void ReceiveDialogContext(hstring dialogId, ident talkerId, hstring textId, hstring[] answerTextIds, string textArgs, timespan duration)
{
    if (dialogId != EMPTY_HSTRING) {
        string text = Game.GetText(TextPackKey(TextPackName::Dialogs, dialogId, textId));
        Critter? talker = talkerId != ZERO_IDENT ? Game.GetCritter(talkerId) : null;
        text = Game.FormatTags(text, textArgs, talker);

        string answersOneLine;

        for (int i = 0; i < answerTextIds.length(); i++) {
            string answerText = Game.GetText(TextPackKey(TextPackName::Dialogs, dialogId, answerTextIds[i]));
            answerText = Game.FormatTags(answerText, textArgs, talker);

            answersOneLine += answerText;
            answersOneLine += i < answerTextIds.length() - 1 ? "\n" : "";
        }

        // Прокидываем контекст диалога в AI-мост до показа экрана: params внутри ShowScreen
        // опустошается, поэтому захватываем текст/ответы из источника.
        AiControl::SetDialogState(dialogId, talkerId, text, answersOneLine);

        dict<string, any> params = {};
        params["TalkerIsNpc"] = talkerId != ZERO_IDENT;
        params["TalkerId"] = talkerId != ZERO_IDENT ? any(talkerId) : any();
        params["Text"] = text;
        params["Answers"] = answersOneLine;
        params["TalkTime"] = duration;

        Gui::ShowScreen(GuiScreen::Dialog, params);
    }
    else {
        AiControl::ClearDialogState();
        Gui::HideScreen(GuiScreen::Dialog);
    }
}

#endif

}
