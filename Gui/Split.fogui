//     {
//       "$type": "Text",
//       "Text": null,
//       "DynamicText":
{
    {
        {
            Split @split = cast<Split>(Screen);
            int count = split.SplitCount;
            string result;
            if (count >= 10000) {
                return "" + count;
            }
            else if (count >= 1000) {
                return "0" + count;
            }
            else if (count >= 100) {
                return "00" + count;
            }
            else if (count >= 10) {
                return "000" + count;
            }
            else {
                return "0000" + count;
            }
        }
    }
}
