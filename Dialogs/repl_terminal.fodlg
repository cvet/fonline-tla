[Dialog]
Speech 1 # Преддиалоговые установки
  Answer 2 # ---

Speech 2 # Вас приветствует терминал для операций над репл...
  Script ReplicationTerminal::dlg_Reset
  Answer 3 # [Пополнить свой счет]
    Result Script ReplicationTerminal::r_PaySelf
  Answer 6 # [Снять деньги со счета]
  Answer 7 # [Пополнить счет другого клиента]
    Result Property Player TerminalPlayerId = 0
  Answer Exit # [Выйти]

Speech 3 # Какую сумму желаете внести на счет?
  Script ReplicationTerminal::dlg_TransferReal
  Answer Back # [Назад]
  Answer Exit # [Выход]

Speech 4 # Какую сумму желаете внести на счет другого клие...
  Script ReplicationTerminal::dlg_TransferReal
  Answer Back # [Назад]
  Answer Exit # [Выход]

Speech 5 # Какую сумму желаете перечислить с вашего счета ...
  Script ReplicationTerminal::dlg_TransferVirtual
  Answer Back # [Назад]
  Answer Exit # [Выход]

Speech 6 # Какую сумму желаете снять со счета?
  Script ReplicationTerminal::dlg_TakeMoney
  Answer Back # [Назад]
  Answer Exit # [Выход]

Speech 7 # Введите имя клиента.
  Script ReplicationTerminal::dlg_ChoosePlayer
  Answer Back # [Назад]
  Answer Exit # [Выход]
    Result Script ReplicationTerminal::r_ChoosePlayerResult

Speech 8 # Выберите способ передачи денег.
  Answer 4 # [Наличные]
  Answer 5 # [Перечисление со своего счета]
  Answer Back # [Назад]
  Answer Exit # [Выход]

