{
    {
        {
            // Data[ 1 ]  -  start level
            Elevator elevator = cast<Elevator>(GuiScreensExt::NeedScreen(Screen));
            CurPlayer.ServerCall.Rpc_SelectLevel(int(elevator.Data[1]) + Index, 0, 0);
            Gui::HideScreen();
        }
    }
