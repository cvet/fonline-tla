{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Format Scripts",
            "type": "shell",
            "command": "${workspaceFolder}/FormatSource.bat",
            "windows": {
                "command": "${workspaceFolder}/FormatSource.bat"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Generate GuiScreens.fos",
            "type": "shell",
            "command": "${workspaceFolder}/Tools/InterfaceEditor/InterfaceEditor.exe",
            "windows": {
                "command": "${workspaceFolder}/Tools/InterfaceEditor/InterfaceEditor.exe",
                "args": [
                    "-SilentGenerate"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Update Scripts And Gui",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Format Scripts",
                "Generate GuiScreens.fos"
            ],
            "problemMatcher": []
        },
        {
            "label": "BakeResources",
            "type": "shell",
            "command": "cmake",
            "windows": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "BakeResources"
                ]
            },
            "linux": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "BakeResources"
                ]
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build TLA_Server",
            "type": "shell",
            "command": "cmake",
            "windows": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "TLA_Server"
                ]
            },
            "linux": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "TLA_Server"
                ]
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Prepare TLA_Server",
            "dependsOrder": "sequence",
            "dependsOn": [
                "BakeResources",
                "Build TLA_Server"
            ],
            "problemMatcher": []
        },
        {
            "label": "Prepare TLA_ServerHeadless",
            "dependsOrder": "sequence",
            "dependsOn": [
                "BakeResources",
                "Build TLA_ServerHeadless"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build TLA_ServerHeadless",
            "type": "shell",
            "command": "cmake",
            "windows": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "TLA_ServerHeadless"
                ]
            },
            "linux": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "TLA_ServerHeadless"
                ]
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build TLA_UnitTests",
            "type": "shell",
            "command": "cmake",
            "windows": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "TLA_UnitTests"
                ]
            },
            "linux": {
                "args": [
                    "--build",
                    "${workspaceFolder}/Build/Auto",
                    "--config",
                    "RelWithDebInfo",
                    "--target",
                    "TLA_UnitTests"
                ]
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Prepare TLA_UnitTests",
            "dependsOrder": "sequence",
            "dependsOn": [
                "BakeResources",
                "Build TLA_UnitTests"
            ],
            "problemMatcher": []
        }
    ]
}
