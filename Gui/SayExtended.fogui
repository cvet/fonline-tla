//   "OnShow":
{
    {
        {
            if (params != null && params.length() > 0) {
                HeaderMessageID = params["MsgHeaderId"];
                if (params.length() > 4) {
                    InputMessageID = params["InputMessageID"];
                    ProtoID = params["ProtoID"];
                    HexX = params["HexX"];
                    HexY = params["HexY"];
                    FromScenery = true;
                }
                else {
                    FromScenery = false;
                }
            }
        }
    }
}
