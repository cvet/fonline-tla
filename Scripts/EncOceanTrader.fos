// EncOceanTrader — серверный энкаунтерный океанский торговец.
// Обязанности: инициализация торговца и охранника, периодическое умерщвление по таймеру, отметка недоступности энкаунтера при смерти. Сторона: SERVER.
// Связи: CritterState, GameProps (EncOceanTraderAlive), Worldmap.
namespace EncOceanTrader
{

#if SERVER

const timespan DeathTime = Time::Minutes(50);

// Инициализация торговца: запрет репликации и кражи, запуск таймера смерти.
// Если этого торговца убить, то его уже нельзя будет встретить на глобале.
void TraderInit(Critter npc, bool firstTime)
{
    npc.ReplicationTime = -1;
    npc.IsNoSteal = true;
    npc.StartTimeEvent(DeathTime, HeartAttack);
    npc.OnDead.Subscribe(TraderDead);
}

// При смерти торговца помечаем энкаунтер недоступным на глобальной карте.
[[Event]]
void TraderDead(Critter npc, Critter killer)
{
    Game.EncOceanTraderAlive = false;
}

// Периодическое умерщвление по таймеру: «сердечный приступ» убивает торговца и перезапускает таймер.
[[TimeEvent]] [[Async]]
void HeartAttack(Critter cr, TimeEventContext event)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    if (!cr.IsDead()) {
        CritterState::ToDead(cr, CritterActionAnim::DeadFront, null);
    }

    timespan delayTicks = DeathTime;
    if (delayTicks != ZERO_TIMESPAN) {
        event.Repeat(delayTicks);
    }
}

// Инициализация охранника: запрет репликации и боевые параметры рукопашной.
void AmericaInit(Critter npc, bool firstTime)
{
    npc.ReplicationTime = -1;
    npc.MeleeDamageBase += 5;
    npc.CriticalChanceBase = 50;
    npc.SkillUnarmed = 150;
}

#endif

}
