  "IsNotHittable": false,
  "CheckTransparentOnHit": false,
  "GlobalScope": null,
  "ClassFields": "ident RadioId;",
  "OnInit": null,
  "OnShow": "\r\nRadioId   = params[\"ItemId\"];\r\nauto checkbox = cast<Gui::CheckBox>(Find(\"BroadcastOnOff\"));\r\ncheckbox.SetChecked (Radio::GetRadioActivity(RadioId, true));\r\ncheckbox = cast<Gui::CheckBox>(Find(\"ReceiveOnOff\"));\r\ncheckbox.SetChecked (Radio::GetRadioActivity(RadioId, false));\r\nItem item = Radio::GetItemRadio(RadioId);\r\n\r\nif (item == null) {\r\n    Gui::HideScreen();\r\n    return;\r\n}\r\n\r\nauto channelTextBox = cast< ChannelNumber >( Find( \"ChannelNumber\" ) );\r\nchannelTextBox.SetChannel(item.Radio.Channel);\r\n\r\n\r\nint broadcast = 0;\r\nif (item.Radio.Broadcast == RadioBroadcastType::Zone) {\r\n    broadcast = (item.Radio.BroadcastZones == Settings.RadioBroadcastZones1 ? 1 : 2);\r\n}\r\nelse if (item.Radio.Broadcast == RadioBroadcastType::Location) {\r\n    broadcast = 3;\r\n}\r\nelse if (item.Radio.Broadcast == RadioBroadcastType::Map) {\r\n    broadcast = 4;\r\n}\r\n\r\nauto switcher          = cast< SwitchBroadcast >( Find( \"SwitchBroadcast\" ) );\r\nswitcher.BroadCastType = broadcast;\r\nswitcher.SetBackgroundImage(\"art/intrface/Radio/radio_dial\" + broadcast + \".png\");\r\n",
  "OnHide": null,
