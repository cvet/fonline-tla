[[ModuleInit]]
void InitClientMain()
{
    Game.OnStart.Subscribe(start);
    Game.OnFinish.Subscribe(finish);
    Game.OnLoop.Subscribe(loop);
    Game.OnMouseMove.Subscribe(MouseMove);
    Game.OnRenderIface.Subscribe(RenderIface);
    Game.OnCritterIn.Subscribe(CritterIn);
    Game.OnCritterOut.Subscribe(CritterOut);
    Game.OnItemMapIn.Subscribe(ItemMapIn);
    // OnItemMapChanged removed
    Game.OnItemMapOut.Subscribe(ItemMapOut);
    Game.OnItemInvIn.Subscribe(ItemInvIn);
    // OnItemInvChanged removed
    Game.OnItemInvOut.Subscribe(ItemInvOut);
    Game.OnContainerChanged.Subscribe(ContainerChanged);
    Game.OnCritterAction.Subscribe(CritterAction);
    Game.OnCritterActionEx.Subscribe(CritterAction);
    Game.OnItemsCollection.Subscribe(ItemsCollection);
    Game.OnScreenSizeChanged.Subscribe(OnScreenSizeChanged);
    Game.OnInfoMessage.Subscribe(OnInfoMessage);
}

// Call on client loaded or new client_main.fos script received.
[[Event]]
void start()
{
    Game.BindFont(FontType::Default, "Fonts/Default.fofnt");
    Game.BindFont(FontType::OldFo, "Fonts/OldDefault.fofnt");
    Game.BindFont(FontType::Num, "Fonts/Numbers.fofnt");
    Game.BindFont(FontType::BigNum, "Fonts/BigNumbers.fofnt");
    Game.BindFont(FontType::SandNum, "Fonts/SandNumbers.fofnt");
    Game.BindFont(FontType::Special, "Fonts/Special.fofnt");
    Game.BindFont(FontType::Thin, "Fonts/Thin.fofnt");
    Game.BindFont(FontType::Fat, "Fonts/Fat.fofnt");
    Game.BindFont(FontType::Big, "Fonts/Big.fofnt");
    Gui::EngineCallback_Start();

    Gui::AddDragAndDropHandler(ItemsDragAndDropHandler);

    // ClientScreenTest::InitTestScreen();

    ChosenTabs::InitChosenTabs();

    // Temporarily disabled: after engine bump video playback covers the framebuffer with a stuck/empty texture.
    // Game.PlayVideo("video/TheLifeAfterIntro.ogv|video/TheLifeAfterIntro.ogg", true, false);
    // Game.PlayVideo("video/TheLifeAfterIntroSlide.ogv|video/TheLifeAfterIntroSlide" + (Settings.Client.Language == "russ" ? "RU" : "EN") + ".ogg", true, true);
}

// Call on client finish.
[[Event]]
void finish()
{
    //
}

// Main loop function. Next call every cycle.
nanotime MouseStayTick = ZERO_NANOTIME;

[[Event]]
void loop()
{
    // Description under cursor
    if (Gui::Cursor == CursorType::Default && Game.FrameTime - Time::Milliseconds(1200) >= MouseStayTick && MouseStayTick != ZERO_NANOTIME) {
        MouseStayTick = ZERO_NANOTIME;
        Gui::Screen? screen = Gui::GetActiveScreen();
        if (screen == null) {
            return;
        }

        Item? item;
        Critter? cr;

        Gui::Object? hoveredObj = screen.FindMouseHit();
        if (hoveredObj != null) {
            Gui::ItemView? itemView = hoveredObj.Grid != null ? cast<Gui::ItemView?>(hoveredObj.Grid) : null;
            if (itemView != null) {
                item = itemView.GetItem(hoveredObj.CellIndex);
            }
        }
        else if (HasCurMap && !screen.IsModal) {
            Entity? entity = CurMap.GetEntityAtScreenPos(Game.MousePos);
            item = cast<Item>(entity);
            cr = cast<Critter>(entity);
        }

        if (item != null) {
            Messaging::Info(ItemDescription(item, ItemLookTypes::OnlyName));
        }
        else if (cr != null) {
            Messaging::Info(CritterDescription(cr, CritterLookTypes::LookShort));
        }
    }

    Gui::EngineCallback_Loop();
}

[[Event]]
void MouseMove(ipos offset)
{
    if (Gui::Cursor == CursorType::Default) {
        MouseStayTick = Game.FrameTime;
    }
    else {
        MouseStayTick = ZERO_NANOTIME;
    }
}

// Render interface function. You can use Draw* functions only there.
// Layer specification:
//    1
// Game map
//    2, 3
// PopUp menu, Cursor
//    4
//
// Extra layers:
// Global map
//    100 (over map), 101 (over all)
[[Event]]
void RenderIface()
{
    if (Gui::IsScreenActive(GuiScreen::Game) && HasCurMap) {
        CurMap.DrawMap();
    }

    Game.OnPreRenderIface.Fire();
    ChosenTabs::DrawChosenTabs();
    if (HasCurMap) {
        CritterIcons::DrawIcons();
    }

    Gui::EngineCallback_Draw();

    Game.OnPostRenderIface.Fire();

    string version = Settings.Common.GitBranch == "master" ? "v" + Settings.Common.GameVersion : "WIP " + Settings.Common.GitBranch;
    Game.DrawText("FOnline TLA " + version, ipos(50, 10), isize(), Color::White, TextFormat(FontType::Default, FontFlag(0), 0));

    // Help info
    if (Settings.Client.HelpInfo) {
        // About
        string aboutText = "FOnline " + (Settings.Game.Singleplayer ? "Singleplayer" : "") + "\n" + "by Gamers for Gamers\n" + "version " +
                           Settings.Common.GameVersion + "\n" + "\n" + "Traffic, bytes:\n" + "Send: " + "" + "\n" + "Receive: " + "" + "\n" +
                           "Sum: " + ("".toInt() + "".toInt()) + "\n" + "\n" + "FPS: " + Settings.Render.FixedFPS + " (" +
                           (!Settings.Render.VSync ? "" + math::abs(Settings.Render.FixedFPS) : "VSync") +
                           (!Settings.Render.VSync && Settings.Render.FixedFPS < 0 ? ", sleep" : "") + ")\n" + "Ping: " + Settings.ClientNetwork.Ping + "\n" +
                           "\n" + "Sound: " + Settings.Audio.SoundVolume + "\n" + "Music: " + Settings.Audio.MusicVolume + "\n";
        if (Settings.Gui.DebugInfo) {
            Gui::Object[] focusedObjects = Gui::GetFocusedObjects();
            Gui::Object? pressedObject = Gui::GetPressedObject();
            Gui::Object? hoveredObject = Gui::GetHoveredObject();
            aboutText += "\n" + "Focused object: " + (!focusedObjects.isEmpty() ? focusedObjects.first().Name + " (" + focusedObjects.length() + ")" : "None") +
                         "\n" + "Pressed object: " + (pressedObject != null ? pressedObject.Name : "None") + "\n" +
                         "Hovered object: " + (hoveredObject != null ? hoveredObject.Name : "None");
        }

        Game.DrawText(aboutText,
                      ipos(30, 30),
                      isize(Settings.View.ScreenWidth, Settings.View.ScreenHeight),
                      ucolor(187, 187, 187),
                      TextFormat(FontType::Big, FontFlag(0), 0));

        // Help
        Game.DrawText(MsgStr::GetGameText(MsgStr::StrGameHelp),
                      ipos(0, 0),
                      isize(Settings.View.ScreenWidth, Settings.View.ScreenHeight),
                      Color::White,
                      TextFormat(FontType::Default, FontFlag(int(FontFlag::CenterX) | int(FontFlag::CenterY)), 0));
    }

    // Zoom text
    if (Settings.View.MapZoomEnabled && Settings.View.MapZoomInProgress && HasCurMap) {
        string zoomText = MsgStr::GetGameText(MsgStr::StrZoom);
        zoomText = Game.ReplaceText(zoomText, "%d", "" + int(1.0 / CurMap.SpritesZoom * 100.0));
        zoomText = Game.ReplaceText(zoomText, "%%", "%");
        Game.DrawText(zoomText,
                      ipos(0, 0),
                      isize(Settings.View.ScreenWidth, Settings.View.ScreenHeight),
                      Color::Sand,
                      TextFormat(FontType::Big, FontFlag(int(FontFlag::CenterX) | int(FontFlag::CenterY)), 0));
    }

    Gui::EngineCallback_DrawCursor();

    /*
       else if( layer == 100 && Settings.GmapActive )
       {
        // Here you can draw on global map

        // bool  Settings.GmapActive - активна ли глобальная карта и все ли следующие нижеприведенные переменные корректны;
        // bool  Settings.GmapWait   - включен режим ожидания ответа о подтверждении энкаунтера;
        // float Settings.GmapZoom   - текущий масштаб, не забывайте учитывать его при рисовании на карте;
        // int   Settings.GmapOffsetX/Y   - смещение карты от нулевой координаты (верхний-левый угол);
        // int   Settings.GmapGroupCurX/Y - координаты группы игрока;
        // int   Settings.GmapGroupToX/Y  - координаты точки назначения;
        // float Settings.GmapGroupSpeed  - текущая скорость передвижения.
        // Для примера, расчет текущего пикселя группы:
        // x = Settings.GmapGroupX / Settings.GmapZoom + Settings.GmapOffsetX, y = Settings.GmapGroupY / Settings.GmapZoom + Settings.GmapOffsetY.
       }
     */
}

// Called on something critter in/out game.
[[Event]]
void CritterIn(Critter cr)
{
    if (cr.ControlledByPlayer) {
        cr.SetName(cr.DisplayName);
    }
    else {
        cr.SetName(CritterDescription(cr, CritterLookTypes::OnlyName));
    }

    if (!cr.IsChosen) {
        cr.NameOffset = -10;
    }

    cr.SexTagFemale = cr.Gender == GenderType::Female;

    if (cr.IsChosen) {
    }

    // For correct dialog formatting (male/female)
    cr.SexTagFemale = cr.Gender == GenderType::Female;
}

