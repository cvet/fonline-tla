// clang-format on

// Возвращает имя ресурса анимации для модели криттера.
// Для путей вида "art/critters/<6 символов>": сначала пробуем алиас из CritterTypes,
// иначе — подмену из словаря anims. Если подмены нет, отдаём исходное имя без изменений.
hstring GetCritterAlias(hstring modelName)
{
    string name = modelName;

    if (name.substr(0, 13) == "art/critters/") {
        name = name.substr(13, 6);

        CritterTypes::CritterType? crType = CritterTypes::GetCritterType(name);
        if (crType != null) {
            CritterTypes::CritterType? aliasType = crType.AliasType();
            if (aliasType != null) {
                return ("art/critters/" + aliasType.Name + "aa.frm").hstr();
            }
        }

        if (anims.exists(name)) {
            return ("art/critters/" + anims.get(name) + "aa.frm").hstr();
        }
    }

    return modelName;
}

// Возвращает базовое имя модели, по которому подбираются звуки криттера.
// Для путей "art/critters/<6 символов>" отдаёт донора из словаря anims, если он есть.
string GetCritterSound(hstring modelName)
{
    string name = modelName;
    if (name.substr(0, 13) == "art/critters/") {
        name = name.substr(13, 6);
        if (anims.exists(name)) {
            return anims.get(name);
        }
    }

    return name;
}

// Проверяет, есть ли у типа криттера анимация под указанное оружие (weaponAnim).
// Если тип не определён — анимации нет.
bool IsCritterStateAnim(Critter cr, int weaponAnim)
{
    auto crType = CritterTypes::GetCritterType(cr);
    if (crType != null) {
        return crType.HasAnim(weaponAnim);
    }

    return false;
    // breadcrumb миграции: прежняя проверка по таблице cr.Anims до перехода на CritterTypes
    // return cr.Anims[ weaponAnim - 1 ];
}

