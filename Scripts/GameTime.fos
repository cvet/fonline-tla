// Возвращает представление времени в виде строки в формате dd.mm.yy hh:mm.
string SynchronizedTimeToString(synctime gameTime)
{
    int year = 0;
    int month = 0;
    int day = 0;
    int hour = 0;
    int minute = 0;
    int second = 0;
    int millisecond = 0;
    Game.UnpackSynchronizedTime(gameTime, year, month, day, hour, minute, second, millisecond);

    return "" + (day > 9 ? ("" + day) : ("0" + day)) + "." + (month > 9 ? ("" + month) : ("0" + month)) + "." + year + " " +
           (hour > 9 ? ("" + hour) : ("0" + hour)) + ":" + (minute > 9 ? ("" + minute) : ("0" + minute));
}

