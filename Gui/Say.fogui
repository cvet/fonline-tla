{
    {
        // Окно вызвано из интерфейса диалога
        bool FromDialog;
        //Признак: не выводить введенный текст в лог
        bool DontShowMessage;
        bool TalkerIsNpc;
        ident TalkerId;
    }
}
//   "OnInit": null,
