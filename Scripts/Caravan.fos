}

[[DialogResult]]
void SaveCaravanId(Critter player, Critter? npc, any caravanId)
{
    if (npc != null) {
        auto lastSelectCaravan = player.LastSelectedCaravan.clone();
        lastSelectCaravan[npc.Id] = caravanId;
        player.LastSelectedCaravan = lastSelectCaravan;
    }
}

// lex name. lex where
void WhereIsCaravaner(Critter player, Critter? npc, string& textArgs)
{
    if (!Tla::IsDialogGenerated(textArgs)) {
        return;
    }

    if (npc == null) {
        return;
    }

    auto lastSelectCaravan = player.LastSelectedCaravan;
    if (!lastSelectCaravan.exists(npc.Id)) {
        return;
    }

    textArgs = "|name:этот караванщик|where:черт его знает куда. Не могу понять";
    CaravanInfo? crv = GetCaravan(lastSelectCaravan[npc.Id]);
    if (crv != null) {
        Critter? cr = crv.Leader.GetLeader();
        if (cr != null) {
            textArgs = "|name:" + MsgStr::NpcNameTag(cr.DialogId);
            Map? map = cr.GetMap();
            if (map != null) {
                Location loc = map.GetLocation();
                if (!loc.AutoGarbage) {
                    textArgs += "|where:" + MsgStr::LocNameTag(loc.ProtoId);
                    return;
                }
            }

            textArgs += "|where: Пустошь, их координаты: " + cr.WorldPos.x + ":" + cr.WorldPos.y;
        }
    }
}

