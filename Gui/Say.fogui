//       "OnLMouseClick":
{
    {
        {
            string inputText = Screen.FindText("MainSayText").Text;
            if (!cast<Say>(Parent).DontShowMessage) {
                Messaging::Info(inputText);
            }
            //Game.CustomCall( "ScreenSay_" + inputText );
            Critter @chosen = Game.GetChosen();
            if (chosen is null) {
                Gui::HideScreen();
                return;
            }
            if (chosen.CanSendSay) {
                Game.CurPlayer.ServerCall.Rpc_ProcessSay(inputText, cast<Say>(Parent).FromDialog, cast<Say>(Parent).TalkerId, cast<Say>(Parent).TalkerIsNpc);
            }
            Gui::HideScreen();
        }
    }
}
