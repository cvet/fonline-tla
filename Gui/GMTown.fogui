{
    {
        {
            GMTown @gmTown = cast<GMTown>(Screen);
            ident locId = gmTown.LocId;
            int entrance = gmTown.IndexMaps[CellIndex];
            Game.CurPlayer.ServerCall.ProcessGlobalMapCommand(10, locId, entrance); //GM_CMD_VIEW_MAP
        }
    }
}
