//       "ClassFields":
{
    {
        int BroadCastType = 0;

        void SwitchBroadCast(bool reverse)
        {
            if (reverse) {
                BroadCastType--;
                if (BroadCastType < 0) {
                    BroadCastType = 4;
                }
            }
            else {
                BroadCastType++;

                if (BroadCastType > 4) {
                    BroadCastType = 0;
                }
            }
            SetBackgroundImage("art/intrface/Radio/radio_dial" + BroadCastType + ".png");
            Radio::ChangeRadioBroadcastType(cast<Radio>(Parent).RadioId, BroadCastType);
        }
    }
}
