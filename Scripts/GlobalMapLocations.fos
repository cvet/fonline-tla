// GlobalMapLocations — данные о локациях глобальной карты и их синхронизация сервер→клиент.
// SERVER: собирает список известных криттеру локаций (и параметры группы) и шлёт их клиенту
//   через RemoteCall при входе на глобалку, начальной инфо и изменении KnownLocations.
// CLIENT: хранит полученные локации, ищет локацию под курсором и инициирует вход в неё.
// Связи: Location (валидация известных локаций), GlobalmapGroup (группа на глобальной карте),
//   Serializator (упаковка/распаковка передаваемых данных), Flags (битовые флаги набора данных).
namespace GlobalMapLocations
{

#if SERVER || CLIENT

///@ RemoteCall Client GetGlobalMapData(int32 flags, uint8[] data)

// Битовые флаги: какие порции данных глобальной карты пакуются и передаются клиенту.
const int GM_INFO_LOCATIONS = 0x01;
const int GM_INFO_CRITTERS = 0x02;
const int GM_INFO_GROUP_PARAM = 0x04;
const int GM_INFO_ZONES_FOG = 0x08;
const int GM_INFO_ALL = 0x0F;
const int GM_INFO_FOG = 0x10;
const int GM_INFO_LOCATION = 0x20;

// На клиенте неизвестен класс Location, поэтому данные о локациях передаются отдельной структурой.
class LocationData
{
#if SERVER
    LocationData(Location loc)
    {
        LocId = loc.Id;
        LocPid = loc.ProtoId;
        LocWx = loc.WorldPos.x;
        LocWy = loc.WorldPos.y;
        Radius = loc.Radius;
        Color = loc.Color;
    }
#endif

    ident LocId;
    hstring LocPid;
    int LocWx;
    int LocWy;
    int Radius;
    ucolor Color;

    void Save(Serializator::Serializator save)
    {
        save.Set(LocId);
        save.Set(LocPid);
        save.Set(LocWx);
        save.Set(LocWy);
        save.Set(Radius);
        save.Set(Color);
    }

    void Load(Serializator::Serializator load)
    {
        load.Get(LocId);
        load.Get(LocPid);
        load.Get(LocWx);
        load.Get(LocWy);
        load.Get(Radius);
        load.Get(Color);
    }

    string ToString()
    {
        return "LocPid: " + LocPid + "; LocId: " + LocId + "; LocWx: " + LocWx + "; LocWy: " + LocWy + "; Radius: " + Radius + "; Color: " + Color;
    }
};

#if SERVER

// Подписка на события, при которых клиенту нужно переотправить данные глобальной карты.
[[ModuleInit]]
void InitGlobalMapLocations()
{
    Game.OnGlobalMapCritterIn.Subscribe(OnGlobalMapCritterIn);
    Game.OnCritterSendInitialInfo.Subscribe(OnCritterSendInitialInfo);

    Game.AddPropertySetter(CritterProperty::KnownLocations, OnPlayerSetKnownLocations);
}

// При смене списка известных локаций обновляем их у криттера, только если он на глобалке (без карты).
[[PropertySetter]]
void OnPlayerSetKnownLocations(Critter cr)
{
    if (cr.GetMap() == null) {
        SetGlobalMapData(GM_INFO_LOCATIONS, cr);
    }
}

// При начальной отправке инфо криттеру, находящемуся на глобалке, шлём весь набор данных карты.
[[Event]]
void OnCritterSendInitialInfo(Critter cr)
{
    if (cr.GetMap() == null) {
        SetGlobalMapData(GM_INFO_ALL, cr);
    }
}

// При входе криттера на глобальную карту обновляем у клиента список локаций.
[[Event]]
void OnGlobalMapCritterIn(Critter cr)
{
    SetGlobalMapData(GM_INFO_LOCATIONS, cr);
}

// Пакует запрошенные флагами порции данных глобальной карты и отправляет их клиенту криттера.
void SetGlobalMapData(int flags, Critter cr)
{
    auto save = Serializator::Serializator();

    if (Flags::HasFlag(flags, GM_INFO_LOCATIONS)) {
        Location::ValidateKnownLocations(cr);

        ident[] locations = cr.KnownLocations.clone();
        save.Set(locations.length());
        for (int i = 0, l = locations.length(); i < l; i++) {
            Location? loc = Game.GetLocation(locations[i]);
            if (loc != null) {
                auto locData = LocationData(loc);
                locData.Save(save);
            }
        }
    }

    if (Flags::HasFlag(flags, GM_INFO_GROUP_PARAM)) {
        auto group = GlobalmapGroup::GetGlobalMapGroup(cr);
        group.Save(save);
    }

    cr.PlayerClientCall.GetGlobalMapData(flags, save.GetData());
}

#endif

#if CLIENT

// Полученные с сервера локации глобальной карты (клиент не знает класс Location).
LocationData[] GMLocations = {};

// Возвращает мировые координаты первой локации с заданным прото-id; false — если такой нет.
bool GetLocationCoordinates(hstring locPid, int& locWx, int& locWy)
{
    for (int i = 0, l = GMLocations.length(); i < l; i++) {
        if (GMLocations[i].LocPid == locPid) {
            locWx = GMLocations[i].LocWx;
            locWy = GMLocations[i].LocWy;
            return true;
        }
    }

    return false;
}

// Возвращает локацию под точкой (x, y) — первую, в чей радиус попадает точка; null — если ни одной.
LocationData ? GetHoveredLocationData(int x, int y) //TODO: проверить, почему так часто вызывается
{
    for (int i = 0, l = GMLocations.length(); i < l; i++) {
        auto locInfo = GMLocations[i];
        // TODO: проверка наложения локаций
        if (int(math::sqrt(float(Math::Pow2(x - locInfo.LocWx) + Math::Pow2(y - locInfo.LocWy)))) <= locInfo.Radius) {
            return locInfo;
        }
    }

    return null;
}

// Принимает с сервера упакованные данные глобальной карты и распаковывает запрошенные флагами порции.
[[ClientRemoteCall]]
void GetGlobalMapData(int flags, uint8[] data)
{
    auto load = Serializator::Serializator();
    if (load.SetData(data) == 0) {
        return;
    }

    if (Flags::HasFlag(flags, GM_INFO_LOCATIONS)) {
        GMLocations.clear();
        int count = 0;
        load.Get(count);
        for (int i = 0; i < count; i++) {
            auto locData = LocationData();
            locData.Load(load);
            GMLocations.insertLast(locData);
        }
    }

    if (Flags::HasFlag(flags, GM_INFO_GROUP_PARAM)) {
        GlobalmapGroup::LoadGlobalMapGroupData(load);
    }
}

// Пытается войти в локацию под текущей позицией группы; работает, только когда группа стоит (не движется и не в энкаунтере).
bool TryEnterHoveredLocation()
{
    ident locId = ZERO_IDENT;
    auto group = GlobalmapGroup::GetCurrentGroup();
    if (!group.IsMoving && !group.IsEncounter) {
        auto locInfo = GetHoveredLocationData(group.CurX, group.CurY);
        if (locInfo != null) {
            locId = locInfo.LocId;
        }
    }

    if (locId != ZERO_IDENT) {
        GlobalmapGroup::RuleGlobalCommand(3, locId, 0);
        return true;
    }

    return false;
}

#endif

#endif

}
