#if CLIENT
string NpcName(hstring dlg, hstring pid)
{
    if (dlg != EMPTY_HSTRING && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (dlg.uhash + 10)))) {
        return Game.GetText(TextPackKey(TextPackName::Dialogs, "" + (dlg.uhash + 10)));
    }
    else {
        return Game.GetText(TextPackKey(TextPackName::Critters, "" + (pid.uhash)));
    }
}

string NpcDesc(hstring dlg, hstring pid)
{
    if (dlg != EMPTY_HSTRING && Game.IsTextPresent(TextPackKey(TextPackName::Dialogs, "" + (dlg.uhash + 21)))) {
        return Game.GetText(TextPackKey(TextPackName::Dialogs, "" + (dlg.uhash + 21)));
    }
    else {
        return Game.GetText(TextPackKey(TextPackName::Critters, "" + (pid.uhash + "Desc".hstr().uhash)));
    }
}
#endif
}
