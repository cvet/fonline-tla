// Items
Item? GetCritterHandItem(Critter cr)
{
    return cr.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main);
}
Item? GetCritterOffHandItem(Critter cr)
{
    return cr.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Secondary);
}
Item? GetCritterArmorItem(Critter cr)
{
    return cr.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Armor);
}
bool CanCritterDropItemsOnDead(Critter cr)
{
    return !cr.IsNoSteal && !cr.IsNoDrop;
}

// Parameters
bool IsCritterInjured(Critter cr)
{
    return cr.IsDamagedEye || cr.IsDamagedRightArm || cr.IsDamagedLeftArm || cr.IsDamagedRightLeg || cr.IsDamagedLeftLeg;
}
int CritterFingersDoorId(ident critterId)
{
    return int(0x80000000 | critterId.value);
}
int CritterEyesDoorId(ident critterId)
{
    return int(0x40000000 | critterId.value);
}

