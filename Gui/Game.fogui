//   "OnGlobalMouseDown":
{
    {
        {
            if (Settings.MapZoomEnabled && Settings.MapZoomInProgress) {
                if (button == MouseButton::WheelUp) {
                    Game.CurMap.ChangeZoom(Game.CurMap.SpritesZoom - 0.01);
                }
                else if (button == MouseButton::WheelDown) {
                    Game.CurMap.ChangeZoom(Game.CurMap.SpritesZoom + 0.01);
                }
                else if (button == MouseButton::Middle) {
                    Game.CurMap.ChangeZoom(1.0);
                }
            }

            if (GetChild(0).FindMouseHit() is null) {
                if (button == MouseButton::Left) {
                    GameLMouseDown();
                }
                else if (button == MouseButton::Right) {
                    isHitIfaceOnMouseDown = (FindMouseHit() !is null);
                }
            }
        }
    }
}
//   "OnGlobalMouseUp":
{
    {
        {
            if (GetChild(0).FindMouseHit() is null) {
                if (button == MouseButton::Left) {
                    GameLMouseUp();
                }
                else if (button == MouseButton::Middle) {
                    Critter @cr = Game.CurMap.GetCritterAtScreenPos(Game.MousePos);
                    if (cr != null && cr.IsChosen) {
                        ChosenActions::SetChosenActions({Tla::ChosenDir, (Input::IsShiftDown() ? 1 : 0), 0, 0, 0, 0, 0});
                    }
                }
                else if (button == MouseButton::Right && !isHitIfaceOnMouseDown) {
                    GuiScreensExt::NextCursor();
                }
            }
        }
    }
}
