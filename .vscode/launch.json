            "request": "launch",
            "preLaunchTask": "Prepare TLA_Server",
            "program": "${workspaceFolder}/Binaries/Server-Linux-x64/TLA_Server",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb"
        },
        {
            "name": "Launch TLA_UnitTests (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "Prepare TLA_UnitTests",
            "program": "${workspaceFolder}/Binaries/Tests-Linux-x64/TLA_UnitTests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "externalConsole": false,
