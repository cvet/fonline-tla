// Усложненный крафт
// - для отображения в пипбое требуется знание рецепта
// - для производства необходимо находиться рядом со специальным станком
// - у станка может задаваться таймаут на последующее использование. Таймаут сохраняется. Создается также тайм эвент на очистку.
// - если на карте несколько одинаковых станков и у них указан таймаут - у него будет общее значение.

/* У прессов для производства аммуниции и токарных станков есть по несколько изображений, но используется один прототип,
   чтобы не добавлять лишние проверки в скрипт - просто переключайтесь между изображениями через параметр PicMap
   в маппере, название кадра будет то же самое, меняется только цифра в конце.
   Сейчас доступно по два варианта для станков:
   art/scenery/manufact_ammo1.fofrm
   art/scenery/manufact_ammo2.fofrm
   art/scenery/manufact_lathe1.fofrm
   art/scenery/manufact_lathe2.fofrm
 */

///@ Property Map Server hstring=>synctime FixBoyWorkBenchTimeout Mutable Persistent // Таймаут на крафт для станка. Если равен = 0 значит истек.
///@ Property Map Server hstring=>int32 FixBoyWorkBenchCharges Mutable Persistent // Число зарядов станка если =0 запускается таймаут на обновление.

const int DEFAULT_RADIUS = 5;  // Радиус поиска станка в гексах, по умолчанию.
const int DEFAULT_CHARGES = 2; // Число зарядов в станке по умолчанию.
timespan DefaultTimeout(Critter cr)
{
    return Time::GameDays(7 + 10 - cr.Luck);
}
const hstring SCENERY_HUB_WORKBENCH = "generic_4277".hstr();  // Код прототипа сценери для крафта плазменных гранат (Хабологи)
const hstring SCENERY_SHOE_WORKBENCH = "generic_4278".hstr(); // Код прототипа сценери для крафта Ши
const hstring SCENERY_AMMO_PRESS = "generic_4279".hstr();     // Пресс для производства аммуниции (2 вида, различаются изображением терминала)
const hstring SCENERY_LATHE = "generic_4281".hstr();          // Токарный станок (второй вариант - станок на не-ржавом столе)
const hstring SCENERY_WORKBENCH = "generic_4282".hstr();      // Верстак по-умолчанию.
const hstring SCENERY_STOVE = "generic_3200".hstr();          // Печь для плавки хитина
const int STR_NO_WORKBENCH = 300;                             // Для производства требуется находиться рядом со cпециальным станком или верстаком.
const int STR_TIMEOUT = 301;                                  // Станок или верстак в неработоспособном состоянии. Производство невозможно. Попробуйте позже.
const int STR_NO_CHARGES = 302; // Станок или верстак в неработоспособном состоянии. Произведен максимум возможных предметов. Производство невозможно.

/*                РЕЦЕПТЫ                 */

int AnyStuff(Critter player, int state, MainCraft craft)
{
    return Something(player, SCENERY_WORKBENCH, DEFAULT_RADIUS, CritterProperty::FixboyDefault, state, Time::GameHours(2), 100);
}

int SuperSledge(Critter player, int state, MainCraft craft) // Рецепт на изготовление суперкувалды. Ши.
{
    return Something(player, SCENERY_SHOE_WORKBENCH, DEFAULT_RADIUS, CritterProperty::SFRecipeSsupersledge, state, DefaultTimeout(player), DEFAULT_CHARGES);
}

int ChitinArmor(Critter player, int state, MainCraft craft) // Хитиновая броня
{
    if (state == Tla::FixboyList) {
        if (ByRecipe(player, Content::Item::chitin_armor_recipe, state, craft) == FIX_SUCCESS) {
            return FIX_SUCCESS;
        }

        return Something(player, SCENERY_STOVE, 10, CritterProperty::SFChitinArmorRecipeKnown, state, Time::GameDays(1), 1);
    }

    if (state == Tla::FixboyButton) {
        return Something(player, SCENERY_STOVE, 10, CritterProperty::SFChitinArmorRecipeKnown, state, Time::GameDays(1), 1);
    }

    if (state == Tla::FixboyCraft) {
        ByRecipe(player, Content::Item::chitin_armor_recipe, state, craft);
        Something(player, SCENERY_STOVE, 10, CritterProperty::SFChitinArmorRecipeKnown, state, Time::GameDays(1), 1);
        if (player.CountItem(Content::Item::metal_trash) > 3) {
            int chance = 0, luck = player.Luck;
            if (luck > 9) {
                chance = 15;
            }

            if (luck > 7 && luck < 10) {
                chance = 10;
            }

            if (luck > 5 && luck < 8) {
                chance = 5;
            }

            if (AdvancedCraft(player, Content::Item::chitin_armor, Content::Item::chitin_armor_mk_ii, chance, true, 2, state)) {
                player.DestroyItem(Content::Item::metal_trash, 2);
            }
        }
    }

    return FIX_SUCCESS;
}

int PlasmaGrenade(Critter player, int state, MainCraft craft) // Рецепт на изготовление плазменных гранат. Хабологи.
{
    return Something(player, SCENERY_HUB_WORKBENCH, DEFAULT_RADIUS, CritterProperty::SFRecipePlasmagrenades, state, DefaultTimeout(player), 50);
}

int NitroExpress(Critter player, int state, MainCraft craft) // Рецепт на изготовление винтовки .700 калибра, включен по-умолчанию.
{
    return Something(player, SCENERY_LATHE, DEFAULT_RADIUS, CritterProperty::Fixboy700NitroExpress, state, DefaultTimeout(player), 2);
}

int NitroExpressRounds(Critter player, int state, MainCraft craft)
{
    return Something(player, SCENERY_AMMO_PRESS, DEFAULT_RADIUS, CritterProperty::FixboyAmmoPressOperator, state, Time::GameHours(10), 10);
}

int AnyRounds(Critter player, int state, MainCraft craft)
{
    return Something(player, SCENERY_AMMO_PRESS, DEFAULT_RADIUS, CritterProperty::FixboyAmmoPressOperator, state, Time::GameHours(2), 10);
}

/*                РЕЦЕПТЫ                */

// player - крафтящий игрок
// pidWorkbench - код прототипа элемента сценери, служащего станком
// radius - радиус поиска станка
// varNum - номер проверяемой переменной
// state - Fix boy function call state
// timeOut - время в игровых минутах, сколько станок будет простаивать
// charges - максимальное число предметов, которые может изготовить игрок за один таймаут
int Something(Critter player, hstring pidWorkbench, int radius, int varNum, int state, timespan timeOut, int charges)
{
    if (state == Tla::FixboyList) {
        if (!CheckRecipeKnown(player, varNum)) {
            return FIX_FAIL;
        }
    }

    if (state == Tla::FixboyButton) {
        if (!CheckWorkbenchNearPlayer(player, pidWorkbench, radius)) {
            Messaging::Info(player, TextPackKey(TextPackName::Text, "" + (STR_NO_WORKBENCH)));
            return FIX_FAIL;
        }

        if (!CheckWorkbenchTimeOut(player, pidWorkbench, charges)) {
            Messaging::Info(player, TextPackKey(TextPackName::Text, "" + (STR_TIMEOUT)));
            return FIX_FAIL;
        }

        if (!CheckWorkbenchCharges(player, pidWorkbench)) {
            Messaging::Info(player, TextPackKey(TextPackName::Text, "" + (STR_NO_CHARGES)));
            return FIX_FAIL;
        }
    }

    if (state == Tla::FixboyCraft) {
        SetWorkbenchCharges(player, pidWorkbench, charges);
        if (!CheckWorkbenchCharges(player, pidWorkbench)) {
            SetWorkbenchTimeout(player, pidWorkbench, timeOut);
        }
    }

    return FIX_SUCCESS;
}

// Проверка, истек ли таймаут на производство для заданного типа станка на данной карте
// true  - таймаут прошел, или не назначался
// false - таймаут установлен, и еще не истек
bool CheckWorkbenchTimeOut(Critter player, hstring pidWorkbench, int maxCharges)
{
    Map? map = player.GetMap();
    if (map == null) {
        return false;
    }

    synctime time = map.FixBoyWorkBenchTimeout.get(pidWorkbench, ZERO_SYNCTIME);
    if (time == ZERO_SYNCTIME) {
        return true;
    }

    if (Game.SynchronizedTime < time) {
        return false;
    }
    else {
        SetWorkbenchCharges(player, pidWorkbench, maxCharges);
    }

    return true;
}

// Проверяет, есть ли заряды в станке
bool CheckWorkbenchCharges(Critter player, hstring pidWorkbench)
{
    Map? map = player.GetMap();
    if (map == null) {
        return false;
    }

    return map.FixBoyWorkBenchCharges.get(pidWorkbench, 0) > 0;
}

// Проверка, что рядом с игроком находится станок для производства того или иного итема
// pidWorkbench - код прототипа элемента Scenery, который играет роль станка
// radius - максимальное расстояние до станка, в котором должен находиться игрок
bool CheckWorkbenchNearPlayer(Critter player, hstring pidWorkbench, int radius)
{
    Map? map = player.GetMap();
    if (map == null) {
        return false;
    }

    return map.GetStaticItemsInRadius(player.Hex, radius, pidWorkbench).length() > 0;
}

// Проверка, что игроку известен рецепт
// varNum - номер переменной, в которой хранится признак известности рецепта
bool CheckRecipeKnown(Critter player, int varNum)
{
    return player.GetAsInt(CritterProperty(varNum)) == 1;
}

// Установка таймаута на работу станка
// timeout = время, в течении которого станок недоступен, в игровых минутах
void SetWorkbenchTimeout(Critter player, hstring pidWorkbench, timespan timeout)
{
    if (timeout == ZERO_TIMESPAN) {
        return;
    }

    Map? map = player.GetMap();
    if (map == null) {
        return;
    }

    auto fixBoyWorkBenchTimeout = map.FixBoyWorkBenchTimeout.clone();
    fixBoyWorkBenchTimeout[pidWorkbench] = Game.SynchronizedTime + timeout;
    map.FixBoyWorkBenchTimeout = fixBoyWorkBenchTimeout;
}

// Изменение числа зарядов станка
// chargesMax - максимальное число зарядов в станке
void SetWorkbenchCharges(Critter player, hstring pidWorkbench, int chargesMax)
{
    if (chargesMax == 0) {
        return;
    }

    Map? map = player.GetMap();
    if (map == null) {
        return;
    }

    auto fixBoyWorkBenchCharges = map.FixBoyWorkBenchCharges.clone();
    int charges = fixBoyWorkBenchCharges.get(pidWorkbench, 0);
    charges = (charges > 0 ? charges - 1 : chargesMax);
    fixBoyWorkBenchCharges[pidWorkbench] = charges;
    map.FixBoyWorkBenchCharges = fixBoyWorkBenchCharges;
}

/* Крафт с бумажным рецептом, рецепт исчезает после крафта */
int ByRecipe(Critter player, hstring recipePid, int state, MainCraft craft)
{
    if (state == Tla::FixboyList) {
        if (player.CountItem(recipePid) < 1) { // Нет рецепта в инвентаре
            return FIX_FAIL;
        }
    }

    if (state == Tla::FixboyCraft) {
        player.DestroyItem(recipePid, 1); // Удаляем рецепт после крафта
    }

    return FIX_SUCCESS;
}

/* В результате крафта может появиться более продвинутый экземпляр предмета */
/*
   basePid = код предмета, который производит игрок
   advancedPid = код предмета, который получится при проке
   signed = признак, подписывать предмет или нет.
   info - инфо предмета, на которое нужно переключиться
   Подписываются только предметы ARMOR, WEAPON
 */
bool AdvancedCraft(Critter player, hstring basePid, hstring advancedPid, int chance, bool signed, int info, int state)
{
    if (state == Tla::FixboyCraft && Game.Random(0, 100) < chance) {
        any[] values = {player.Id, basePid, advancedPid};
        if (signed) {
            ProtoItem proto = Game.GetProtoItem(advancedPid);
            int type = proto.Type;
            if (type == ItemType::Weapon || type == ItemType::Armor) {
                values.insertLast(any(info));
            }
        }

        Game.StartTimeEvent(ZERO_TIMESPAN, ProcessAdvancedCraft, values);
        return true;
    }

    return false;
}

// Временное событие, убираем скрафченый базовый предмет, заменяем усовершенствованным
[[TimeEvent]]
void ProcessAdvancedCraft(any[] values)
{
    Critter? cr = Game.GetCritter(values[0]);
    if (cr != null) {
        Item? baseItem = cr.GetItem(hstring(values[1]));
        if (baseItem != null) {
            Game.DestroyItem(baseItem, 1);
            Item advItem = cr.AddItem(hstring(values[2]), 1);
            if (values.length() > 3) {
                advItem.Info = values[3];
                advItem.TextArgs = TextFormatting::TextArg("craftername", PlayerRegistration::GetPlayerName(cr.Id));
            }
        }
    }
}

[[ServerRemoteCall]] [[Async]]
void Rpc_CraftItem(Player player, int state, int craftId, int p2)
{
    Critter? cr = player.GetControlledCritter();
    if (cr == null) {
        return;
    }

    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    any[] data = {};
    int strNum = 0;
    if (state == Tla::FixboyList && craftId == 0) {
        for (int i = 0; i < CraftList.length(); i++) {
            MainCraft craft = CraftList[i];
            if (craft.CheckOnView(cr)) {
                data.insertLast(any(craft.Id));
                data.insertLast(any(craft.CheckOnCraft(cr) ? 1 : 0));
                any[] outItems = craft.OutItems;
                data.insertLast(any(outItems.length()));
                for (int j = 0; j < outItems.length(); j++) {
                    data.insertLast(outItems[j]);
                }
            }
        }
    }
    else if (state == Tla::FixboyList && craftId != 0) {
        MainCraft? craft = GetCraft(craftId);
        if (craft == null) {
            return;
        }

        any[] needResources = craft.NeedResources;
        data.insertLast(any(needResources.length()));
        for (int i = 0; i < needResources.length(); i++) {
            data.insertLast(needResources[i]);
        }

        any[] needTools = craft.NeedTools;
        data.insertLast(any(needTools.length()));
        for (int i = 0; i < needTools.length(); i++) {
            data.insertLast(needTools[i]);
        }

        int[] needParams = craft.OnCraft;
        data.insertLast(any(needParams.length()));
        for (int i = 0; i < needParams.length(); i++) {
            data.insertLast(any(needParams[i]));
        }
    }
    else if (state == Tla::FixboyButton) {
        MainCraft? craft = GetCraft(craftId);
        if (craft == null) {
            return;
        }

        strNum = craft.CraftedItem(cr) ? MsgStr::StrFixSuccess : MsgStr::StrFixFail;
    }

    cr.PlayerClientCall.ShowFixBoy(craftId, strNum, 0, data);
}
#endif

#if CLIENT
any[] g_PendingFixBoyData = {};

[[ClientRemoteCall]]
void ShowFixBoy(int craftId, int strNum, int p2, any[] data)
{
    Game.Log("data len:@" + data.length());
    g_PendingFixBoyData = data;
    Gui::HideScreen(GuiScreen::FixBoy);
    Gui::ShowScreen(GuiScreen::FixBoy, dict<string, any> = {{"CraftId", craftId}, {"StrNum", strNum}});
}
#endif

