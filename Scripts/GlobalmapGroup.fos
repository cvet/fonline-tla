[[ModuleInit]]
void InitGlobalmapGroup()
{
    Game.OnGlobalMapCritterIn.Subscribe(OnGlobalMapCritterIn);
    Game.OnGlobalMapCritterOut.Subscribe(OnGlobalMapCritterOut);
    Game.OnCritterInit.Subscribe(OnCritterInit);
    Game.LoadImage(Tla::ImageRelief, "relief_tla.png");
}

[[Event]]
void OnCritterInit(Critter cr, bool firstTime)
{
    cr.StartTimeEvent(Time::Milliseconds(0), Time::Milliseconds(1000), OnCritterIdle);
}

[[TimeEvent]] [[Async]]
void OnCritterIdle(Critter cr)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    // Global map
    if (cr.GetMap() == null) {
        auto group = GetGlobalMapGroup(cr);
        if (!Sync::Lock(group.CritMove)) {
            return;
        }

        if (cr.Id == group.Rule.Id) {
            GroupMove(group);
        }
    }
}

[[Event]]
void OnGlobalMapCritterIn(Critter cr)
{
    int tripId = cr.GlobalMapTripId;

    if (!AllGlobalGroups.exists(tripId)) {
        GlobalMapGroup group = GlobalMapGroup(cr);

        AllGlobalGroups.set(tripId, group);
        GroupStartMove(cr);
    }
    else {
        GlobalMapGroup group = AllGlobalGroups.get(tripId);

        group.CritMove.insertLast(cr);
    }
}

[[Event]]
void OnGlobalMapCritterOut(Critter cr)
{
    int tripId = cr.GlobalMapTripId;
    GlobalMapGroup group = AllGlobalGroups.get(tripId);

    int index = group.CritMove.findByRef(cr);
    verify(index != -1, "Assertion failed");
    group.CritMove.removeAt(index);

    if (!group.CritMove.isEmpty()) {
        if (cr.Id == group.Rule.Id) {
            // Give rule to critter with highest charisma
            Critter newRule;
            int maxCharisma = 0;

            for (int i = 0; i < group.CritMove.length(); i++) {
                Critter cr2 = group.CritMove[i];
                int charisma = cr2.Charisma;

                if (maxCharisma == 0 || charisma > maxCharisma) {
                    newRule = cr2;
                    maxCharisma = charisma;
                }
            }

            group.Rule = newRule;
        }
    }
    else {
        AllGlobalGroups.remove(tripId);
    }
}

// int processType    - see in Global map events in _defines.fos;
// Critter cr        - who called this function, in most times is leader of group;
// Item car          - group car, can be null;
// float curX, curY - current position;
// float toX, toY   - destination position;
// float speed       - speed of group, must set in Tla::GlobalProcessSetMove,
//                      also you can type zero to stop group;
// int encounterDescriptor - if encounterDescriptor != 0 than GlobalInvite calls;
// bool waitForAnswer       - if waitForAnswer == false than GlobalInvite calls after this function,
//                            else call after leader confirm invite;
void GlobalProcess(int processType, Critter cr, Item? car, float& curX, float& curY, float& toX, float& toY, float& speed, int& encounterDescriptor,
                    bool& waitForAnswer)
{
    int movementType = (car != null ? car.Car_MovementType : Tla::GmWalkGround);
    int curXi = int(curX);
    int curYi = int(curY);

    if (processType == Tla::GlobalProcessMove) {
        // Save current distantion to compare in the end
        float lastDist = Tla::Distance(curX, curY, toX, toY);

        // Calcuate speed
        float speedPix = speed * float(Settings.GlobalMap.GlobalMapMoveTime) / 1000.0f;
        float speedAngle = math::atan2(toY - curY, toX - curX);
        float speedX = math::cos(speedAngle) * speedPix;
        float speedY = math::sin(speedAngle) * speedPix;

        float speedMod = 1.0f;
        if (movementType == Tla::GmWalkGround) {
            // Speed modifiers
            //  F   E   D   C   B   A   9    8   7    6   5    4   3    2   1    0
            // 1.5 1.4 1.3 1.2 1.1 1.0 0.95 0.9 0.85 0.8 0.75 0.7 0.65 0.6 0.55 0.0
            switch (Worldmap::GetGlobalMapRelief(curXi, curYi)) {
            case 0x0:
                speedMod = 1.00f;
                break;
            case 0x1:
                speedMod = 0.55f;
                break;
            case 0x2:
                speedMod = 0.60f;
                break;
            case 0x3:
                speedMod = 0.65f;
                break;
            case 0x4:
                speedMod = 0.70f;
                break;
            case 0x5:
                speedMod = 0.75f;
                break;
            case 0x6:
                speedMod = 0.80f;
                break;
            case 0x7:
                speedMod = 0.85f;
                break;
            case 0x8:
                speedMod = 0.90f;
                break;
            case 0x9:
                speedMod = 0.95f;
                break;
            case 0xA:
                speedMod = 1.00f;
                break;
            case 0xB:
                speedMod = 1.10f;
                break;
            case 0xC:
                speedMod = 1.20f;
                break;
            case 0xD:
                speedMod = 1.30f;
                break;
            case 0xE:
                speedMod = 1.40f;
                break;
            case 0xF:
                speedMod = 1.50f;
                break;
            default:
                break;
            }
        }

        if (car != null && speedMod != 1.0f) {
            float pass = float(car.Car_Passability);
            if (pass > 100.0f && speedMod < 1.0f) {
                speedMod += (1.0f - speedMod) * (pass - 100.0f) / 100.0f;
            }
            else if (pass > 100.0f && speedMod > 1.0f) {
                speedMod -= (speedMod - 1.0f) * (pass - 100.0f) / 100.0f;
            }
            else if (pass < 100.0f && speedMod < 1.0f) {
                speedMod -= (1.0f - speedMod) * (100.0f - pass) / 100.0f;
            }
            else if (pass < 100.0f && speedMod > 1.0f) {
                speedMod += (speedMod - 1.0f) * (100.0f - pass) / 100.0f;
            }
        }

        // Apply step
        curX += speedX * speedMod;
        curY += speedY * speedMod;

        int oldXi = curXi;
        int oldYi = curYi;
        curXi = int(curX); // Round
        curYi = int(curY); // Round

        // Check new position
        if (oldXi != curXi || oldYi != curYi) {
            // Check borders
            int gmWidth = Settings.GlobalMap.GlobalMapWidth * Settings.GlobalMap.GlobalMapZoneLength;
            int gmHeight = Settings.GlobalMap.GlobalMapHeight * Settings.GlobalMap.GlobalMapZoneLength;
            if (curXi < 0 || curYi < 0 || curXi >= gmWidth || curYi >= gmHeight) {
                if (curXi < 0) {
                    curXi = 0;
                }

                if (curXi >= gmWidth) {
                    curXi = gmWidth - 1;
                }

                if (curYi < 0) {
                    curYi = 0;
                }

                if (curYi >= gmHeight) {
                    curYi = gmHeight - 1;
                }

                // Stop group
                curX = float(curXi);
                curY = float(curYi);
                speed = 0.0f;
                return;
            }

            // Move from old to new and find last correct position
            int relief = Worldmap::GetGlobalMapRelief(oldXi, oldYi);
            int steps = Math::Max(Math::Abs(curXi - oldXi), Math::Abs(curYi - oldYi));
            int newXi = oldXi;
            int newYi = oldYi;
            if (steps > 0) {
                float xx = float(oldXi);
                float yy = float(oldYi);
                float oxx = float(curXi - oldXi) / float(steps);
                float oyy = float(curYi - oldYi) / float(steps);

                for (int i = 0; i < steps; i++) {
                    xx += oxx;
                    yy += oyy;
                    int xxi = int(xx >= 0.0f ? xx + 0.5f : xx - 0.5f);
                    int yyi = int(yy >= 0.0f ? yy + 0.5f : yy - 0.5f);

                    int relief_ = Worldmap::GetGlobalMapRelief(xxi, yyi);
                    if (movementType == Tla::GmWalkGround && relief != 0 && relief_ == 0) {
                        break;
                    }

                    if (movementType == Tla::GmWalkWater && relief_ != 0) {
                        break;
                    }

                    newXi = xxi;
                    newYi = yyi;
                }
            }

            if (newXi != curXi || newYi != curYi) {
                // Stop group
                curX = float(newXi);
                curY = float(newYi);
                speed = 0.0f;
                return;
            }

            // Zone
            int oldZoneX = oldXi / Settings.GlobalMap.GlobalMapZoneLength;
            int oldZoneY = oldYi / Settings.GlobalMap.GlobalMapZoneLength;
            int curZoneX = curXi / Settings.GlobalMap.GlobalMapZoneLength;
            int curZoneY = curYi / Settings.GlobalMap.GlobalMapZoneLength;

            // Change zone
            if (oldZoneX != curZoneX || oldZoneY != curZoneY) {
                Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(cr);
                ScanZone(group, curZoneX, curZoneY);
            }

            // Check for complete travelling
            float curDist = Tla::Distance(curX, curY, toX, toY);
            if (curDist <= 0.01f || curDist > lastDist) {
                curX = toX;
                curY = toY;
                speed = 0.0f;
                return;
            }
        }

        // Car processing
        if (car != null) {
            int fuel = car.Charge;
            int deterioration = car.Deterioration;

            if (fuel <= 0 || deterioration >= int(car.Car_MaxDeterioration)) {
                int str = (fuel <= 0 ? MsgStr::StrCarFuelEmpty : MsgStr::StrCarBroken);
                Messaging::Info(cr, TextPackKey(TextPackName::Game, "" + (str)));
                speed = 0.0f;
                return;
            }

            // Car values created for the call every 500 ms
            fuel -= car.Car_FuelConsumption * Settings.GlobalMap.GlobalMapMoveTime / 500;
            deterioration += car.Car_DeteriorationRate * Settings.GlobalMap.GlobalMapMoveTime / 500;
            if (fuel < 0) {
                fuel = 0;
            }

            if (deterioration > int(car.Car_MaxDeterioration)) {
                deterioration = int(car.Car_MaxDeterioration);
            }

            if (fuel != int(car.Charge) || deterioration != int(car.Deterioration)) {
                car.Charge = fuel;
                car.Deterioration = deterioration;
            }
        }

        cr.GlobalMapMoveCounter += 1;
        if (cr.GlobalMapMoveCounter % (Settings.GlobalMap.EncounterTime / Settings.GlobalMap.GlobalMapMoveTime) == 0) {
            Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(cr);
            Game.Log("cr.GlobalMapMoveCounter" + cr.GlobalMapMoveCounter + "gogo");
            // Validate charisma
            Critter leader = group[0];
            if (int(group.length()) > leader.Charisma + leader.PerkMagneticPersonality) {
                Messaging::Info(leader, TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritBadCharisma)));
                speed = 0.0f; // Stop
                return;
            }

            // Try find encounter
            if (Location::GetVisibleLocations(ipos(curXi, curYi), 0, cr).length() == 0) {
                Worldmap::FindEncounter(group, car, curXi, curYi, encounterDescriptor, waitForAnswer, false);
            }
        }
    }
    else if (processType == Tla::GlobalProcessEnter) {
        // Enter to empty encounter
        if (movementType == Tla::GmWalkWater && Worldmap::GetGlobalMapRelief(curXi, curYi) == 0) {
            // Find land
            bool landFounded = false;
            const int maxx = Settings.GlobalMap.GlobalMapWidth * Settings.GlobalMap.GlobalMapZoneLength;
            const int maxy = Settings.GlobalMap.GlobalMapHeight * Settings.GlobalMap.GlobalMapZoneLength;
            for (int ox = -1; ox <= 1; ox++) {
                for (int oy = -1; oy <= 1; oy++) {
                    int xx = curXi + ox;
                    int yy = curYi + oy;
                    if (xx >= 0 && xx < maxx && yy >= 0 && yy < maxy && Worldmap::GetGlobalMapRelief(xx, yy) != 0) {
                        Worldmap::FindEncounter(GlobalmapGroupExtended::GetGlobalGroup(cr), car, xx, yy, encounterDescriptor, waitForAnswer, true);
                        ox = oy = 2; // Exit from loop
                        landFounded = true;
                    }
                }
            }

            if (!landFounded) {
                Worldmap::FindEncounter(GlobalmapGroupExtended::GetGlobalGroup(cr), car, curXi, curYi, encounterDescriptor, waitForAnswer, true);
            }
        }
        else {
            Worldmap::FindEncounter(GlobalmapGroupExtended::GetGlobalGroup(cr), car, curXi, curYi, encounterDescriptor, waitForAnswer, true);
        }
    }
    else if (processType == Tla::GlobalProcessSetMove) {
        Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(cr);

        // Validate charisma
        Critter leader = group[0];
        if (int(group.length()) > leader.Charisma + leader.PerkMagneticPersonality) {
            Messaging::Info(leader, TextPackKey(TextPackName::Game, "" + (MsgStr::StrCritBadCharisma)));
            if (car != null) {
                CheckForLocationWithoutParking(cr, car, curX, curY);
            }

            return;
        }

        // Calculate speed
        speed = Tla::GLOBAL_MAP_BASE_SPEED;

        if (car != null) {
            // Validate car
            int strNum = 0;
            if (group.length() > car.Car_CrittersCapacity) {
                strNum = MsgStr::StrCarCritOverload;
            }
            else if (car.Charge == 0) {
                strNum = MsgStr::StrCarFuelEmpty;
            }
            else if (car.Deterioration >= car.Car_MaxDeterioration) {
                strNum = MsgStr::StrCarBroken;
            }

            if (strNum != 0) {
                Messaging::Info(leader, TextPackKey(TextPackName::Game, "" + (strNum)));
                speed = 0.0f;
                CheckForLocationWithoutParking(cr, car, curX, curY);
                return;
            }

            speed = car.Car_Speed * Tla::GLOBAL_MAP_BASE_SPEED / 20.0f;

            // Find near water for boats
            // In radius of one zone (left, top, right, bottom)
            if (car.Car_MovementType == Tla::GmWalkWater) {
                if (Worldmap::GetGlobalMapRelief(curXi, curYi) != 0) {
                    const int maxx = Settings.GlobalMap.GlobalMapWidth * Settings.GlobalMap.GlobalMapZoneLength;
                    const int maxy = Settings.GlobalMap.GlobalMapHeight * Settings.GlobalMap.GlobalMapZoneLength;
                    const int[] ox = {-1, 0, 1, 0};
                    const int[] oy = {0, -1, 0, 1};
                    for (int i = 1, ii = Settings.GlobalMap.GlobalMapZoneLength; i <= ii; i++) {
                        for (int j = 0; j < 4; j++) {
                            int xx = curXi + ox[j] * i;
                            int yy = curYi + oy[j] * i;
                            if (xx >= 0 && xx < maxx && yy >= 0 && yy < maxy && Worldmap::GetGlobalMapRelief(xx, yy) == 0) {
                                curX = float(xx);
                                curY = float(yy);
                                // Exit from loop
                                j = 4;
                                i = ii;
                            }
                        }
                    }
                }
            }
        }
        else {
            // Pathfinder perk bonus
            int speedDiv = 100 - cr.PerkPathfinder * 25;
            if (speedDiv <= 0) {
                speedDiv = 1;
            }

            speed = speed * 100.0f / float(speedDiv);
        }
    }
    else if (processType == Tla::GlobalProcessNpcIdle) {
        // Critter cr - is npc who call idle
        // Process npc group on global map
        if (curX == toX && curY == toY) // Stopped
        {
            // If you want enter to location under group than type
            // encounterDescriptor = int(-1);
            // waitForAnswer = false;
        }
    }
    else if (processType == Tla::GlobalProcessKick) {
        if (Worldmap::GetGlobalMapRelief(curXi, curYi) == 0) {
            // Say to leader
            Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(cr);
            Messaging::Info(group[0], TextPackKey(TextPackName::Game, "" + (MsgStr::StrCantKickOnWater)));
            return;
        }

        // GlobalmapGroupExtended::LeaveGlobalGroup(cr);
    }
}

// Call on invite to encaunter.
// If mapId != 0 than group enter to it.
void GlobalInvite(Critter leader, Item car, int encounterDescriptor, int combatMode, ident& mapId, mpos& hex, mdir& dir)
{
    // Enter to map under group
    if (encounterDescriptor == int(-1)) {
        Location[] locations = Location::GetLocationsInRadius(leader.WorldPos, 0);
        if (locations.length() != 0) {
            Location loc = locations[0];
            Map map = loc.GetMapByIndex(0);
            if (Entrance::MapGetEntryCoords(map, 0, 0, hex)) {
                mapId = map.Id;
                dir = mdir(hdir(0xFF));
            }
        }

        return;
    }

    // Find encounter
    uint8 dirByte = dir.hex.value;
    Worldmap::InviteToEncounter(GlobalmapGroupExtended::GetGlobalGroup(leader), car, encounterDescriptor, combatMode, mapId, hex, dirByte);
    dir = mdir(hdir(dirByte));
}

void ScanZone(Critter[] group, int zx, int zy)
{
    Location[] locs1, locs2;
    bool loc2Founded = false;

    locs1 = Location::GetZoneLocations(zx, zy, 1);

    for (int i = 0; i < group.length(); i++) {
        Critter cr = group[i];
        if (!cr.ControlledByPlayer) {
            continue;
        }

        int lookLen = (cr.PerkScout != 0 ? 2 : 1);

        if (lookLen == 2 && !loc2Founded) {
            locs2 = Location::GetZoneLocations(zx, zy, 2);
            loc2Founded = true;
        }

        // Open fog
        int mapw = Settings.GlobalMap.GlobalMapWidth;
        int maph = Settings.GlobalMap.GlobalMapHeight;
        for (int x = -lookLen; x <= lookLen; x++) {
            for (int y = -lookLen; y <= lookLen; y++) {
                int zx_ = zx + x;
                int zy_ = zy + y;
                if (zx_ >= 0 && zx_ < mapw && zy_ >= 0 && zy_ < maph) {
                    int fog = (zx == zx_ && zy == zy_ ? GlobalMapFog::GM_FOG_NONE : GlobalMapFog::GM_FOG_HALF);
                    if (GlobalMapFog::GetFog(cr, zx_, zy_) < fog) {
                        GlobalMapFog::SetFog(cr, zx_, zy_, fog);
                    }
                }
            }
        }

        // Find new locations
        Location[] locs = (lookLen == 1 ? locs1 : locs2);
        for (int j = 0; j < locs.length(); j++) {
            Location loc = locs[j];
            if (!Location::IsKnownLoc(cr, loc.Id)) {
                Location::SetKnownLoc(cr, loc.Id);
            }
        }
    }
}

void CheckForLocationWithoutParking(Critter cr, Item car, float& curX, float& curY)
{
    Location[] locations = {};
    locations = Location::GetVisibleLocations(ipos(int(curX), int(curY)), 0, cr);
    if (locations.length() != 0) {
        Location loc = locations[0];
        Map map = loc.GetMapByIndex(0);

        bool placeFounded = false;
        Entrance::Entry[] entries = Entrance::ParseEntries(map, car.Car_Entrance);
        for (int i = 0; i < entries.length(); i++) {
            if (map.CheckPlaceForItem(entries[i].Hex, car.ProtoId)) {
                placeFounded = true;
                break;
            }
        }

        if (!placeFounded) {
            curX = loc.WorldPos.x + int(loc.Radius) * (Game.Random(0, 1) == 0 ? int(1) : int(-1));
            curY = loc.WorldPos.y + int(loc.Radius) * (Game.Random(0, 1) == 0 ? int(1) : int(-1));
        }
    }
}

int GetGlobalMapTripId()
{
    Game.LastGlobalMapTrip = Game.LastGlobalMapTrip + 1;
    return Game.LastGlobalMapTrip;
}

class GlobalMapGroup
{
    Critter[] CritMove = {};
    Critter Rule;

    float CurX, CurY;
    float ToX, ToY;
    float Speed;
    bool IsSetMove;
    nanotime TimeCanFollow;
    nanotime ProcessLastTick;
    int EncounterDescriptor;
    nanotime EncounterTick;
    bool EncounterForce;

    bool IsValid()
    {
        return !CritMove.isEmpty();
    }

    void Stop()
    {
        Speed = 0.0f;
        ToX = CurX;
        ToY = CurY;
    }

    // Critter can follow leader on GM trip start
    bool CheckForFollow(Critter cr)
    {
        if (IsSetMove) { // ?? уже началось движение
            return false;
        }

        if (Game.FrameTime >= TimeCanFollow) { // прошло время, пока криттер мог присоединиться в группу
            return false;
        }

        if (GetCritter(cr.Id) != null) { // криттер уже в группе
            return false;
        }

        if (CritMove.length() >= GM_MAX_GROUP_COUNT) {
            return false;
        }

        return true;
    }

    GlobalMapGroup(Critter rule)
    {
        Clear();
        Rule = rule;
        CritMove.insertLast(rule);
    }

    Item? GetCar()
    {
        Item[] items = Rule.GetItems(ItemProperty::Type, ItemType::Car);
        if (!items.isEmpty()) {
            return items.first();
        }

        return null;
    }

    Critter? GetCritter(ident crid)
    {
        for (int i = 0; i < CritMove.length(); i++) {
            if (CritMove[i].Id == crid) {
                return CritMove[i];
            }
        }

        return null;
    }

    bool IsMoving()
    {
        return Speed > 0.0f && (CurX != ToX || CurY != ToY);
    }

    bool IsEncounter()
    {
        return EncounterDescriptor > 0;
    }

    int GetSize()
    {
        return CritMove.length();
    }

    void Clear()
    {
        CurX = CurY = ToX = ToY = 0.0f;
        IsSetMove = false;
        TimeCanFollow = ZERO_NANOTIME;
        ProcessLastTick = Game.GetPrecisionTime();
        EncounterDescriptor = 0;
        EncounterTick = ZERO_NANOTIME;
        EncounterForce = false;
    }

    void SendGlobalData(int type)
    {
        for (int i = 0; i < CritMove.length(); i++) {
            Critter cr = CritMove[i];
            GlobalMapLocations::SetGlobalMapData(type, cr);
        }
    }

    void Save(Serializator::Serializator save)
    {
        save.Set(int(CurX));
        save.Set(int(CurY));
        save.Set(int(ToX));
        save.Set(int(ToY));
        save.Set(IsMoving());
        save.Set(IsEncounter());
    }
};

dict<int, GlobalMapGroup> AllGlobalGroups = {};

GlobalMapGroup GetGlobalMapGroup(Critter cr)
{
    int tripId = cr.GlobalMapTripId;

    if (tripId == 0) {
        throw("Critter is not on global map", cr);
    }

    return AllGlobalGroups[tripId];
}

// Начало движения группы на глобальной карте для лидера группы. Он может быть одним криттером в составе группы.
void GroupStartMove(Critter cr)
{
    auto group = GetGlobalMapGroup(cr);

    group.Clear();
    group.CurX = cr.WorldPos.x;
    group.CurY = cr.WorldPos.y;
    group.ToX = group.CurX;
    group.ToY = group.CurY;
    group.Speed = 0.0f;

    group.TimeCanFollow = Game.FrameTime + TIME_CAN_FOLLOW_GM;

    GlobalMapLocations::SetGlobalMapData(GM_INFO_ALL, cr);

    ProcessGroup(cr, group, GLOBAL_PROCESS_START_FAST);
}

void ProcessGroup(Critter cr, GlobalMapGroup? group, int type) // 13 hits
{
    if (group == null) {
        return;
    }

    // Catchers
    int encounter_descriptor = 0;
    bool wait_for_answer = false;
    Critter rule = group.Rule;
    float cur_wx = group.CurX;
    float cur_wy = group.CurY;
    float to_wx = group.ToX;
    float to_wy = group.ToY;
    float speed = group.Speed;
    float base_speed = group.Speed;
    bool callGlobalProcess = true;

    if ((cr.OnGlobalMapProcess.Fire(type, group.GetCar(), cur_wx, cur_wy, to_wx, to_wy, speed, encounter_descriptor, wait_for_answer) ==
         EventResult::StopChain)) {
        callGlobalProcess = false;
    }
    else {
        encounter_descriptor = 0;
        wait_for_answer = false;
        cur_wx = group.CurX;
        cur_wy = group.CurY;
        to_wx = group.ToX;
        to_wy = group.ToY;
        speed = group.Speed;
    }

    if (!group.IsValid()) {
        return;
    }

    if (callGlobalProcess) {
        GlobalmapGroup::GlobalProcess(type, cr, group.GetCar(), cur_wx, cur_wy, to_wx, to_wy, speed, encounter_descriptor, wait_for_answer);
    }

    if (!group.IsValid()) {
        return;
    }

    // Check ranges
    float max_wx = float(GlobalMapMaxX());
    float max_wy = float(GlobalMapMaxY());
    if (cur_wx < 0.0f) {
        cur_wx = 0.0f;
    }

    if (cur_wy < 0.0f) {
        cur_wy = 0.0f;
    }

    if (cur_wx >= max_wx) {
        cur_wx = max_wx - 1;
    }

    if (cur_wy >= max_wy) {
        cur_wy = max_wy - 1;
    }

    if (to_wx < 0.0f) {
        to_wx = 0.0f;
    }

    if (to_wy < 0.0f) {
        to_wy = 0.0f;
    }

    if (to_wx >= max_wx) {
        to_wx = max_wx - 1;
    }

    if (to_wy >= max_wy) {
        to_wy = max_wy - 1;
    }

    if (speed < 0.0f) {
        speed = 0.0f;
    }

    if (cur_wx == to_wx && cur_wy == to_wy) {
        speed = 0.0f;
    }

    if (speed == 0.0f) {
        to_wx = cur_wx;
        to_wy = cur_wy;
    }

    // Current position
    if (cur_wx != group.CurX || cur_wy != group.CurY || speed != group.Speed) {
        group.CurX = cur_wx;
        group.CurY = cur_wy;
        group.Speed = speed;

        int cur_wxi = int(cur_wx);
        int cur_wyi = int(cur_wy);

        for (int i = 0, l = group.CritMove.length(); i < l; i++) {
            Critter cr1 = group.CritMove[i];
            cr1.WorldPos = ipos(cur_wxi, cur_wyi);
            GlobalMapLocations::SetGlobalMapData(GM_INFO_GROUP_PARAM, cr1);
        }
    }

    // New target
    if (type == GLOBAL_PROCESS_SET_MOVE || to_wx != group.ToX || to_wy != group.ToY) {
        GroupSetMove(group, to_wx, to_wy, speed);
        return;
    }

    // Stop
    if (base_speed > 0.0f && speed <= 0.0f) {
        group.Stop();
        ProcessGroup(rule, group, GLOBAL_PROCESS_STOPPED);
        return;
    }

    if (type == GLOBAL_PROCESS_STOPPED) {
        group.SendGlobalData(GM_INFO_GROUP_PARAM);
    }

    // Encounter
    if (encounter_descriptor > 0) {
        group.EncounterDescriptor = encounter_descriptor;
        if (type == GLOBAL_PROCESS_ENTER) {
            InviteGroup(group, 0);
            // InviteGroup( group, rule->GetDefaultCombat() );
        }
        else {
            if (wait_for_answer) {
                group.EncounterTick = Game.GetPrecisionTime() + GM_ANSWER_WAIT_TIME;
                group.EncounterForce = false;
            }
            else {
                group.EncounterTick = Game.GetPrecisionTime() + GM_LIGHT_TIME;
                group.EncounterForce = true;
            }

            group.SendGlobalData(GM_INFO_GROUP_PARAM);
        }
    }
}

void GiveRule(Critter cr, Critter newRule) // 5 hits
{
    auto group = GetGlobalMapGroup(cr);

    if (group.CritMove.length() < 2 || group.Rule.Id != cr.Id || cr.Id == newRule.Id) {
        return;
    }

    group.Rule = newRule;
}

void StopGroup(Critter cr) // 3hits
{
    auto group = GetGlobalMapGroup(cr);

    group.ToX = group.CurX;
    group.ToY = group.CurY;
    group.Speed = 0.0f;

    ProcessGroup(cr, group, GLOBAL_PROCESS_STOPPED);
}

bool GroupToMap(GlobalMapGroup group, Map? map, hstring entry, mpos hexMap, int mdir) // 6hits
{
    if (map == null) {
        Game.Log("Map null ptr");
        return false;
    }

    Critter rule = group.Rule;
    uint8 dir;
    mpos hex, car_hex;
    Item? car = group.GetCar();
    Critter? car_owner;

    if (car != null) {
        car_owner = group.GetCritter(car.CritterId);
        if (car_owner == null) {
            Game.Log(" - Car owner not found");
        }
    }

    if (hexMap.x >= map.Size.width || hexMap.y >= map.Size.height || mdir >= 6 || hexMap == mpos()) {
        if (car != null) {
            int entries = Entrance::MapCountEntry(map, Tla::ENTRY_CAR);
            int entriesPass = Entrance::MapCountEntry(map, Tla::ENTRY_CAR_CRITTERS);
            int entryNum = -1;

            for (int i = 0; i < entries && i < entriesPass; i++) {
                Entrance::MapGetEntryCoords(map, Tla::ENTRY_CAR, i, car_hex);
                if (map.CheckPlaceForItem(car_hex, car.ProtoId)) {
                    Entrance::MapGetEntryCoords(map, Tla::ENTRY_CAR_CRITTERS, i, hex);
                    entryNum = i;
                    break;
                }
            }

            if (entryNum < 0) {
                Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_CAR_PLACE_NOT_FOUND)));
                return false;
            }

            Entrance::MapGetEntryCoords(map, Tla::ENTRY_CAR, entryNum, hex);
            if (!map.CheckPlaceForItem(car_hex, car.ProtoId)) {
                Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_CAR_PLACE_NOT_FOUND)));
                return false;
            }

            if (mdir < 6) {
                dir = mdir;
            }
        }
        else {
            if (!Entrance::GetEntryFreeHex(map, Tla::ENTRY_DEFAULT, hex)) {
                Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_PLACE_NOT_FOUND)));
                return false;
            }
        }
    }
    else {
        hex = hexMap;
        dir = mdir;
        if (car != null) {
            int entries = Entrance::MapCountEntry(map, Tla::ENTRY_CAR);
            int entriesPass = Entrance::MapCountEntry(map, Tla::ENTRY_CAR_CRITTERS);
            int entryNum = -1;

            for (int i = 0; i < entries && i < entriesPass; i++) {
                Entrance::MapGetEntryCoords(map, Tla::ENTRY_CAR, i, car_hex);
                if (map.CheckPlaceForItem(car_hex, car.ProtoId)) {
                    Entrance::MapGetEntryCoords(map, Tla::ENTRY_CAR_CRITTERS, i, hex);
                    entryNum = i;
                    break;
                }
            }

            if (entryNum < 0) {
                Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_CAR_PLACE_NOT_FOUND)));
                return false;
            }
        }
    }

    auto transitCr = group.CritMove;

    // Transit rule
    rule.WorldPos = ipos(int(group.CurX), int(group.CurY));
    if (car != null) {
        ItemMovement::MoveItem(car, 1, map, car_hex);
    }

    rule.TransferToMap(map, hex, HDIR_Random);

    // Transit other
    for (int i = 0, l = transitCr.length(); i < l; i++) {
        Critter cr1 = transitCr[i];
        if (cr1.Id == rule.Id) {
            continue;
        }

        cr1.WorldPos = ipos(int(group.CurX), int(group.CurY));

        cr1.TransferToMap(map, hex, HDIR_Random);
        if (cr1.GetMap() == null) // Проверить, что криттер успеет сюда попасть
        // if( !Transit( cr, map, hx, hy, dir,  car  != null ? 3 : 2, true ) )
        {
            GroupStartMove(cr1);
            continue;
        }
    }

    group.Clear();
    return true;
}

[[Async]]
bool GroupToLoc(Critter rule, ident locId, int entrance, bool force = false) // 3 hits
{
    if (rule.GetMap() != null) {
        return false;
    }

    auto group = GetGlobalMapGroup(rule);

    if (locId == ZERO_IDENT) {
        return false;
    }

    if (rule.Id != group.Rule.Id) {
        Game.Log(" - Critter is not rule.\n");
        return false;
    }

    if (!force && !Location::IsKnownLoc(rule, locId) && rule.ControlledByPlayer) {
        Game.Log(" - Critter '%s' is not known location. CriterId: " + rule.Id);
        return false;
    }

    Location? loc = Game.GetLocation(locId);
    if (loc == null) {
        if (rule.ControlledByPlayer) {
            Location::UnsetKnownLoc(rule, locId);
        }

        GlobalMapLocations::SetGlobalMapData(GM_INFO_LOCATIONS, rule);
        // rule->Send_GlobalInfo( GM_INFO_LOCATIONS );
        Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_LOCATION_NOT_FOUND)));
        return false;
    }

    if (!Sync::Lock(loc, group.CritMove)) {
        return false;
    }

    // force позволяет избежать проверки расстояния до локи
    if (!force && int(math::sqrt(float(Math::Pow2(int(group.CurX) - loc.WorldPos.x) + Math::Pow2(int(group.CurY) - loc.WorldPos.y)))) > loc.Radius) {
        if (rule.ControlledByPlayer) {
            GlobalMapLocations::SetGlobalMapData(GM_INFO_LOCATIONS, rule);
        }

        Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_LOCATION_REMOVED)));
        return false;
    }

    if (!force && !Location::IsCanEnter(loc, group.CritMove.length())) {
        Messaging::Info(rule, TextPackKey(TextPackName::Game, "" + (MsgStr::STR_GLOBAL_PLAYERS_OVERFLOW)));
        return false;
    }

    if (loc.GetMapCount() == 0) {
        if (rule.ControlledByPlayer) {
            Location::UnsetKnownLoc(rule, locId);
        }

        Game.Log(" - Location is empty.");
        return false;
    }

    if (entrance >= loc.MapEntrances.length()) {
        Game.Log(" - Invalid entrance.");
        return false;
    }

    bool result = CheckEntrance(loc, group.CritMove, entrance);
    if (!result) {
        Game.Log(" - Can't enter in entrance " + entrance);
        return false;
    }

    if ((Game.OnLocationEnter.Fire(loc, group.CritMove, entrance) == EventResult::StopChain)) {
        return false;
    }

    hstring mapProto = loc.MapEntrances[entrance * 2];
    hstring entry = loc.MapEntrances[entrance * 2 + 1];
    Map? map = loc.GetMap(mapProto);

    if (map == null) {
        if (rule.ControlledByPlayer) {
            Location::UnsetKnownLoc(rule, locId);
        }

        Game.Log(" - Map " + mapProto + " not found in location " + locId);
        return false;
    }

    if (!Sync::Lock(loc, map, group.CritMove)) {
        return false;
    }

    return GroupToMap(group, map, entry, mpos(), 0);
}

int DistSqrt(int x1, int y1, int x2, int y2)
{
    int dx = x1 - x2;
    int dy = y1 - y2;
    return int(math::sqrt(double(dx * dx + dy * dy)));
}

void GroupSetMove(GlobalMapGroup group, float to_x, float to_y, float speed) // 6 hits
{
    int dist = DistSqrt(int(to_x), int(to_y), int(group.CurX), int(group.CurY));

    if (speed <= 0.0f || dist == 0) {
        group.Speed = 0.0f;
        group.ToX = group.CurX;
        group.ToY = group.CurY;
    }
    else {
        group.Speed = speed;
        group.ToX = to_x;
        group.ToY = to_y;
    }

    GlobalMapLocations::SetGlobalMapData(GM_INFO_GROUP_PARAM, group.Rule);
    // group->Rule->SendA_GlobalInfo( group, GM_INFO_GROUP_PARAM );
    if (Game.GetPrecisionTime() > group.ProcessLastTick + Time::Milliseconds(Settings.GlobalMap.GlobalMapMoveTime)) {
        group.ProcessLastTick = Game.GetPrecisionTime();
    }

    if (!group.IsSetMove) {
        group.IsSetMove = true;
        ProcessGroup(group.Rule, group, GLOBAL_PROCESS_START);
    }
}

void GroupMove(GlobalMapGroup group) // 3hits
{
    auto tick = Game.GetPrecisionTime();
    Critter rule = group.Rule;

    // Encounter
    if (group.EncounterDescriptor > 0) {
        if (tick < group.EncounterTick) {
            return;
        }

        // Force invite
        if (group.EncounterForce) {
            InviteGroup(group, 0); // TODO: turnbasedrule->GetDefaultCombat() );
            return;
        }

        // Continue walk
        group.EncounterDescriptor = 0;
        GlobalMapLocations::SetGlobalMapData(GM_INFO_GROUP_PARAM, rule);
        group.ProcessLastTick = tick;
    }

    // Start callback
    if (!group.IsSetMove && tick >= group.TimeCanFollow) {
        group.IsSetMove = true;
        ProcessGroup(rule, group, GLOBAL_PROCESS_START);
        return;
    }

    // Move
    if (group.IsMoving()) {
        auto dtime = tick - group.ProcessLastTick;
        if (dtime >= Time::Milliseconds(Settings.GlobalMap.GlobalMapMoveTime)) {
            if (dtime >= Time::Milliseconds(Settings.GlobalMap.GlobalMapMoveTime * 2)) {
                dtime = ZERO_TIMESPAN;
            }

            group.ProcessLastTick = tick - Time::Milliseconds(dtime.milliseconds % Settings.GlobalMap.GlobalMapMoveTime);

            if (rule.ControlledByPlayer && rule.IsDead()) // && rule.IsOffline() )
            {
                group.Stop();
                ProcessGroup(rule, group, GLOBAL_PROCESS_STOPPED);
                return;
            }

            ProcessGroup(rule, group, GLOBAL_PROCESS_MOVE);
        }
    }
}

void InviteGroup(GlobalMapGroup group, int combat_mode) // 5hits
{
    int encounter_descriptor = group.EncounterDescriptor;
    group.EncounterDescriptor = 0;

    ident map_id;
    mpos hex;
    mdir dir;
    Critter rule = group.Rule;
    bool GlobalInvite = true;

    if ((rule.OnGlobalMapInvite.Fire(group.GetCar(), encounter_descriptor, combat_mode, map_id, hex, dir) == EventResult::StopChain)) {
        GlobalInvite = false;
    }
    else {
        map_id = ZERO_IDENT;
        hex = mpos();
        dir = 0;
    }

    if (!group.IsValid()) {
        return;
    }

    if (GlobalInvite) {
        GlobalmapGroup::GlobalInvite(rule, group.GetCar(), encounter_descriptor, combat_mode, map_id, hex, dir);
    }

    if (!group.IsValid()) {
        return;
    }

    if (map_id != ZERO_IDENT) {
        Map? map = Game.GetMap(map_id);
        if (map != null) {
            GroupToMap(group, map, "0".hstr(), hex, (dir.hex.value < 6 ? int(dir.hex.value) : int(rule.Dir.hex.value)));
        }
    }
    else {
        group.SendGlobalData(GM_INFO_GROUP_PARAM);
    }
}

bool CheckEntrance(Location loc, Critter[] arr, int entrance) // 5 hits
{
    return Game.OnGlobalMapCheckEntranceAllowed.Fire(loc, arr, entrance) == EventResult::ContinueChain;
}

[[Async]]
void ProcessGlobalMapCommandImpl(Player player, int command, any param1, any param2)
{
    Critter? cl = player.GetControlledCritter();
    if (cl == null) {
        return;
    }

    switch (command) {
    case GM_CMD_FOLLOW_CRIT: {
        if (param1 == 0) {
            break;
        }

        Critter? cr = Game.GetCritter(param1);
        if (cr == null) {
            break;
        }

        if (!Sync::Lock(cl, cr)) {
            break;
        }

        if (cl.FollowLeaderId == cr.Id) {
            cl.FollowLeaderId = ZERO_IDENT; // unfollow
        }
        else {
            cl.FollowLeaderId = cr.Id;
        }
    } break;
    case GM_CMD_SETMOVE: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        if (cl.Id != group.Rule.Id) {
            break;
        }

        if (float(param1) >= float(GlobalMapMaxX()) || float(param2) >= float(GlobalMapMaxY())) {
            break;
        }

        if (group.EncounterDescriptor > 0) {
            break;
        }

        group.ToX = float(param1);
        group.ToY = float(param2);
        ProcessGroup(cl, group, GLOBAL_PROCESS_SET_MOVE);
    } break;
    case GM_CMD_STOP:
        break;
    case GM_CMD_TOLOCAL: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        if (cl.Id != group.Rule.Id) {
            break;
        }

        if (group.EncounterDescriptor > 0) {
            break;
        }

        if (Time::IsTimeoutActive(cl.TimeoutTransfer)) {
            Messaging::Info(cl, TextPackKey(TextPackName::Game, "" + (MsgStr::StrTimeoutTransferWait)));
            break;
        }

        if (param1 == 0) {
            if (cl.GetMap() != null || cl.Id != group.Rule.Id) {
                break;
            }

            group.EncounterDescriptor = 0;
            ProcessGroup(cl, group, GLOBAL_PROCESS_ENTER);
        }
        else {
            GroupToLoc(cl, param1, param2);
        }
    }
        return;
    case GM_CMD_ANSWER: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        if (cl.Id != group.Rule.Id) {
            break;
        }

        if (group.EncounterDescriptor == 0 || group.EncounterForce) {
            break;
        }

        if (int(param1) >= 0) // Yes
        {
            InviteGroup(group, param1);
            return;
        }
        else if (group.EncounterDescriptor > 0) // No
        {
            group.EncounterDescriptor = 0;
            group.SendGlobalData(GM_INFO_GROUP_PARAM);
        }
    } break;
    case GM_CMD_FOLLOW: {
        // Find rule
        Critter? rule = Game.GetCritter(param1);
        if (rule == null || !Sync::Lock(cl, rule) || rule.GetMap() != null) {
            break;
        }

        auto group = GetGlobalMapGroup(rule);
        if (!Sync::Lock(cl, group.CritMove)) {
            break;
        }

        if (rule.Id != group.Rule.Id) {
            break;
        }

        // Check for follow
        if (!group.CheckForFollow(cl)) {
            break;
        }

        if (Game.GetDistance(rule.MapLeaveHex, cl.Hex) > FOLLOW_DIST + rule.Multihex + cl.Multihex) {
            break;
        }

        cl.TransferToGlobalGroup(rule);
        if (cl.GetMap() == null) { // TODO: проверить, что успевает покинуть карту
            break;
        }
    }
        return;
    case GM_CMD_KICKCRIT: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        if (group.CritMove.length() < 2 || group.EncounterDescriptor > 0) {
            break;
        }

        Critter? kick_cr;

        if (cl.Id == param1) // Kick self
        {
            if (cl.Id == group.Rule.Id) {
                break;
            }

            kick_cr = cl;
        }
        else // Kick other
        {
            if (cl.Id != group.Rule.Id) {
                break;
            }

            kick_cr = group.GetCritter(param1);
            if (kick_cr == null) {
                break;
            }
        }

        if (kick_cr == null) {
            break;
        }

        ProcessGroup(kick_cr, group, GLOBAL_PROCESS_KICK);
    } break;
    case GM_CMD_GIVE_RULE: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        // Check
        if (cl.Id == param1 || cl.Id != group.Rule.Id || group.EncounterDescriptor > 0) {
            break;
        }

        Critter? newRule = group.GetCritter(param1);
        if (newRule == null || !newRule.ControlledByPlayer || !newRule.IsOnline()) {
            break;
        }

        GiveRule(cl, newRule);
        StopGroup(cl);
    } break;
    case GM_CMD_ENTRANCES: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        if (group.EncounterDescriptor > 0) {
            break;
        }

        ident locId = param1;
        if (locId == ZERO_IDENT) {
            break;
        }

        Location? loc = Game.GetLocation(locId);
        if (loc == null || !Sync::Lock(loc, group.CritMove) || DistSqrt(int(group.CurX), int(group.CurY), loc.WorldPos.x, loc.WorldPos.y) > int(loc.Radius)) {
            break;
        }

        nanotime tick = Game.GetPrecisionTime();
        if (cl.LastSendEntrancesLocId == locId && tick < cl.LastSendEntrancesTick + GM_ENTRANCES_SEND_TIME) {
            Game.Log(" Client '%s' ignore send entrances timeout." + cl.Id);
            break;
        }

        cl.LastSendEntrancesLocId = locId;
        cl.LastSendEntrancesTick = tick;

        int[] allowedEntrances = {};

        Game.Log("loc.MapEntrances " + loc.MapEntrances.length());

        for (int i = 0, l = loc.MapEntrances.length(); i < l; i += 2) {
            Game.Log("Entrance " + i + " - " + loc.MapEntrances[i]);
            Game.Log("Entrance " + (i + 1) + " - " + loc.MapEntrances[i + 1]);
            if (CheckEntrance(loc, group.CritMove, i)) {
                allowedEntrances.insertLast(i / 2);
            }
        }

        // cl.PlayerClientCall.SetCurrentLocationEntrances( loc.ProtoId, allowedEntrances );
        cl.PlayerClientCall.ShowGMTown(loc.Id, loc.ProtoId, allowedEntrances);
    } break;
    case GM_CMD_VIEW_MAP: {
        auto group = GetGlobalMapGroup(cl);
        if (!Sync::Lock(group.CritMove)) {
            break;
        }

        if (group.EncounterDescriptor > 0) {
            break;
        }

        ident locId = param1;
        if (locId == ZERO_IDENT) {
            break;
        }

        Location? loc = Game.GetLocation(locId);
        if (loc == null || !Sync::Lock(loc, group.CritMove) || DistSqrt(int(group.CurX), int(group.CurY), loc.WorldPos.x, loc.WorldPos.y) > int(loc.Radius)) {
            break;
        }

        int entrance = param2;

        if (entrance >= loc.MapEntrances.length()) {
            break;
        }

        if (!CheckEntrance(loc, group.CritMove, entrance)) {
            break;
        }

        hstring mapProto = loc.MapEntrances[entrance * 2];
        hstring entry = loc.MapEntrances[entrance * 2 + 1];
        Map? map = loc.GetMap(mapProto);
        if (map == null) {
            break;
        }

        if (!Sync::Lock(loc, map, group.CritMove)) {
            break;
        }

        uint8 dir;
        mpos hex;
        // if( !map->GetStartCoord( hx, hy, dir, loc->Proto->Entrance[ entrance ].second ) )
        if (!Entrance::GetEntryFreeHex(map, entry, hex)) {
            break;
        }

        int look = 0; // 0? cr.LookDistance

        cl.ViewMap(map, 0, hex, 0);
        cl.PlayerClientCall.ShowTownView(locId, entrance);

    } break;
    default:
        Game.Log(" - Unknown command " + command + "; from critter:   " + cl.Id);
        break;
    }

    CritterState::Wait(cl, Settings.Movement.Breaktime);
}

[[ServerRemoteCall]] [[Async]]
void ProcessGlobalMapCommand(Player player, int command, any param1, any param2) // Process_RuleGlobal
{
    ProcessGlobalMapCommandImpl(player, command, param1, param2);
}

#endif

#endif

