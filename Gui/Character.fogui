//   "OnShow":
{
    {
        {
            UnspentSP = GetPropValue(CritterProperty::UnspentSkillPoints);
            SkillUp.clear();
            if (GetPropValue(CritterProperty::UnspentPerks) > 0) {
                Gui::ShowScreen(GuiScreen::Perk);
            }
        }
    }
}
