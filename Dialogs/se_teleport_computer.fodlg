[Comment]


[Dialog]
Speech 1 # Predialogue installations
  Answer 2 # ...
    Demand Property Player SpecialEncounterTeleport == 1
  Answer 5 # уже сделано
    Demand Property Player SpecialEncounterTeleport != 1

Speech 2 # Для тестирования телепортационного устройства у...
  Answer Exit # [Выход]
  Answer 3 # [Отключить контроль веса предметов]
    Demand Property Player SkillScience <= 100
  Answer 4 # [Отключить контроль веса предметов]
    Demand Property Player SkillScience > 100
  Answer Exit* # [Начать тестирование]
    Result Script SeTeleport::r_ChangeItems 52 53 0
    Result Property Player SpecialEncounterTeleport = 2

Speech 3 # Несанкционированный доступ. Запрещена настройка...
  Answer Exit # [Выход]

Speech 4 # Контроль веса отключен. Для тестирования телепо...
  Answer Exit # [Выход]
  Answer Exit* # [Начать тестирование]
    Demand Script SeTeleport::d_CheckIsNotAnyCritterInPlace 52 53
    Result Script SeTeleport::r_ChangeItems 52 53 1
    Result Property Player SpecialEncounterTeleport = 2
  Answer Exit** # [Начать тестирование]
    Demand Script SeTeleport::d_CheckIsNpcInPlace 52 53
    Demand Or
    Demand Script SeTeleport::d_CheckIsPlayerInPlace 52 53
    Result Script SeTeleport::r_SwapCritters 52 53
    Result Property Player SpecialEncounterTeleport = 2

Speech 5 # [Терминал вышел из строя]
  Answer Exit # [Выход]

