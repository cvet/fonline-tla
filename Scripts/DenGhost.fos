// DenGhost — квестовый призрак Дена.
// SERVER. Неуязвим вне квеста (реген HP + крик), смерть только через диалог KillGhost; авто-воскрешение и наказание за кражу.
// Связи: CritterState, Messaging, Dialogs, GameTime, MsgStr, Content.
namespace DenGhost
{

#if SERVER

///@ Property Game Server bool DenGhostIsDead Mutable Persistent

// Номера строк в диалоге den_ghost (крик / провал кражи / провал кражи с травмой)
const int STRNUM_SCREAM = 1;
const int STRNUM_STEAL = 2;
const int STRNUM_STEAL_INJURE = 3;

// Инициализация призрака: при первом запуске задаём неуязвимые параметры,
// затем синхронизируем фактическое состояние (жив/мёртв) со значением переменной квеста.
void GhostInit(Critter ghost, bool firstTime)
{
    if (firstTime) {
        // Максимально возможное HP, чтобы призрак был неуязвим вне квеста
        ghost.MaxLifeBase = 9999;
        ghost.CurrentHp = 9999;
        // И запредельный класс брони
        ghost.ArmorClassBase = 90;
    }

    // Приводим реальное состояние призрака в соответствие с флагом квеста
    if (ghost.Condition == CritterCondition::Dead && !Game.DenGhostIsDead) {
        CritterState::ToAlive(ghost);
    }
    else if (ghost.Condition != CritterCondition::Dead && Game.DenGhostIsDead) {
        CritterState::ToDead(ghost, CritterActionAnim::DeadBurnRun, null);
    }

    ghost.OnAttacked.Subscribe(GhostAttacked);
    ghost.OnDead.Subscribe(GhostDead);
    ghost.OnRespawn.Subscribe(GhostRespawn);
    ghost.OnStealing.Subscribe(GhostStealing);
}

// Обработчики событий

// Призрак неуязвим: любая атака мгновенно восстанавливает HP, и он лишь пугает игрока криком.
[[Event]]
EventResult GhostAttacked(Critter ghost, Critter attacker)
{
    // Полностью восстанавливаем HP
    ghost.CurrentHp = ghost.MaxLife;

    // Кричим, чтобы напугать игрока
    Messaging::SayShoutOnHead(ghost, MsgStr::DialogTextKey(Content::Dialog::den_ghost, STRNUM_SCREAM));

    // Атака ни к чему не приводит — прерываем цепочку
    return EventResult::StopChain;
}

// Если призрак умер не через квестовый диалог, он автоматически воскресает.
[[Event]]
void GhostDead(Critter ghost, Critter killeer)
{
    // Призрак убит не через квестовый диалог
    if (!Game.DenGhostIsDead) {
        // Воскрешаем призрака
        Game.StartTimeEvent(GameTime::GameSeconds(60), RessurectGhost, ghost.Id);
    }
}

[[Event]]
void GhostRespawn(Critter ghost)
{
    Game.DenGhostIsDead = false;
}

// Обработка кражи у призрака.
// Попытка кражи в любом случае проваливается, при этом есть шанс повредить вору правую руку.
[[Event]]
void GhostStealing(Critter ghost, Critter thief, Item item, int count)
{
    if (thief.ControlledByPlayer) {
        int injureHandChance = 20;
        int injureHandRoll = Game.Random(1, 100);

        if (injureHandRoll <= injureHandChance) {
            thief.IsDamagedRightArm = true;
            Messaging::Info(thief, MsgStr::DialogTextKey(Content::Dialog::den_ghost, STRNUM_STEAL_INJURE));
        }
        else {
            Messaging::Info(thief, MsgStr::DialogTextKey(Content::Dialog::den_ghost, STRNUM_STEAL));
        }
    }
}

// Диалог

// Мгновенно убивает призрака (единственный легитимный способ его смерти — через квест).
[[DialogResult]]
void KillGhost(Critter player, Critter ghost, any val)
{
    // Фиксируем, что призрак убит через квестовый диалог
    Game.DenGhostIsDead = true;
    // Убиваем призрака
    CritterState::ToDead(ghost, CritterActionAnim::DeadBurnRun, null);
    // С задержкой запускаем диалог о проклятом сокровище
    Game.StartTimeEvent(GameTime::GameSeconds(60), RunTreasureDialog, player.Id);
}

// Обработчики отложенных событий

// Воскрешает призрака.
[[TimeEvent]]
void RessurectGhost(any value)
{
    Critter? ghost = Game.GetCritter(value);
    if (ghost == null) {
        return;
    }

    // Пробуем воскресить призрака; ToAlive бросает исключение, если гексы трупа заняты,
    // поэтому заранее проверяем проходимость и при занятости повторяем позже,
    // а не полагаемся на ложное возвращаемое значение
    Map? map = ghost.GetMap();
    if (map != null && map.IsHexesMovable(ghost.Hex, ghost.Multihex)) {
        CritterState::ToAlive(ghost);
    }
    else {
        Game.StartTimeEvent(GameTime::GameSeconds(2 * 60), RessurectGhost, value);
    }
}

// Запускает диалог о проклятом сокровище.
[[TimeEvent]]
void RunTreasureDialog(any value)
{
    Critter? player = Game.GetCritter(value);
    if (player == null) {
        return;
    }

    Dialogs::RunDialog(player, Content::Dialog::den_ghost_treasure, false);
}

#endif

}
