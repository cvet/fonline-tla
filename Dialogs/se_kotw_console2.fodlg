    Result Property Player PoisoningLevel += 1
    Result Script SeKotw::r_InfoMessage 3
  Answer 9 # [Ещё]

Speech 9 # Почему магистром Ордена Рыцарей Пустоши стал Де...
  Answer Exit # Он убил всех конкурентов и подкупил коллегию вы...
    Result Property Player IsDamagedRightLeg = 1
    Result Script SeKotw::r_InfoMessage 3
  Answer 10 # Леди Озера рукой в убранстве чистейшей венециан...
  Answer 9 # [Назад]
  Answer Exit* # [Выход]

Speech 10 # Сколько имен выгравировано на мемориале Рыцарей...
  Answer Exit # Эмм… а ну это… я не стал читать.
    Result Property Player IsDamagedLeftLeg = 1
    Result Script SeKotw::r_InfoMessage 7
  Answer Exit* # 51
    Result Property Player CurrentHp -= 1
