/* **************************************** Основные методы ***************************************** */
// караван по идентификатору
CaravanInfo? GetCaravan(int idCaravan)
{
    if (Caravans.length() == 0) {
        return null;
    }

    for (int i = 0; i < Caravans.length(); i++) {
        if (Caravans[i].CaravanId == idCaravan) {
            return Caravans[i];
        }
    }

    return null;
}

// добавление нового описания караванов
// idCaravan - код каравана
// crvType = тип каравана
// speed = множитель скорости движения по глобальной карте
// qVar = номер квестовой переменная для данного каравана
// maxGrp = максимальный размер группы каравана включая игроков и караванщика
void SetupCaravan(int idCaravan, int crvType, int speed, CritterProperty qVar, int maxGrp)
{
    // проверяем, что каравана с таким ид нет в массиве
    CaravanInfo? existing = GetCaravan(idCaravan);
    CaravanInfo ci;
    if (existing != null) {
        existing.CaravanReset();
        ci = existing;
    }
    else {
        ci = CaravanInfo();
        Caravans.insertLast(ci);
        ci.CaravanId = idCaravan;
    }

    ci.Type = crvType;
    ci.GlobalSpeedMultiplayer = speed;
    ci.QuestVarNum = qVar;
    ci.MaxGroup = maxGrp;
}

// настройка лидера каравана
// idCaravan - код каравана.
// dialog - номер диалога нпц
// pid = прототип криттера
// bag = номер сумки
// team = номер команды
void SetupCaravanLeader(int idCaravan, hstring dialog, hstring pid, int bag, int team, int ai, int level)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    // внимание! если нпц - караван лидер уже был ранее добавлен, об удалении криттера при необходимости, нужно позаботиться дополнительно
    // проверка ci.Leader.Id!=0
    ci.Leader = CaravanLeaderInfo();
    DebugLogVerbose("SetupCaravanLeader 1. IdCaravan" + ci.CaravanId + "; Level" + ci.Leader.Level);
    ci.Leader.DialogId = dialog;
    ci.Leader.NpcPid = pid;
    ci.Leader.BagId = bag;
    ci.Leader.TeamId = team;
    ci.Leader.AiPack = ai;
    ;
    ci.Leader.Level = level;
    DebugLogVerbose("new level" + ci.Leader.Level);
    ci.Leader.CaravanId = idCaravan;
}

// настройка лидера каравана по существующему НПЦ
// idCaravan - код каравана
// leader - нпц проводник. Он должен уже существовать.
void SetupCaravanLeader(int idCaravan, Critter leader)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    ci.Leader = CaravanLeaderInfo();
    DebugLogVerbose("SetupCaravanLeader 2. " + idCaravan + " IdCaravan" + ci.CaravanId + "; Level" + ci.Leader.Level);
    ci.Leader.DialogId = leader.DialogId;
    ci.Leader.NpcPid = leader.ProtoId;
    ci.Leader.BagId = leader.BagId;
    ci.Leader.TeamId = leader.TeamId;
    ci.Leader.AiPack = leader.AiId;
    ci.Leader.CaravanId = idCaravan;
    ci.Leader.CritterId = leader.Id;
    DebugLogVerbose("new level" + ci.Leader.Level);
    leader.CaravanCrvId = idCaravan;
}

// настройка положения лидера караванов в исходной и конечной точках
// idCaravan - код каравана.
// locPid - код прототипа локации
// mapPid - код прототипа карты
// x, y - координаты гекса на котором появится нпц
// isStartPos - признак, стартовая или конечная позиция. Если true - устанавливаем StartPos, иначе EndPos
void SetupCaravanLiderPosition(int idCaravan, hstring locPid, hstring mapPid, int x, int y, bool isStartPos)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    if (isStartPos) {
        ci.Leader.StartPos = NpcPosition(locPid, mapPid, mpos(x, y));
    }
    else {
        ci.Leader.EndPos = NpcPosition(locPid, mapPid, mpos(x, y));
    }
}

// настройка караванных повозок, появляющихся на локации
// idCaravan - код каравана.
// numCabs - число повозок, которые нужно добавить
void SetupCaravanCabs(int idCaravan, int numCabs)
{
    CaravanInfo? ci = GetCaravan(idCaravan);

    if (ci == null) {
        return;
    }

    ci.Cabs.clear();

    for (int i = 0; i < numCabs; i++) {
        ci.Cabs.insertLast(CaravanCabInfo());
    }
}

// добавление описания лута в одну из повозок
// idCaravan - код каравана.
// cabNum - порядковый номер повозки, если <0 лут будет добавлен в рандомную повозку
// itemPid - прототип итема
// minNum - минимальное число
// maxNum - максимальеное число
// chanceAppear - шанс в процентах на появление
void AddLootToCaravanCabs(int idCaravan, int cabNum, hstring itemPid, int minNum, int maxNum, int chanceAppear, bool isReverseRouteLoot)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    CaravanCabInfo? cab = ci.GetCab(cabNum);
    if (cab == null) {
        return;
    }

    cab.AddLoot(itemPid, minNum, maxNum, chanceAppear, isReverseRouteLoot);
}

// добавление точки маршрута движения по глобалу
// idCaravan - код каравана.
// x - координаты на глобальной карте по оси Х
// у - координаты на глобальной карте по оси У
void AddRoutePoint(int idCaravan, int x, int y)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    ci.AddRoutePoint(x, y);
}

// добавление описания охранника
// idCaravan - код каравана.
// pid - прототип криттера
// dialogId - диалог
// initScript - имя скрипта
// aiPack - пакет АИ
// bagId - сумка
// teamId - команда
// level - уровень
// reaction - скорость реакции на события
// isNervous - уровень "нервозности"
// chanceJoin
// isUnique
void AddGuardInfo(int idCaravan, hstring pid, hstring dialogId, callback_void_Critter_bool initScript, int aiPack, int bagId, int teamId, int level,
                  int reaction, int isNervous, int chanceJoin, bool isUnique)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    ci.CaravanGuards.insertLast(
        CaravanGuardInfo(idCaravan, pid, dialogId, initScript, aiPack, bagId, teamId, level, reaction, isNervous, chanceJoin, isUnique));
}

// добавление спутников-нпц, не участвующих в заварушке
// idCaravan - код каравана.
// pid - прототип криттера
// dialog - диалог
// team - команда
// bag - инвентарь
void AddFollowerInfo(int idCaravan, hstring pid, hstring dialog, int team, int bag)
{
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        return;
    }

    CaravanNpcFollowerInfo f = CaravanNpcFollowerInfo();

    f.CaravanId = idCaravan;
    f.Pid = pid;
    f.DialogId = dialog;
    f.TeamId = team;
    f.BagId = bag;

    ci.Followers.insertLast(f);
}

/* ************************ Расписание движения караванов. Подготовка и начало. ********************* */
// в базе события не сохраняются, поскольку при рестарте сервера караван ломается
// каждый караван отправляется один раз в месяц
// idCaravan - код уже существующего описания каравана
// prepareDay - день, в который проводник начинает принимать заявки на участие
// prepareHour - час в который проводник начинает принимать заявки на участие
// startDay - день отправления караванов
// startHour - час отправления караванов
bool SheduleCaravan(int idCaravan, int prepareDay, int prepareHour, int startDay, int startHour)
{
    any[] values = {};

    values.insertLast(any(idCaravan));
    values.insertLast(any(prepareDay));
    values.insertLast(any(prepareHour));
    values.insertLast(any(startDay));
    values.insertLast(any(startHour));

    synctime time = GameTime::GetNearSynchronizedTime(0, 0, prepareDay, prepareHour, 0, 0);
    DebugLogVerbose("SheduleCaravan idCaravan = " + idCaravan);
    Game.StartTimeEvent(time - Game.SynchronizedTime, StartPrepareCaravan, values);
    return true;
}

[[TimeEvent]]
void StartPrepareCaravan(any[] values)
{
    if (values.length() == 0) {
        Game.Log("Shedule caravan error");
        return;
    }

    int idCaravan = values[0];
    int prepareDay = values[1];
    int prepareHour = values[2];
    int startDay = values[3];
    int startHour = values[4];
    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        Game.Log("Can not found CaravanInfo Id=" + idCaravan);
        return;
    }

    DebugLogVerbose("e_PrepareCaravan idCaravan = " + ci.CaravanId + ";");
    if (ci.Leader.CritterId != ZERO_IDENT) {
        Critter? leader = ci.Leader.GetLeader();
        if (leader != null) {
            if (leader.IsDead()) {
                Game.StartTimeEvent(Time::GameHours(4), StartPrepareCaravan, values);
                return;
            }
        }
    }

    synctime time = GameTime::GetNearSynchronizedTime(0, 0, startDay, startHour, 0, 0);
    Game.StartTimeEvent(time - Game.SynchronizedTime, BeginCaravan, values);
    PrepareCaravan(idCaravan);
}

[[TimeEvent]]
void BeginCaravan(any[] values)
{
    if (values.length() < 5) {
        Game.Log("Shedule caravan error");
        return;
    }

    int idCaravan = values[0];
    int prepareDay = values[1];
    int prepareHour = values[2];
    int startDay = values[3];
    int startHour = values[4];

    CaravanInfo? ci = GetCaravan(idCaravan);
    if (ci == null) {
        Game.Log("Can not found CaravanInfo Id=" + idCaravan);
        return;
    }

    StartCaravanImpl(idCaravan);
    Game.StartTimeEvent((GameTime::GetNearSynchronizedTime(0, 0, prepareDay, prepareHour, 0, 0) - Game.SynchronizedTime), StartPrepareCaravan, values);
}

/* **************************** Проводник караванов. Скрипт и обработчики *************************** */
void CaravanLeaderInit(Critter leader, bool firstTime)
{
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        return;
    }

    CaravanLeaderInfo li = ci.Leader;
    li.CritterId = leader.Id;

    if (firstTime) {
        leader.Level = ci.Leader.Level;
        AmplifyCaravaneer(leader);
    }

    leader.CharismaBase = 10;
    leader.OnGlobalMapProcess.Subscribe(CaravanLeaderOnGlobal);
    leader.OnDead.Subscribe(CaravanLeaderOnDead);
    leader.OnSomeCritterDead.Subscribe(CaravanLeaderOnSeeSmthDead);
    leader.OnGlobalMapInvite.Subscribe(CaravanLeaderOnInvite);
    leader.OnMessage.Subscribe(CaravanLeaderOnMessage);
    leader.OnSomeCritterUseSkill.Subscribe(CaravanLeaderOnSmthUseSkill);
    leader.OnNpcPlaneEnd.Subscribe(CaravanLeaderOnPlaneEnd);
    SetEvents(leader, ci.Leader.Virtue);
}

[[Event]]
EventResult CaravanLeaderOnPlaneEnd(Critter cr, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(cr, planeId);
    if (plane == null) {
        return EventResult::StopChain;
    }

    Map? map = cr.GetMap();
    if (map != null) {
        if (reason != NpcPlanes::REASON_SUCCESS && plane.Type == NpcPlanes::AI_PLANE_WALK && map.IsHexMovable(plane.Walk_Hex)) {
            {
                plane.Walk_Cut--;
            }
        }
    }

    return EventResult::StopChain;
}

// снятие обработчиков, если не известен караван
void CancelEvents(Critter leader)
{
    leader.OnGlobalMapProcess.Unsubscribe(CaravanLeaderOnGlobal);
    leader.OnDead.Unsubscribe(CaravanLeaderOnDead);
    leader.OnSomeCritterDead.Unsubscribe(CaravanLeaderOnSeeSmthDead);
    leader.OnGlobalMapInvite.Unsubscribe(CaravanLeaderOnInvite);
    leader.OnMessage.Unsubscribe(CaravanLeaderOnMessage);
    leader.OnSomeCritterUseSkill.Unsubscribe(CaravanLeaderOnSmthUseSkill);
    leader.OnNpcPlaneEnd.Unsubscribe(CaravanLeaderOnPlaneEnd);
}

// при воровстве у караванщиков игрок становится врагом каравана
[[Event]]
void CaravanLeaderOnSmthUseSkill(Critter cr, Critter thief, CritterProperty skill, Critter? onCritter, Item onItem, StaticItem onScenery)
{
    if (onCritter == null) {
        return;
    }

    CaravanInfo? ci = GetCaravan(onCritter.CaravanCrvId);
    if (ci == null) {
        return;
    }

    if (skill == CritterProperty::SkillSteal && ci.PlayerIsGuard(onCritter.Id)) {
        SetPlayerCaravanTheftFailure(thief, ci);
        ci.RemoveGuard(thief.Id);
        PlayerToCaravanEnemy(thief, ci);
    }
}

const int[] entries = {
    243,
    244,
    0}; // гексы на которых можно поставить, в первую очередь пробуем поставить на точках входа нпц, чтобы игроки были на некотором расстоянии от повозок
void FindCabPlace(Map map, int maxCabs, mpos[] hexes)
{
    int oX1 = 0; // координаты объекта, повозка№1
    int oY1 = 0;
    int oX2 = 0; // координаты объекта повозка№2
    int oY2 = 0;

    mpos hex, hex1, hex2;
    // i - индекс номер гекса в массиве entries
    // j = индекс гекса среди найденных на карте
    // l - число гексов данного номера
    // ents - число номеров гекса в массиве entries
    // tries - число попыток найти место для кабов
    for (int i = 0, j = 0, tries = 0, l = Entrance::MapCountEntry(map, entries[j]), ents = entries.length(); i < l && j < ents && tries < 30; i++) {
        tries++;
        if (Entrance::MapGetEntryCoords(map, entries[j], i, hex)) {
            // координаты гекса нашли
            // находим позицию в половинном расстоянии
            oX1 = int(hex.x - (MIN_DIST_CABS_DIST / 2));                               // смещение по оси х на запад
            oY1 = int(hex.y + (MIN_DIST_CABS_DIST / 2) * (1 - Game.Random(0, 1) * 2)); // смещение по оси y на юг или на север
            hex1 = mpos(oX1, oY1);
            if (Entrance::GetFreeHex(map, 1, hex1)) {
                // считаем, что первая точка найдена
                oX2 = int(hex.x + (MIN_DIST_CABS_DIST / 2));                               // смещение по оси х на запад
                oY2 = int(hex.y + (MIN_DIST_CABS_DIST / 2) * (1 - Game.Random(0, 1) * 2)); // смещение по оси y на юг или на север
                hex2 = mpos(oX2, oY2);
                if (Entrance::GetFreeHex(map, 1, hex2)) {
                    // вторая точка тоже найдена
                    // помещаем координаты в массивы
                    hexes.insertLast(hex1);
                    hexes.insertLast(hex2);
                    if (maxCabs > 0 && hexes.length() > maxCabs) {
                        break;
                    }
                }
            }
        }

        // к следующему номеру гексов, если на предыдушем не нашли ничего
        if (i + 1 == l && j + 1 < ents) {
            j++;
            l = Entrance::MapCountEntry(map, entries[j]);
            i = 0;
        }
    }
}

// сообщение от нпц
[[Event]]
void CaravanLeaderOnMessage(Critter leader, Critter fromCr, int message, any value)
{
    if (message == MSG_WHERE_IS_DA_LEADER) {
        MoveToCaravanLeader(fromCr, leader, Game.Random(2, 10));
    }
}

// вход на энкаунтер
[[Event]]
EventResult CaravanLeaderOnInvite(Critter leader, Item car, int encounterDescriptor, int combatMode, ident mapId, mpos hex, mdir dir)
{
    Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(leader);
    uint8 dirByte = dir.hex.value;
    Worldmap::InviteToEncounter(group, null, encounterDescriptor, combatMode, mapId, hex, dirByte);
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        return EventResult::StopChain;
    }

    if (!CheckHasPlayerInGroup(group)) {
        if (ci.Type == CRV_TYPE_ONEWAY_DELETELEADER || ci.Type == CRV_TYPE_ONEWAY_DELETELEADER_BOTH) {
            Game.StartTimeEvent(GameTime::GameSeconds(TIME_TO_DELETE_LEADER), DeleteLeader, leader.Id); //SavedDeferredCall
            // Обязательно сохраняем эвент. Иначе можно оказаться с двумя начлаьниками караванов.
        }

        ci.TerminateCaravan();
        return EventResult::StopChain;
    }

    Map? map = Game.GetMap(mapId);
    if (map == null) {
        Game.Log("Invalid map");
        return EventResult::StopChain;
    }

    ci.CaravanStatus = CRV_STATUS_ON_ENCOUNTER;

    // ищем место для нескольких повозок
    // кладем по две повозки
    // находим место, где можно поставить 2 повозки
    // между повозками расстояние должно быть 7..8 гексов
    mpos[] hexes = {};

    FindCabPlace(map, 100, hexes); // TODO: поставить нормальное ограничение, сейчас использую для проверки, сколько точек будет найдено

    Item[] cabItems = {};
    for (int i = 0, lx = hexes.length(), lc = ci.Cabs.length(); i < lx && i < lc; i++) {
        Item? cab = ci.Cabs[i].PlaceCabOnMap(map, hexes[i], ci.IsReversed);

        if (cab != null) {
            cabItems.insertLast(cab);
            cab.CaravanCabLeaderId = leader.Id;
            cab.OnCritterUseSkill.Subscribe(OnTryOpenCabs);
            cab.NoBlock = false;
        }
    }

    // располагаем небоевых нпц в составе каравана
    if (cabItems.length() > 0) {
        for (int j = 0; j < ci.Followers.length(); j++) {
            ci.Followers[j].AddNpcNearItem(map, cabItems[Game.Random(0, (cabItems.length() - 1))], 8);
        }

        // если есть повозки, проводник ходит от одной к другой
        leader.StartTimeEvent(Time::Asap(), Time::Seconds(1), CaravanLeaderIdleOnEncounter);
        leader.CaravanIdleCount = 9;
    }
    else {
        if (ci.Followers.length() > 0) {
            Critter? firstFollower = ci.Followers[0].AddNpcNearCritter(map, leader, 1);
            if (firstFollower != null) {
                for (int k = 1; k < ci.Followers.length(); k++) {
                    ci.Followers[k].AddNpcNearCritter(map, firstFollower, 6);
                }
            }
            else {
                for (int k = 1; k < ci.Followers.length(); k++) {
                    ci.Followers[k].AddNpcNearCritter(map, leader, 20);
                }
            }
        }
    }

    return EventResult::StopChain;
}

[[Event]]
EventResult OnTryOpenCabs(Item item, Critter cr, CritterProperty skill)
{
    // залезть в контейнер можно только, если проводник мертв
    Critter? leader = Game.GetCritter(item.CaravanCabLeaderId);
    if (leader != null) {
        if (!leader.IsAlive()) {
            return EventResult::StopChain;
        }

        Messaging::SayShoutOnHead(leader, TextPackKey(TextPackName::Text, "" + (STR_DONT_TOUCH)));
        return EventResult::StopChain;
    }

    return EventResult::StopChain;
}

// при долгом простое, проводник перемещается к одной из повозок
[[TimeEvent]] [[Async]]
void CaravanLeaderIdleOnEncounter(Critter leader)
{
    if (!Sync::LockCritterWithMap(leader)) {
        return;
    }

    DebugLog("leader enc iddle fired/ Geck" + leader.IsGeck);
    if (leader.CaravanIdleCount > 9) {
        Map? map = leader.GetMap();
        if (map == null) {
            return;
        }

        Item[] cabs = map.GetItems(Game.Random(0, 1) == 0 ? Content::Item::wagon_red : Content::Item::wagon_grey);
        if (!cabs.isEmpty()) {
            leader.CaravanIdleCount = 0;
            int idx = Game.Random(0, cabs.length() - 1);
            mpos hex = cabs[idx].Hex;
            if (Entrance::GetFreeHex(map, 4, hex)) {
                NpcPlanes::AddWalkPlane(leader, NpcPlanes::AI_PLANE_WALK_PRIORITY, hex, HDIR_Random, (Game.Random(0, 5) == 1 ? true : false), 1);
            }
        }
    }
    else {
        leader.CaravanIdleCount += 1;
    }
}

// смерть игрока = провал квеста для этого игрока
[[Event]]
void CaravanLeaderOnSeeSmthDead(Critter leader, Critter fromCrit, Critter? killer)
{
    DebugLog("CaravanLeaderOnSeeSmthDead");
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        // перестраховка
        CancelEvents(leader);
        Game.Log("Caravan error; CaravanInfo not found");
        return;
    }

    if (!ci.PlayerIsGuard(fromCrit.Id)) {
        return;
    }

    // убит игрок-охранник
    if (fromCrit.ControlledByPlayer) {
        SetPlayerCaravanDeadFailure(fromCrit, ci);
        return;
    }

    // игрок охранник убил нпц-охранника
    if (killer == null) {
        return;
    }

    if (killer.ControlledByPlayer) {
        SetPlayerCaravanTheftFailure(killer, ci);
        PlayerToCaravanEnemy(killer, ci);
    }
}

// смерть проводника = провал квеста всем игрокам
[[Event]]
void CaravanLeaderOnDead(Critter leader, Critter? killer)
{
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        // перестраховка
        CancelEvents(leader);
        Game.Log("Caravan error; CaravanInfo not found");
        return;
    }

    if (ci.CaravanStatus > CRV_STATUS_PREPARE && ci.CaravanStatus < CRV_STATUS_END) {
        SetQuestState(ci, CARAVAN_FAILURE_CARAVANLEADER_DEAD);
        if (killer != null) {
            if (killer.ControlledByPlayer) {
                SetPlayerKilledCaravanLeaderFailure(killer, ci);
                PlayerToCaravanEnemy(killer, ci);
                ci.RemoveGuard(killer.Id);
            }
        }
    }

    // удаляем проводника досрочно
    if (ci.Type == CRV_TYPE_ONEWAY_DELETELEADER || ci.Type == CRV_TYPE_ONEWAY_DELETELEADER_BOTH) {
        Game.StartTimeEvent(GameTime::GameSeconds(TIME_TO_DELETE_LEADER), DeleteLeader, leader.Id); //SavedDeferredCall
        // Обязательно сохраняем эвент. Иначе можно оказаться с двумя начлаьниками караванов.
    }
}

// глобальная карта
[[Event]]
EventResult CaravanLeaderOnGlobal(Critter leader, int type, Item car, float x, float y, float toX, float toY, float speed, int encounterDescriptor,
                                  bool waitForAnswer)
{
    Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(leader);
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        // перестраховка
        CancelEvents(leader);
        Game.Log("Caravan error; CaravanInfo not found");
        return EventResult::StopChain;
    }

    if (type == Tla::GlobalProcessMove || type == Tla::GlobalProcessStopped) {
        // во всех остальных случаях необходимо проверить, что в группе есть хотя бы один игрок
        if (!CheckHasPlayerInGroup(group)) {
            // Удаляем караван и лидера
            ci.TerminateCaravan();
            return EventResult::StopChain;
        }
    }
    else {
        for (int i = 0; i < group.length(); i++) {
            if (group[i].ControlledByPlayer) {
                SetPlayerCaravanJoined(group[i], ci);
            }
        }
    }

    if (encounterDescriptor != 0) {
        return EventResult::StopChain; // Энкаунтер
    }

    ci.CaravanRoute.SetRouteDir(int(x), int(y), toX, toY);
    // установка направления движения

    if (type != Tla::GlobalProcessMove) {
        // все точки маршрута пройдены или не назначены
        if (ci.CaravanRoute.RouteEnded()) {
            Location? loc = Game.GetLocation(ci.Leader.EndPos.LocPid);
            if (loc == null) {
                return EventResult::StopChain;
            }

            int endX = loc.WorldPos.x;
            int endY = loc.WorldPos.y;
            if ((endX == int(x)) and (endY == int(y))) {
                // маршрут закончен
                if (EndCaravan(leader)) {
                    return EventResult::StopChain;
                }
                else {
                    // проблемы с завершением каравана
                    Worldmap::FindEncounter(group, null, int(x), int(y), encounterDescriptor, waitForAnswer, true);
                    Game.Log("Can not end caravan");
                    return EventResult::StopChain;
                }
            }
            else {
                // encounterDescriptor = 0;
                toX = endX;
                toY = endY;
            }
        }

        speed = Tla::GLOBAL_MAP_BASE_SPEED * ci.GlobalSpeedMultiplayer;
        return EventResult::StopChain;
    }

    waitForAnswer = false;
    return EventResult::StopChain;
}

/* ********************************* Этап№1 сбор заявок от игроков ********************************** */
void PrepareCaravan(int CaravanId)
{
    CaravanInfo? ci = GetCaravan(CaravanId);
    if (ci == null) {
        return;
    }

    ci.CaravanReset();
    ci.CaravanStatus = CRV_STATUS_PREPARE;

    Critter? leader = ci.Leader.GetLeader();
    if (leader == null) {
        Critter[] critters = GetCrittersByDialogId(ci.Leader.StartPos.GetMap(), ci.Leader.DialogId, ci.Leader.NpcPid);
        if (!critters.isEmpty()) {
            leader = critters[0];
            ci.Leader.SetLeaderCritter(leader);
        }
        else {
            critters = GetCrittersByDialogId(ci.Leader.EndPos.GetMap(), ci.Leader.DialogId, ci.Leader.NpcPid);
            if (!critters.isEmpty()) {
                leader = critters[0];
                ci.Leader.SetLeaderCritter(leader);
            }
        }

        if (leader == null) {
            if (!ci.Leader.PlaceLeaderCritterToPos(ci.Leader.StartPos)) {
                return;
            }
        }
    }

    if (!ci.Leader.CheckLeaderInPos(true)) {
        if (!ci.Leader.TransferToPos(true)) {
            return;
        }
    }

    leader = ci.Leader.GetLeader();
    if (leader == null) {
        return;
    }

    SetEvents(leader, ci.Leader.Virtue);
}

/* ********************************** Этап№2 отправление каравана *********************************** */
void StartCaravanImpl(any caravanId)
{
    CaravanInfo? ci = GetCaravan(caravanId);
    if (ci == null) {
        return;
    }

    Critter? leader = ci.Leader.GetLeader();
    if (leader == null) {
        return;
    }

    if (leader.IsDead()) {
        return;
    }

    Map? map = leader.GetMap();
    if (map == null) {
        return;
    }

    // проверка, хватает ли игроков
    if (ci.PlayersRequested.length() == 0) {
        ci.CaravanStatus = CRV_STATUS_BEFORE_START;
        return;
    }

    int curPlayersInGrp = 0;
    // группа караванщиков
    Critter[] caravanGroup = {};
    caravanGroup.insertLast(leader);
    // всех игроков в группу, сколько разрешено
    for (int i = 0; i < ci.PlayersRequested.length(); i++) {
        Critter? player = Game.GetCritter(ci.PlayersRequested[i]);
        if (player == null) {
            continue;
        }

        if (player.IsDead()) {
            continue;
        }

        Map? playerMap = player.GetMap();
        if (player.GetMap() == null) {
            continue;
        }

        if (Game.GetDistance(leader.Hex, player.Hex) <= LEADER_SEARCH_RADIUS) {
            ci.RequstedToGuard(player.Id);
            caravanGroup.insertLast(player);
            curPlayersInGrp++;
        }

        if (curPlayersInGrp >= ci.MaxPlayers) {
            break;
        }
    }

    if (ci.PlayersRequested.length() > ci.MaxPlayers) {
        ci.PlayersRequested.resize(ci.MaxPlayers);
    }

    if (curPlayersInGrp == 0) {
        return;
    }

    // число попыток, чтобы не завис цикл
    int numTry = 0;
    // индекс из списка определений охранников
    int idx = 0;
    // добавление НПЦ-охранников в группу ci.CaravanGuards
    while (caravanGroup.length() < ci.MaxGroup && ci.CaravanGuards.length() > 0) {
        DebugLog("adding guards");
        numTry++;
        if (numTry >= 20) {
            break; // 20 попыток должно хватить
        }

        Critter? guard = ci.CaravanGuards[idx].GetCritterGuard(map, leader);
        idx = (idx + 1 < ci.CaravanGuards.length() ? idx + 1 : 0);
        if (guard != null) {
            ci.Caravaneers.insertLast(guard.Id);
            caravanGroup.insertLast(guard);
        }
    }

    // основной скрипт проводника
    leader.SetupScript(CaravanLeaderInit);
    ci.CaravanStatus = CRV_STATUS_START_MOVE;
    // начало движения по глобальной карте
    leader.TransferToGlobal();
}

[[TimeEvent]]
void StartCaravan(any caravanId)
{
    StartCaravanImpl(caravanId);
}

/* **************************** Этап№3. Выход со случайного энкаунтера ****************************** */
void ContinueCaravan(Critter leader)
{
    DebugLog("continue caravan started");
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + leader.CaravanCrvId);
        return;
    }

    Map? map_leader = leader.GetMap();
    if (map_leader == null) {
        return;
    }

    Critter[] caravanGroup = {};
    caravanGroup.insertLast(leader);
    DebugLog("try find caravaneers");
    ident[] deadGuardIds = {};
    for (int i = 0; i < ci.Caravaneers.length(); i++) {
        Critter? guard = Game.GetCritter(ci.Caravaneers[i]);
        if (guard == null) {
            deadGuardIds.insertLast(ci.Caravaneers[i]); // охранника нужно убрать из списка
            // TODO: добавить установку значения переменной для инвалидных охранников
            continue;
        }

        // охранник найден
        Map? map = guard.GetMap();
        if (map == null) {
            deadGuardIds.insertLast(ci.Caravaneers[i]); // охранника нужно убрать из списка
            if (guard.ControlledByPlayer) {
                SetPlayerCaravanAbandonedFailure(guard, ci);
            }

            continue;
        }

        if (guard.IsDead() || map.Id != map_leader.Id) {
            deadGuardIds.insertLast(ci.Caravaneers[i]); // охранника нужно убрать из списка
            if (guard.ControlledByPlayer) {
                SetPlayerCaravanAbandonedFailure(guard, ci);
            }

            continue;
        }

        caravanGroup.insertLast(guard);
    }

    for (int j = 0; j < deadGuardIds.length(); j++) {
        ci.RemoveGuard(deadGuardIds[j]);
    }

    DebugLog("status sent");
    ci.CaravanStatus = CRV_STATUS_ON_GLOBAL;
    if (CheckHasPlayerInGroup(caravanGroup)) {
        leader.TransferToGlobal();
    }
}

/* ***************************** Этап 4. Завершение движения каравана ******************************* */
// завершение каравана. Караван пришел в пункт назначения.
bool EndCaravan(Critter leader)
{
    CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
    if (ci == null) {
        CancelEvents(leader);
        Game.Log("Error: CaravanInfo not found. Id = " + leader.CaravanCrvId);
        return false;
    }

    // переключаем статус квеста игрокам
    for (int i = 0; i < ci.Caravaneers.length(); i++) {
        Critter? player = Game.GetCritter(ci.Caravaneers[i]);
        if (player != null) {
            if (player.ControlledByPlayer) {
                SetPlayerFirstCaravanSuccess(player, ci);
                SetPlayerNextCaravanSuccess(player, ci);
            }
        }
    }

    Map? map = ci.Leader.EndPos.GetMap();
    if (map == null) {
        return false;
    }

    auto hex = ci.Leader.EndPos.Hex;
    if (!Entrance::GetFreeHex(map, 3, hex)) {
        return false;
    }

    if (!Entrance::CritterTransferToMapEntry(leader, map.Id, "0".hstr())) {
        return false;
    }

    leader.HomeMapId = map.Id;
    leader.HomeHex = hex;
    leader.HomeDir = leader.Dir.hex.value;
    ci.CaravanStatus = CRV_STATUS_END;

    // удаляем нпц-охранников
    for (int j = 0; j < ci.Caravaneers.length(); j++) {
        Critter? guard = Game.GetCritter(ci.Caravaneers[j]);
        if (guard != null) {
            if (!guard.ControlledByPlayer) {
                Game.DestroyCritter(guard);
            }
        }
    }

    CancelEvents(leader);
    if (ci.Type == CRV_TYPE_TWOWAY) {
        ci.CaravanRoute.ReverseRouteCurve();
        SwitchNpcPosition(ci.Leader.StartPos, ci.Leader.EndPos);
        ci.IsReversed = (ci.IsReversed ? false : true);
    }

    if (ci.Type == CRV_TYPE_ONEWAY_TRANSITLEADER) {
        Game.StartTimeEvent(GameTime::GameSeconds(TIME_TO_WAIT_AT_ENDPOINT), TransferToStartPos, leader.Id);
    }

    if (ci.Type == CRV_TYPE_ONEWAY_DELETELEADER || ci.Type == CRV_TYPE_ONEWAY_DELETELEADER_BOTH) {
        ci.CaravanStatus = CRV_STATUS_END;
        Game.StartTimeEvent(GameTime::GameSeconds(TIME_TO_DELETE_LEADER + TIME_TO_WAIT_AT_ENDPOINT), DeleteLeader, leader.Id); //SavedDeferredCall
        // Обязательно сохраняем эвент. Иначе можно оказаться с двумя начлаьниками караванов.
    }

    DebugLog("End Caravan success");
    return true;
}

[[TimeEvent]]
void DeleteLeader(any value)
{
    DebugLog("try delete leader");
    Critter? leader = Game.GetCritter(value);
    if (leader != null) {
        CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
        if (ci != null) {
            ci.CaravanReset();
            CaravanLeaderInfo li = ci.Leader;
            if (li.CritterId != leader.Id) {
                Game.Log("Wrong eader id");
                return;
            }
        }

        if (!leader.ControlledByPlayer) {
            Game.DestroyCritter(leader);
        }
    }

    DebugLog("success");
}

[[TimeEvent]]
void TransferToStartPos(any value)
{
    Critter? leader = Game.GetCritter(value);
    if (leader != null) {
        CaravanInfo? ci = GetCaravan(leader.CaravanCrvId);
        if (ci != null) {
            ci.Leader.TransferToPos(true);
        }
    }
}

/* ********************************************* ОБЩЕЕ ********************************************** */
// проверка, в массиве есть хотя бы один игрок
bool CheckHasPlayerInGroup(Critter[] group)
{
    for (int i = 0; i < group.length(); i++) {
        if (group[i].ControlledByPlayer) {
            return true;
        }
    }

    return false;
}

// Инструкция атаковать игрока всем караванщикам
void PlayerToCaravanEnemy(Critter player, CaravanInfo ci)
{
    DebugLog("PlayerToCaravanEnemy start");
    for (int i = 0; i < ci.Caravaneers.length(); i++) {
        Critter? cr = Game.GetCritter(ci.Caravaneers[i]);
        if (cr != null) {
            if (!cr.ControlledByPlayer && !EnemyStack::CheckEnemyInStack(cr, player.Id)) {
                EnemyStack::AddEnemyToStack(cr, player.Id);
            }
        }
    }
}

// установка статуса всем караванщикам, независимо от того, онлайн игрок или нет
// у переменной должен быть статус >0
void SetQuestState(CaravanInfo ci, int state)
{
    DebugLog("SetQuestState start");
    for (int i = 0; i < ci.Caravaneers.length(); i++) {
        Critter? cr = Game.GetCritter(ci.Caravaneers[i]);
        if (cr != null) {
            if (!cr.ControlledByPlayer) {
                continue;
            }

            SetQuestState(ci.QuestVarNum, state, cr);
        }
    }
}

// установка статуса переменной для конкретного криттера
// статус у переменной должен быть>0
void SetQuestState(CritterProperty prop, int state, Critter cr)
{
    if (cr.GetAsInt(prop) < CRV_STATUS_PREPARE) {
        return;
    }

    cr.SetAsInt(prop, state);
}

/* ******************************************** ДИАЛОГИ ********************************************* */
// функция для использования в диалогах: признак = группа полная (максимум 5 игроков)
bool IsFullPartyImpl(Critter player, Critter caravaneer)
{
    // получаем описание каравана
    CaravanInfo? ci = GetCaravan(caravaneer.CaravanCrvId);
    if (ci == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + caravaneer.CaravanCrvId);
        return true;
    }

    return (ci.PlayersRequested.length() > ci.MaxPlayers);
}

[[DialogDemand]]
bool IsFullParty(Critter player, Critter caravaneer)
{
    return IsFullPartyImpl(player, caravaneer);
}

// функция для использования в диалогах: признак = еще не набрано 5 игроков
[[DialogDemand]]
bool NotIsFullParty(Critter player, Critter caravaneer)
{
    return not IsFullPartyImpl(player, caravaneer);
}

// функция для использования в диалогах: признак = заявка игрока уже принята
bool HasPlayerRequestImpl(Critter player, Critter caravaneer)
{
    CaravanInfo? crv = GetCaravan(caravaneer.CaravanCrvId);
    if (crv == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + caravaneer.CaravanCrvId);
        return false;
    }

    for (int i = 0; i < crv.PlayersRequested.length(); i++) {
        if (crv.PlayersRequested[i] == player.Id) {
            return true;
        }
    }

    return false;
}

[[DialogDemand]]
bool HasPlayerRequest(Critter player, Critter caravaneer)
{
    return HasPlayerRequestImpl(player, caravaneer);
}

// функция для использования в диалогах: признак = заявка игрока еще не принята
[[DialogDemand]]
bool NotHasPlayerRequest(Critter player, Critter caravaneer)
{
    return not HasPlayerRequestImpl(player, caravaneer);
}

// признак - может идти в сопровождение
[[DialogDemand]]
bool CanJoin(Critter player, Critter caravaneer)
{
    CaravanInfo? crv = GetCaravan(caravaneer.CaravanCrvId);
    if (crv == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + caravaneer.CaravanCrvId);
        return false;
    }

    return CanPlayerJoinCaravan(player, crv);
}

// записывает игрока в список желающих
void PutPlayerRequest2InfoImpl(Critter player, Critter caravaneer)
{
    CaravanInfo? crv = GetCaravan(caravaneer.CaravanCrvId);
    if (crv == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + caravaneer.CaravanCrvId);
        return;
    }

    if (!HasPlayerRequestImpl(player, caravaneer)) {
        crv.PlayersRequested.insertLast(player.Id);
    }
}

[[DialogResult]]
void PutPlayerRequest2Info(Critter player, Critter caravaneer)
{
    PutPlayerRequest2InfoImpl(player, caravaneer);
}

// продолжение движения каравана
[[DialogResult]]
void ContinueCaravanResult(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    CaravanInfo? crv = GetCaravan(npc.CaravanCrvId);
    if (crv == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + npc.CaravanCrvId);
        return;
    }

    if (crv.CaravanStatus != CRV_STATUS_ON_ENCOUNTER) {
        return;
    }

    if (HasPlayerRequestImpl(player, npc)) {
        ContinueCaravan(npc);
    }
}

// Мгновенно запускает караван, вне расписания
[[DialogResult]]
void StartCaravan(Critter player, Critter npc)
{
    CaravanInfo? ci = GetCaravan(npc.CaravanCrvId);
    if (ci != null) {
        PutPlayerRequest2InfoImpl(player, npc);
        DebugLog("time start");
        StartCaravanImpl(npc.CaravanCrvId);
    }
}

// проверка, в каком состоянии караван для нпц
bool IsCaravanStatusImpl(Critter player, Critter npc, int status)
{
    CaravanInfo? ci = GetCaravan(npc.CaravanCrvId);
    if (ci == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + npc.CaravanCrvId);
        if (status == 0) {
            return true;
        }

        return false;
    }

    return (int(ci.CaravanStatus) == status);
}

[[DialogDemand]]
bool IsCaravanStatus(Critter player, Critter npc, any status)
{
    return IsCaravanStatusImpl(player, npc, status);
}

[[DialogDemand]]
bool NotIsCaravanStatus(Critter player, Critter npc, any status)
{
    return !IsCaravanStatusImpl(player, npc, status);
}

// признак, караван не начинался или закончен
[[DialogDemand]]
bool CaravanEndedOrNotStarted(Critter player, Critter npc)
{
    CaravanInfo? ci = GetCaravan(npc.CaravanCrvId);
    if (ci == null) {
        // Game.Log("Error: CaravanInfo not found. Id = " + npc.CaravanCrvId);
        return true;
    }

    // Game.Log("st"+ci.CaravanStatus);
    return (ci.CaravanStatus == CRV_STATUS_BEFORE_START || ci.CaravanStatus == CRV_STATUS_END);
}

// проверка, игрок ни разу не заваливал квест на сопровождение данного каравана
[[DialogDemand]]
bool PlayerHasNoCaravanFailures(Critter player, Critter npc)
{
    CaravanInfo? ci = GetCaravan(npc.CaravanCrvId);
    if (ci == null) {
        // Game.Log("Error: CaravanInfo not found. Id = " + npc.CaravanCrvId);
        return true;
    }

    return !HasPlayerFailedCaravanQuest(player, ci);
}

// проверка караван пойдет обратно или в начальном направлении
bool IsCaravanReversedImpl(Critter player, Critter npc)
{
    CaravanInfo? ci = GetCaravan(npc.CaravanCrvId);
    if (ci == null) {
        Game.Log("Error: CaravanInfo not found. Id = " + npc.CaravanCrvId);
        return false;
    }

    return (ci.IsReversed);
}

[[DialogDemand]]
bool IsCaravanReversed(Critter player, Critter npc)
{
    return IsCaravanReversedImpl(player, npc);
}

[[DialogDemand]]
bool NotIsCaravanReversed(Critter player, Critter npc)
