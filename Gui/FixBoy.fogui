// FOGUI V2
// {
//   "$type": "Screen",
//   "IsModal": true,
//   "IsMultiinstance": false,
//   "IsCloseOnMiss": false,
//   "AvailableCursors": null,
//   "IsCanMove": true,
//   "IsMoveIgnoreBorders": false,
//   "BackgroundImage": "art/intrface/fixboy.png",
//   "BackgroundImageLayout": "None",
//   "CropContent": false,
//   "IsVerticalScroll": false,
//   "IsHorizontalScroll": false,
//   "Expanded": true,
//   "Selected": true,
//   "Active": true,
//   "Name": "FixBoy",
//   "Position": "0, 0",
//   "Size": "640, 480",
//   "Anchor": "None",
//   "Dock": "None",
//   "IsDraggable": false,
//   "IsNotHittable": false,
//   "CheckTransparentOnHit": false,
//   "GlobalScope":
{
    enum NumMenu
    {
        MenuList,
        MenuCraft,
        MenuDesc,
    }

    class CCraft
    {
        int Id;
        any[] OutItems = {};
        bool IsCanCraft;

        CCraft(int id, any[] items, bool isCanCraft)
        {
            Id = id;
            OutItems = items;
            IsCanCraft = isCanCraft;
        }
    };

    void SetPositionOnWhoileSize(Gui::Object parent)
    {
        int x = 0, y = 0;
        for (int i = 0; i < parent.ChildCount; i++) {
            Gui::Object curObj = parent.GetChild(i);
            if (cast<Gui::Grid?>(curObj) == null) {
                SetPositionOnWhoileSize(curObj);
            }
            if (i == 0) {
                x = curObj.Pos.x;
                y = curObj.Pos.y;
                continue;
            }
            Gui::Object preObj = parent.GetChild(i - 1);
            int centerX = 0, centerY = 0, wholeWidth = 0, wholeHeight = 0;
            preObj.GetWholeSize(ipos(centerX, centerY), isize(wholeWidth, wholeHeight), false);
            y += wholeHeight;
            curObj.SetPosition(curObj.Pos.x, y);
        }
    }

    void ChangeChildActive(Gui::Object obj, string name)
    {
        for (int i = 0; i < obj.ChildCount; i++) {
            obj.GetChild(i).SetActive(false);
        }
        if (!name.isEmpty()) {
            GuiScreensExt::NeedObject(obj.Find(name)).SetActive(true);
        }
    }
}
//   "ClassFields":
{
    {
        NumMenu Menu;

        CCraft[] CraftList = {};
        CCraft CraftItem;
        int StrNum;

        any[] OutItems = {};
        any[] NeedResources = {};
        any[] NeedTools = {};
        any[] NeedParams = {};

        void SetMenu(NumMenu menu)
        {
            if (menu == Menu) {
                return;
            }
            Menu = menu;

            switch (Menu) {
            case GuiScreens::FixBoy::NumMenu::MenuDesc:
                ChangeChildActive(GuiScreensExt::NeedObject(Find("Panel1")), "MessageText");
                break;

            case GuiScreens::FixBoy::NumMenu::MenuList:
                ChangeChildActive(GuiScreensExt::NeedObject(Find("Panel1")), "ShowCraftItemGrid");
                break;

            case GuiScreens::FixBoy::NumMenu::MenuCraft:
                ChangeChildActive(GuiScreensExt::NeedObject(Find("Panel1")), "ShowCraftParamPanel");
                SetPositionOnWhoileSize(GuiScreensExt::NeedObject(Find("ShowCraftParamPanel")));
                break;

            default:
                break;
            }
        }
    }
}
//   "OnInit":
{
    {
        {
        }
    }
}
//   "OnShow":
{
    {
        {
            if (params.length() == 0) {
                CurPlayer.ServerCall.Rpc_CraftItem(Tla::FixboyList, 0, 0);
                SetMenu(GuiScreens::FixBoy::NumMenu::MenuDesc);
            }
            else {
                StrNum = params["StrNum"];
                if (StrNum != 0) {
                    SetMenu(GuiScreens::FixBoy::NumMenu::MenuDesc);
                    return;
                }

                int craftId = params["CraftId"];
                if (craftId == 0) {
                    any[] data = FixBoy::g_PendingFixBoyData;
                    CraftList.clear();
                    int index = 0;
                    while (index + 5 < data.length()) {
                        int id = int(data[index++]);
                        bool isCanCraft = int(data[index++]) == 1;
                        int len = int(data[index++]);
                        any[] outItems = array<any>(len);
                        for (int i = 0; i < len; i++) {
                            outItems[i] = data[index++];
                        }
                        CraftList.insertLast(CCraft(id, outItems, isCanCraft));
                    }
                    SetMenu(GuiScreens::FixBoy::NumMenu::MenuList);
                }
                else {
                    Game.Log("Crafft id!");
                    int index = 0;
                    any[] data = FixBoy::g_PendingFixBoyData;
                    if (data.length() == 0) {
                        return;
                    }

                    int length = index + int(data[index++]);
                    NeedResources.clear();
                    while (index < length) {
                        NeedResources.insertLast(data[index++]);
                    }

                    length = index + int(data[index++]);
                    NeedTools.clear();
                    while (index < length) {
                        NeedTools.insertLast(data[index++]);
                    }

                    length = index + int(data[index++]);
                    NeedParams.clear();
                    while (index < length) {
                        NeedParams.insertLast(data[index++]);
                    }

                    SetMenu(GuiScreens::FixBoy::NumMenu::MenuCraft);
                }
            }
        }
    }
}
