{
    {
        {
            any[] actions = {};
            ChosenActions::GetChosenActions(actions);
            int[] useItemAction = {Tla::ChosenTakeAll, 0, 0, 0, 0, 0, 0};
            for (int i = 0; i < useItemAction.length(); i++) {
                actions.insertLast(useItemAction[i]);
            }
            ChosenActions::SetChosenActions(actions);
        }
    }
}
