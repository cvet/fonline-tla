// GameEventStorehouse — серверный игровой ивент «склад» на глобальной карте: создаёт
// скрытую локацию-хранилище, куда складывается отобранный у игроков и НПЦ лут.
// SERVER: создание локации в случайном регионе, наполнение охраной (бандиты-«шакалы»),
//   перенос лута в контейнер и отложенное уничтожение переполненного склада.
// Связи: Location/Map/Entrance (поиск и создание локаций, входы), EncounterNpc и
//   EnemyStack (инициализация и агрессия охраны), ItemMovement (перенос предметов),
//   Tla (служебные хелперы), Content (прото-id локации, карты, предметов, криттеров).
namespace GameEventStorehouse
{

#if SERVER

///@ Property Location Server ident StorehouseContId Mutable Persistent

// Разброс (радиус) случайного смещения точки установки локации от базовых координат региона
int LocationDelta()
{
    return int(3 * Settings.GlobalMap.GlobalMapZoneLength);
}

// Радиус поиска уже существующего склада рядом с координатами региона
int LocationSearchRadius()
{
    return 6 * Settings.GlobalMap.GlobalMapZoneLength;
}

const int ENTRY_GUARD = 177;
const int ENTRY_DIR = 178;
const int MAX_CONTAINER_ITEMS = 200;

// Базовые точки регионов глобальной карты, рядом с которыми может появиться склад
const int[][] GlobalCoords = {{668, 1121}, {375, 709}, {274, 367}, {685, 218}, {1224, 632}, {1073, 1181}, {1019, 119}};

// Точка входа игрового ивента: разово создаёт склад в случайном регионе, если его там ещё нет
void CreateStoreHouse()
{
    // Выбираем случайный регион из заданного списка
    int idx = Game.Random(0, GlobalCoords.length() - 1);

    // Если рядом с выбранным регионом склад уже существует — выходим
    Location[] locations = Location::GetLocationsInRadius(ipos(GlobalCoords[idx][0], GlobalCoords[idx][1]), LocationSearchRadius());
    if (locations.length() > 0) {
        for (int i = 0, l = locations.length(); i < l; i++) {
            Location loc = locations[i];
            if (loc.StorehouseContId != ZERO_IDENT) {
                return; // в данном регионе уже есть склад
            }
        }
    }

    // Случайно смещаем точку от центра региона и отбрасываем координаты у самого края карты
    int locX = GlobalCoords[idx][0] + Game.Random(-1 * LocationDelta(), LocationDelta());
    int locY = GlobalCoords[idx][1] + Game.Random(-1 * LocationDelta(), LocationDelta());
    if (locX < Settings.GlobalMap.GlobalMapZoneLength || locY < Settings.GlobalMap.GlobalMapZoneLength ||
        locX >= Settings.GlobalMap.GlobalMapZoneLength * (Settings.GlobalMap.GlobalMapHeight - 3) ||
        locY >= Settings.GlobalMap.GlobalMapZoneLength * (Settings.GlobalMap.GlobalMapHeight - 3)) {
        Game.Log("Triing create location: x=" + locX + "; y=" + locY);
        return;
    }

    // Создаём скрытую локацию-склад в выбранной точке
    Location loc = Location::CreateLocation(Content::Location::desert_12, ipos(locX, locY), null);
    loc.AutoGarbage = false;
    loc.Hidden = true;
    Map map = loc.GetMapByIndex(0);
    map.SetupScript(MapInit);
    // Запоминаем контейнер-склад (сундук на карте) и расставляем у входов охрану-«шакалов»
    Item[] items = map.GetItems(Content::Item::footlocker_clean_left);
    if (items.length() > 0) {
        loc.StorehouseContId = items[0].Id;
        loc.Hidden = true;
        loc.AutoGarbage = false;
        mpos hex;
        Entrance::GetNearEntry(map, ENTRY_DIR, hex);
        Entrance::Entry[] entries = Entrance::ParseEntries(map, ENTRY_GUARD);
        for (int i = 0; i < entries.length(); i++) {
            mdir dir = Game.GetDirection(entries[i].Hex, hex);
            hstring pid = Game.Random(0, 1) == 0 ? Content::Critter::JackalSniper : Content::Critter::JackalTerminator;
            int[] props = {CritterProperty::TeamId,
                           Teams::Bandit,
                           CritterProperty::NpcRole,
                           17,
                           CritterProperty::BagId,
                           pid == Content::Critter::JackalSniper ? Bags::Sniper1 : Bags::Term1,
                           CritterProperty::ReplicationTime,
                           -1};
            Critter npc = map.AddCritter(pid, entries[i].Hex, dir, Tla::GetCritPropsDict(props));
            npc.SetupScript(EncounterNpc::NpcInit);
        }
    }
}

// Инициализация карты склада: подписываемся на вход криттеров, чтобы натравить охрану
void MapInit(Map map, bool firstTime)
{
    map.OnCritterIn.Subscribe(MapInCritter);
}

// При входе игрока на карту склада все охранники-«шакалы» получают его как цель
[[Event]]
void MapInCritter(Map map, Critter cr)
{
    if (cr.ControlledByPlayer) {
        Critter[] npc = map.GetCritters(CritterFindType::NonDeadNpc);
        for (int i = 0; i < npc.length(); i++) {
            Critter hostile = npc[i];
            if (hostile.NpcRole == 17) {
                EnemyStack::AddEnemyToStack(hostile, cr.Id);
            }
        }
    }
}

// Складывает переданный лут в ближайший склад; при переполнении запускает его уничтожение
void SaveLoot2Storehouse(int WorldX, int WorldY, Item[] items)
{
    // Ищем рядом с указанными мировыми координатами локацию-склад
    Location[] locations = Location::GetLocationsInRadius(ipos(WorldX, WorldY), LocationSearchRadius());
    Location? storeHouse;
    if (locations.length() > 0) {
        for (int i = 0, l = locations.length(); i < l; i++) {
            Location loc = locations[i];
            if (loc.StorehouseContId != ZERO_IDENT) {
                storeHouse = loc;
                break;
            }
        }
    }

    // Переносим лут в контейнер; при переполнении раскрываем склад и через 4 дня уничтожаем
    if (storeHouse != null && storeHouse.Hidden && storeHouse.StorehouseContId != ZERO_IDENT) {
        Item? container = Game.GetItem(storeHouse.StorehouseContId);
        if (container != null) {
            ItemMovement::MoveItems(items, container, Tla::RootContainerStack());
            if (CountContainerItems(container) > MAX_CONTAINER_ITEMS) {
                storeHouse.Hidden = false;
                Game.StartTimeEvent(Time::GameDays(4), DeferredDestroyLocation, storeHouse.Id); //SavedDeferredCall
            }

            return;
        }
    }
}

// Считает «вес» содержимого склада: штабелируемое (оружие/броня/химия) — по Count, прочее — поштучно
int CountContainerItems(Item container)
{
    int count = 0;
    Item[] items = container.GetItems(Tla::RootContainerStack());
    for (int i = 0; i < items.length(); i++) {
        Item item = items[i];
        if (item.Type == ItemType::Weapon || item.Type == ItemType::Armor || item.Type == ItemType::Drug) {
            count += item.Count;
        }
        else {
            count += 1;
        }
    }

    return count;
}

// Отложенное (по таймеру) уничтожение переполненного склада, если он ещё существует
[[TimeEvent]]
void DeferredDestroyLocation(any value)
{
    Location? loc = Game.GetLocation(ident(value));
    if (loc != null) {
        Game.DestroyLocation(loc.Id);
    }
}

#endif

}
