      "Dock": "None",
      "IsDraggable": false,
      "IsNotHittable": false,
      "CheckTransparentOnHit": false,
      "GlobalScope": "",
      "ClassFields": "int RadioChannel;\r\nvoid SetChannel(int channel)\r\n{\r\n    RadioChannel        = channel;\r\n    SetText(\"\" + channel, FONT_DEFAULT, FT_CENTERX | FT_CENTERY);\r\n    SetTextColor(COLOR_GREEN);\r\n}",
      "OnInit": null,
      "OnShow": null,
      "OnHide": null,
      "OnAppear": null,
      "OnDisappear": null,
      "OnDraw": null,
      "OnPostDraw": null,
      "OnMove": null,
      "OnMouseDown": null,
      "OnMouseUp": null,
      "OnMousePressed": null,
      "OnLMousePressed": null,
      "OnRMousePressed": null,
      "OnMouseClick": null,
      "OnLMouseClick": null,
      "OnRMouseClick": null,
      "OnMouseMove": null,
      "OnGlobalMouseDown": null,
      "OnGlobalMouseUp": null,
      "OnGlobalMousePressed": null,
      "OnGlobalMouseClick": null,
      "OnGlobalMouseMove": null,
      "OnInput": "        Item item = Radio::GetItemRadio( cast<Radio>(Parent).RadioId);\r\n        string t  = Text;\r\n\r\n        if (!item.Radio.FixedChannel) {\r\n            if (!t.isEmpty() && t[-1] == \"\\n\") {\r\n                t[-1] = \"\";\r\n            }\r\n\r\n            int channel = t.toInt(0);\r\n            channel = Math::Clamp(channel, 0, 0xFFFF);\r\n            t = \"\" + channel;\r\n\r\n            RadioChannel = channel;\r\n\r\n            if (key == KeyCode::Return || key == KeyCode::Numpadenter) {\r\n                Radio::ChangeRadioChannel(item.Id, RadioChannel);\r\n            }\r\n        }\r\n        else {\r\n            t = \"\" + RadioChannel;\r\n            Messaging::Info(TextPackName::Game, MsgStr::Get(\"RadioCantShiftChannel\"));\r\n        }",
      "OnGlobalInput": null,
      "OnActiveChanged": null,
      "OnFocusChanged": null,
      "OnHoverChanged": null,
      "OnDragChanged": null,
      "OnResizeGrid": null,
      "OnDrawItem": null,
