// MapSfHubb — серверная инициализация локации хабологов (карта sf_hubb).
// Зона ответственности: при входе на карту гарантирует наличие NPC-проводника
// (Honomer), делегируя его создание модулю HubLab.
// Сторона исполнения: SERVER.
namespace MapSfHubb
{

#if SERVER

// При инициализации карты добавляем проводника, если его ещё нет
// (идемпотентное создание реализовано в HubLab::AddNewHonomer).
void MapInit(Map map, bool firstTime)
{
    HubLab::AddNewHonomer();
}

#endif

}
