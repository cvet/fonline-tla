namespace Perks
{

#if SERVER || CLIENT

// Author: cvet

bool PerkCheck(Critter cr, CritterProperty perk)
{
    // clang-format off
    switch (perk) {
        // Perks
        case CritterProperty::PerkAwareness: return (cr.PerkAwareness < 1 && cr.Level >= 3 && cr.PerceptionBase >= 5);
        case CritterProperty::PerkBonusHthAttacks: return (cr.PerkBonusHthAttacks < 1 && cr.Level >= 15 && cr.AgilityBase >= 6);
        case CritterProperty::PerkBonusHthDamage: return (cr.PerkBonusHthDamage < 3 && cr.Level >= 3 && cr.AgilityBase >= 6 && cr.StrengthBase >= 6);
        case CritterProperty::PerkBonusMove: return (cr.PerkBonusMove < 2 && cr.Level >= 6 && cr.AgilityBase >= 5);
        case CritterProperty::PerkBonusRangedDamage: return (cr.PerkBonusRangedDamage < 2 && cr.Level >= 6 && cr.AgilityBase >= 6 && cr.LuckBase >= 6);
        case CritterProperty::PerkBonusRateOfFire: return (cr.PerkBonusRateOfFire < 1 && cr.Level >= 15 && cr.AgilityBase >= 7 && cr.IntellectBase >= 6 && cr.PerceptionBase >= 6);
        case CritterProperty::PerkEarlierSequence: return (cr.PerkEarlierSequence < 3 && cr.Level >= 3 && cr.PerceptionBase >= 6);
        case CritterProperty::PerkFasterHealing: return (cr.PerkFasterHealing < 3 && cr.Level >= 3 && cr.EnduranceBase >= 6);
        case CritterProperty::PerkMoreCriticals: return (cr.PerkMoreCriticals < 3 && cr.Level >= 6 && cr.LuckBase >= 6);
        case CritterProperty::PerkRadResistance: return (cr.PerkRadResistance < 2 && cr.Level >= 6 && cr.EnduranceBase >= 6 && cr.IntellectBase >= 4);
        case CritterProperty::PerkToughness: return (cr.PerkToughness < 3 && cr.Level >= 3 && cr.EnduranceBase >= 6 && cr.LuckBase >= 6);
        case CritterProperty::PerkStrongBack: return (cr.PerkStrongBack < 3 && cr.Level >= 3 && cr.StrengthBase >= 6 && cr.EnduranceBase >= 6);
        case CritterProperty::PerkSharpshooter: return (cr.PerkSharpshooter < 1 && cr.Level >= 9 && cr.PerceptionBase >= 7 && cr.IntellectBase >= 6);
        case CritterProperty::PerkSilentRunning: return (cr.PerkSilentRunning < 1 && cr.Level >= 6 && cr.AgilityBase >= 6 && cr.SkillSneak >= 50);
        case CritterProperty::PerkSurvivalist: return (cr.PerkSurvivalist < 3 && cr.Level >= 3 && cr.EnduranceBase >= 6 && cr.IntellectBase >= 6 && cr.SkillOutdoorsman >= 40);
        case CritterProperty::PerkMasterTrader: return (cr.PerkMasterTrader < 1 && cr.Level >= 9 && cr.CharismaBase >= 7 && cr.SkillBarter >= 60);
        case CritterProperty::PerkEducated: return (cr.PerkEducated < 3 && cr.Level >= 6 && cr.IntellectBase >= 6);
        case CritterProperty::PerkHealer: return (cr.PerkHealer < 2 && cr.Level >= 3 && cr.PerceptionBase >= 7 && cr.AgilityBase >= 6 && cr.IntellectBase >= 5 && cr.SkillFirstAid >= 40);
        case CritterProperty::PerkBetterCriticals: return (cr.PerkBetterCriticals < 1 && cr.Level >= 9 && cr.Perception >= 6 && cr.Luck >= 6 && cr.Agility >= 4);
        case CritterProperty::PerkSlayer: return (cr.PerkSlayer < 1 && cr.Level >= 24 && cr.AgilityBase >= 8 && cr.StrengthBase >= 8 && cr.SkillUnarmed >= 80 && cr.PerkSniper == 0 && cr.PerkTerminator == 0);
        case CritterProperty::PerkSniper: return (cr.PerkSniper < 1 && cr.Level >= 24 && cr.AgilityBase >= 8 && cr.PerceptionBase >= 8 && cr.SkillSmallGuns >= 80 && cr.PerkSlayer == 0 && cr.PerkTerminator == 0);
        case CritterProperty::PerkSilentDeath: return (cr.PerkSilentDeath < 1 && cr.Level >= 18 && cr.AgilityBase >= 10 && cr.SkillSneak >= 80 && cr.SkillUnarmed >= 80);
        case CritterProperty::PerkActionBoy: return (cr.PerkActionBoy < 2 && cr.Level >= 12 && cr.AgilityBase >= 5);
        case CritterProperty::PerkLifegiver: return (cr.PerkLifegiver < 2 && cr.Level >= 12 && cr.EnduranceBase >= 4);
        case CritterProperty::PerkDodger: return (cr.PerkDodger < 1 && cr.Level >= 9 && cr.AgilityBase >= 6);
        case CritterProperty::PerkSnakeater: return (cr.PerkSnakeater < 2 && cr.Level >= 6 && cr.EnduranceBase >= 3);
        case CritterProperty::PerkMrFixit: return (cr.PerkMrFixit < 1 && cr.Level >= 12 && cr.SkillRepair >= 40 && cr.SkillScience >= 40);
        case CritterProperty::PerkMedic: return (cr.PerkMedic < 1 && cr.Level >= 12 && cr.SkillFirstAid >= 40 && cr.SkillDoctor >= 40);
        case CritterProperty::PerkMasterThief: return (cr.PerkMasterThief < 1 && cr.Level >= 12 && cr.SkillSteal >= 50 && cr.SkillLockpick >= 50);
        case CritterProperty::PerkSpeaker: return (cr.PerkSpeaker < 1 && cr.Level >= 9 && cr.SkillSpeech >= 50);
        case CritterProperty::PerkHeaveHo: return (cr.PerkHeaveHo < 3 && cr.Level >= 6);
        case CritterProperty::PerkPickpocket: return (cr.PerkPickpocket < 1 && cr.Level >= 15 && cr.AgilityBase >= 8 && cr.SkillSteal >= 80);
        case CritterProperty::PerkGhost: return (cr.PerkGhost < 1 && cr.Level >= 6 && cr.SkillSneak >= 60);
        case CritterProperty::PerkExplorer: return (cr.PerkExplorer < 1 && cr.Level >= 9);
        case CritterProperty::PerkPathfinder: return (cr.PerkPathfinder < 2 && cr.Level >= 6 && cr.EnduranceBase >= 6 && cr.SkillOutdoorsman >= 40);
        case CritterProperty::PerkScout: return (cr.PerkScout < 1 && cr.Level >= 3 && cr.PerceptionBase >= 7);
        case CritterProperty::PerkRanger: return (cr.PerkRanger < 1 && cr.Level >= 6 && cr.PerceptionBase >= 6);
        case CritterProperty::PerkQuickPockets: return (cr.PerkQuickPockets < 1 && cr.Level >= 3 && cr.AgilityBase >= 5);
        case CritterProperty::PerkSmoothTalker: return (cr.PerkSmoothTalker < 3 && cr.Level >= 3 && cr.IntellectBase >= 4 && cr.IntellectBase < 10);
        case CritterProperty::PerkSwiftLearner: return (cr.PerkSwiftLearner < 3 && cr.Level >= 3 && cr.IntellectBase >= 4);
        case CritterProperty::PerkAdrenalineRush: return (cr.PerkAdrenalineRush < 1 && cr.Level >= 6 && cr.StrengthBase < 10);
        case CritterProperty::PerkCautiousNature: return (cr.PerkCautiousNature < 1 && cr.Level >= 3 && cr.PerceptionBase >= 6);
        case CritterProperty::PerkComprehension: return (cr.PerkComprehension < 1 && cr.Level >= 3 && cr.IntellectBase >= 6);
        case CritterProperty::PerkDemolitionExpert: return (cr.PerkDemolitionExpert < 1 && cr.Level >= 9 && cr.AgilityBase >= 4 && cr.SkillTraps >= 75);
        case CritterProperty::PerkGambler: return (cr.PerkGambler < 1 && cr.Level >= 6 && cr.SkillGambling >= 50);
        case CritterProperty::PerkGainStrength: return (cr.PerkGainStrength < 1 && cr.Level >= 12 && cr.StrengthBase < 10);
        case CritterProperty::PerkGainPerception: return (cr.PerkGainPerception < 1 && cr.Level >= 12 && cr.PerceptionBase < 10);
        case CritterProperty::PerkGainEndurance: return (cr.PerkGainEndurance < 1 && cr.Level >= 12 && cr.EnduranceBase < 10);
        case CritterProperty::PerkGainCharisma: return (cr.PerkGainCharisma < 1 && cr.Level >= 12 && cr.CharismaBase < 10);
        case CritterProperty::PerkGainIntelligence: return (cr.PerkGainIntelligence < 1 && cr.Level >= 12 && cr.IntellectBase < 10);
        case CritterProperty::PerkGainAgility: return (cr.PerkGainAgility < 1 && cr.Level >= 12 && cr.AgilityBase < 10);
        case CritterProperty::PerkGainLuck: return (cr.PerkGainLuck < 1 && cr.Level >= 12 && cr.LuckBase < 10);
        case CritterProperty::PerkHarmless: return (cr.PerkHarmless < 1 && cr.Level >= 6 && cr.SkillSteal >= 50 && cr.Karma >= 50);
        case CritterProperty::PerkHereAndNow: return (cr.PerkHereAndNow < 1 && cr.Level >= 9);
        case CritterProperty::PerkHthEvade: return (cr.PerkHthEvade < 1 && cr.Level >= 12 && cr.SkillUnarmed >= 75);
        case CritterProperty::PerkKamaSutraMaster: return (cr.PerkKamaSutraMaster < 1 && cr.Level >= 3 && cr.EnduranceBase >= 5 && cr.AgilityBase >= 5);
        case CritterProperty::PerkKarmaBeacon: return (cr.PerkKarmaBeacon < 1 && cr.Level >= 9 && cr.CharismaBase >= 6);
        case CritterProperty::PerkLightStep: return (cr.PerkLightStep < 1 && cr.Level >= 9 && cr.AgilityBase >= 5 && cr.LuckBase >= 5);
        case CritterProperty::PerkLivingAnatomy: return (cr.PerkLivingAnatomy < 1 && cr.Level >= 12 && cr.SkillDoctor >= 60);
        case CritterProperty::PerkMagneticPersonality: return (cr.PerkMagneticPersonality < 1 && cr.Level >= 6 && cr.CharismaBase < 10);
        case CritterProperty::PerkNegotiator: return (cr.PerkNegotiator < 1 && cr.Level >= 6 && cr.SkillSpeech >= 50 && cr.SkillBarter >= 50);
        case CritterProperty::PerkPackRat: return (cr.PerkPackRat < 1 && cr.Level >= 6);
        case CritterProperty::PerkPyromaniac: return (cr.PerkPyromaniac < 1 && cr.Level >= 9 && cr.SkillBigGuns >= 75);
        case CritterProperty::PerkQuickRecovery: return (cr.PerkQuickRecovery < 1 && cr.Level >= 3 && cr.AgilityBase >= 5);
        case CritterProperty::PerkSalesman: return (cr.PerkSalesman < 1 && cr.Level >= 6 && cr.SkillBarter >= 50);
        case CritterProperty::PerkStonewall: return (cr.PerkStonewall < 1 && cr.Level >= 3 && cr.StrengthBase >= 6);
        case CritterProperty::PerkThief: return (cr.PerkThief < 1 && cr.Level >= 3);
        case CritterProperty::PerkWeaponHandling: return (cr.PerkWeaponHandling < 1 && cr.Level >= 12 && cr.AgilityBase >= 5);
        case CritterProperty::PerkTerminator: return (cr.PerkTerminator < 1 && cr.Level >= 24 && cr.StrengthBase >= 8 && cr.EnduranceBase >= 8 && cr.SkillDoctor >= 80 && cr.PerkSniper == 0 && cr.PerkSlayer == 0);
    default:
        break;
    }

    return false;
    // clang-format on
}

#if !CLIENT
void PerkUp(Critter cr, CritterProperty perk)
{
    switch (perk) {
    // Perks
    case CritterProperty::PerkAwareness: /*Examining a target shows hitpoints, weapon and ammunition count*/
        break;
    case CritterProperty::PerkBonusHthAttacks: /*-1 Ap on HtH attacks*/
        break;
    case CritterProperty::PerkBonusHthDamage:
        cr.MeleeDamageBase += 2;
        break;
    case CritterProperty::PerkBonusMove:
        cr.MaxMoveApBase += 2;
        break;
    case CritterProperty::PerkBonusRangedDamage: /*In calc damage +2 per range*/
        break;
    case CritterProperty::PerkBonusRateOfFire: /*-1 Ap on ranged attacks*/
        break;
    case CritterProperty::PerkEarlierSequence:
        cr.SequenceBase += 2;
        break;
    case CritterProperty::PerkFasterHealing:
        cr.HealingRateBase += 2;
        break;
    case CritterProperty::PerkMoreCriticals:
        cr.CriticalChanceBase += 5;
        break;
    case CritterProperty::PerkRadResistance:
        cr.RadiationResistanceBase += 15;
        break;
    case CritterProperty::PerkToughness:
        cr.NormalResistanceBase += 10;
        break;
    case CritterProperty::PerkStrongBack:
        cr.CarryWeightBase += Drugs::PoundsToGrams(50);
        break;
    case CritterProperty::PerkSharpshooter:
        cr.BonusLook += 6; /*+2 perception on ranged attack*/
        break;
    case CritterProperty::PerkSilentRunning: /*No steal off while running*/
        break;
    case CritterProperty::PerkSurvivalist:
        cr.SkillOutdoorsman += 25;
        if (cr.SkillOutdoorsman > Tla::MaxSkillValue()) {
            cr.SkillOutdoorsman = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkMasterTrader: /*Barter k is zero on buy*/
        break;
    case CritterProperty::PerkEducated:
        cr.UnspentSkillPoints += 2; /*+2 skill points per range*/
        break;
    case CritterProperty::PerkHealer: /*Additional Hp bonus in scripts*/
        break;
    case CritterProperty::PerkBetterCriticals:
        cr.MaxCriticalBase += 20;
        break;
    case CritterProperty::PerkSlayer: /*All unarmed and melee attacks is critical*/
        break;
    case CritterProperty::PerkSniper: /*All gun attacks is critical*/
        break;
    case CritterProperty::PerkSilentDeath: /*Attack from sneak from back x2 damage*/
        break;
    case CritterProperty::PerkActionBoy:
        cr.ActionPointsBase += 1;
        break;
    case CritterProperty::PerkLifegiver:
        cr.MaxLifeBase += 4;
        break;
    case CritterProperty::PerkDodger:
        cr.ArmorClassBase += 5;
        break;
    case CritterProperty::PerkSnakeater:
        cr.PoisonResistanceBase += 25;
        break;
    case CritterProperty::PerkMrFixit:
        cr.SkillRepair += 10;
        if (cr.SkillRepair > Tla::MaxSkillValue()) {
            cr.SkillRepair = Tla::MaxSkillValue();
        }
        cr.SkillScience += 10;
        if (cr.SkillScience > Tla::MaxSkillValue()) {
            cr.SkillScience = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkMedic:
        cr.SkillFirstAid += 20;
        if (cr.SkillFirstAid > Tla::MaxSkillValue()) {
            cr.SkillFirstAid = Tla::MaxSkillValue();
        }
        cr.SkillDoctor += 20;
        if (cr.SkillDoctor > Tla::MaxSkillValue()) {
            cr.SkillDoctor = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkMasterThief:
        cr.SkillSteal += 20;
        if (cr.SkillSteal > Tla::MaxSkillValue()) {
            cr.SkillSteal = Tla::MaxSkillValue();
        }
        cr.SkillLockpick += 20;
        if (cr.SkillLockpick > Tla::MaxSkillValue()) {
            cr.SkillLockpick = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkSpeaker:
        cr.SkillSpeech += 40;
        if (cr.SkillSpeech > Tla::MaxSkillValue()) {
            cr.SkillSpeech = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkHeaveHo: /*+2 strength for throwing weapon*/
        break;
    case CritterProperty::PerkPickpocket: /*Ignore size and facing while stealing*/
        break;
    case CritterProperty::PerkGhost: /*+20% sneak on night*/
        break;
    case CritterProperty::PerkExplorer: /*Higher chance of finding special places and people in random encounters*/
        break;
    case CritterProperty::PerkPathfinder: /*+25% speed on global per range*/
        break;
    case CritterProperty::PerkScout: /*This will increase the amount of the map you can see while exploring and make finding the special random encounters a
                                        little easier.*/
        break;
    case CritterProperty::PerkRanger:
        cr.SkillOutdoorsman += 15; /*Fewer hostile random encounters*/
        if (cr.SkillOutdoorsman > Tla::MaxSkillValue()) {
            cr.SkillOutdoorsman = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkQuickPockets: /*Inventory items move ap cost div 2*/
        break;
    case CritterProperty::PerkSmoothTalker: /*+2 intellect on dialogs checks*/
        break;
    case CritterProperty::PerkSwiftLearner: /*+5% add experience per range*/
        break;
    case CritterProperty::PerkAdrenalineRush: /*+1 strength on <50% hp in battle*/
        break;
    case CritterProperty::PerkCautiousNature: /*+3 perception on encounter generate*/
        break;
    case CritterProperty::PerkComprehension: /*50% more points on books reading*/
        break;
    case CritterProperty::PerkDemolitionExpert: /*Used in explosion script*/
        break;
    case CritterProperty::PerkGambler:
        cr.SkillGambling += 40;
        if (cr.SkillGambling > Tla::MaxSkillValue()) {
            cr.SkillGambling = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkGainStrength:
        cr.StrengthBase += 1;
        break;
    case CritterProperty::PerkGainPerception:
        cr.PerceptionBase += 1;
        break;
    case CritterProperty::PerkGainEndurance:
        cr.EnduranceBase += 1;
        break;
    case CritterProperty::PerkGainCharisma:
        cr.CharismaBase += 1;
        break;
    case CritterProperty::PerkGainIntelligence:
        cr.IntellectBase += 1;
        break;
    case CritterProperty::PerkGainAgility:
        cr.AgilityBase += 1;
        break;
    case CritterProperty::PerkGainLuck:
        cr.LuckBase += 1;
        break;
    case CritterProperty::PerkHarmless:
        cr.SkillSteal += 40;
        if (cr.SkillSteal > Tla::MaxSkillValue()) {
            cr.SkillSteal = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkHereAndNow: /*+1 level*/
        cr.Experience += Parameters::NextLevelNeedExp(cr) - cr.Experience;
        break;
    case CritterProperty::PerkHthEvade: /*+3 ac per 1 ap on end turn*/
        break;
    case CritterProperty::PerkKamaSutraMaster: /*In dialogs*/
        break;
    case CritterProperty::PerkKarmaBeacon: /*Karma x2*/
        break;
    case CritterProperty::PerkLightStep: /*50% less chance of setting off a trap*/
        break;
    case CritterProperty::PerkLivingAnatomy:
        cr.SkillDoctor += 20; /*Also +5 dmg*/
        if (cr.SkillDoctor > Tla::MaxSkillValue()) {
            cr.SkillDoctor = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkMagneticPersonality: /*+1 people in group*/
        break;
    case CritterProperty::PerkNegotiator:
        cr.SkillSpeech += 20;
        if (cr.SkillSpeech > Tla::MaxSkillValue()) {
            cr.SkillSpeech = Tla::MaxSkillValue();
        }
        cr.SkillBarter += 20;
        if (cr.SkillBarter > Tla::MaxSkillValue()) {
            cr.SkillBarter = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkPackRat:
        cr.CarryWeightBase += Drugs::PoundsToGrams(50);
        break;
    case CritterProperty::PerkPyromaniac: /*+5 damage on fire attack*/
        break;
    case CritterProperty::PerkQuickRecovery: /* 1 ap for stending up*/
        break;
    case CritterProperty::PerkSalesman:
        cr.SkillBarter += 40;
        if (cr.SkillBarter > Tla::MaxSkillValue()) {
            cr.SkillBarter = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkStonewall: /*Reduction in chance to be knocked down during combat*/
        break;
    case CritterProperty::PerkThief:
        cr.SkillSneak += 10;
        if (cr.SkillSneak > Tla::MaxSkillValue()) {
            cr.SkillSneak = Tla::MaxSkillValue();
        }
        cr.SkillLockpick += 10;
        if (cr.SkillLockpick > Tla::MaxSkillValue()) {
            cr.SkillLockpick = Tla::MaxSkillValue();
        }
        cr.SkillSteal += 10;
        if (cr.SkillSteal > Tla::MaxSkillValue()) {
            cr.SkillSteal = Tla::MaxSkillValue();
        }
        cr.SkillTraps += 10;
        if (cr.SkillTraps > Tla::MaxSkillValue()) {
            cr.SkillTraps = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkWeaponHandling: /*In use weapon strength +3*/
        break;
    case CritterProperty::PerkNcrPerception:
        cr.PerceptionBase += 1;
        break;
    case CritterProperty::PerkNcrEndurance:
        cr.EnduranceBase += 1;
        break;
    case CritterProperty::PerkNcrBarter:
        cr.SkillBarter += 5;
        if (cr.SkillBarter > Tla::MaxSkillValue()) {
            cr.SkillBarter = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkNcrRepair:
        cr.SkillRepair += 5;
        if (cr.SkillRepair > Tla::MaxSkillValue()) {
            cr.SkillRepair = Tla::MaxSkillValue();
        }
        break;
    case CritterProperty::PerkTerminator:
        cr.EmpResistanceBase -= 1000;
        break;
    default:
        break;
    }
}

void PerkDown(Critter cr, CritterProperty perk)
{
    switch (perk) {
    // Perks
    case CritterProperty::PerkAwareness:
        break;
    case CritterProperty::PerkBonusHthAttacks:
        break;
    case CritterProperty::PerkBonusHthDamage:
        cr.MeleeDamageBase -= 2;
        break;
    case CritterProperty::PerkBonusMove:
        cr.MaxMoveApBase -= 2;
        break;
    case CritterProperty::PerkBonusRangedDamage:
        break;
    case CritterProperty::PerkBonusRateOfFire:
        break;
    case CritterProperty::PerkEarlierSequence:
        cr.SequenceBase -= 2;
        break;
    case CritterProperty::PerkFasterHealing:
        cr.HealingRateBase -= 2;
        break;
    case CritterProperty::PerkMoreCriticals:
        cr.CriticalChanceBase -= 5;
        break;
    case CritterProperty::PerkRadResistance:
        cr.RadiationResistanceBase -= 15;
        break;
    case CritterProperty::PerkToughness:
        cr.NormalResistanceBase -= 10;
        break;
    case CritterProperty::PerkStrongBack:
        cr.CarryWeightBase -= Drugs::PoundsToGrams(50);
        break;
    case CritterProperty::PerkSharpshooter:
        cr.BonusLook -= 6;
        break;
    case CritterProperty::PerkSilentRunning:
        break;
    case CritterProperty::PerkSurvivalist:
        cr.SkillOutdoorsman -= 25;
        if (cr.SkillOutdoorsman < -(Tla::MaxSkillValue())) {
            cr.SkillOutdoorsman = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkMasterTrader:
        break;
    case CritterProperty::PerkEducated:
        cr.UnspentSkillPoints -= 2;
        break;
    case CritterProperty::PerkHealer:
        break;
    case CritterProperty::PerkBetterCriticals:
        cr.MaxCriticalBase -= 20;
        break;
    case CritterProperty::PerkSlayer:
        break;
    case CritterProperty::PerkSniper:
        break;
    case CritterProperty::PerkSilentDeath:
        break;
    case CritterProperty::PerkActionBoy:
        cr.ActionPointsBase -= 1;
        break;
    case CritterProperty::PerkLifegiver:
        cr.MaxLifeBase -= 4;
        break;
    case CritterProperty::PerkDodger:
        cr.ArmorClassBase -= 5;
        break;
    case CritterProperty::PerkSnakeater:
        cr.PoisonResistanceBase -= 25;
        break;
    case CritterProperty::PerkMrFixit:
        cr.SkillRepair -= 20;
        if (cr.SkillRepair < -(Tla::MaxSkillValue())) {
            cr.SkillRepair = -(Tla::MaxSkillValue());
        }
        cr.SkillScience -= 20;
        if (cr.SkillScience < -(Tla::MaxSkillValue())) {
            cr.SkillScience = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkMedic:
        cr.SkillFirstAid -= 20;
        if (cr.SkillFirstAid < -(Tla::MaxSkillValue())) {
            cr.SkillFirstAid = -(Tla::MaxSkillValue());
        }
        cr.SkillDoctor -= 20;
        if (cr.SkillDoctor < -(Tla::MaxSkillValue())) {
            cr.SkillDoctor = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkMasterThief:
        cr.SkillSteal -= 20;
        if (cr.SkillSteal < -(Tla::MaxSkillValue())) {
            cr.SkillSteal = -(Tla::MaxSkillValue());
        }
        cr.SkillLockpick -= 20;
        if (cr.SkillLockpick < -(Tla::MaxSkillValue())) {
            cr.SkillLockpick = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkSpeaker:
        cr.SkillSpeech -= 40;
        if (cr.SkillSpeech < -(Tla::MaxSkillValue())) {
            cr.SkillSpeech = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkHeaveHo:
        break;
    case CritterProperty::PerkPickpocket:
        break;
    case CritterProperty::PerkGhost:
        break;
    case CritterProperty::PerkExplorer:
        break;
    case CritterProperty::PerkPathfinder:
        break;
    case CritterProperty::PerkScout:
        break;
    case CritterProperty::PerkRanger:
        break;
    case CritterProperty::PerkQuickPockets:
        break;
    case CritterProperty::PerkSmoothTalker:
        break;
    case CritterProperty::PerkSwiftLearner:
        break;
    case CritterProperty::PerkAdrenalineRush:
        break;
    case CritterProperty::PerkCautiousNature:
        break;
    case CritterProperty::PerkComprehension:
        break;
    case CritterProperty::PerkDemolitionExpert:
        break;
    case CritterProperty::PerkGambler:
        cr.SkillGambling -= 40;
        if (cr.SkillGambling < -(Tla::MaxSkillValue())) {
            cr.SkillGambling = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkGainStrength:
        cr.StrengthBase -= 1;
        break;
    case CritterProperty::PerkGainPerception:
        cr.PerceptionBase -= 1;
        break;
    case CritterProperty::PerkGainEndurance:
        cr.EnduranceBase -= 1;
        break;
    case CritterProperty::PerkGainCharisma:
        cr.CharismaBase -= 1;
        break;
    case CritterProperty::PerkGainIntelligence:
        cr.IntellectBase -= 1;
        break;
    case CritterProperty::PerkGainAgility:
        cr.AgilityBase -= 1;
        break;
    case CritterProperty::PerkGainLuck:
        cr.LuckBase -= 1;
        break;
    case CritterProperty::PerkHarmless:
        cr.SkillSteal -= 40;
        if (cr.SkillSteal < -(Tla::MaxSkillValue())) {
            cr.SkillSteal = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkHereAndNow:
        break;
    case CritterProperty::PerkHthEvade:
        break;
    case CritterProperty::PerkKamaSutraMaster:
        break;
    case CritterProperty::PerkKarmaBeacon:
        break;
    case CritterProperty::PerkLightStep:
        break;
    case CritterProperty::PerkLivingAnatomy:
        cr.SkillDoctor -= 20;
        if (cr.SkillDoctor < -(Tla::MaxSkillValue())) {
            cr.SkillDoctor = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkMagneticPersonality:
        break;
    case CritterProperty::PerkNegotiator:
        cr.SkillSpeech -= 20;
        if (cr.SkillSpeech < -(Tla::MaxSkillValue())) {
            cr.SkillSpeech = -(Tla::MaxSkillValue());
        }
        cr.SkillBarter -= 20;
        if (cr.SkillBarter < -(Tla::MaxSkillValue())) {
            cr.SkillBarter = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkPackRat:
        cr.CarryWeightBase -= Drugs::PoundsToGrams(50);
        break;
    case CritterProperty::PerkPyromaniac:
        break;
    case CritterProperty::PerkQuickRecovery:
        break;
    case CritterProperty::PerkSalesman:
        cr.SkillBarter -= 40;
        if (cr.SkillBarter < -(Tla::MaxSkillValue())) {
            cr.SkillBarter = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkStonewall:
        break;
    case CritterProperty::PerkThief:
        cr.SkillSneak -= 10;
        if (cr.SkillSneak < -(Tla::MaxSkillValue())) {
            cr.SkillSneak = -(Tla::MaxSkillValue());
        }
        cr.SkillLockpick -= 10;
        if (cr.SkillLockpick < -(Tla::MaxSkillValue())) {
            cr.SkillLockpick = -(Tla::MaxSkillValue());
        }
        cr.SkillSteal -= 10;
        if (cr.SkillSteal < -(Tla::MaxSkillValue())) {
            cr.SkillSteal = -(Tla::MaxSkillValue());
        }
        cr.SkillTraps -= 10;
        if (cr.SkillTraps < -(Tla::MaxSkillValue())) {
            cr.SkillTraps = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkWeaponHandling:
        break;
    case CritterProperty::PerkNcrPerception:
        cr.PerceptionBase -= 1;
        break;
    case CritterProperty::PerkNcrEndurance:
        cr.EnduranceBase -= 1;
        break;
    case CritterProperty::PerkNcrBarter:
        cr.SkillBarter -= 5;
        if (cr.SkillBarter < -(Tla::MaxSkillValue())) {
            cr.SkillBarter = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkNcrRepair:
        cr.SkillRepair -= 5;
        if (cr.SkillRepair < -(Tla::MaxSkillValue())) {
            cr.SkillRepair = -(Tla::MaxSkillValue());
        }
        break;
    case CritterProperty::PerkTerminator:
        cr.EmpResistanceBase += 1000;
        break;
    default:
        break;
    }
}
#endif

#endif

