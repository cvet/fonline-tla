// MapAtoll — серверная логика локации «Атолл»: инициализация карты и торговцев.
// Зона ответственности: настройка NPC-торговцев и периодическое обновление их
// ассортимента по таблице лута atollLoot (товары выдаются группами, что позволяет
// согласовать оружие с подходящими патронами).
// Сторона исполнения: SERVER.
namespace MapAtoll
{

#if SERVER

// Торговцы на Атолле. Периодически получают лут из таблицы atollLoot.
// Предметы появляются группами, это позволяет настроить появление оружия и патронов к нему, например.

const int CTE_REFRESH = 17;

// При входе на карту настраиваем NPC: задаём время репликации и для торговцев Атолла
// включаем расчёт только за наличные.
void MapInit(Map map, bool firstTime)
{
    Critter[] critters = map.GetCritters(CritterFindType::NonDeadNpc);
    for (int i = 0; i < critters.length(); i++) {
        Critter cr = critters[i];
        cr.ReplicationTime = 480;
        if (cr.DialogId == Content::Dialog::atoll_trader) {
            cr.IsBarterOnlyCash = true;
        }
    }
}

// clang-format off

