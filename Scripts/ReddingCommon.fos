// Усиление нпц
void PowerNpc(Critter cr)
{
    cr.StrengthBase = Game.Random(8, 10);
    cr.PerceptionBase = Game.Random(8, 10);
    cr.EnduranceBase = Game.Random(8, 10);
    cr.AgilityBase = Game.Random(8, 10);
    cr.Level = Game.Random(24, 30);
    cr.ActionPointsBase = Game.Random(10, 12);
    cr.CriticalChanceBase = Game.Random(20, 30);

    for (int i = 0; i < CritterPropertyGroup::ResistsBase.length(); i++) {
        if (CritterPropertyGroup::ResistsBase[i] != CritterProperty::EmpResistanceBase) {
            cr.SetAsInt(CritterPropertyGroup::ResistsBase[i], Game.Random(40, 70));
        }
    }

    int type = Game.Random(0, 4);
    switch (type) {
    case 1:
        cr.PerkSniper = 1;
        cr.PerkTerminator = 0;
        cr.PerkSlayer = 0;
        break;
    case 2:
        cr.PerkTerminator = 1;
        cr.PerkSniper = 0;
        cr.PerkSlayer = 0;
        break;
    case 3:
        cr.PerkSlayer = 1;
        cr.PerkSniper = 0;
        cr.PerkTerminator = 0;
        break;
    case 4:
        cr.PerkTerminator = 1;
        cr.PerkSlayer = 1;
        cr.PerkSniper = 0;
        break;
    default:
        cr.PerkSniper = 0;
        cr.PerkTerminator = 0;
        cr.PerkSlayer = 0;
        break;
    }

    cr.PerkBetterCriticals = (Game.Random(1, 10) == 1 ? 1 : 0);
    cr.PerkBonusRangedDamage = 1;
    cr.PerkLifegiver = Game.Random(1, 3);
    cr.PerkBonusRateOfFire = 1;
    cr.PerkBonusHthDamage = 1;
    for (int i = 0; i < CritterPropertyGroup::Skills.length(); i++) {
        cr.SetAsInt(CritterPropertyGroup::Skills[i], Game.Random(150, 250));
    }

    cr.MaxLifeBase = Game.Random(250, 500);
    cr.CurrentHp = cr.MaxLife;
}

[[ItemStatic]]
bool RooneyGrave(Critter player, StaticItem scenery, Item? item, any skill)
{
    if (item == null) {
        return true;
    }

    if (player.ReddRooneyCemetery < 3 && player.ReddRooneyCemetery > 0 && item.ProtoId == Content::Item::flower &&
        player.CountItem(Content::Item::flower) > 1) {
        player.ReddRooneyCemetery = 3;
        player.DestroyItem(Content::Item::flower, 2);
        Messaging::Info(player, TextPackKey(TextPackName::Text, "" + (STR_GRAVE)));
        player.Experience += 200;
    }

    return true;
}

const int STR_POISONED_NO_QUEST = 1;

void PoisonedInit(Critter cr, bool firstTime)
{
    CritterState::ToKnockout(cr,
                             AnimHelpers::KnockoutActionAnimDefaultBegin(true),
                             AnimHelpers::KnockoutActionAnimDefaultIdle(true),
                             AnimHelpers::KnockoutActionAnimDefaultEnd(true),
                             1000,
                             cr.Hex);
    cr.OnSomeUseItemOnMe.Subscribe(SmthUseItem);
}

// CRITTER_EVENT_USE_ITEM_ON_ME
[[Event]]
EventResult SmthUseItem(Critter cr, Critter whoUse, Item item, int param)
{
    if (item.ProtoId == Content::Item::antidote) {
        if (whoUse.ReddDoctorPoisoned == 1) {
            Dialogs::RunDialog(whoUse, Content::Dialog::redd_poisoned, false);
            return EventResult::StopChain;
        }
        else {
            Messaging::SayEmote(cr, MsgStr::DialogTextKey(cr.DialogId, STR_POISONED_NO_QUEST));
        }
    }

    return EventResult::StopChain;
}

// Квест "На Связи" Доктор Джонсон
const int DOCTOR_CHANNEL = 1717;
const int STR_FIRST = 3300;
const int STR_LAST = 3340;
const int STR_BREAK_FIRST = 3341;
const int STR_BREAK_LAST = 3343;

// Проверка, в инвентаре игрока есть радио с нужной волной
[[DialogDemand]]
bool CheckRadio(Critter player, Critter npc)
{
    Item[] items = player.GetItems();
    for (int i = 0; i < items.length(); i++) {
        if (items[i].HasRadio && items[i].Radio.Channel == DOCTOR_CHANNEL) { // TODO: вставить проверку канала
            return true;
        }
    }

    return false;
}

[[DialogResult]]
void Broadcast(Critter player, Critter npc)
{
    DebugLog("broadcat result");
    Game.StartTimeEvent(Time::Seconds(8), BeginBroadcast);
}

[[TimeEvent]]
void BeginBroadcast()
{
    DebugLog("Begin broadcast");
    if (Game.ReddJohnsonBroadcast) {
        return;
    }

    Game.ReddJohnsonBroadcast = true;
    Game.StartTimeEvent(ZERO_TIMESPAN, Broadcast, STR_FIRST); //SavedDeferredCall
}

[[TimeEvent]]
void Broadcast(any value)
{
    DebugLog("broadcast " + value);
    if (not Game.ReddJohnsonBroadcast) {
        return;
    }

    if (value >= STR_LAST) {
        Game.ReddJohnsonBroadcast = false;
        return;
    }

    Radio::SendChannelRadioMessage(DOCTOR_CHANNEL, TextPackKey(TextPackName::Text, "" + (value)));

    value = int(value) + 1;

    Game.StartTimeEvent(Time::Seconds(8), Broadcast, value); //SavedDeferredCall
}

// Инициализация нпц. происходит при вводе нпц в игру
void GuardInit(Critter npc, bool firstTime)
{
    // вешаем обработчики событий
    npc.OnCritterAppeared.Subscribe(GuardOnAddCritter);
    npc.OnCritterDisappeared.Subscribe(GuardOnRemoveCritter);
    // npc.StartTimeEvent(Time::Asap(), Time::Seconds(1), GuardIdle);
    npc.OnNpcPlaneEnd.Subscribe(GuardEndPlane);
    npc.OnMessage.Subscribe(GuardOnMessage);
    npc.OnSomeCritterMoveItem.Subscribe(GuardOnMoveItem);
    npc.OnSomeCritterUseItem.Subscribe(GuardOnUseItem);
    npc.OnSomeCritterStealing.Subscribe(GuardStealing);
    npc.OnSomeCritterAttack.Subscribe(GuardOnSmthAttack);
    npc.OnSomeCritterDropItem.Subscribe(GuardOnDropItem); // r17

    // Создаем событие наблюдения
    if (not firstTime && npc.CountTimeEvent(Observing) == 0) {
        npc.StartTimeEvent(GuardLib::ObservationPeriod(), Observing);
    }
}

[[TimeEvent]]
void Observing(Critter npc, TimeEventContext event)
{
    timespan delayTicks = Grd.EventObserving(npc);
    if (delayTicks != ZERO_TIMESPAN) {
        event.Repeat(delayTicks);
    }
}

[[Event]]
void GuardOnAddCritter(Critter crit, Critter showCrit)
{
    Grd.EventOnAddCritter(crit, showCrit);
}

[[Event]]
void GuardOnRemoveCritter(Critter crit, Critter hideCrit)
{
    Grd.EventOnRemoveCritter(crit, hideCrit);
}

[[Event]]
EventResult GuardEndPlane(Critter npc, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(npc, planeId);

    Grd.EventEndPlane(npc);
    return EventResult::StopChain;
}

[[Event]]
void GuardOnMoveItem(Critter crit, Critter fromCrit, Item item, CritterItemSlot fromSlot)
{
    Grd.EventOnMoveItem(crit, fromCrit, Game.GetItem(item.Id), fromSlot);
}

[[Event]]
void GuardOnMessage(Critter crit, Critter fromCrit, int message, any value)
{
    Grd.EventOnMessage(crit, fromCrit, message, value);
}

[[Event]]
void GuardOnUseItem(Critter crit, Critter fromCrit, Item item, Critter onCritter, Item onItem, StaticItem onScenery, int param)
{
    Grd.EventOnUseItem(crit, fromCrit, item, onCritter, onItem, null);
}

[[Event]]
void GuardOnDropItem(Critter crit, Critter fromCrit, Item item) // r17
{
    Grd.EventOnDropItem(crit, fromCrit, item);
}

[[Event]]
void GuardOnSmthAttack(Critter crit, Critter fromCrit, Critter target, Item weapon, int weaponMode, ProtoItem ammo)
{
    Grd.EventOnSmthAttack(crit, fromCrit, target);
}

[[Event]]
void GuardStealing(Critter crit, Critter thief, Critter fromCrit, Item item, int count)
{
    Grd.EventStealing(crit, fromCrit, thief, false, item, count);
}

