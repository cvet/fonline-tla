//               "OnLMousePressed": null,
//               "OnRMousePressed": null,
//               "OnMouseClick": null,
//               "OnLMouseClick":
{
    {
        {
            if (UnspentSP < GetPropValue(CritterProperty::UnspentSkillPoints)) {
                any[] args = {};
                for (int i = 0; i < SkillUp.length(); i++) {
                    if (SkillUp.getValue(i) != 0) {
                        auto skill = SkillUp.getKey(i);
                        auto skill_value = SkillUp.getValue(i);
                        if (IsTagSkill(skill)) {
                            skill_value /= 2;
                        }
                        args.insertLast(skill);
                        args.insertLast(skill_value);
                    }
                }
                if (args.length() > 1) {
                    Game.CurPlayer.ServerCall.ProcessSkillsUp(args);
                }
            }
            Gui::HideScreen();
        }
    }
}
