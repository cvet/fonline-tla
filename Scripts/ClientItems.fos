// ClientItems — клиентские коллекции предметов для интерфейса.
// Ключевое: получение коллекций (инвентарь/лут/бартер), исключение отданных/убранных предметов,
// перенос между коллекциями, отправка бартер-оффера на сервер; SERVER-часть принимает оффер под локами.
// Сторона: MIXED (CLIENT основной + SERVER RemoteCall). Связи: Gui, Barter, Sync, ClientDefines, Content.
namespace ClientItems
{

///@ RemoteCall Server ProcessBarterNpcOffer(ident[] saleItemsIds, int32[] saleItemsCount, ident[] buyItemsIds, int32[] buyItemsCount)

#if CLIENT

enum Collection
{
    ChosenAll,
    Inventory,
    Loot,
    BarterOffer,
    BarterTraderOffer,
    RecievedItems
}

// Клиентские «теневые» коллекции: что пришло от сервера и что игрок уже отдал/убрал в UI
// (бартер-оффер обеих сторон и временно изъятые предметы). Используются для оптимистичного
// отображения до подтверждения сервером.
Item[] ReceivedItems = {};
Item[] BarterOfferItems = {};
Item[] BarterTraderOfferItems = {};
Item[] RemovedItems = {};

[[ModuleInit]]
void InitClientItems()
{
    Game.OnReceiveItems.Subscribe(OnReceiveItems);
}

// Получили предметы от сервера: сбрасываем теневые коллекции и по типу передачи открываем
// нужный экран (бартер или подбор/контейнер).
[[Event]]
void OnReceiveItems(Item[] items, any contextParam)
{
    ReceivedItems.clear();
    BarterOfferItems.clear();
    BarterTraderOfferItems.clear();
    RemovedItems.clear();

    ReceivedItems = items;

    if (int(contextParam) != 0) {
        return;
    }

    Critter chosen = Chosen;

    TransferTypes transfer = chosen.TransferType;

    if (transfer != TransferTypes::Close) {
        if (transfer == TransferTypes::CritBarter) {
            Gui::ShowScreen(GuiScreen::Barter, dict<string, any> = {{"CritterId", chosen.TransferContainerId}});
        }
        else {
            ident crId;
            ident itemId;

            if (transfer == TransferTypes::CritLoot || transfer == TransferTypes::CritSteal || transfer == TransferTypes::FarCrit) {
                crId = chosen.TransferContainerId;
            }
            else if (transfer == TransferTypes::HexContUp || transfer == TransferTypes::HexContDown || transfer == TransferTypes::SelfCont ||
                     transfer == TransferTypes::FarCont) {
                itemId = chosen.TransferContainerId;
            }

            Gui::ShowScreen(GuiScreen::PickUp, dict<string, any> = {{"TargetCritterId", crId}, {"TargetItemId", itemId}});
        }
    }
}

// Собирает коллекцию предметов для UI по её типу и вычитает уже отданное в бартер и временно
// убранное, чтобы интерфейс показывал актуальный остаток до подтверждения сервером.
Item[] GetCollection(Collection collection)
{
    Item[] items = {};
    Critter? chosen = HasChosen ? Chosen : null;

    if (collection == Collection::ChosenAll) {
        if (chosen != null) {
            items = chosen.GetItems();
        }
    }
    else if (collection == Collection::Inventory) {
        if (chosen != null) {
            items = chosen.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
        }
    }
    else if (collection == Collection::Loot) {
        items = ReceivedItems;
        // breadcrumb миграции: альтернативный источник лута из инвентаря криттера-цели; не удалять.
        /*if (chosen != null && chosen.TransferContainerId != ZERO_IDENT) {
            Critter? targetCr = Game.GetCritter(chosen.TransferContainerId);
            if (targetCr != null) {
                items = targetCr.GetItems(ItemProperty::CritterSlot, CritterItemSlot::Inventory);
                TODO: Уточнить, зачем здесь предметы забираются из инвентаря
                криттера, ведь они невовремя обновляются. На сервере предмет изъят из инвентаря,
                на клиенте нет (если это не chosen)
            }
        }*/
    }
    else if (collection == Collection::BarterOffer) {
        items = BarterOfferItems;
    }
    else if (collection == Collection::BarterTraderOffer) {
        items = BarterTraderOfferItems;
    }
    else if (collection == Collection::RecievedItems) {
        items = ReceivedItems;
    }

    if (collection != Collection::BarterOffer && collection != Collection::BarterTraderOffer) {
        ExcludeItems(items, collection != Collection::Loot ? BarterOfferItems : BarterTraderOfferItems);
    }

    ExcludeItems(items, RemovedItems);

    return items;
}

// Помечает count единиц предмета как временно убранные (теневая коллекция RemovedItems),
// чтобы UI скрыл их до подтверждения сервером.
void RemoveItem(Collection collection, Item& item, int count)
{
    verify(count > 0, "Assertion failed");
    verify(count <= item.Count, "Assertion failed");

    RemovedItems.insertLast(item.Clone(count));
}

// Заготовка переноса предмета в/из бартер-оффера (тело не реализовано).
void BarterItem(bool offer, Item& item, int count)
{
    // breadcrumb миграции: незавершённая ветка по флагу offer; не удалять
    // if( offer )
}

// Вычитает excludeItems из items по Id: полностью убирает предмет или уменьшает его количество
// клонированием, чтобы исходные предметы не мутировались.
void ExcludeItems(Item[] & items, Item[] & excludeItems)
{
    for (int i = 0; i < excludeItems.length(); i++) {
        Item excludeItem = excludeItems[i];
        for (int j = 0; j < items.length(); j++) {
            Item item = items[j];
            if (excludeItem.Id == item.Id) {
                if (excludeItem.Count >= item.Count) {
                    items.removeAt(j);
                }
                else {
                    items[j] = item.Clone(item.Count - excludeItem.Count);
                }

                break;
            }
        }
    }
}

// Сопоставляет числовой тип коллекции из UI (ClientDefines) с внутренним enum Collection.
Collection GetCollectionFromType(int collectionType)
{
    Collection collection = Collection::ChosenAll;

    switch (collectionType) {
    case ClientDefines::ITEMS_CHOSEN_ALL:
        collection = Collection::ChosenAll;
        break;
    case ClientDefines::ITEMS_INVENTORY:
        collection = Collection::Inventory;
        break;
    case ClientDefines::ITEMS_BARTER:
    case ClientDefines::ITEMS_PICKUP_FROM:
        collection = Collection::Inventory;
        break;
    case ClientDefines::ITEMS_PICKUP:
        collection = Collection::Loot;
        break;
    case ClientDefines::ITEMS_BARTER_OFFER:
        collection = Collection::BarterOffer;
        break;
    case ClientDefines::ITEMS_BARTER_OPPONENT_OFFER:
        collection = Collection::BarterTraderOffer;
        break;
    case ClientDefines::ITEMS_BARTER_OPPONENT:
        collection = Collection::Loot;
        break;
    }

    return collection;
}

// Точка входа для UI: пересобрать коллекцию по числовому типу.
Item[] RefreshItemsCollection(int collectionType)
{
    Collection collection = GetCollectionFromType(collectionType);
    return GetCollection(collection);
}

// Удаляет предмет по Id из свежесобранной коллекции (работает над локальной копией коллекции).
void RemoveItemFromCollection(ident itemId, Collection collection)
{
    Item[] items = GetCollection(collection);
    for (int j = 0; j < items.length(); j++) {
        Item item = items[j];
        if (itemId == item.Id) {
            items.removeAt(j);
            break;
        }
    }
}

// Меняет количество предмета в коллекции, заменяя его клоном с новым count.
void ChangeCollectionItemCount(ident itemId, Collection collection, int count)
{
    Item[] items = GetCollection(collection);
    for (int j = 0; j < items.length(); j++) {
        if (itemId == items[j].Id) {
            Item item = items[j].Clone(count);
            items.removeAt(j);
            items.insertAt(j, item);
            break;
        }
    }
}

// Ищет предмет в коллекции по Id; если в коллекции нет — берёт его напрямую из игры.
Item? GetCollectionItem(ident itemId, Collection collection)
{
    Item[] items = GetCollection(collection);
    for (int i = 0; i < items.length(); i++) {
        if (items[i].Id == itemId) {
            return items[i];
        }
    }

    return Game.GetItem(itemId);
}

// Формирует из обеих сторон бартер-оффера параллельные массивы Id/количество и отправляет
// оффер на сервер удалённым вызовом.
void BarterOffer()
{
    ident[] saleItemsIds = {};
    int[] saleItemsCount = {};
    ident[] buyItemsIds = {};
    int[] buyItemsCount = {};

    Item[] itemsSale = GetCollection(Collection::BarterOffer);
    Item[] itemsBuy = GetCollection(Collection::BarterTraderOffer);

    for (int i = 0, l = itemsSale.length(); i < l; i++) {
        saleItemsIds.insertLast(itemsSale[i].Id);
        saleItemsCount.insertLast(itemsSale[i].Count);
    }

    for (int i = 0, l = itemsBuy.length(); i < l; i++) {
        buyItemsIds.insertLast(itemsBuy[i].Id);
        buyItemsCount.insertLast(itemsBuy[i].Count);
    }

    CurPlayer.ServerCall.ProcessBarterNpcOffer(saleItemsIds, saleItemsCount, buyItemsIds, buyItemsCount);
}

// Переносит предмет между инвентарём/лутом и соответствующим бартер-оффером: для переноса
// «в оффер» наращивает стек или добавляет клон, для «из оффера» уменьшает или убирает предмет.
void BarterTransfer(ident item_id, int collectionTypeFrom, int item_count)
{
    Collection collectionFrom;
    Collection collectionTo;
    switch (collectionTypeFrom) {
    case ClientDefines::ITEMS_BARTER:
        collectionTo = Collection::BarterOffer;
        collectionFrom = Collection::Inventory;
        break;
    case ClientDefines::ITEMS_BARTER_OFFER:
        collectionTo = Collection::Inventory;
        collectionFrom = Collection::BarterOffer;
        break;
    case ClientDefines::ITEMS_BARTER_OPPONENT:
        collectionTo = Collection::BarterTraderOffer;
        collectionFrom = Collection::Loot;
        break;
    case ClientDefines::ITEMS_BARTER_OPPONENT_OFFER:
        collectionTo = Collection::Loot;
        collectionFrom = Collection::BarterTraderOffer;
        break;
    default:
        return;
    }

    Item? item = GetCollectionItem(item_id, collectionFrom);

    if (item == null) {
        return;
    }

    if (item_count > item.Count) {
        return;
    }

    Item? itemTo = null;
    Item[] itemsTo = GetCollection(collectionTo);

    if (item.Stackable) {
        for (int i = 0; i < itemsTo.length(); i++) {
            if (itemsTo[i].ProtoId == item.ProtoId) {
                itemTo = itemsTo[i];
                break;
            }
        }
    }

    if (collectionTypeFrom == ClientDefines::ITEMS_BARTER || collectionTypeFrom == ClientDefines::ITEMS_BARTER_OPPONENT) {
        if (itemTo != null) {
            ChangeCollectionItemCount(item_id, collectionTo, itemTo.Count + item_count);
        }
        else {
            itemsTo.insertLast(item.Clone(item_count));
        }
    }
    else {
        if (item.Count - item_count == 0 || !item.Stackable) {
            RemoveItemFromCollection(item.Id, collectionFrom);
        }
        else {
            ChangeCollectionItemCount(item_id, collectionFrom, item.Count - item_count);
        }
    }
}

#endif

#if SERVER

// Серверный приём бартер-оффера: берёт локи на криттера, торговца и их карты, затем передаёт
// обработку в Barter. Без полного набора локов выходит, не трогая состояние.
[[ServerRemoteCall]] [[Async]]
void ProcessBarterNpcOffer(Player player, ident[] saleItemsIds, int[] saleItemsCount, ident[] buyItemsIds, int[] buyItemsCount)
{
    Critter? cr = player.GetControlledCritter();
    if (cr == null) {
        return;
    }

    Critter? trader = Game.GetCritter(cr.TransferContainerId);
    if (trader != null && !Sync::Lock(cr, trader)) {
        return;
    }

    Map? crMap = cr.GetMap();
    Map? traderMap = trader != null ? trader.GetMap() : null;
    Entity[] entities = {cr};
    if (trader != null) {
        entities.insertLast(trader);
    }

    if (crMap != null) {
        entities.insertLast(crMap);
    }

    if (traderMap != null) {
        entities.insertLast(traderMap);
    }

    if (!Sync::Lock(entities)) {
        return;
    }

    Barter::ProcessBarterNpcOffer(cr, saleItemsIds, saleItemsCount, buyItemsIds, buyItemsCount);
}

#endif

}
