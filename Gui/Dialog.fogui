{
    {
        {
            //Dialog@ dialog = cast< Dialog >( Screen );
            //Game.CustomCall( "DialogAnswer " + dialog.TalkerIsNpc + " " + dialog.TalkerId + " " + CellIndex );

            if (!GuiScreensExt::IsPingInProgress()) {
                Game.CurPlayer.ServerCall.SpeechAnswer(CellIndex);
                GuiScreensExt::Ping();
            }
        }
    }
}
