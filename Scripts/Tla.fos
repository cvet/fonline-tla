// все это скорее всего не работает

bool IsDialogGenerated(string str)
{
    return str.length() == 0;
}
bool IsDialogSayMode(string str)
{
    return str.length() > 0 && str != "*";
}
bool IsDialogEnd(string str)
{
    return str == "*";
}

int NumericalNumber(int num)
{
    return ((num) % 2) != 0 ? (num) * ((num) / 2 + 1) : (num) * (num) / 2 + (num) / 2;
}
int Min(int a, int b)
{
    return a < b ? a : b;
}

float Min(float a, float b)
{
    return a < b ? a : b;
}

double Min(double a, double b)
{
    return a < b ? a : b;
}
int Max(int a, int b)
{
    return a > b ? a : b;
}

float Max(float a, float b)
{
    return a > b ? a : b;
}

double Max(double a, double b)
{
    return a > b ? a : b;
}
int Clamp(int x, int low, int high)
{
    return x > high ? high : (x < low ? low : x);
}

float Clamp(float x, float low, float high)
{
    return x > high ? high : (x < low ? low : x);
}

double Clamp(double x, double low, double high)
{
    return x > high ? high : (x < low ? low : x);
}
int Abs(int val)
{
    return val > 0 ? val : -val;
}

float Abs(float val)
{
    return val > 0 ? val : -val;
}

double Abs(double val)
{
    return val > 0 ? val : -val;
}
float Distance(float x1, float y1, float x2, float y2)
{
    return math::sqrt(Pow2(x1 - x2) + Pow2(y1 - y2));
}
int Pow2(int a)
{
    return a * a;
}

float Pow2(float a)
{
    return a * a;
}

double Pow2(double a)
{
    return a * a;
}

