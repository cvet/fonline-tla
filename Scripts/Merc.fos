namespace Merc // Sort 2
{

#if SERVER

// Базовые типы мерков, для использования без дополнительного скриптования
const int MERC_CUSTOM = 0;          // произвольный, без выраженного типа
const int MercFollowerDefault = 1;  // по умолчанию, отменяет следование при атаке со стороны игрока
const int MercFollowerHarmless = 2; // безобидный, не отменяет следование при агрессии со стороны игрока
const int MercFollowerCanLose = 3;  // то же, что и №1 - но может отставать при превышении расстояния между игроком и нпц значения LostDist
const int MercGuardDefault = 4;     // Охранник по умолчанию. При атаке кем-то хозяина присоединяется к бою

// Базовые расстояния от мерка до хозяина.
const int MMDistNone = 0;   // Не установлена
const int MMDistClose = 1;  // Вплотную
const int MMDistShort = 3;  // Короткая дистанция - 3 гекса
const int MMDistMedium = 8; // Средняя дистанция - 8 гексов
const int MMDistFar = 20;   // Дальняя дистанция - 20 гексов

bool ShouldCancelOnMasterAttack(Critter cr)
{
    return cr.MercCancelOnAttack;
}
bool CanLoseMerc(Critter cr)
{
    return cr.MercLoseDist > 0;
}
bool ShouldMercAlwaysRun(Critter cr)
{
    return cr.MercAlwaysRun;
}

mdir GetDir(Critter cr0, Critter cr1)
{
    return Game.GetDirection(cr0.Hex, cr1.Hex);
}

// Debug Log
// #define DebugLog#(s) (Game.Log(s))
void DebugLog(string s)
{
}

// * ********* Типовые шаблоны для мерков. Для использования в качестве заготовок *********//

// число параметров мерка для некоего типа. Если потребуется добавить новый параметр,нужно изменить это число и дописать параметры для каждого типа мерков
const int MERC_PARAM_COUNT = 7;
const int MERC_TYPE_COUNT = 4; // число типов мерков. При добавлении нового типа, увеличивайте число вручную
int MercTableCell(int type, int col)
{
    return _mercInfo[((type > MERC_TYPE_COUNT ? Merc::MercFollowerDefault : type) - 1) * MERC_PARAM_COUNT + col];
}
timespan ReleaseTime()
{
    return Time::GameMinutes(60);
} // 60 минут = время в игровых минутах до уничтожения/или переноса на домашнюю позицию мерка после вызова CancelMerc.
timespan FireTime()
{
    return Time::GameDays(30 * 3);
} // Время службы по умолчанию - 3 месяца
/*
   type                         - тип мерка
   loseDist                     - дистанция, на которой мерк отстанет от игрока, 0= не будет отставать
   alwaysRun                    - перемещается бегом (если анимация позволяет)
   cancelOnMasterDead           - сброс мерка при смерти хозяина
   cancelOnMasterAttack         - сброс мерка при атаки мерка хозяином
   defendMaster                 - атакует тех, кто напал на хозяина
   assistMaster                 - атакует тех, на кого напал хозяин
   cancelTime                   - время завершения службы
 */

// clang-format off

const int[] _mercInfo =
{
    //  type,                   loseDist,  alwaysRun,  cancelOnMasterDead,  cancelOnMasterAttack,  defendMaster,  assistMaster
    Merc::MercFollowerDefault,      0,         0,          1,                   1,                     0,             0,
    Merc::MercFollowerHarmless,     0,         0,          0,                   0,                     0,             0,
    Merc::MercFollowerCanLose,     MMDistFar, 0,          1,                   1,                     0,             0,
    Merc::MercGuardDefault,         0,         0,          1,                   1,                     1,             0
};

// clang-format on

bool CanMercLose(int type)
{
    return MercTableCell(type, 1) > MMDistNone;
}
int MercLoseDistance(int type)
{
    return MercTableCell(type, 1);
}
int MercAlwaysRun(int type)
{
    return MercTableCell(type, 2);
}
int MercCancelOnMasterAttack(int type)
{
    return MercTableCell(type, 4);
}
int MercDefendMaster(int type)
{
    return MercTableCell(type, 5);
}
int MercAssistMaster(int type)
{
    return MercTableCell(type, 6);
}
// #define _MercCancelOnMasterDead #(type) (MercTableCell(type, 3)) не реализовано

// * *************************** Скрипт инициализации мерка ***************************** *//
void MercInit(Critter merc, bool firstTime)
{
    merc.StartTimeEvent(Time::Asap(), Time::Seconds(1), MercIdle); // Обязательный скрипт. В нем контролируется положение мерка относительно игрока

    merc.OnSomeCritterDead.Subscribe(MercSmthDead);
    merc.OnAttacked.Subscribe(MercAttacked);
    merc.OnDead.Subscribe(MercDead);
    merc.OnSomeCritterAttacked.Subscribe(MercSmthAttacked);
    merc.OnGlobalMapProcess.Subscribe(MercGlobalProcess);

    merc.IsNoHome = true;
    merc.IsGeck = true; // Чтобы НПЦ не удалялся при выходе игрока с энкаунтера.
}

// * ****************************** Обработка событий мерка ***************************** *//

[[Event]]
EventResult MercGlobalProcess(Critter cr, int type, Item, float, float, float, float, float, int, bool)
{
    if (type == Tla::GlobalProcessNpcIdle) {
        MercIdleImpl(cr);
    }

    return EventResult::StopChain;
}

[[Event]]
void MercSmthAttacked(Critter merc, Critter fromCr, Critter attacker)
{
    if (NpcPlanes::IsCurPlane(merc, NpcPlanes::AI_PLANE_ATTACK)) {
        return; // Реакция будет лишь в том случае, если у самого мерка нет планов атаки кого-либо.
    }

    if (attacker.Id == merc.Id) {
        return;
    }

    if (merc.MercMasterId == fromCr.Id) // Атакован хозяин мерка
    {
        if (merc.MercDefendMaster) {
            NpcPlanes::AddAttackPlane(merc, 0, attacker);
        }

        return;
    }

    if (merc.MercMasterId == attacker.Id) // Атакующий - хозяин мерка
    {
        if (merc.MercAssistMaster) {
            NpcPlanes::AddAttackPlane(merc, 0, fromCr);
        }

        return;
    }
}

void MercDeadImpl(Critter merc, Critter killer)
{
    DebugLog("Canceld merc");
    CancelMerc(merc);
}

[[Event]]
void MercDead(Critter merc, Critter killer)
{
    MercDeadImpl(merc, killer);
}

[[Event]]
EventResult MercAttacked(Critter merc, Critter attacker)
{
    if (attacker.Id == merc.MercMasterId && ShouldCancelOnMasterAttack(merc)) {
        CancelMerc(merc); // хозяин атаковал мерка
    }

    return EventResult::StopChain;
}

void MercSmthDeadImpl(Critter merc, Critter fromCr, Critter killer)
{
    if (fromCr.Id == merc.MercMasterId) {
        // пока - однозначаная отмена мерка при гибели хозяина
        CancelMerc(merc);
    }
}

[[Event]]
void MercSmthDead(Critter merc, Critter fromCr, Critter killer)
{
    MercSmthDeadImpl(merc, fromCr, killer);
}

void MercIdleImpl(Critter merc)
{
    if (merc.MercMasterId == ZERO_IDENT) {
        return;
    }

    if (merc.MercCancelTime < Game.SynchronizedTime) {
        CancelMerc(merc);
        return;
    }

    Critter? master = Game.GetCritter(merc.MercMasterId);
    if (master == null) {
        return;
    }

    if (master.IsDead()) {
        MercSmthDeadImpl(merc, master, null);
        return; // погиб хозяин
    }

    Map? map_master = master.GetMap();
    Map? map_merc = merc.GetMap();
    if (map_master != null) {
        mpos hex = master.Hex;
        Entrance::GetFreeHex(map_master, 1, hex);
        if (map_merc != null) {
            if (map_master.Id == map_merc.Id) {
                int dist = Game.GetDistance(merc, master);
                if (CanLoseMerc(merc)) {
                    if (dist > merc.MercLoseDist) {
                        CancelMerc(merc);
                        DebugLog("lost master.Dist=" + dist + " losedist" + merc.MercLoseDist);
                        return; // потеряли
                    }
                }

                if (dist > merc.MercMasterDist) {
                    if (!merc.MercWaitForMaster) {
                        NpcPlanes::AddWalkPlane(merc, 0, hex, GetDir(merc, master), ShouldMercAlwaysRun(merc), 1);
                    }
                }
            }
            else {
                if (!merc.MercWaitForMaster) {
                    merc.TransferToMap(map_master, hex, HDIR_Random);
                }
            }
        }
        else {
            merc.TransferToMap(map_master, hex, HDIR_Random);
        }
    }
    else {
        if (merc.MercCancelOnGlobal) {
            // Мерк отменяет режим службы, если хозяин вышел на глобал и установлен параметр MercCancelOnGlobal
            CancelMerc(merc);
            return;
        }

        // хозяин на глобале
        if (merc.MercWaitForMaster) {
            return;
        }

        Critter[] globalGroup = GlobalmapGroupExtended::GetGlobalGroup(master);
        if (!GlobalmapGroupExtended::GetGlobalGroup(merc).isEmpty() || globalGroup.isEmpty()) {
            return;
        }

        Critter leader = globalGroup[0];
        if (leader.Charisma > int(globalGroup.length())) {
            merc.TransferToGlobalGroup(master);
        }
    }
}

[[TimeEvent]]
void MercIdle(Critter merc)
{
    MercIdleImpl(merc);
}

// * ***************************** Добавление мерков игроку ***************************** *//
// Добавление мерка одного из преустановленных типов игроку
// player - хозяин мерка
// merc - мерк
// type - тип мерка
bool Merc2Player(Critter player, Critter merc, int type) // Predefined Mercs
{
    return Merc2Player(player,
                       merc,
                       (MercAlwaysRun(type) > 0),
                       (MercCancelOnMasterAttack(type) > 0),
                       MercLoseDistance(type),
                       MMDistShort,
                       type,
                       (MercDefendMaster(type) > 0),
                       (MercAssistMaster(type) > 0),
                       ZERO_TIMESPAN);
}

// Добавление мерка игроку. Тип мерка Merc::MercFollowerDefault.
// player - хозяин мерка
// merc - мерк
bool Merc2Player(Critter player, Critter merc) // Default follower
{
    return Merc2Player(player, merc, Merc::MercFollowerDefault);
}

bool Merc2Player(Critter player, Critter merc, bool alwaysRun, bool cancelOnAttack, int loseDist, int mercMasterDist, int type, bool defendMaster,
                 bool assistMaster) // Custom Mercs
{
    return Merc2Player(player, merc, alwaysRun, cancelOnAttack, loseDist, mercMasterDist, type, defendMaster, assistMaster, ZERO_TIMESPAN);
}

// Добавление мерка с подробной настройкой параметров
// player - хозяин мерка
// merc - мерк
// merc - мерк
// alwaysRun - признак: мерк всегда перемещается бегом
// cancelOnAttack - признак: если игрок атакует мерка, мерк слетит с этого игрока
// loseDist - дистанция, при превышении которой между игроком и нпц, отменяется режим мерка.
// При loseDist= 0 - мерк не будет отставать от хозяина
// mercMasterDist - дистанция, на которую будет стремиться приблизиться мерк при перемещении хозяина по карте
// type - тип мерка
// defendMaster - признак, мерк будет защищать хозяина, если хозяин был атакован кем-то
// assistMaster - признак, если хозяин кого-то атакует, мерк присоединится к атаке
// fireTime - время увольнения
bool Merc2Player(Critter player, Critter merc, bool alwaysRun, bool cancelOnAttack, int loseDist, int mercMasterDist, int type, bool defendMaster,
                 bool assistMaster, timespan fireTime) // Custom Mercs
{
    if (merc.Id == player.Id) {
        Game.Log("Wrong mercenary master... Merc creation failed");
        return false;
    }

    merc.MercType = type;
    merc.MercMasterId = player.Id;
    merc.MercAlwaysRun = alwaysRun;
    merc.MercCancelOnAttack = cancelOnAttack;
    merc.MercLoseDist = loseDist;
    merc.MercMasterDist = mercMasterDist;
    merc.MercDefendMaster = defendMaster;
    merc.MercAssistMaster = assistMaster;
    merc.MercCancelTime = Game.SynchronizedTime + (fireTime == ZERO_TIMESPAN ? FireTime() : fireTime);
    merc.TeamId = Teams::Default;
    merc.SetupScript(MercInit);

    return true;
}

// Добавление мерка с частичной настройкой параметров
// player - хозяин мерка
// merc - мерк
// merc - мерк
// alwaysRun - признак: мерк всегда перемещается бегом
// cancelOnAttack - признак: если игрок атакует мерка, мерк слетит с этого игрока
// loseDist - дистанция, при превышении которой между игроком и нпц, отменяется режим мерка.
// При loseDist= 0 - мерк не будет отставать от хозяина
// mercMasterDist - дистанция, на которую будет стремиться приблизиться мерк при перемещении хозяина по карте
bool Merc2Player(Critter player, Critter merc, bool alwaysRun, bool cancelOnAttack, int loseDist, int mercMasterDist) // Custom Mercs
{
    return Merc2Player(player, merc, alwaysRun, cancelOnAttack, loseDist, mercMasterDist, MERC_CUSTOM, false, false, ZERO_TIMESPAN);
}

// * **************************** Отмена режима мерка у нпц ***************************** *//
void CancelMerc(Critter merc)
{
    for (int i = 0; i < CritterPropertyGroup::Mercs.length(); i++) {
        merc.SetAsInt(CritterPropertyGroup::Mercs[i], 0);
    }

    merc.SetupScript(null);
    merc.StopTimeEvent(MercIdle); // Обязательный скрипт. В нем контролируется положение мерка относительно игрока
    merc.OnSomeCritterDead.Unsubscribe(MercSmthDead);
    merc.OnAttacked.Unsubscribe(MercAttacked);
    merc.OnDead.Unsubscribe(MercDead);
    merc.OnSomeCritterAttacked.Unsubscribe(MercSmthAttacked);
    merc.OnGlobalMapProcess.Unsubscribe(MercGlobalProcess);

    Game.StartTimeEvent(ReleaseTime(), ReleaseMerc, merc.Id); //SavedDeferredCall
}

[[TimeEvent]]
void ReleaseMerc(any value)
{
    Critter? merc = Game.GetCritter(value);
    if (merc != null) {
        merc.IsGeck = false;
        merc.IsNoHome = false;
        // Если домашняя позиция нпц найдена, перемещаем его домой.
        auto map = Game.GetMap(merc.HomeMapId);
        if (merc.HomeMapId != ZERO_IDENT && map != null) {
            merc.ReplicationTime = 0;
            if (merc.IsDead()) {
                CritterState::ToAlive(merc);
            }

            merc.TransferToMap(map, merc.HomeHex, hdir(merc.HomeDir));
        }

        // Домашняя позиция не найдена, криттера нужно удалять
        Game.DestroyCritter(merc);
    }
}

// * *********************** Получение мерков игрока ******************** *//
// Все мерки игрока записываются в переданный массив mercs
// Возвращаемое значение - число найденных мерков
// player - хозяин мерков
int GetPlayerMercs(Critter player, Critter[] mercs)
{
    Map? map = player.GetMap();
    mercs.clear();
    if (map == null) {
        // Игрок на глобале
        // можно и не найти всех мерков - поскольку после выхода на глобал у них уходит какоето время на присоедиение в группу
        Critter[] globalGrp = GlobalmapGroupExtended::GetGlobalGroup(player);
        for (int i = 0; i < globalGrp.length(); i++) {
            if (globalGrp[i].MercMasterId == player.Id) {
                mercs.insertLast(globalGrp[i]);
            }
        }
    }
    else {
        Critter[] critters = map.GetCritters(CritterFindType::NonDeadNpc);
        for (int i = 0; i < critters.length(); i++) {
            if (critters[i].MercMasterId == player.Id) {
                mercs.insertLast(critters[i]);
            }
        }
    }

    return mercs.length();
}

// Возвращает всех мерков хозяина с указанной NpcRole
// player - хозяин мерка
// mercs - список мерков данного хозяина с указанной ролью
// mercRole - роль искомого мерка
int GetPlayerMercs(Critter player, Critter[] mercs, int mercRole)
{
    Critter[] critters = {};
    if (GetPlayerMercs(player, critters) > 0) {
        for (int i = 0; i < critters.length(); i++) {
            Critter merc = critters[i];
            if (merc.NpcRole == mercRole) {
                mercs.insertLast(merc);
            }
        }

        return mercs.length();
    }
    else {
        return 0;
    }
}

// Возвращает первого найденного мерка с указанной NpcRole
// player - хозяин мерка
// mercRole - роль искомого мерка
Critter? GetPlayerMerc(Critter player, int mercRole)
{
    Critter[] mercs = {};
    if (GetPlayerMercs(player, mercs) > 0) {
        for (int i = 0; i < mercs.length(); i++) {
            Critter merc = mercs[i];
            if (merc.NpcRole == mercRole) {
                return merc;
            }
        }
    }

    return null;
}

