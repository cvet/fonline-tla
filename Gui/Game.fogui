//           "OnLMouseClick":
{
    {
        {
            //Game.CustomCall( "ChangeSlot" );

            Critter chosen = Game.GetChosen();
            if (chosen is null) {
                return;
            }
            /*  
                Item item1 = chosen.GetItem( ItemProperty::CritterSlot, CritterItemSlot::Main );
                Item item2 = chosen.GetItem( ItemProperty::CritterSlot, CritterItemSlot::Secondary );
                if( item1 != null)
                    ChosenActions::SetAction( { Tla::ChosenMoveItem, item1.Id, item1.Count, CritterItemSlot::Secondary, 0, 0, 0 }, false, true );
                if( item2 != null)
                    ChosenActions::SetAction( { Tla::ChosenMoveItem, item2.Id, item2.Count, CritterItemSlot::Main, 0, 0, 0 }, false, true );
                   */

            //   Critter chosen = Game.GetChosen();
            Item item2 = chosen.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Secondary);
            if (item2 != null) {
                ChosenActions::SetAction({Tla::ChosenMoveItem, item2.Id, item2.Count, CritterItemSlot::Main, 0, 0, 0}, false, true);
                return;
            }

            Item item1 = chosen.GetItem(ItemProperty::CritterSlot, CritterItemSlot::Main);
            if (item1 != null) {
                ChosenActions::SetAction({Tla::ChosenMoveItem, item1.Id, item1.Count, CritterItemSlot::Secondary, 0, 0, 0}, false, true);
            }
        }
    }
}
