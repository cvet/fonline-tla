{
    {
        void FiltersChanged()
        {
            bool filter1Checked = cast<Gui::CheckBox>(Parent.Find("Filter1")).IsChecked;
            bool filter2Checked = cast<Gui::CheckBox>(Parent.Find("Filter2")).IsChecked;

            ChangeDisplayedMessage(MessageBoxType::Talk, filter1Checked);
            ChangeDisplayedMessage(MessageBoxType::Combat, filter2Checked);
        }
    }
}
