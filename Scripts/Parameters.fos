}

[[PropertyGetter]]
bool CritterGetIsAddicted(Critter cr)
{
    bool[] addictions = cr.Addictions.clone();
    for (int i = 0; i < addictions.length(); i++) {
        if (addictions[i]) {
            return true;
        }
    }

    return false;
}

