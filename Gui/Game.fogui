//                       "OnMousePressed": null,
//                       "OnLMousePressed": null,
//                       "OnRMousePressed": null,
//                       "OnMouseClick": null,
//                       "OnLMouseClick": null,
//                       "OnRMouseClick": null,
//                       "OnMouseMove": null,
//                       "OnGlobalMouseDown": null,
//                       "OnGlobalMouseUp": null,
//                       "OnGlobalMousePressed": null,
//                       "OnGlobalMouseClick": null,
