// MainIntro — сюжетное вступление для новозарегистрированного игрока (стартовая локация, интро, инициация).
// Отвечает за: создание временных стартовых локаций и телепорт игрока, перенос между картами интро по диалогу,
// сцену инициации (эффект молнии/ЭМИ, открытие дверей) и финальную сцену «смерть → репликация → голодиск».
// Сторона исполнения: SERVER (вся логика под #if SERVER).
// Прогресс по вступлению хранится в Property-декларации MainQuest у криттера; этапы заданы константами MAINQ_ST_*.
// Связи: Location, Entrance, CritterState, Effects, Messaging, Holodisk, Replication, GameTime, Trigger.
namespace MainIntro
{

const int STR_INITIATION_DONE = 20;

#if SERVER

///@ Property Critter Common uint8 MainQuest Mutable OwnerSync Persistent Group = Quests Quest = 5001 Max = 21

///@ Property Map Server bool QIntroInitiated Mutable Persistent
///@ Property Map Server bool IntroDoorsOpen Mutable Persistent

const int INTRO_WORLD_X = 5;                       // координаты расположения стартовой локации на глобале, ось Х
const int INTRO_WORLD_Y = 5;                       // координаты расположения стартовой локации на глобале, ось У
const hstring ENTRY_ENTRANCE1 = ("" + 0).hstr();   // номер Entry-гекса, на котором начинает игрок
const hstring ENTRY_ENTRANCE2 = ("" + 240).hstr(); // номер Entry-гекса, на котором начинает игрок
const int TRIBAL_INT = 3;                          // максимальный интелект, при котором вместо кожаной куртки у игрока будет скин дикаря
const int MAINQ_ST_START_COMPLETE = 1;             // Сюжетный квест: игрок вышел со стартовой локации. Используется при проверке, где должен появиться игрок
const int MAINQ_ST_INTRO_COMPLETE = 2;             // Сюжетный квест: игрок вышел из локации интро.
const int HOLODISK_INFO_INTRO = 43;                // номер голодиска, выдаваемого в центре репликации по завершению интерлюдии
const int STR_NOTIFY_HOLODISK = 6000;              // В вашем Пипбое записана важная информация.

// Отладочный лог вступления; обёртка над Game.Log
void DebugLog(string s)
{
    Game.Log("" + s);
}
// breadcrumb миграции: прежде DebugLog был макросом-заглушкой, отключающим лог; оставлено как ссылка
// #define DebugLog                         # (s)

// Проверка: Вышел ли игрок со стартовой локации
bool CheckPlayerCompleteStart(Critter player)
{
    return player.MainQuest >= MAINQ_ST_START_COMPLETE;
}

// Проверка: Вышел ли игрок со второй сюжетной карты
bool CheckPlayerCompleteIntro(Critter player)
{
    return player.MainQuest >= MAINQ_ST_INTRO_COMPLETE;
}

// Создание локации начала игры для персонажа, который только что был зарегистрирован
// Возвращает истину если локация нужна, создалась и игрок телепортирован на карту
bool SetPlayerStartLocation(Critter player)
{
    // Стартовые локации не нужно сохранять. Иначе, если регистрировать тучу персонажей, для каждого придется сохранить свою локацию
    Location loc = Location::CreateLocation(Content::Location::intro_martin, ipos(INTRO_WORLD_X, INTRO_WORLD_Y), null);
    Map map = loc.GetMapByIndex(0);

    if (!Entrance::CritterTransferToMapEntry(player, map.Id, (Game.Random(0, 1) == 0 ? ENTRY_ENTRANCE1 : ENTRY_ENTRANCE2))) {
        return false;
    }

    // Изменение типа криттера, чтобы не было пижамы с рождения
    hstring crType = (player.Gender == GenderType::Male ? Tla::CRTYPE_DW_LEATHER_JACKET_M : Tla::CRTYPE_DW_LEATHER_JACKET_F);
    if (player.Intellect <= TRIBAL_INT) {
        crType = (player.Gender == GenderType::Male ? Tla::CRTYPE_DW_TRIBAL_M : Tla::CRTYPE_DW_TRIBAL_F);
    }

    verify(crType != EMPTY_HSTRING, "Assertion failed");
    player.ModelNameBase = crType;
    player.ModelName = crType;

    return true;
}

// Отправляет игрока на вторую локацию
// Возвращает истину если локация нужна, создалась и игрок телепортирован на карту
bool SetPlayerIntroLocation(Critter player)
{
    Location loc = Location::CreateLocation(Content::Location::hubologists_initialization, ipos(INTRO_WORLD_X, INTRO_WORLD_Y), null);
    Map map = loc.GetMapByIndex(0);
    Entrance::CritterTransferToMapEntry(player, map.Id, ENTRY_ENTRANCE1);
    return true;
}

// Пытается установить начальную локацию для игрока (либо стартовая карта с виком/кессиди итд, либо вторая карта с убийством
// true - локация была установлена
// false - не получилось установить, или уже не требуется
bool SetPlayerStoryLineLocation(Critter player)
{
    // Игрок уже завершил вступление
    if (CheckPlayerCompleteIntro(player)) {
        return false;
    }

    if (!CheckPlayerCompleteStart(player)) {
        // Игрок только зарегистрировался, или в последний раз вышел в оффлайн из стартовой локации
        return SetPlayerStartLocation(player);
    }
    else {
        // Игрок уже выходил из стартовой локации
        return SetPlayerIntroLocation(player);
    }
}

// Перенос игрока со стартовой локации в результате диалога с ключевым персонажем
[[DialogResult]]
void TransferToIntro(Critter player, Critter npc)
{
    SetPlayerIntroLocation(player);
    player.MainQuest = MAINQ_ST_START_COMPLETE;
}

// Триггер входа в лифт в конце интро: запускает сцену «выстрел → смерть → репликация» и завершает вступление
[[ItemTrigger]]
void KillPlayerOnIntro(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    CritterState::Wait(player, 3000);
    Effects::FadeScreen(player, Color::Black, Color::Black, Time::Milliseconds(5000));

    // Отложенные стадии сцены по таймеру; SavedDeferredCall — переживают сохранение/перезапуск сервера
    Game.StartTimeEvent(Time::Seconds(1), KillPlayer, player.Id);       // SavedDeferredCall
    Game.StartTimeEvent(Time::Seconds(2), OnPlayerDead, player.Id);     // SavedDeferredCall
    Game.StartTimeEvent(Time::Seconds(5), ReplicateCritter, player.Id); // SavedDeferredCall
    player.MainQuest = MAINQ_ST_INTRO_COMPLETE;
}

// Entry-гекс, по которому бьют молнии (эффект ЭМИ) во время сцены инициации
const int HEX_LIGHTNING = 323;

// Триггер сцены инициации: при первом входе игрока запускает эффекты молнии, иначе работает как обычная дверь.
// Однократность гарантируется флагом карты QIntroInitiated; открытие дверей — флагом IntroDoorsOpen
[[ItemTrigger]]
void Initiation(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    Map? map = player.GetMap();
    if (map != null) {
        if (entered && player.ControlledByPlayer) {
            if (!map.QIntroInitiated) {
                map.QIntroInitiated = true;
                CritterState::Wait(player, 3000);
                any[] values = {map.Id, player.Id};
                Game.StartTimeEvent(Time::Seconds(1), SmallEffect, values); //SavedDeferredCall
                Game.StartTimeEvent(Time::Seconds(5), MainEffect, values);  //SavedDeferredCall
                return;
            }
        }

        if (!map.IntroDoorsOpen) {
            return;
        }
    }

    Trigger::DoorOpenImpl(player, trigger, entered, dir);
}

// Малый этап сцены: повторяющиеся вспышки молний по entry-гексам, пока двери не открыты.
// Сам себя перезапускает раз в игровую секунду; гард по карте/криттеру отсекает случай, когда игрок ушёл
[[TimeEvent]]
void SmallEffect(any[] values)
{
    ident mapId = values[0];
    ident crId = values[1];
    if (mapId != ZERO_IDENT && crId != ZERO_IDENT) {
        Map? map = Game.GetMap(mapId);
        Critter? cr = Game.GetCritter(crId);
        if (cr != null) {
            Map? mapCr = cr.GetMap();
            if (map != null && mapCr != null && (mapCr.Id == map.Id)) {
                if (!map.IntroDoorsOpen) {
                    Entrance::Entry[] entries = Entrance::ParseEntries(map, HEX_LIGHTNING);
                    for (int i = 0; i < entries.length(); i++) {
                        Effects::RunEffect(map, Content::Item::explode_emp, entries[i].Hex, Game.Random(1, 2));
                        Game.Log("molniya");
                    }

                    Game.StartTimeEvent(GameTime::GameSeconds(1), SmallEffect, values); // SavedDeferredCall
                }
            }
        }
    }
}

// Завершающий этап сцены: финальный взрыв на гексе игрока, открытие дверей (флаг IntroDoorsOpen)
// и сообщение об окончании инициации. Останавливает повтор SmallEffect через тот же флаг
[[TimeEvent]]
void MainEffect(any[] values)
{
    ident mapId = values[0];
    ident crId = values[1];
    if (mapId != ZERO_IDENT && crId != ZERO_IDENT) {
        Map? map = Game.GetMap(mapId);
        Critter? cr = Game.GetCritter(crId);
        if (cr != null) {
            Map? mapCr = cr.GetMap();
            if (map != null && mapCr != null && (mapCr.Id == map.Id)) {
                if (!map.IntroDoorsOpen) {
                    Effects::RunEffect(map, Content::Item::explode_emp, cr.Hex, 3);
                    map.IntroDoorsOpen = true;
                    Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_INITIATION_DONE)));
                }
            }
        }
    }
}

// Стадия 1 сцены смерти: звук выстрела по игроку
[[TimeEvent]]
void KillPlayer(any value)
{
    Critter? player = Game.GetCritter(value);
    if (player != null) {
        Effects::PlaySound(player, "WA@2XXX1.acm"); // выстрел
    }
}

// Стадия 2 сцены смерти: предсмертный стон и перевод игрока в состояние «мёртв»
[[TimeEvent]]
void OnPlayerDead(any value)
{
    Critter? player = Game.GetCritter(value);
    if (player == null) {
        return;
    }

    Effects::PlaySound(player, (player.Gender == GenderType::Male ? "HFXXXBF.acm" : "HMXXXBF.acm")); // стон
    CritterState::ToDead(player, CritterActionAnim::DeadFront, null);
}

// Стадия 3 сцены: возвращаем игроку обычную модель, выдаём голодиск интро и запускаем репликацию (возрождение)
[[TimeEvent]]
void ReplicateCritter(any value)
{
    Critter? player = Game.GetCritter(value);
    if (player == null) {
        return;
    }

    hstring crType = (player.Gender == GenderType::Male ? Tla::CRTYPE_DEFAULT_M : Tla::CRTYPE_DEFAULT_F);
    // breadcrumb миграции: прежний API смены типа криттера; сейчас тип задаётся через ModelNameBase ниже
    // player.ChangeCrType( crType );
    player.ModelNameBase = crType;

    Holodisk::AddHolodiskInfo(player, HOLODISK_INFO_INTRO);
    Game.StartTimeEvent(GameTime::GameSeconds(3), ShowMessage, player.Id); // SavedDeferredCall
    Replication::ReplicateCritter(player);
}

// Финал сцены: обнуляем счётчики репликации и уведомляем игрока о записи в Пип-бой
[[TimeEvent]]
void ShowMessage(any value)
{
    Critter? player = Game.GetCritter(value);
    if (player == null) {
        return;
    }

    player.ReplicationCount = 0;
    player.ReplicationMoney = 0;
    // breadcrumb миграции: раньше уведомление показывалось через диалоговое окно/SayMsg; сейчас — Messaging::Info ниже
    // player.ShowScreen( GuiScreen::DialogBox, 0, "None" );
    // player.SayMsg( Tla::SayDialogboxText, TextPackName::Text, STR_NOTIFY_HOLODISK );
    Messaging::Info(player, TextPackKey(TextPackName::Text, "" + (STR_NOTIFY_HOLODISK)));
}

// Пустой обработчик ответа диалогового окна (заглушка-цель для кнопки закрытия), оставлен для парного breadcrumb выше
void None(Critter player, int answerI, string answerS)
{
    // ...
}

#endif

}
