{
    {
        {
            Dialog @dialog = cast<Dialog>(Screen);
            string text = Game.EncodeUtf8(TEXT_SYMBOL_DOT) + dialog.Answers[CellIndex];
            Game.Log("dText " + CellIndex + " : " + dialog.Answers[CellIndex]);
            int lines = 0;
            isize box;
            Game.GetTextInfo(text, isize(Size.width, 1000), TextFont, TextFlags, box, lines);
            SetSize(Size.width, box.height);
            SetText(text);
        }
    }
}
