void RunStopPhase()
{
    DebugLog("RACING STOP");
    StopRacing();
}

void StopRacing()
{
    GameEvent::StopGameEvent(EVENT_RACING_STOP);
    Location[] checkPoints = {};
    checkPoints = Game.GetLocations(Content::Location::den_racing_checkpoint);
    for (int i = 0, l = checkPoints.length(); i < l; i++) {
        Location loc = checkPoints[i];
        loc.AutoGarbage = true;
    }

    if (Game.RacingWinnersFound == 2) {
        Radio::SendChannelRadioMessage(8, TextPackKey(TextPackName::Text, "" + (3955)));
        Radio::SendChannelRadioMessage(0, TextPackKey(TextPackName::Text, "" + (3955)));
    }
    else {
        Radio::SendChannelRadioMessage(8, TextPackKey(TextPackName::Text, "" + (3956)));
        Radio::SendChannelRadioMessage(0, TextPackKey(TextPackName::Text, "" + (3956)));
    }

    Map? map = Game.GetMap(Content::Map::den_carstop);
    if (map == null) {
        return;
    }

    Critter[] critters = map.GetCritters(CritterFindType::Npc);
    for (int i = 0; i < critters.length(); i++) {
        Critter cr = critters[i];
        if (cr.NpcRole == ROLE_GUARD || cr.NpcRole == ROLE_BODYGUARD || cr.NpcRole == ROLE_BILL) {
            cr.StartTimeEvent(Time::Minutes(Game.Random(2, 5)), cte_DelNpc, 0);
        }

        if (cr.NpcRole == ROLE_SPECTATOR) {
            cr.StartTimeEvent(Time::Minutes(1), cte_Npc2HomePos);
        }
    }
}

[[DialogResult]]
void r_StopEvent(Critter cr, Critter npc)
{
    StopRacing();
}

[[TimeEvent]]
void cte_DelNpc(Critter cr, any rate)
{
    if (!cr.ControlledByPlayer) {
        Game.DestroyCritter(cr);
    }

    return;
}

void dlg_Winner(Critter player, Critter npc, string& textArgs)
{
    if (!Tla::IsDialogGenerated(textArgs)) {
        return;
    }

    textArgs = "|winner:Избранный";
    if (Game.RacingWinner != ZERO_IDENT) {
        textArgs = "|winner:" + PlayerRegistration::GetPlayerName(Game.RacingWinner);
    }
}

