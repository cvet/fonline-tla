[[Event]]
void OnInfoMessage(EngineInfoMessage infoMessage, string extraText)
{
    if (infoMessage == EngineInfoMessage::ServerLog) {
        Messaging::Info(extraText);
    }
    else if (Game.IsTextPresent(TextPackKey(TextPackName::Game, "" + (int(infoMessage))))) {
        Messaging::Info(Game.GetText(TextPackKey(TextPackName::Game, "" + (int(infoMessage)))));
    }
    else {
        Messaging::Info(Game.EnumToString(infoMessage));
    }
}

