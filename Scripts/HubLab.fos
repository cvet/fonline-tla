// HubLab — серверная логика квеста "Секретная лаборатория хабологов".
// Отвечает за: проводника Хономера (спавн, сопровождение игрока на глобалке,
// поведение в лаборатории, открытие/закрытие двери, починку компьютера),
// охрану и лаборантов локации, проверки/результаты диалогов квеста,
// триггеры карты (атака игрока без робы, авто-закрытие двери, старт сцены).
// Сторона: только SERVER.
// Связи: NpcDialog, NpcPlanes, NpcRevenge, EnemyStack, Entrance, Lockers,
// GlobalmapGroupExtended, AnimHelpers, Messaging, Tla.
namespace HubLab
{

#if SERVER

///@ Property Critter Common uint8 SFAhs7Escort Mutable OwnerSync Persistent Group = Quests Quest = 4434 Max = 3
///@ Property Critter Server ident SFHonomerPlayerId Mutable Persistent
///@ Property Critter Server ident SFEscortLocation Mutable Persistent
///@ Property Critter Server uint8 SFLabFailed Mutable Persistent Max = 1
///@ Property Critter Server bool QHubLabIsDialogRun Mutable Persistent

///@ Property Map Server bool SFLabHonomerInside Mutable Persistent

const hstring ENTRY_HONOMER = ("" + 43).hstr();  // Место спавна проводника.
const hstring ENTRY_LAB_ENTER = ("" + 1).hstr(); // Место, куда приходит нпц с сопровождающим
const int CTE_CLEAR_FOLLOWER = 121;
const int LAB_WORLD_X = 532;
const int LAB_WORLD_Y = 1435;
const int DIALOG_GUARD = 2;
const int ROLE_GUARD = 18;
const hstring ENTRY_DOOR_NEAR = ("" + 19).hstr(); // Гекс перед дверью, на котором будет переходить хономер перед ее открытием
const hstring ENTRY_REPAIR = ("" + 20).hstr();    // Гекс на котором Хономер останавливается для ремонта
const hstring ENTRY_DOOR = ("" + 21).hstr();      // Гекс под дверью
const int MSG_DIALOG_END = 4023;
const int ROLE_START_DIALOG = 22; // Роль нпц, который затевает обсуждение произошедшего
const int AlarmTextId = 8030;
const int STR_OPEN = 8031;
const int MSG_OPEN = 4024;
const hstring ENTRY_HELL = ("" + 242).hstr();

// Заглушка отладочного лога; рабочая реализация — закомментированный макрос ниже
// (breadcrumb со времён переноса на текущий движок, включается при отладке).
// #define DebugLog #(s) (Game.Log("" + s))
void DebugLog(string s)
{
}

// Хономер рядом, если на карте игрока есть живой НПЦ с диалогом проводника.
bool IsHonomerNearImpl(Critter player, Critter npc)
{
    Map? map = player.GetMap();
    if (map == null) {
        return false;
    }

    Critter[] critters = map.GetCritters(Content::Critter::ElronologistFemale, CritterFindType::NonDeadNpc);
    for (int i = 0; i < critters.length(); i++) {
        if (critters[i].DialogId == Content::Dialog::sf_honomer) {
            return true;
        }
    }

    return false;
}

[[DialogDemand]]
bool IsHonomerNear(Critter player, Critter npc)
{
    return IsHonomerNearImpl(player, npc);
}

[[DialogDemand]]
bool NoHonomerNear(Critter player, Critter npc)
{
    return !IsHonomerNearImpl(player, npc);
}

// Добавление проводника на карту sf_hubb.
void AddNewHonomer()
{
    Map? map = Game.GetMap(Content::Map::sf_hubb);
    mpos hex;
    if (map != null && Entrance::GetNearEntry(map, ENTRY_HONOMER, hex)) {
        Critter[] critters = map.GetCritters(Content::Critter::ElronologistFemale, CritterFindType::Npc);
        for (int i = 0; i < critters.length(); i++) {
            if (critters[i].DialogId == Content::Dialog::sf_honomer) {
                return;
            }
        }

        int[] props = {CritterProperty::DialogId, Content::Dialog::sf_honomer.hash};
        Critter npc = map.AddCritter(Content::Critter::ElronologistFemale, hex, HDIR_Random, Tla::GetCritPropsDict(props));
        npc.SetupScript(HonomerInit);
    }
}

// Инициализация проводника: подписка на нужные события и запуск idle-таймера,
// который удерживает дом криттера на текущей карте.
void HonomerInit(Critter cr, bool firstTime)
{
    cr.OnGlobalMapProcess.Subscribe(HonomerGlobalProcess);
    cr.OnFinish.Subscribe(HonomerFinish);
    cr.OnDead.Subscribe(HonomerDead);
    cr.StartTimeEvent(Time::Asap(), Time::Seconds(1), HonomerIdle);
    cr.OnMessage.Subscribe(HonomerMessage);
    cr.OnNpcPlaneEnd.Subscribe(HonomerPlaneEnd);
}

[[Event]]
void HonomerMessage(Critter cr, Critter fromCr, int message, any value)
{
    if (value == 2 || value == 4) {
        NpcDialog::NpcMessageImpl(cr, fromCr, message, value);
    }
}

// По завершении плана НПЦ в лаборатории ведём Хономера: у двери — открыть её и
// перенацелить дом на место ремонта; у места ремонта — начать диалог или анимировать
// использование (имитация починки).
[[Event]]
EventResult HonomerPlaneEnd(Critter cr, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(cr, planeId);

    if (NpcPlanes::IsNoPlanes(cr) && HonomerInLabImpl(cr, cr)) {
        mpos hex;
        Map? map = cr.GetMap();
        if (map != null && Entrance::MapGetEntryCoords(map, ENTRY_DOOR_NEAR, 0, hex)) {
            if (hex == cr.Hex) {
                // Хономер стоит перед дверью
                // Открываем дверь и даем план на продвижение к компу
                Entrance::MapGetEntryCoords(map, ENTRY_DOOR, 0, hex);
                Item? door = map.GetItemOnHex(hex, Content::Item::door_2019);
                if (door != null) {
                    Lockers::SwitchLocker(door, true);
                    Game.StartTimeEvent(Time::Seconds(1), Item::AutoCloseDoor, door.Id); // SavedDeferredCall
                }

                if (Entrance::MapGetEntryCoords(map, ENTRY_REPAIR, 0, hex)) {
                    cr.HomeMapId = map.Id;
                    cr.HomeHex = hex;
                    cr.HomeDir = 0;
                }

                return EventResult::StopChain;
            }
        }

        if (map != null && Entrance::MapGetEntryCoords(map, ENTRY_REPAIR, 0, hex)) {
            if (plane == null || plane.Type != NpcPlanes::AI_PLANE_MISC) {
                if (hex == cr.Hex) {
                    NpcDialog::BeginDialog(cr, 4);
                }
            }
            else {
                if (Game.Random(1, 3) == 1) {
                    AnimHelpers::AnimateCritterUse(cr);
                }
            }
        }
    }

    return EventResult::StopChain;
}

[[Event]]
void HonomerDead(Critter cr, Critter killer)
{
    HonomerIdleImpl(cr);
}

// Сопровождение игрока по глобальной карте: если игрок покинул группу — убираем НПЦ;
// иначе ведём проводника к локации лаборатории и по прибытии переносим внутрь,
// засчитываем шаг квеста и опыт, запускаем диалог охранника.
[[Event]]
EventResult HonomerGlobalProcess(Critter cr, int type, Item car, float x, float y, float toX, float toY, float speed, int encounterDescriptor,
                                 bool waitForAnswer)
{
    if (type != Tla::GlobalProcessStartFast && type != Tla::GlobalProcessStart) {
        bool ok = false;
        Critter[] group = GlobalmapGroupExtended::GetGlobalGroup(cr);
        // Проверка что игрок в группе с нпц
        Critter? player = Game.GetCritter(cr.SFHonomerPlayerId);
        if (player != null) {
            for (int i = 0, l = group.length(); i < l; i++) {
                if (group[i].Id == player.Id) {
                    ok = true;
                    break;
                }
            }
        }

        if (!ok) {
            // Нет игрока в группе
            Game.DestroyCritter(cr);
            return EventResult::StopChain;
        }
    }

    if (type != Tla::GlobalProcessMove) {
        if (cr.SFEscortLocation != ZERO_IDENT) {
            Location? loc = Game.GetLocation(cr.SFEscortLocation);
            if (loc != null) {
                if (loc.WorldPos.x == int(x) && loc.WorldPos.y == int(y)) {
                    Map map = loc.GetMapByIndex(1);
                    Entrance::CritterTransferToMapEntry(cr, map.Id, ENTRY_LAB_ENTER);
                    loc.AutoGarbage = true;
                    cr.StartTimeEvent(Time::Asap(), Time::Seconds(1), HonomerIdle);
                    if (cr.SFHonomerPlayerId != ZERO_IDENT) {
                        Critter? player = Game.GetCritter(cr.SFHonomerPlayerId);
                        if (player != null && player.SFAhs7Escort == 2) {
                            player.SFAhs7Escort = 3;
                            player.Experience += 1000;
                        }
                    }

                    NpcDialog::BeginDialog(cr, DIALOG_GUARD);
                }
                else {
                    speed = Tla::GLOBAL_MAP_BASE_SPEED;
                    toX = loc.WorldPos.x;
                    toY = loc.WorldPos.y;
                }

                return EventResult::StopChain;
            }
        }

        // не найдена локация или переменная
        // такого произойти не может, но на всякий случай...
        Game.DestroyCritter(cr);
        return EventResult::StopChain;
    }

    return EventResult::StopChain;
}

// Привязываем дом криттера к текущей карте, чтобы НПЦ не пытался уйти на прежнюю.
void HonomerIdleImpl(Critter cr)
{
    Map? map = cr.GetMap();
    if (map != null && map.Id != cr.HomeMapId) {
        cr.HomeMapId = map.Id;
        cr.HomeHex = cr.Hex;
        cr.HomeDir = 0;
    }
}

[[TimeEvent]] [[Async]]
void HonomerIdle(Critter cr, TimeEventContext event)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    HonomerIdleImpl(cr);
    event.Stop();
}

// Когда текущий проводник выгружается, восстанавливаем его на стартовой карте.
[[Event]]
void HonomerFinish(Critter cr)
{
    AddNewHonomer();
}

// НПЦ находится внутри локации лаборатории хабологов.
bool HonomerInLabImpl(Critter player, Critter npc)
{
    Map? map = npc.GetMap();
    return (map != null && (map.GetLocation().ProtoId == Content::Location::hubologists_lab));
}

[[DialogDemand]]
bool HonomerInLab(Critter player, Critter npc)
{
    return HonomerInLabImpl(player, npc);
}

[[DialogDemand]]
bool NotHonomerInLab(Critter player, Critter npc)
{
    return !HonomerInLabImpl(player, npc);
}

// НПЦ закреплён за этим игроком как проводник.
bool IsMyFollowerImpl(Critter player, Critter? npc)
{
    return npc != null && npc.SFHonomerPlayerId == player.Id;
}

[[DialogDemand]]
bool IsMyFollower(Critter player, Critter npc)
{
    return IsMyFollowerImpl(player, npc);
}

[[DialogDemand]]
bool NotMyFollower(Critter player, Critter npc)
{
    return !IsMyFollowerImpl(player, npc);
}

// Закрепляем проводника за игроком; через игровой день привязка сбрасывается.
[[DialogResult]]
void SetFollower(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    npc.SFHonomerPlayerId = player.Id;
    // Через игровой день сбрасываем Id
    if (npc.CountTimeEvent(ClearFollower) > 0) {
        npc.StopTimeEvent(ClearFollower);
    }

    npc.StartTimeEvent(Time::GameDays(1), ClearFollower, 0);
}

[[TimeEvent]] [[Async]]
void ClearFollower(Critter cr, any rate)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    cr.SFHonomerPlayerId = ZERO_IDENT;
    return;
}

// Старт сопровождения: создаём (или переиспользуем) скрытую локацию лаборатории,
// запоминаем её на игроке и НПЦ и выводим обоих на глобальную карту одной группой.
[[DialogResult]]
void Travel(Critter player, Critter npc)
{
    Location? locHandle;
    if (player.SFEscortLocation != ZERO_IDENT) {
        locHandle = Game.GetLocation(player.SFEscortLocation);
    }

    if (locHandle == null) {
        Location loc = Location::CreateLocation(Content::Location::hubologists_lab, ipos(LAB_WORLD_X, LAB_WORLD_Y), null);

        loc.Hidden = true;
        loc.AutoGarbage = false;
        locHandle = loc;
    }

    if (locHandle == null) {
        return;
    }

    Location loc = locHandle;
    npc.SFEscortLocation = loc.Id;
    player.SFEscortLocation = loc.Id;

    Critter[] grp = {};
    grp.insertLast(npc);
    grp.insertLast(player);
    npc.TransferToGlobalWithGroup(grp);
}

// Поднимаем тревогу по всей локации: все локальные НПЦ на всех картах берут цель
// во враги и получают план на атаку.
void AttackPlayer(Critter target)
{
    Map? map = target.GetMap();
    if (map == null) {
        return;
    }

    Location loc = map.GetLocation();
    int maps = loc.GetMapCount();
    for (int i = 0; i < maps; i++) {
        Map currentMap = loc.GetMapByIndex(i);
        Critter[] critters = currentMap.GetCritters(CritterFindType::Npc);
        for (int j = 0; j < critters.length(); j++) {
            Critter cr = critters[j];
            if (NpcRevenge::IsLocalNpc(cr, currentMap) && !EnemyStack::CheckEnemyInStack(cr, target.Id)) {
                EnemyStack::AddEnemyToStack(cr, target.Id);
                NpcPlanes::AddAttackPlane(cr, 0, target);
            }
        }
    }
}

// Охранник лабы
void DoorGuardInit(Critter cr, bool firstTime)
{
    cr.OnMessage.Subscribe(DoorGuardMessage);
    cr.OnAttacked.Subscribe(HubAttacked);
    cr.NpcRole = ROLE_GUARD;
}

[[Event]]
EventResult HubAttacked(Critter cr, Critter attacker)
{
    AttackPlayer(cr);
    return EventResult::StopChain;
}

// По завершении диалога с охранником сдвигаем дом собеседника к гексу перед дверью.
[[Event]]
void DoorGuardMessage(Critter cr, Critter fromCr, int message, any value)
{
    if (value == 2) {
        NpcDialog::NpcMessageImpl(cr, fromCr, message, value);
    }

    if (message == MSG_DIALOG_END && value == 2) {
        mpos hex;
        if (Entrance::MapGetEntryCoords(cr.GetMap(), ENTRY_DOOR_NEAR, 0, hex) && hex != fromCr.HomeHex) {
            fromCr.HomeHex = hex;
        }
    }
}

// Дверь
void DoorInit(Item item, bool firstTime)
{
    item.OnCritterUseSkill.Subscribe(DoorSkill);
}

// Игрок не в стелсе не может взломать дверь штатным применением навыка.
[[Event]]
EventResult DoorSkill(Item item, Critter cr, CritterProperty skill)
{
    if (cr.ControlledByPlayer && !cr.InSneakMode) {
        return (Item::GuardedItemSkillImpl(item, cr, skill)) ? EventResult::StopChain : EventResult::ContinueChain;
    }

    return EventResult::StopChain;
}

// Лаборанты
void HubInit(Critter cr, bool firstTime)
{
    if (cr.NpcRole == ROLE_START_DIALOG) {
        cr.OnMessage.Subscribe(HubMessage);
    }

    cr.OnAttacked.Subscribe(HubAttacked);
}

[[Event]]
void HubMessage(Critter cr, Critter fromCr, int message, any value)
{
    if (value == 3) {
        NpcDialog::NpcMessageImpl(cr, fromCr, message, value);
    }
}

// Начало диалога между хабологами, когда игрок наступит на триггер
[[ItemTrigger]]
void NpcDialog(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    Map? map = player.GetMap();
    if (map == null) {
        return;
    }

    Critter? cr = map.GetCritter(CritterProperty::NpcRole, ROLE_START_DIALOG, CritterFindType::NonDeadNpc);
    if (cr != null && not cr.QHubLabIsDialogRun && NpcPlanes::IsNoPlanes(cr)) {
        cr.QHubLabIsDialogRun = true;
        NpcDialog::BeginDialog(cr, 3);
    }
}

// Автоматическое закрытие двери, если Хономер вышел
[[ItemTrigger]]
void CloseDoor(Critter cr, StaticItem trigger, bool entered, mdir dir)
{
    if (!cr.ControlledByPlayer && cr.DialogId == Content::Dialog::sf_honomer) {
        Map? map = cr.GetMap();
        if (map == null) {
            return;
        }

        if (!map.SFLabHonomerInside) {
            map.SFLabHonomerInside = true;
            mpos hex;
            if (Entrance::MapGetEntryCoords(map, ENTRY_DOOR, 0, hex)) {
                Item? door = map.GetItemOnHex(hex, Content::Item::door_2019);
                if (door != null) {
                    Lockers::SwitchLocker(door, false);
                }
            }
        }
    }

    // TODO: сделать открытие двери, если игрок наступил на триггер, дверь закрыта, и игрок в робе
}

// Если игрок не в робе наступил на триггер, будет атакован
[[ItemTrigger]]
void Attack(Critter cr, StaticItem trigger, bool entered, mdir dir)
{
    if (cr.InSneakMode) {
        return;
    }

    hstring pid;
    Item? item = Tla::GetCritterArmorItem(cr);
    if (item != null) {
        pid = item.ProtoId;
    }

    if (cr.ControlledByPlayer && pid != Content::Item::purple_robe && pid != Content::Item::keepbrige_robe && pid != Content::Item::black_robe) {
        Map? map = cr.GetMap();
        if (map != null && cr.SFLabFailed == 0) {
            AttackPlayer(cr);
            Critter[] critters = map.GetCrittersInRadius(trigger.Hex, map.Size.width, CritterFindType::NonDeadNpc);
            if (!critters.isEmpty()) {
                Messaging::SayShout(critters[0], TextPackKey(TextPackName::Text, "" + (AlarmTextId)));
            }
        }
    }
}

// Игрок одет в одну из роб хабологов (пропуск-маскировка для лаборатории).
bool InRobeImpl(Critter cr, Critter npc)
{
    hstring pid;
    Item? item = Tla::GetCritterArmorItem(cr);
    if (item != null) {
        pid = item.ProtoId;
    }

    return (pid == Content::Item::purple_robe || pid == Content::Item::keepbrige_robe || pid == Content::Item::black_robe);
}

[[DialogDemand]]
bool InRobe(Critter cr, Critter npc)
{
    return InRobeImpl(cr, npc);
}

[[DialogDemand]]
bool NotRobe(Critter player, Critter npc)
{
    return !InRobeImpl(player, npc);
}

// Показываем игроку кат-сцену "ада" через камеру на отдельной карте.
[[DialogResult]]
void ShowHell(Critter player, Critter npc)
{
    Map? map = Game.GetMap(Content::Map::repl_hell);
    if (map != null) {
        mpos hex;
        if (Entrance::MapGetEntryCoords(map, ENTRY_HELL, 0, hex)) {
            player.ViewMap(map, 50, hex, 5);
        }
    }
}

#endif

