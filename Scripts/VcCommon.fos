#if SERVER

///@ Property Critter Common uint8 VCAmandaHelpJoshua Mutable OwnerSync Persistent Group = Quests Quest = 8836 Max = 9
///@ Property Critter Server uint8 VCMailRemembered Mutable Persistent Max = 1
///@ Property Critter Server uint8 VCBeautyHoloRemembered Mutable Persistent Max = 1
///@ Property Critter Server synctime VCityCommonBarkusTimeSay Mutable Persistent

///@ Property Item Server bool VCityCommonIsMail Mutable Persistent
///@ Property Item Server ident VCityCommonMailOwnerId Mutable Persistent

///@ Property Map Server synctime VCLastBarDialog Mutable Persistent

// Квест "Семья". Вэлери
const int STR_LOW_SPEECH = 5800;   // Строка при чтении письма - низкая речь.
const int STR_HIGH_SPEECH = 5801;  // Строка при чтении письма - высокая речь.
const int STR_HIGH_SPEECH2 = 5802; // Чтобы сократить объем текста - выводим за два приема.
const int MIN_SPEECH = 100;        // Минимальная речь для того, чтобы прочесть письмо.

[[DialogResult]]
void GiveMail(Critter cr, Critter npc)
{
    Item item = cr.AddItem(Content::Item::postman_letter, 1);
    item.TextArgs = "|reciever:" + MsgStr::NpcNameTag(Content::Dialog::klam_vic) + "|location:" + MsgStr::LocNameTag(Content::Location::klamath);
    item.SetupScript(ValeryMailInit);
    item.VCityCommonIsMail = true;
    item.VCityCommonMailOwnerId = cr.Id;
}

void ValeryMailInit(Item item, bool firstTime)
{
    item.OnCritterUse.Subscribe(MailUse);
}

[[Event]]
EventResult MailUse(Item item, Critter cr, int param)
{
    if (cr.Id != item.VCityCommonMailOwnerId) {
        return EventResult::StopChain;
    }

    if (cr.SkillSpeech < MIN_SPEECH) {
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_LOW_SPEECH)));
    }
    else {
        if (cr.VCMailRemembered == 0) {
            cr.VCMailRemembered = 1;
            cr.Experience += 500;
        }

        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_HIGH_SPEECH)));
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_HIGH_SPEECH2)));
    }

    return EventResult::StopChain;
}

bool HasMailImpl(Critter cr, Critter npc)
{
    Item[] items = cr.GetItems();
    for (int i = 0; i < items.length(); i++) {
        if (items[i].ProtoId == Content::Item::postman_letter && items[i].VCityCommonIsMail) {
            return true;
        }
    }

    return false;
}

[[DialogDemand]]
bool HasMail(Critter cr, Critter npc)
{
    return HasMailImpl(cr, npc);
}

[[DialogDemand]]
bool NoMail(Critter cr, Critter npc)
{
    return (!HasMailImpl(cr, npc));
}

// Квест, "Свет мой, Зеркальце". ГУ, Хелен Трой
const int HOLO_MSG_ID = 55;
const int STR_LOW_SCIENCE = 5805;
const int STR_HIGH_SCIENCE = 5806;
const int MIN_SCIENCE = 100;
const int MIN_DOCTOR = 80;

[[DialogResult]]
void WriteHolodisk(Critter player, Critter npc, any val)
{
    if (player.CountItem(Content::Item::holodisk) == 0) {
        return;
    }

    player.DestroyItem(Content::Item::holodisk, 1);
    Item holo = player.AddItem(Content::Item::holodisk, 1);
    holo.SetupScript(HoloInit);
}

void HoloInit(Item holo, bool firstTime)
{
    holo.HolodiskNum = HOLO_MSG_ID;
    holo.OnCritterUse.Subscribe(HoloUse);
    holo.OnCritterUseSkill.Subscribe(HoloSkill);
}

[[Event]]
EventResult HoloSkill(Item item, Critter cr, CritterProperty skill)
{
    return EventResult::StopChain;
}

[[Event]]
EventResult HoloUse(Item item, Critter cr, int param)
{
    if (cr.Gender == 0) {
        return EventResult::StopChain;
    }

    if (cr.SkillScience >= MIN_SCIENCE && cr.SkillDoctor >= MIN_DOCTOR) {
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_HIGH_SCIENCE)));
        if (cr.VCBeautyHoloRemembered == 0) {
            cr.VCBeautyHoloRemembered = 1;
        }
    }
    else {
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_LOW_SCIENCE)));
    }

    return EventResult::StopChain;
}

// Клиника для доктора Блэка.

[[DialogResult]]
void CancelDoctorMerc(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    Merc::CancelMerc(npc);
    npc.SetupScript(MapGeckCity::GeckTraderInit);
}

bool CheckIsBlackHere(Critter player, Critter? npc)
{
    if (npc == null) {
        return false;
    }

    Map? map = npc.GetMap();
    if (map == null) {
        return false;
    }

    return !map.GetCritters(Content::Item::vic_water_flask, CritterFindType::NonDeadNpc).isEmpty();
}

bool CheckNotBlackHere(Critter player, Critter npc)
{
    return (!CheckIsBlackHere(player, npc));
}

// Проказник Баркус
const int STR_BARKUS_MALE = 1;
const int STR_BARKUS_FEMALE = 2;
void BarkusInit(Critter cr, bool firstTime)
{
    cr.ShowCritterDist1 = 8;
    cr.OnCritterAppearedDist1.Subscribe(BarkusShowCr);
}

[[Event]]
void BarkusShowCr(Critter cr, Critter showCrit)
{
    if (cr.VCityCommonBarkusTimeSay < Game.SynchronizedTime && showCrit.ControlledByPlayer && showCrit.IsAlive()) {
        if (showCrit.VCAmandaHelpJoshua >= 7) {
            Messaging::Say(cr, MsgStr::DialogTextKey(cr.DialogId, (cr.Gender == 0 ? STR_BARKUS_MALE : STR_BARKUS_FEMALE)));
            cr.VCityCommonBarkusTimeSay = Game.SynchronizedTime + Time::Seconds(30); // Не чаще двух раз в минуту
        }
    }
}

// Диалог посетителей бара у стойки
const int ROLE_BAR_TALKER = 56; // Роль говорунов

void BarTalkerInit(Critter cr, bool firstTime)
{
    cr.NpcDialogTimeWait = 4;
    cr.OnMessage.Subscribe(NpcDialog::NpcMessage);
}

[[ItemTrigger]]
void RunNpcDialog(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    if (!entered || !player.ControlledByPlayer) {
        return;
    }

    Map? map = player.GetMap();
    if (map == null) {
        return;
    }

    if (Game.SynchronizedTime >= map.VCLastBarDialog) {
        map.VCLastBarDialog = Game.SynchronizedTime + Time::Minutes(30);
        Critter? cr = map.GetCritter(CritterProperty::NpcRole, ROLE_BAR_TALKER, CritterFindType::NonDeadNpc);
        if (cr != null) {
            NpcDialog::BeginDialog(cr, 5);
        }
    }
}

#endif

}
