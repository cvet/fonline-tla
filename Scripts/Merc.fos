// Хозяин мерка
Critter? GetMaster(Critter merc)
{
    return Game.GetCritter(merc.MercMasterId);
}

// Признак, является ли криттер чьим-то мерком
bool IsMerc(Critter merc)
{
    return merc.MercMasterId != ZERO_IDENT;
}

/* **************************************** DEBUG *************************************** */
void Merc(Critter cr, any mercId, any ld)
{
    Critter? merc = Game.GetCritter(mercId);
    Merc2Player(cr, merc);
}

void MercParam(Critter cr, any mercId, any param, any value)
{
    Critter? merc = Game.GetCritter(mercId);
    if (merc == null) {
        return;
    }

    merc.SetAsInt(CritterProperty(int(param)), value);
}

// Функции для использования в диалогах
// **************************************** Функции - условия **************************************/
// НПЦ является чьим-то мерком
bool NpcIsMercImpl(Critter player, Critter? npc)
{
    if (npc == null) {
        return false;
    }

    return IsMerc(npc);
}

[[DialogDemand]]
bool NpcIsMerc(Critter player, Critter npc)
{
    return NpcIsMercImpl(player, npc);
}

// НПЦ не является чьим-то мерком
[[DialogDemand]]
bool NpcIsNotMerc(Critter player, Critter npc)
{
    return !NpcIsMercImpl(player, npc);
}

// НПЦ - мерк данного игрока
bool NpcIsPlayerMercImpl(Critter player, Critter? npc)
{
    if (npc == null) {
        return false;
    }

    if (!IsMerc(npc)) {
        return false;
    }

    return npc.MercMasterId == player.Id;
}

[[DialogDemand]]
bool NpcIsPlayerMerc(Critter player, Critter npc)
{
    return NpcIsPlayerMercImpl(player, npc);
}

// НПЦ - не мерк данного игрока
[[DialogDemand]]
bool NpcIsNotPlayerMerc(Critter player, Critter npc)
{
    return !NpcIsPlayerMercImpl(player, npc);
}

// Проверка какого-то из параметров мерка
// param - номер параметра (см. MERC_... параметры в _defines.fos)
// value - проверяемое значение.
// true - значение параметра мерка равно указанному значению
// false - npc не мерк, или значение параметра не равно указанному значению
bool CheckMercParamIsValueImpl(Critter player, Critter? npc, int param, int value)
{
    if (npc == null) {
        return false;
    }

    if (!IsMerc(npc)) {
        return false;
    }

    return npc.GetAsInt(CritterProperty(param)) == value;
}

[[DialogDemand]]
bool CheckMercParamIsValue(Critter player, Critter npc, any param, any value)
{
    return CheckMercParamIsValueImpl(player, npc, param, value);
}

// инверсия проверки CheckMercParamIsValue
[[DialogDemand]]
bool CheckMercParamIsNotValue(Critter player, Critter npc, any param, any value)
{
    return !CheckMercParamIsValueImpl(player, npc, param, value);
}

// Проверка: У лидера группы, в которой находится игрок, достаточно харизмы для найма ОДНОГО нпц
bool CharismaOkImpl(Critter player, Critter npc)
{
    Critter? leader = GlobalmapGroupExtended::GetFollowLeader(player);
    if (leader == null) {
        Critter[] grp;
        int grLen = GlobalmapGroupExtended::GetFollowGroup(player, CritterFindType::Any, grp);
        return (grLen < player.Charisma);
    }

    Critter[] grp;
    int grLen = GlobalmapGroupExtended::GetFollowGroup(leader, CritterFindType::Any, grp);
    return (grLen < leader.Charisma);
}

[[DialogDemand]]
bool CharismaOk(Critter player, Critter npc)
{
    return CharismaOkImpl(player, npc);
}

[[DialogDemand]]
bool NotCharismaOk(Critter player, Critter npc)
{
    return (!CharismaOkImpl(player, npc));
}

// Проверка, что мерк с Id, сохраненным в переменной находится неподалеку
bool CheckMercNearImpl(Critter player, Critter npc, int varNum, int radius)
{
    if (varNum == 0) {
        return false;
    }

    ident id = player.GetAsAny(CritterProperty(varNum));
    if (id == ZERO_IDENT) {
        return false;
    }

    Critter? merc = Game.GetCritter(id);
    if (merc == null) {
        return false;
    }

    if (merc.MercMasterId != player.Id) {
        return false;
    }

    Map? masterMap = player.GetMap();
    Map? mercMap = merc.GetMap();
    if (mercMap == null || masterMap == null) {
        return false;
    }

    if (mercMap.Id != masterMap.Id) {
        return false;
    }

    return Game.GetDistance(merc, player) <= int(radius);
}

[[DialogDemand]]
bool CheckMercNear(Critter player, Critter npc, any varNum, any radius)
{
    return CheckMercNearImpl(player, npc, varNum, radius);
}

[[DialogDemand]]
bool NotMercNear(Critter player, Critter npc, any varNum, any radius)
{
    return !CheckMercNearImpl(player, npc, varNum, radius);
}

// **************************************** Функции - результаты **************************************/
// Добавление мерка игроку
// производится добавление стандартного спутника (см. таблицу _mercInfo)
// Добавление производится только для нпц, который не является чьим то мерком
[[DialogResult]]
void AddMerc2Player(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    if (IsMerc(npc)) {
        return;
    }

    Merc2Player(player, npc);
}

[[DialogResult]]
void AddMerc2Player(Critter player, Critter? npc, any type)
{
    if (npc == null) {
        return;
    }

    if (IsMerc(npc)) {
        return;
    }

    Merc2Player(player, npc, type);
}

// Отмена мерка у игрока, мерк необязательно является мерком именно этого игрока
[[DialogResult]]
void CancelMerc(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    if (!IsMerc(npc)) {
        return;
    }

    CancelMerc(npc);
}

// Отмена мерка данного игрока. Если нпц - чужой мерк, отмены не будет
void CancelPlayerMerc(Critter player, Critter? npc)
{
    if (npc == null) {
        return;
    }

    if (!IsMerc(npc)) {
        return;
    }

    if (npc.MercMasterId != player.Id) {
        return;
    }

    CancelMerc(npc);
}

// Установка параметров мерка
// сработает только, если нпц является чьим-то мерком
// param - номер параметра (см. MERC_... параметры в _defines.fos)
// value - значение
[[DialogResult]]
void SetMercParameter(Critter player, Critter? npc, any param, any value)
{
    if (npc == null) {
        return;
    }

    if (!IsMerc(npc)) {
        return;
    }

    npc.SetAsInt(CritterProperty(param), value);
}

// Специальный метод для сохранения Id мерка в переменную
[[DialogResult]]
void SaveMercId(Critter player, Critter? npc, any varNum)
{
    if (npc == null) {
        return;
    }

    player.SetAsAny(CritterProperty(varNum), npc.Id);
}

// Отмена мерка через Id, в переменной
[[DialogResult]]
void CancelMerc(Critter player, Critter npc, any varNum)
{
    Critter? merc = Game.GetCritter(player.GetAsAny(CritterProperty(varNum)));
    if (merc != null) {
        CancelMerc(merc);
    }
}

[[DialogResult]]
void WaitMaster(Critter player, Critter? npc)
{
    Map? map = player.GetMap();
    if (map == null || npc == null) {
        return;
    }

    Location loc = map.GetLocation();
    if (loc.AutoGarbage == true) {
        Location::SetKnownLoc(player, loc);
    }

    npc.MercWaitForMaster = true;
}

[[DialogResult]]
void FollowMaster(Critter player, Critter? npc)
{
    if (npc != null) {
        npc.MercWaitForMaster = false;
    }
}

// Функции-диалоги
// Имя хозяина
void Master(Critter player, Critter? npc, string& masterName)
{
    if (!Tla::IsDialogGenerated(masterName) || npc == null) {
        return;
    }

    masterName = "|mastername:";
    masterName += PlayerRegistration::GetPlayerName(npc.MercMasterId);
}

#endif

}
