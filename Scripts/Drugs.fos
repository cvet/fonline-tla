// Drugs — система препаратов и химии (порт системы Fallout 2).
// SERVER: применение наркотиков, стадии эффект/ломка/привыкание, тайм-евенты, привязки. CLIENT/SERVER: чтение DrugEffects.
// Связи: Poison, Radiation, Messaging, CritterState, Flags, MsgStr, Addictions, Content.
namespace Drugs
{

const int STR_DOUGHNUTS_BUFF = 70061;

///@ Property Critter Common CritterProperty=>int32 DrugEffects Mutable OwnerSync Persistent
///@ Property Critter Common uint8 DoughnutsCounter Mutable OwnerSync Persistent Max = 20

int PoundsToGrams(int lbs)
{
    return (lbs) * 453;
}

#if SERVER

// Флаги-модификаторы эффекта от черт криттера (Fallout 2 traits):
// Chem Reliant — плюс: быстрее отходит от побочек химии; минус: вдвое выше шанс привыкания.
// Chem Resistant — плюс: на 50% меньше шанс привыкания; минус: на 50% короче действие химии.
const int DRUG_EFFECT_DIV2_WITHDRAWAL = 1;
const int DRUG_EFFECT_MUL2_ADDICTION = 2;
const int DRUG_EFFECT_DIV2_ADDICTION = 4;
const int DRUG_EFFECT_DIV2_DURATION = 8;

// Упаковка стадии и флагов в одно число rate: младшие 24 бита — стадия, старший байт — флаги.
int RateToStage(int rate)
{
    return (rate) & 0xFFFFFF;
}

int RateToFlags(int rate)
{
    return (rate) >> 24;
}

int BuildRate(int stage, int flags)
{
    return (((flags) & 0xFF) << 24) | ((stage) & 0xFFFFFF);
}

