{
    {
        {
            // Data[ 6 ]  -  additional pic offset
            // Data[ 7 - 8 ]  -  additional pic point
            Elevator elevator = cast<Elevator>(GuiScreensExt::NeedScreen(Screen));
            SetBackgroundImage(hstring(elevator.Data[6]));
            SetPosition(int(elevator.Data[7]), int(elevator.Data[8]));
        }
    }
}
