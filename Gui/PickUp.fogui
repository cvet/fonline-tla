{
    {
        {
            Critter chosen = Game.GetChosen();
            if (chosen is null) {
                return;
            }
            TransferTypes transfer = chosen.TransferType;
            if (transfer == TransferTypes::CritSteal) {
                FindButton("TakeAllButton").SetActive(false);
            }
        }
    }
}
