{
    {
        ident RadioId;
    }
}
//   "OnInit": null,
//   "OnShow":
{
    {
        {
            RadioId = params["ItemId"];
            auto checkbox = cast<Gui::CheckBox>(Find("BroadcastOnOff"));
            checkbox.SetChecked(Radio::GetRadioActivity(RadioId, true));
            checkbox = cast<Gui::CheckBox>(Find("ReceiveOnOff"));
            checkbox.SetChecked(Radio::GetRadioActivity(RadioId, false));
            Item item = Radio::GetItemRadio(RadioId);

            if (item == null) {
                Gui::HideScreen();
                return;
            }

            auto channelTextBox = cast<ChannelNumber>(Find("ChannelNumber"));
            channelTextBox.SetChannel(item.Radio.Channel);

            int broadcast = 0;
            if (item.Radio.Broadcast == RadioBroadcastType::Zone) {
                broadcast = (item.Radio.BroadcastZones == Settings.RadioBroadcastZones1 ? 1 : 2);
            }
            else if (item.Radio.Broadcast == RadioBroadcastType::Location) {
                broadcast = 3;
            }
            else if (item.Radio.Broadcast == RadioBroadcastType::Map) {
                broadcast = 4;
            }

            auto switcher = cast<SwitchBroadcast>(Find("SwitchBroadcast"));
            switcher.BroadCastType = broadcast;
            switcher.SetBackgroundImage("art/intrface/Radio/radio_dial" + broadcast + ".png");
        }
    }
}
