// EncounterItems — генерация лута на энкаунтерах. Ключевые обязанности: таблица предметов
// (прототип, тип энка, кол-во, шанс, гекс), определение типа энкаунтера по локации/карте,
// выбор гексов и спавн предметов или закладка в контейнеры. Сторона: SERVER.
// Связи: Entrance, PidsGroups, Tla, Math.
namespace EncounterItems
{

#if SERVER

/* На энкаунтере есть по 5-10 гексов респауна итемов.
   Т.е., если взять шанс выпадения в 70%, то на энкаунтере будет
   по 3-7 предметов в среднем. Гексов специально выставлено больше,
   чтобы предметы каждый раз спавнились в новом месте. */

const int ETYPE_ANY = 0;       // Может встретиться везде
const int ETYPE_MOUNTAINS = 1; // Горы
const int ETYPE_DESERT = 2;    // Пустыня
const int ETYPE_CAVERN = 3;    // Пещеры
const int ETYPE_CITY = 4;      // Город
const int ETYPE_COAST = 5;     // Берег
const int ETYPE_OCEAN = 6;     // Океан
const int ETYPE_DEFAULT = 7;   // Не используется

const int ENT_NAT = 11;   // Природные ресурсы
const int ENT_TRASH = 12; // Хлам
const int ENT_RES = 13;   // Ресурсы для крафта
const int ENT_CONT1 = 14; // Контейтер уровень 1
const int ENT_CONT2 = 15; // Контейнер уровень 2

// Таблица гексов
const int[] gex_table = {ENT_NAT, ENT_TRASH, ENT_RES, ENT_CONT1, ENT_CONT2};

