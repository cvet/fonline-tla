namespace PlayerRegistration
{

///@ Property Game Common CritterProperty[] RegProperties Mutable OwnerSync Persistent
///@ Property Critter Common bool IsGenerated Mutable OwnerSync Persistent
///@ RemoteCall Server LoginExistingPlayer(string name)
///@ RemoteCall Server RegisterNewPlayer(string name, CritterProperty=>int32 props)

#if SERVER

const hstring PlayerNamesCollectionName = "PlayerNames".hstr();

Player GetPlayerByName(string playerName)
{
    ident playerId = ResolvePlayerIdByName(playerName);
    return playerId != ZERO_IDENT ? Game.GetPlayer(playerId) : null;
}

ident ResolvePlayerIdByName(string playerName)
{
    if (!Game.DbHasRecord(PlayerNamesCollectionName, playerName)) {
        return ZERO_IDENT;
    }
    dict<string, string> linkEntry = Game.DbGetRecord(PlayerNamesCollectionName, playerName);
    if (!linkEntry.exists("PlayerId")) {
        return ZERO_IDENT;
    }
    ident playerId = ZERO_IDENT;
    playerId.value = linkEntry["PlayerId"].toInt64();
    return playerId;
}

void UpsertPlayerName(string playerName, ident playerId)
{
    Game.DbSetRecord(PlayerNamesCollectionName, playerName, {{"PlayerId", "" + playerId.value}});
}

void ModuleInit()
{
    AddRegistrationProperty(CritterProperty::StrengthBase);
    AddRegistrationProperty(CritterProperty::PerceptionBase);
    AddRegistrationProperty(CritterProperty::EnduranceBase);
    AddRegistrationProperty(CritterProperty::CharismaBase);
    AddRegistrationProperty(CritterProperty::IntellectBase);
    AddRegistrationProperty(CritterProperty::AgilityBase);
    AddRegistrationProperty(CritterProperty::LuckBase);
    AddRegistrationProperty(CritterProperty::TagSkill1);
    AddRegistrationProperty(CritterProperty::TagSkill2);
    AddRegistrationProperty(CritterProperty::TagSkill3);
    for (int i = 0; i < CritterPropertyGroup::Traits.length(); i++) {
        AddRegistrationProperty(CritterPropertyGroup::Traits[i]);
    }
    AddRegistrationProperty(CritterProperty::Age);
    AddRegistrationProperty(CritterProperty::Gender);
}

void AddRegistrationProperty(CritterProperty prop)
{
    auto properies = Game.RegProperties;
    properies.insertLast(prop);
    Game.RegProperties = properies;
}

[[ServerRemoteCall]]
void LoginExistingPlayer(Player player, string name)
{
    ident playerId = ResolvePlayerIdByName(name);
    if (playerId == ZERO_IDENT) {
        Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (STR_NET_WRONG_LOGIN)));
        player.Disconnect();
        return;
    }

    player.SetName(name);
    Game.LoginPlayerToExistentRecord(player, playerId);
}

bool ValidateRegistrationProps(Player player, string name, dict<CritterProperty, int> props)
{
    int nameError = Parameters::CheckPlayerName(name);
    if (nameError != 0) {
        Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (nameError)));
        Game.Log("Player registration rejected due to invalid name");
        return false;
    }

    for (int i = 0; i < Game.RegProperties.length(); i++) {
        if (!props.exists(Game.RegProperties[i])) {
            Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (MsgStr::StrNetWrongSpecial)));
            Game.Log("Player registration rejected due to missing registration prop");
            return false;
        }
    }

    for (int i = 0; i < props.length(); i++) {
        if (Game.RegProperties.find(props.getKey(i)) == -1) {
            Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (MsgStr::StrNetWrongSpecial)));
            Game.Log("Player registration rejected due to unexpected registration prop");
            return false;
        }
    }

    int special = 0;
    for (int i = 0; i < CritterPropertyGroup::SpecialBase.length(); i++) {
        CritterProperty prop = CritterPropertyGroup::SpecialBase[i];
        int value = props.get(prop, 0);

        if (value < 1 || value > 10) {
            Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (MsgStr::StrNetWrongSpecial)));
            Game.Log("Player registration rejected due to invalid SPECIAL values");
            return false;
        }

        special += value;
    }

    if (special != Settings.StartSpecialPoints) {
        Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (MsgStr::StrNetWrongSpecial)));
        Game.Log("Player registration rejected due to invalid SPECIAL sum");
        return false;
    }

    if ((props.get(CritterProperty::TagSkill1, CritterProperty::None) != CritterProperty::None &&
         CritterPropertyGroup::Skills.find(CritterProperty(props.get(CritterProperty::TagSkill1, CritterProperty::None))) == -1) ||
        (props.get(CritterProperty::TagSkill2, CritterProperty::None) != CritterProperty::None &&
         CritterPropertyGroup::Skills.find(CritterProperty(props.get(CritterProperty::TagSkill2, CritterProperty::None))) == -1) ||
        (props.get(CritterProperty::TagSkill3, CritterProperty::None) != CritterProperty::None &&
         CritterPropertyGroup::Skills.find(CritterProperty(props.get(CritterProperty::TagSkill3, CritterProperty::None))) == -1)) {
        Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (MsgStr::StrNetWrongTagskill)));
        Game.Log("Player registration rejected due to invalid tag skills");
        return false;
    }

    return true;
}

[[ServerRemoteCall]]
void RegisterNewPlayer(Player player, string name, dict<CritterProperty, int> props)
{
    if (!ValidateRegistrationProps(player, name, props)) {
        player.Disconnect();
        return;
    }

    if (ResolvePlayerIdByName(name) != ZERO_IDENT) {
        Messaging::Info(player, TextPackKey(TextPackName::Game, "" + (STR_NET_ACCOUNT_ALREADY)));
        player.Disconnect();
        return;
    }

    dict<CritterProperty, any> critterProps = {};
    for (int i = 0; i < props.length(); i++) {
        critterProps[props.getKey(i)] = any(props.getValue(i));
    }

    player.SetName(name);
    Critter cr = Game.CreateCritter(Content::Critter::Player, true, critterProps);
    Player loginedPlayer = Game.LoginPlayerToNewRecord(player);

    if (loginedPlayer != null) {
        UpsertPlayerName(name, loginedPlayer.Id);
        loginedPlayer.MainCritterId = cr.Id;
        loginedPlayer.SwitchCritter(cr);
        loginedPlayer.DisplayName = loginedPlayer.Name;
        cr.DisplayName = loginedPlayer.DisplayName;
        cr.IsGenerated = true;
        Game.Log("Player registered and entered the game");
    }
}

string GetPlayerName(ident crId)
{
    Critter cr = Game.GetCritter(crId);
    if (cr != null && cr.ControlledByPlayer) {
        return cr.Name;
    }

    return "";
}

#endif

#if CLIENT

void ModuleInit()
{
    Game.OnConnected.Subscribe(OnConnected);
    Game.OnLoginSuccess.Subscribe(OnLoginSuccess);
    Game.OnConnectingFailed.Subscribe(OnConnectingFailed);
    Game.OnDisconnected.Subscribe(OnDisconnected);
}

dict<CritterProperty, int> RegProps = {};

void ResetRegistrationRequest()
{
    RegProps = {};
}

void CallRegisterPlayer(string name, string pass, dict<CritterProperty, int> props)
{
    // GetCacheData
    Game.SetCacheText("RegName__", name);
    Game.SetCacheText("RegPassword__", pass);
    RegProps = props.clone();
    GuiScreensExt::TryExit();

    if (!Game.IsConnected() && !Game.IsConnecting()) {
        Game.Connect();
    }
}

[[Event]]
void OnConnected()
{
    string name = Game.GetCacheText("RegName__");

    if (name == "") {
        return;
    }

    if (RegProps.length() > 0) {
        CurPlayer.ServerCall.RegisterNewPlayer(name, RegProps.clone());
    }
    else {
        CurPlayer.ServerCall.LoginExistingPlayer(name);
    }
}

[[Event]]
void OnLoginSuccess()
{
    ResetRegistrationRequest();
}

[[Event]]
void OnConnectingFailed()
{
    ResetRegistrationRequest();
}

[[Event]]
void OnDisconnected()
{
    ResetRegistrationRequest();
}

#endif

}
