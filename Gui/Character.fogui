//               "Columns": 1,
//               "Padding": "0, 0",
//               "BackgroundImage": null,
//               "BackgroundImageLayout": "None",
//               "CropContent": true,
//               "IsVerticalScroll": true,
//               "IsHorizontalScroll": false,
//               "Expanded": true,
//               "Selected": false,
//               "Active": true,
//               "Name": "PropsGrid",
//               "Position": "0, 0",
//               "Size": "282, 100",
//               "Anchor": "None",
//               "Dock": "None",
//               "IsDraggable": false,
//               "IsNotHittable": false,
//               "CheckTransparentOnHit": false,
//               "GlobalScope": null,
//               "ClassFields":
{
    {
        string[] Captions = {};
        string[] Descriptions = {};
        string[] Images = {};
        int[] HeadersIndexes = {};

        void FillGrid(int curSwitch)
        {
            Captions.clear();
            Descriptions.clear();
            Images.clear();
            HeadersIndexes.clear();
            ResizeGrid(0);
            switch (curSwitch) {
            case 0:
                FillPerks();
                break;
            case 1:
                FillKarma();
                break;
            case 2:
                FillKills();
                break;
            }
        }

        void FillKills()
        {
            int totalRows = 0;
            Critter @chosen = Game.GetChosen();
            if (chosen is null) {
                return;
            }
            int[] kills = array<int>(chosen.Kills);
            bool killsTitleAdded = false;
            for (int i = 0; i < kills.length(); i++) {
                if (kills[i] != 0) {
                    if (!killsTitleAdded) {
                        killsTitleAdded = true;
                        Captions.insertLast(MSG_GAME(MsgStr::StrKillsName));
                        Descriptions.insertLast(MSG_GAME(MsgStr::StrKillsDesc));
                        Images.insertLast(MSG_GAME(MsgStr::StrKillsSkillDex));
                        HeadersIndexes.insertLast(totalRows);
                        totalRows++;
                    }
                    string text = MSG_GAME(STR_KILL_NAME(i));
                    if (kills[i] > 1) {
                        text += " (" + kills[i] + ")";
                    }

                    Captions.insertLast(text);
                    Descriptions.insertLast(MSG_GAME(STR_KILL_DESC(i)));
                    Images.insertLast(MSG_GAME(MsgStr::StrKillsSkillDex));
                    totalRows++;
                }
            }

            ResizeGrid(totalRows);
        }

        void FillPerks()
        {
            int totalRows = 0;
            // Traits
            bool traitsTitleAdded = false;
            for (int i = 0; i < CritterPropertyGroup::Traits.length(); i++) {
                if (GetPropValue(CritterPropertyGroup::Traits[i]) != 0) {
                    if (!traitsTitleAdded) {
                        traitsTitleAdded = true;
                        Captions.insertLast(MSG_GAME(MsgStr::StrTraitsName));
                        Descriptions.insertLast(MSG_GAME(MsgStr::StrTraitsDescr));
                        Images.insertLast(MSG_GAME(MsgStr::StrTraitsSkilldex));
                        HeadersIndexes.insertLast(totalRows);
                        totalRows++;
                    }

                    Captions.insertLast(MSG_GAME(STR_PARAM_NAME(CritterPropertyGroup::Traits[i])));
                    Descriptions.insertLast(MSG_GAME(STR_PARAM_DESC(CritterPropertyGroup::Traits[i])));
                    Images.insertLast(MSG_GAME(STR_PARAM_PIC(CritterPropertyGroup::Traits[i])));
                    totalRows++;
                }
            }

            // Perks
            bool perksTitleAdded = false;
            for (int i = 0; i < CritterPropertyGroup::Perks.length(); i++) {
                int value = GetPropValue(CritterPropertyGroup::Perks[i]);
                if (value != 0) {
                    if (!perksTitleAdded) {
                        perksTitleAdded = true;
                        Captions.insertLast(MSG_GAME(MsgStr::StrPerksName));
                        Descriptions.insertLast(MSG_GAME(MsgStr::StrPerksDescr));
                        Images.insertLast(MSG_GAME(MsgStr::StrPerksSkilldex));
                        HeadersIndexes.insertLast(totalRows);
                        totalRows++;
                    }
                    string text = MSG_GAME(STR_PARAM_NAME(CritterPropertyGroup::Perks[i]));
                    if (value > 1) {
                        text += " (" + value + ")";
                    }

                    Captions.insertLast(text);
                    Descriptions.insertLast(MSG_GAME(STR_PARAM_DESC(CritterPropertyGroup::Perks[i])));
                    Images.insertLast(MSG_GAME(STR_PARAM_PIC(CritterPropertyGroup::Perks[i])));
                    totalRows++;
                }
            }
            ResizeGrid(totalRows);
        }

        void FillKarma()
        {
            Critter @chosen = Game.GetChosen();
            if (chosen is null) {
                return;
            }

            string karmaCaption = MSG_GAME(MsgStr::StrKarmaGenGenName) + " " + MSG_GAME(MsgStr::StrKarmaGenCaption);
            auto karmaValue = GetPropValue(CritterProperty::Karma);
            auto karmaLevel = Reputation::GetKarmaLevel(karmaValue);
            karmaCaption = Game.ReplaceText(karmaCaption, "%d", karmaValue);
            karmaCaption = Game.ReplaceText(karmaCaption, "%s", MSG_GAME(STR_KARMA_LEVEL_NAME(karmaLevel)));

            Captions.insertLast(karmaCaption);
            Descriptions.insertLast(MSG_GAME(MsgStr::StrKarmaGenDescription));
            Images.insertLast(MSG_GAME(STR_KARMA_LEVEL_SKILLDEX(karmaLevel)));

            int totalRows = 1;

            // Karma perks
            for (int i = 0; i < CritterPropertyGroup::KarmaPerks.length(); i++) {
                auto perk = CritterPropertyGroup::KarmaPerks[i];
                if (GetPropValue(perk) != 0) {
                    Captions.insertLast(MSG_GAME(STR_PARAM_NAME(perk)));
                    Descriptions.insertLast(MSG_GAME(STR_PARAM_DESC(perk)));
                    Images.insertLast(MSG_GAME(STR_PARAM_PIC(perk)));
                    totalRows++;
                }
            }

            // Town reputation
            bool townReputationTitleAdded = false;
            for (int i = 0; i < CritterPropertyGroup::Reputations.length(); i++) {
                if (!townReputationTitleAdded) {
                    townReputationTitleAdded = true;
                    Captions.insertLast(MSG_GAME(MsgStr::StrTownrepTitleName));
                    Descriptions.insertLast(MSG_GAME(MsgStr::StrTownrepTitleDesc));
                    Images.insertLast(MSG_GAME(MsgStr::StrTownrepTitlePic));
                    HeadersIndexes.insertLast(totalRows);
                    totalRows++;
                }

                int value = GetPropValue(CritterPropertyGroup::Reputations[i]);
                auto repLevel = Reputation::GetReputationLevel(value);
                Captions.insertLast(MSG_GAME(STR_REPUTATION_NAME(i)) + ": " + MSG_GAME(STR_REPUTATION_LEVEL_NAME(repLevel)) + " (" + value + ")");
                Descriptions.insertLast(MSG_GAME(STR_REPUTATION_LEVEL_DESC(repLevel)));
                Images.insertLast(MSG_GAME(STR_REPUTATION_LEVEL_SKILLDEX(repLevel)));
                totalRows++;
            }

            // Addiction
            bool addictionTitleAdded = false;
            bool[] addictions = array<bool>(chosen.Addictions);
            for (int i = 0; i < addictions.length(); i++) {
                if (addictions[i]) {
                    if (!addictionTitleAdded) {
                        addictionTitleAdded = true;
                        Captions.insertLast(MSG_GAME(MsgStr::StrAddictTitleName));
                        Descriptions.insertLast(MSG_GAME(MsgStr::StrAddictTitleDesc));
                        Images.insertLast(MSG_GAME(MsgStr::StrAddictTitlePic));
                        HeadersIndexes.insertLast(totalRows);
                        totalRows++;
                    }

                    Captions.insertLast(MSG_GAME(STR_ADDICTION_NAME(i)));
                    Descriptions.insertLast(MSG_GAME(STR_ADDICTION_NAME(i)));
                    Images.insertLast(MSG_GAME(STR_ADDICTION_PIC(i)));
                    totalRows++;
                }
            }
            ResizeGrid(totalRows);
        }
    }
}
