namespace V13ZTurret
{

#if SERVER

// Author: Sufir

void TurretInit(Critter turret, bool firstTime)
{
    turret.IsNoSupply = true;
    turret.OnMessage.Subscribe(TurretGetMessage);
    turret.OnAttacked.Subscribe(FriendlyFire);
    turret.OnAttack.Subscribe(FriendlyFire2);
}

[[Event]]
void TurretGetMessage(Critter turret, Critter fromCr, int message, any value)
{
    if (!turret.IsAlive()) {
        return;
    }

    if (message == V13ZGuard::MsgV13GuardAlarm) {
        Critter? player = Game.GetCritter(value);
        if (player == null) {
            return;
        }

        if (!player.ControlledByPlayer) {
            return;
        }

        NpcPlanes::AddAttackPlane(turret, 0, player.Id, int(float(player.CharismaBase) * 1.5));
        // EnemyStack::AddEnemyToStack( turret,  player.Id  );
    }
    else if (message == V13ZGuard::MsgV13GuardKill) {
        Critter? player = Game.GetCritter(value);
        if (player == null) {
            return;
        }

        if (!player.ControlledByPlayer) {
            return;
        }

        NpcPlanes::AddAttackPlane(turret, 0, player.Id);
    }
}

[[Event]]
EventResult FriendlyFire2(Critter critter, Critter target, Item weapon, int weaponMode, ProtoItem ammo)
{
    return (FriendlyFireImpl(critter, target)) ? EventResult::StopChain : EventResult::StopChain;
}

// Если NPC атакован одним из "своих" - не атакуем его.
bool FriendlyFireImpl(Critter guardian, Critter attacker)
{
    if (!guardian.ControlledByPlayer && !attacker.ControlledByPlayer) {
        if (guardian.NpcRole == V13ZGuard::RoleGuardian || guardian.NpcRole == V13ZGuard::RoleSoldier) {
            CritterState::Wait(guardian, 5000);
            CritterState::Wait(attacker, 5000);
            if (EnemyStack::CheckEnemyInStack(guardian, attacker.Id)) {
                EnemyStack::EraseEnemyFromStack(guardian, attacker.Id);
            }

            if (EnemyStack::CheckEnemyInStack(attacker, guardian.Id)) {
                EnemyStack::EraseEnemyFromStack(attacker, guardian.Id);
            }

            NpcPlanes::EraseAttackPlane(attacker, guardian.Id);
            NpcPlanes::EraseAttackPlane(guardian, attacker.Id);
            return true;
        }
    }

    return false;
}

[[Event]]
EventResult FriendlyFire(Critter guardian, Critter attacker)
{
    return (FriendlyFireImpl(guardian, attacker)) ? EventResult::StopChain : EventResult::StopChain;
}

#endif

}
