//   "OnGlobalMouseMove":
{
    {
        {
            //Game.CustomCall( "ProcessMouseScroll" );
            if ((Settings.Fullscreen && Settings.FullscreenMouseScroll) || (!Settings.Fullscreen && Settings.WindowedMouseScroll)) {
                Settings.ScrollMouseRight = (Game.MousePos.x >= Settings.ScreenWidth - 1);
                Settings.ScrollMouseLeft = (Game.MousePos.x <= 0);
                Settings.ScrollMouseDown = (Game.MousePos.y >= Settings.ScreenHeight - 1);
                Settings.ScrollMouseUp = (Game.MousePos.y <= 0);
            }
        }
    }
}
