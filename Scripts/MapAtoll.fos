// clang-format on

// Инициализация торговца Атолла: фиксируем бартерные/защитные флаги (предметы не теряются,
// не подбираются, не воруются) и запускаем периодическое обновление ассортимента.
void AtollTraderInit(Critter cr, bool firstTime)
{
    cr.SkillBarter = 200;
    cr.IsNoItemGarbager = true;
    cr.IsNoBarter = false;
    cr.IsNoDrop = true;
    cr.IsNoSteal = true;
    cr.IsNoLoot = true;
    cr.IsNoEnemyStack = true;
    cr.IsBarterOnlyCash = true;
    if (cr.CountTimeEvent(RefreshBag) == 0) {
        cr.StartTimeEvent(ZERO_TIMESPAN, RefreshBag);
    }
}

// Периодическое обновление ассортимента торговца: выбираем случайную группу из таблицы,
// уничтожаем текущие предметы и добавляем новые по шансу/диапазону количества, затем
// перепланируем событие на указанное в группе время.
[[TimeEvent]]
void RefreshBag(Critter cr, TimeEventContext event)
{
    int idx = Game.Random(0, atollLoot.length() - 1);
    int timeNext = int(atollLoot[idx][0][0]);
    int chance = 0;
    int qty = 0;

    Item[] items = cr.GetItems();
    Game.DestroyItems(items);

    for (int i = 1; i < atollLoot[idx].length(); i++) {
        chance = int(atollLoot[idx][i][3]);
        if (chance >= 100 || (Game.Random(0, 99) < chance)) {
            qty = Game.Random(int(atollLoot[idx][i][1]), int(atollLoot[idx][i][2]));
            if (qty > 0) {
                hstring pid = hstring(atollLoot[idx][i][0]);
                cr.AddItem(pid, qty);
            }
        }
    }

    timespan delayTicks = Time::Hours(timeNext);
    if (delayTicks != ZERO_TIMESPAN) {
        event.Repeat(delayTicks);
    }
}

#endif

}
