//     {
//       "$type": "Panel",
//       "BackgroundImage": null,
//       "BackgroundImageLayout": "None",
//       "CropContent": false,
//       "IsVerticalScroll": false,
//       "IsHorizontalScroll": false,
//       "Expanded": true,
//       "Selected": false,
//       "Active": true,
//       "Name": "Tip",
//       "Position": "342, 264",
//       "Size": "0, 0",
//       "Anchor": "None",
//       "Dock": "None",
//       "IsDraggable": false,
//       "IsNotHittable": false,
//       "CheckTransparentOnHit": false,
//       "GlobalScope": null,
//       "ClassFields": null,
//       "OnInit": null,
//       "OnShow": null,
//       "OnHide": null,
//       "OnAppear": null,
//       "OnDisappear": null,
//       "OnDraw":
{
    {
        {
            Gui::Object[] focusedObjects = Gui::GetFocusedObjects();
            Gui::Object obj = !focusedObjects.isEmpty() ? focusedObjects.first() : null;
            if (obj == null) {
                return;
            }

            CritterProperty prop = CritterProperty::None;

            if (prop == CritterProperty::None && cast<BaseStat>(obj.Parent) !is null) {
                prop = cast<BaseStat>(obj.Parent).Prop;
            }
            if (prop == CritterProperty::None && cast<HealthStat>(obj.Parent) !is null) {
                prop = cast<HealthStat>(obj.Parent).Prop;
            }
            if (prop == CritterProperty::None && cast<ExtendedStat>(obj.Parent) !is null) {
                prop = cast<ExtendedStat>(obj.Parent).Prop;
            }
            if (prop == CritterProperty::None && cast<Skill>(obj.Parent) !is null) {
                prop = cast<Skill>(obj.Parent).Prop;
            }

            if (cast<TextLevel>(obj) !is null) {
                prop = CritterProperty::Level;
            }
            if (cast<TextExp>(obj) !is null) {
                prop = CritterProperty::Experience;
            }

            if (prop != CritterProperty::None && CurTip != prop) {
                CurTip = prop;
                FindText("Name").Text = MSG_GAME(STR_PARAM_NAME(prop));
                FindText("Desc").Text = MSG_GAME(STR_PARAM_DESC(prop));
                FindPanel("Image").SetBackgroundImage(MSG_GAME(STR_PARAM_PIC(prop)));
            }
            auto panel = cast<PropsPanel>(obj.Parent);
            if (prop == CritterProperty::None && panel !is null) {
                FindText("Name").Text = panel.Caption;
                FindText("Desc").Text = panel.Description;
                FindPanel("Image").SetBackgroundImage(panel.Image);
            }
        }
    }
}
