    Demand Property Player SpecialEncounterKotw < 3
  Answer 13 # Тест проходился
    Demand Property Player SpecialEncounterKotw == 3

Speech 2 # С какой целью был создан Орден Рыцарей Пустоши?
  Answer Exit # Что бы надирать задницы и жевать жвачку.
    Result Property Player CurrentHp -= 1
    Result Script SeKotw::r_InfoMessage 1
  Answer 4 # Что бы защищать слабых от беззакония и насилия.
  Answer 3 # [Ещё]

Speech 3 # С какой целью был создан Орден Рыцарей Пустоши?
  Answer Exit # Что бы скрыть свои зверства под личиной праведн...
    Result Property Player IsDamagedLeftArm = 1
    Result Script SeKotw::r_InfoMessage 2
  Answer Exit* # Что бы проводить такую политику, как будто поли...
    Result Property Player PoisoningLevel += 1
    Result Script SeKotw::r_InfoMessage 3
  Answer 2 # [Назад]
  Answer Exit** # [Выход]

Speech 4 # С кем борются Рыцари Пустоши?
  Answer Exit # Со скукой и унынием.
    Result Property Player CurrentHp -= 1
    Result Script SeKotw::r_InfoMessage 1
  Answer 6 # С рейдерами и бандами разбойников и убийц.
  Answer Exit* # Со здравым смыслом.
    Result Property Player IsDamagedRightArm = 1
  Answer Exit** # С космополитами, буржуями и империалистами.
    Result Property Player PoisoningLevel += 1

Speech 6 # Что говорят Рыцари Пустоши за 5 секунд до боя?
  Answer 8 # Они говорят все это сразу.
  Answer Exit # Привет, Вализар!
    Result Property Player IsDamagedEye = 1
    Result Script SeKotw::r_InfoMessage 5
  Answer Exit* # АРАРАРАРАРАРАРА
    Result Property Player PoisoningLevel += 1
    Result Script SeKotw::r_InfoMessage 3
  Answer Exit** # Я считаю, надо упороться.
    Result Property Player PoisoningLevel += 1
  Answer 7 # [Ещё]

Speech 7 # Что говорят Рыцари Пустоши за 5 секунд до боя?
  Answer Exit # А вы что, уже уехали?
    Result Property Player CurrentHp -= 1
    Result Script SeKotw::r_InfoMessage 1
  Answer Exit* # Заходите, я их всех ранил!
    Result Property Player PoisoningLevel += 1
  Answer 6 # [Назад]
  Answer Exit** # [Выход]

