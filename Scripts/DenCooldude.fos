// DenCooldude — сервер: НПЦ, напевающий песню 'Maybe'.
// Обязанности: по таймеру шёпотом произносит строки диалога 0..5 по кругу с паузами между куплетами.
// Сторона: SERVER. Связи: Messaging, GameTime, MsgStr.
namespace DenCooldude
{

#if SERVER

// Крутой чувак, поёт "Maybe".
// ToDo: сделать чтобы иногда пел в полный голос.

// Текущая строка куплета (0..5). Состояние на уровне модуля — общее для всех НПЦ этого типа.
int currentMsg;

// Сбрасывает счётчик куплетов и запускает первый напев с большой стартовой паузой.
void CooldudeInit(Critter npc, bool firstTime)
{
    currentMsg = 0;
    Game.StartTimeEvent(GameTime::GameSeconds(10 * 60), Sing, npc.Id);
}

// Шёпотом произносит очередную строку куплета и перезапускает таймер на следующую.
[[TimeEvent]]
void Sing(any value)
{
    Critter? npc = Game.GetCritter(value);
    if (npc != null) {
        Messaging::SayWhisperOnHead(npc, MsgStr::DialogTextKey(npc.DialogId, currentMsg));
    }

    // Прошли весь куплет — сбрасываемся к началу и делаем паузу перед новым проигрыванием.
    currentMsg++;
    if (currentMsg > 5) {
        currentMsg = 0;
        Game.StartTimeEvent(Time::Seconds(Game.Random(30, 60)), Sing, value);
        return;
    }

    // Внутри куплета — короткая пауза до следующей строки.
    Game.StartTimeEvent(Time::Seconds(5), Sing, value);
}

#endif

}
