//               "OnDragChanged": null,
//               "OnResizeGrid":
{
    {
        {
            if (!HasChosen) {
                return;
            }

            @ItemCraft = cast<FixBoy>(GuiScreensExt::NeedScreen(Screen)).CraftList[cellIndex];
            any[] outItems = ItemCraft.OutItems;

            int i = 0;
            string result;
            while (i < outItems.length()) {
                if (i != 0) {
                    result += MsgStr::GetGameText(MsgStr::StrAnd);
                }

                string text = MsgStr::GetGameText(MsgStr::StrFixPieces);
                string name = Game.GetText(MsgStr::ProtoItemNameKey(hstring(outItems[i++])));
                text = Game.ReplaceText(text, "%NAME", name);
                text = Game.ReplaceText(text, "%COUNT", outItems[i++]);
                result += text;
            }

            SetText(result);
            SetTextColor(ItemCraft.IsCanCraft ? Color::Text : Color::Red);
        }
    }
}
