ident[] PlayerOk = {};     // Массив с id игроков которых обыскали и им можно проходить
ident[] PlayerWarned = {}; // Массив с id игроков которых предупредили - дважды предупреждать не будут
// ident[] PlayerBad = {}; // Массив с id игроков которые прошли без обыска

GuardLib::CGuardsManager Grd;

void GateGuardInit(Critter guard, bool firstTime)
{
    guard.OnMessage.Subscribe(OnMessage);
    guard.OnCritterAppeared.Subscribe(OnAddCritter);
    guard.OnCritterDisappeared.Subscribe(OnRemoveCritter);
    guard.OnItemOnMapDisappeared.Subscribe(OnPickItem);
}

[[Event]]
void OnAddCritter(Critter npc, Critter player)
{
    if (not player.ControlledByPlayer) {
        return;
    }

    // Game.Log("Add OK.");
    int i = UtilsForArray::FindInArray(PlayerOk, player.Id);
    if (i > 0) {
        PlayerOk.removeAt(i);
    }

    i = UtilsForArray::FindInArray(PlayerWarned, player.Id);
    if (i > 0) {
        PlayerWarned.removeAt(i);
    }
}

// Вызывается, когда из поля зрения NPC исчезает криттер.
[[Event]]
void OnRemoveCritter(Critter npc, Critter player)
{
    if (not player.ControlledByPlayer) {
        return;
    }

    int i = UtilsForArray::FindInArray(PlayerOk, player.Id);
    if (i > 0) {
        PlayerOk.removeAt(i);
    }

    i = UtilsForArray::FindInArray(PlayerWarned, player.Id);
    if (i > 0) {
        PlayerWarned.removeAt(i);
    }
}

// тестирование предмета на разрешонность
bool ItemTest(hstring protoId)
{
    if (UtilsForArray::Present(protoId, PidsGroups::Pids_Drugs) || UtilsForArray::Present(protoId, PidsGroups::Pids_DrugsAlcohol) ||
        UtilsForArray::Present(protoId, PidsGroups::Pids_MiscExplosions) || UtilsForArray::Present(protoId, PidsGroups::Pids_MiscActiveExplosions)) {
        return false;
    }
    else {
        return true;
    }
}

// алгоритм обыска
// возращает коды недопуска
// 0 - все хорошо
// 1 - плохой предмет
// 2 - алкоголь
// 3 - наркотики
// 4 - взрывчатка
// 5 - нету пропуска
int Searching(Critter npc, Critter player)
{
    int result = 5;
    hstring pid;
    Item[] items = player.GetItems();
    for (int i = 0, l = items.length(); i < l; i++) {
        pid = items[i].ProtoId;
        if (not ItemTest(pid)) {
            return 1;
        }

        if (pid == Content::Item::day_pass) {
            result = 0;
        }

        if (pid == Content::Item::fake_citizenship) {
            result = 0;
        }
    }

    return result;
}

// Сообщения от тригеров
[[Event]]
void OnMessage(Critter guard, Critter player, int num, any val)
{
    // Game.Log("OnMessage ok");
    if (not player.ControlledByPlayer) {
        return;
    }

    if (not NpcPlanes::IsNoPlanes(guard)) {
        return;
    }

    if (guard.Condition != CritterCondition::Alive) {
        return;
    }

    if (player.CurrentHp < 0) {
        return;
    }

    if (VcGuardsman::GetRank(player) > 0) {
        return; // Гвардейцам разрешено проходить без пропуска
    }

    if (num == GuardLib::MessagePlayerOnWarningHex) {
        // Предупреждаем игрока
        if (UtilsForArray::Present(player.Id, PlayerWarned)) {
            return; // значит мы его уже предупредили - дважды повторять не будем
        }

        PlayerWarned.insertLast(player.Id);
        Item? itm = Tla::GetCritterArmorItem(player);
        if (itm != null) {
            if (UtilsForArray::Present(itm.ProtoId, PidsGroups::Pids_ArmorHeavy)) {
                Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 5))));
                return;
            }
        }

        Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 1))));
        return;
    }

    if (num == GuardLib::MessagePlayerOnSearchHex) {
        if (Game.GetDistance(guard, player) == 1) {
            if (UtilsForArray::Present(player.Id, PlayerOk)) {
                return; // мы его уже обыскивали - больше покачто небудем.
            }

            guard.SetDir(Game.GetDirection(guard.Hex, player.Hex));
            if (VcGuard::GuardItemTest(Tla::GetCritterHandItem(player))) {
                // оружие в руках
                Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 6))));
                return;
            }

            Item? itm = Tla::GetCritterArmorItem(player);
            if (itm != null) {
                if (UtilsForArray::Present(itm.ProtoId, PidsGroups::Pids_ArmorHeavy)) {
                    // плохая броня
                    Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 5))));
                    return;
                }
            }

            Tla::AnimateCritterUse(guard);
            int searchResult = 0;
            if ((searchResult = Searching(guard, player)) == 0) {
                // все окей
                // Messaging::SayOnHead(guard, TextPackKey("Даже отобрать нечего, "" + (топай дальше")));
                Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 2))));
                PlayerOk.insertLast(player.Id);
            }
            else {
                if (searchResult == 5) { // нету пропуска
                    Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 7))));
                }
                else {
                    // плохие предметы
                    // Messaging::SayOnHead(guard, "О! да у тебя тут Алкоголь и Наркотики. Не уходи от нас братец!");
                    Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 3))));
                    PlayerOk.removeAt(int(UtilsForArray::FindInArray(PlayerOk, player.Id)));
                }
            }

            return;
        }
        else {
            return;
        }
    }

    if (num == GuardLib::MessagePlayerOnAtackHex) {
        if (not UtilsForArray::Present(player.Id, PlayerOk)) {
            // игрок ушел в город и его надо вернуть назад
            // ALERT!
            Messaging::SayShoutOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 4))));
            // guard.Say(SAY_SHOUT_ON_HEAD,"Стой! Стрелять буду!");

            // игрок 'просит' чтобы его пристрелили
            SendMessage::ToWhoSeesMe(player, GuardLib::MessagePleaseKillMeIAmIdiot, 0);

            // Alert(player, GuardLib::MaxAlert, GuardLib::AlertTypeEnterOnDeny);
        }
        else {
            // игрок ушел в город
        }
    }

    if (num == GuardLib::MessagePlayerOnPreEnter) {
        // это не честный обыск, но зато надежный.
        if (Searching(guard, player) != 0) {
            int idx = int(UtilsForArray::FindInArray(PlayerOk, player.Id));
            if (idx >= 0) {
                PlayerOk.removeAt(idx);
            }

            idx = int(UtilsForArray::FindInArray(PlayerOk, player.Id));
            if (idx >= 0) {
                PlayerWarned.removeAt(idx);
            }

            Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 1))));
        }
    }
}

// зона в которой солдаты предупреждают о необходимости обыскивания
[[ItemTrigger]]
void Incoming(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    if (not entered) {
        return;
    }

    // Проверяем игрок ли это
    if (not player.ControlledByPlayer) {
        return;
    }

    // он вышел или вошел?
    if (dir == 1 || dir == 2 || dir == 3) {
        // вышел из города дальше зоны предупреждения
        // удаляем из листов
        // grd.DelObserving(player);//!!!
        // PlayerOk.removeAt(int(UtilsForArray::FindInArray(PlayerOk, player.Id)));
        return;
    }

    // Посылаем сообщение о том, что наступили на этот хекс.
    SendMessage::ToWhoSeesMe(player, GuardLib::MessagePlayerOnWarningHex, 0);
}

// обыскивают
// rename Income -> t_searching
[[ItemTrigger]]
void Income(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    if (not entered) {
        return;
    }

    // Проверяем игрок ли это
    if (not player.ControlledByPlayer) {
        return;
    }

    // Посылаем сообщение о том, что наступили на этот хекс.
    SendMessage::ToWhoSeesMe(player, GuardLib::MessagePlayerOnSearchHex, 0);
}

// игрок проходит первые ворота города
[[ItemTrigger]]
void PreEnter(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    if (not entered) {
        return;
    }

    // Проверяем игрок ли это
    if (not player.ControlledByPlayer) {
        return;
    }

    if (dir == 1 || dir == 2 || dir == 3) {
        return;
    }

    // Посылаем сообщение о том, что наступили на этот хекс.
    SendMessage::ToWhoSeesMe(player, GuardLib::MessagePlayerOnPreEnter, 0);
}

// игрок вошел в город
[[ItemTrigger]]
void Enter(Critter player, StaticItem trigger, bool entered, mdir dir)
{
    if (not entered) {
        return;
    }

    // Проверяем игрок ли это
    if (not player.ControlledByPlayer) {
        return;
    }

    if (dir == 1 || dir == 2 || dir == 3) {
        // вышел из города
        // удаляем из листов
        // убираем из листа наблюдения - больше он охрану не интересует
        // grd.DelObserving(player);//!!!
        return;
    }

    // Посылаем сообщение о том, что наступили на этот хекс.
    SendMessage::ToWhoSeesMe(player, GuardLib::MessagePlayerOnAtackHex, 0);
}

[[Event]]
void OnPickItem(Critter guard, Item hideItem, Critter? picker)
{
    if (picker == null) {
        return;
    }

    if (not picker.ControlledByPlayer) {
        return;
    }

    if (not NpcPlanes::IsNoPlanes(guard)) {
        return;
    }

    if (guard.Condition != CritterCondition::Alive) {
        return;
    }

    // Game.Log("pickup detect");

    if (not ItemTest(hideItem.ProtoId)) {
        int i = 0;
        if (UtilsForArray::FindInArray(PlayerOk, picker.Id, i)) {
            PlayerOk.removeAt(i);
            Messaging::SayOnHead(guard, TextPackKey(TextPackName::Dialogs, "" + (MsgStr::DialogTextId(Content::Dialog::vc_gate_guard, 1))));
        }
    }
}

[[DialogResult]]
int Searching(Critter player, Critter guard, any val)
{
    if (Searching(guard, player) == 0) {
        // окей
        if (not UtilsForArray::Present(player.Id, PlayerOk)) {
            PlayerOk.insertLast(player.Id);
        }

        return 9;
    }

    // не пускаем
    return 10;
}

// constructor [ heX ]

// Инициализация нпц. происходит при вводе нпц в игру
void GuardInit(Critter npc, bool firstTime)
{
    // вешаем обработчики событий
    npc.OnCritterAppeared.Subscribe(GuardOnAddCritter);
    npc.OnCritterDisappeared.Subscribe(GuardOnRemoveCritter);
    // npc.StartTimeEvent(Time::Asap(), Time::Seconds(1), GuardIdle);
    npc.OnNpcPlaneEnd.Subscribe(GuardEndPlane);
    npc.OnMessage.Subscribe(GuardOnMessage);
    npc.OnSomeCritterMoveItem.Subscribe(GuardOnMoveItem);
    npc.OnSomeCritterUseItem.Subscribe(GuardOnUseItem);
    npc.OnSomeCritterStealing.Subscribe(GuardStealing);
    npc.OnSomeCritterAttack.Subscribe(GuardOnSmthAttack);
    npc.OnSomeCritterDropItem.Subscribe(GuardOnDropItem); // r17

    // Создаем событие наблюдения
    if (not firstTime && npc.CountTimeEvent(Observing) == 0) {
        npc.StartTimeEvent(GuardLib::ObservationPeriod(), Observing);
    }
}

[[TimeEvent]]
void Observing(Critter npc, TimeEventContext event)
{
    timespan delayTicks = Grd.EventObserving(npc);
    if (delayTicks != ZERO_TIMESPAN) {
        event.Repeat(delayTicks);
    }
}

[[Event]]
void GuardOnAddCritter(Critter crit, Critter showCrit)
{
    Grd.EventOnAddCritter(crit, showCrit);
}

[[Event]]
void GuardOnRemoveCritter(Critter crit, Critter hideCrit)
{
    Grd.EventOnRemoveCritter(crit, hideCrit);
}

[[Event]]
EventResult GuardEndPlane(Critter npc, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(npc, planeId);

    Grd.EventEndPlane(npc);
    return EventResult::StopChain;
}

[[Event]]
void GuardOnMoveItem(Critter crit, Critter fromCrit, Item item, CritterItemSlot fromSlot)
{
    Grd.EventOnMoveItem(crit, fromCrit, Game.GetItem(item.Id), fromSlot);
}

[[Event]]
void GuardOnMessage(Critter crit, Critter fromCrit, int message, any value)
{
    Grd.EventOnMessage(crit, fromCrit, message, value);
}

[[Event]]
void GuardOnUseItem(Critter crit, Critter fromCrit, Item item, Critter onCritter, Item onItem, StaticItem onScenery, int param)
{
    Grd.EventOnUseItem(crit, fromCrit, item, onCritter, onItem, null);
}

[[Event]]
void GuardOnDropItem(Critter crit, Critter fromCrit, Item item) // r17
{
    Grd.EventOnDropItem(crit, fromCrit, item);
}

[[Event]]
void GuardOnSmthAttack(Critter crit, Critter fromCrit, Critter target, Item weapon, int weaponMode, ProtoItem ammo)
{
    Grd.EventOnSmthAttack(crit, fromCrit, target);
}

[[Event]]
void GuardStealing(Critter crit, Critter thief, Critter fromCrit, Item item, int count)
{
    Grd.EventStealing(crit, fromCrit, thief, false, item, count);
}

