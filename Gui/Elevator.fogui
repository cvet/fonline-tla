//       "OnInit": null,
//       "OnShow":
{
    {
        {
            // Data[ 13 ]  -  buttons count  ( 1 )
            // Data[ 12 ]  -  button down pic offset ( 1 )
            // 14+ -  rect for every button  ( 4 )
            Elevator elevator = cast<Elevator>(GuiScreensExt::NeedScreen(Screen));
            int count = int(elevator.Data[13]);
            _Children.clear();
            for (int i = 0; i < count; i++) {
                ElevatorButton button = CreateElevatorButtonHierarchy(this);
                button.Index = i;
                button.SetPressedImage(hstring(elevator.Data[12]));
                int index = 14 + i * 4;
                int posX = elevator.Data[index];
                int posY = elevator.Data[index + 1];
                button.SetPosition(posX, posY);
                button.SetActive(true);
            }
        }
    }
}
