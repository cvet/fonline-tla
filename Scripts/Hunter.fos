// Hunter — серверная логика цепочки квестов "Лучший охотник Пустоши".
// Отвечает за: торговцев Хьюза и Лоуренса (выдача дудки/токсина по таймауту,
// барные ограничения), счётчик убитых крыс, ультразвуковой свисток для ловли
// крыс, приманку Лоуренса (спавн и наведение крыс на игрока), вертиберд-заглушку.
// Сторона исполнения: только SERVER.
// Связи: Trader, LimitedBarter, NpcPlanes, RatGrenade, Explode, Messaging,
// SendMessage, Entrance, EnemyStack, диалоги Хьюза/Лоуренса.
namespace Hunter
{

#if SERVER

// Квесты цепочки "Лучший охотник Пустоши."

///@ Property Critter Common uint8 BarterLourensRats1 Mutable OwnerSync Persistent Group = Quests Quest = 5200 Max = 4
///@ Property Critter Common uint8 ModLourenceRatsFlute Mutable OwnerSync Persistent Group = Quests Quest = 3317 Max = 3
///@ Property Critter Server uint8 BarterLourensRatBodycount Mutable Persistent Max = 11
///@ Property Critter Server synctime ModHoughRatsFluteTimeout Mutable Persistent
///@ Property Critter Server synctime ModLourenceToxinTimeout Mutable Persistent
///@ Property Critter Server int32 ModLourenceRatsFluteCounter Mutable Persistent Max = 5
///@ Property Critter Server synctime ModLourenceLureActive Mutable Persistent

///@ Property Item Server int32 QHunterCountFluteUse Mutable Persistent

const int MSG_COM2ME = 33;

// Заглушка отладочного лога: тело пустое, чтобы вызовы DebugLog(...) ничего не печатали.
// Исходный макрос оставлен как breadcrumb — раскомментировать при отладке для вывода в лог.
// #define DebugLog            # (s) ( Game.Log( "" + s ) )
void DebugLog(string s)
{
}

// Часть первая: тестовое задание.

// Подставляет цвета имён в сгенерированный диалог (Хьюз — основной текст, Лоуренс — жёлтый контур).
void Colorize(Critter player, Critter npc, string& textArgs)
{
    if (!Tla::IsDialogGenerated(textArgs)) {
        return;
    }

    textArgs = "|colorHugh:" + Color::Tag(Color::Text) + "|colorLourence:" + Color::Tag(Color::ContourYellow);
}

// Засчитывает игроку убитую большую кротокрысу для квеста; на 10-й тушке переводит квест в стадию 2.
void OnCritterKilled(Critter cr, Critter? killer)
{
    if (killer != null && !cr.ControlledByPlayer && killer.ControlledByPlayer && cr.ModelNameBase == Tla::CRTYPE_MOLESKIN_RAT_BIG &&
        killer.BarterLourensRats1 == 1) {
        if (killer.BarterLourensRatBodycount < 10) {
            killer.BarterLourensRatBodycount += 1;
        }
        else {
            killer.BarterLourensRats1 = 2;
        }
    }
}

// Реакция NPC на провал тестового задания: зовёт всех на карте к игроку и через 3 сек запускает подрыв.
[[DialogResult]]
void Explode(Critter player, Critter? npc)
{
    if (npc != null) {
        SendMessage::ToAllOnMap(npc, MSG_COM2ME, player.Id);
        npc.StartTimeEvent(Time::Seconds(3), ExplodeTimeEvent);
    }
}

// Отложенный подрыв динамита на месте NPC и последующая реплика через 2 сек.
[[TimeEvent]] [[Async]]
void ExplodeTimeEvent(Critter cr)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    Map? map = cr.GetMap();
    if (map != null) {
        Explode::Explode(cr.GetMap(), cr.Hex, null, Content::Item::active_dynamite, cr.Var4, Game.Random(0, 50), Game.Random(0, 1));
        cr.StartTimeEvent(Time::Seconds(2), Comment);
    }

    return;
}

// Реплика NPC после подрыва (строка 1 его диалога).
[[TimeEvent]] [[Async]]
void Comment(Critter cr)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    Messaging::Say(cr, MsgStr::DialogTextKey(cr.DialogId, 1));
    return;
}

// Инициализация торговца Хьюза: торговля только за наличные, без кражи/лута/дропа, подписки на барт и планы.
void HoughInit(Critter cr, bool firstTime)
{
    Trader::TraderInit(cr, firstTime);
    cr.OnBarter.Subscribe(HoughBarter);
    cr.MaxTalkers = 1;
    cr.IsBarterOnlyCash = true;
    cr.IsNoBarter = false;
    cr.IsNoDrop = true;
    cr.IsNoSteal = true;
    cr.IsNoLoot = true;
    cr.OnMessage.Subscribe(HoughMessage);
    cr.OnNpcPlaneEnd.Subscribe(HoughPlaneEnd);
}

// По сигналу MSG_COM2ME Хьюз идёт к позвавшему игроку.
[[Event]]
void HoughMessage(Critter cr, Critter fromCr, int message, any value)
{
    if (message == MSG_COM2ME) {
        NpcPlanes::AddWalkPlane(cr, 17, fromCr.Hex, Game.GetDirection(cr.Hex, fromCr.Hex), false, 1);
    }
}

// По достижении точки хода (план с приоритетом 17) ставит короткую misc-паузу.
[[Event]]
EventResult HoughPlaneEnd(Critter cr, int planeId, int reason, Critter someCr, Item someItem)
{
    NpcPlanes::NpcPlane? plane = NpcPlanes::GetCritterPlane(cr, planeId);
    if (plane == null) {
        return EventResult::StopChain;
    }

    if (plane.Priority == 17 && reason == NpcPlanes::REASON_SUCCESS) {
        DebugLog("moing end");
        NpcPlanes::AddMiscPlane(cr, 0, Game.SynchronizedTime + Time::Seconds(3), null);
    }

    return EventResult::StopChain;
}

// Барт у Хьюза: при выкладке предметов по таймаутам подкидывает игроку дудку и токсины,
// чтобы продвигать квесты; выданное добивается отложенным уничтожением, если не куплено.
[[Event]]
EventResult HoughBarter(Critter cr, Critter barterCr, bool attach, int barterCount)
{
    if (attach) {
        any[] values = {cr.Id};
        // Подкидываем в обмен различные девайсы по таймаутам.
        // 1. Дудка
        Item? flute = cr.GetItem(Content::Item::lourence_flute);
        Item? fluteBarter = barterCr.GetItem(Content::Item::lourence_flute);
        if (flute == null && fluteBarter == null) {
            if (barterCr.ModHoughRatsFluteTimeout < Game.SynchronizedTime && barterCr.ModHoughRatsFluteTimeout != ZERO_SYNCTIME) {
                barterCr.ModHoughRatsFluteTimeout = Game.SynchronizedTime + Time::Hours(Game.Random(12, 28) - barterCr.Luck);
                Item newFlute = cr.AddItem(Content::Item::lourence_flute, 1);
                values.insertLast(newFlute.Id);
            }
        }

        // 2. Cупертоксин
        if (barterCr.ModLourenceFloater > 0) {
            if (barterCr.ModLourenceToxinTimeout < Game.SynchronizedTime && barterCr.ModLourenceToxinTimeout != ZERO_SYNCTIME) {
                if (barterCr.ModLourenceToxinRecipe == 1) {
                    Item? toxine = cr.GetItem(Content::Item::danton_poison);
                    Item? toxineBarter = barterCr.GetItem(Content::Item::danton_poison);
                    if (toxine == null && toxineBarter == null) {
                        barterCr.ModLourenceToxinTimeout = Game.SynchronizedTime + Time::Hours(Game.Random(12, 28) - barterCr.Luck);
                        Item newToxine = cr.AddItem(Content::Item::danton_poison, 5);
                        values.insertLast(newToxine.Id);
                    }
                }

                Item? sToxine = cr.GetItem(Content::Item::supertoxine);
                Item? sToxineBarter = barterCr.GetItem(Content::Item::supertoxine);
                if (sToxine == null && sToxineBarter == null) {
                    barterCr.ModLourenceToxinTimeout = Game.SynchronizedTime + Time::Hours(Math::Clamp(Game.Random(10, 15) - barterCr.Luck, 1, 30));
                    Item newSToxine = cr.AddItem(Content::Item::supertoxine, 1);
                    values.insertLast(newSToxine.Id);
                }
            }
        }

        // После всех проверок
        if (values.length() > 1) {
            Game.StartTimeEvent(Time::GameMinutes(10), DestroyItemsHough, values);
        }
    }
    else {
        Item? money = cr.GetItem(Content::Item::bottle_caps);
        if (money != null) {
            Game.DestroyItem(money);
        }
    }

    return EventResult::StopChain;
}

// Удаляет у владельца ранее выданные при барте предметы, если он их так и не забрал (values[0] — id криттера).
[[TimeEvent]]
void DestroyItemsHough(any[] values)
{
    Critter? cr = Game.GetCritter(values[0]);
    if (cr != null) {
        for (int i = 1, l = values.length(); i < l; i++) {
            Item? item = Game.GetItem(values[i]);
            if (item != null && item.CritterId == cr.Id) {
                Game.DestroyItem(item);
            }
        }
    }
}

// Инициализация торговца Лоуренса: только наличные, без кражи/лута/дропа, плюс лимиты на покупку/продажу.
void LourenceInit(Critter cr, bool firstTime)
{
    cr.MaxTalkers = 1;
    cr.IsBarterOnlyCash = true;
    cr.IsNoBarter = false;
    cr.IsNoDrop = true;
    cr.IsNoSteal = true;
    cr.IsNoLoot = true;
    hstring[] sellItems = {Content::Item::lighter,
                           Content::Item::water_flask,
                           Content::Item::blue_condom,
                           Content::Item::cosmetic_case,
                           Content::Item::deck_of_cards,
                           Content::Item::mirror_shades,
                           Content::Item::necklace,
                           Content::Item::watch};
    hstring[] buyItems = {Content::Item::brahmin_skin,
                          Content::Item::meat,
                          Content::Item::gecko_pelt,
                          Content::Item::golden_gecko_pelt,
                          Content::Item::radscorpion_parts};
    LimitedBarter::SaveBarterLimit(cr.Id, sellItems, buyItems);
}

// Вертиберд: декоративный объект, который нельзя вскрыть; на любое использование/навык — отказ.
void VertiberdInit(Item vertiberd, bool firstTime)
{
    vertiberd.CarIsNoLockpick = true;
    vertiberd.OnCritterUseOnSelf.Subscribe(VertiberdUse);
    vertiberd.OnCritterUseSkill.Subscribe(VertiberdSkill);
    vertiberd.Info = 2;
}

// Прямое использование предмета на вертиберде — сообщение "ничего не происходит".
[[Event]]
EventResult VertiberdUse(Item vertiberd, Critter cr, Item usedItem, int param)
{
    Messaging::Info(cr, TextPackKey(TextPackName::Game, "" + (MsgStr::StrUseNothing)));
    return EventResult::StopChain;
}

// Применение навыка на вертиберде — сообщение "ничего не происходит".
[[Event]]
EventResult VertiberdSkill(Item vertiberd, Critter cr, CritterProperty skill)
{
    Messaging::Info(cr, TextPackKey(TextPackName::Game, "" + (MsgStr::StrUseNothing)));
    return EventResult::StopChain;
}

// Ультразвуковой свисток: при первом создании задаёт 10 зарядов и подписку на использование на цели.
void FluteInit(Item item, bool firstTime)
{
    if (firstTime) {
        item.QHunterCountFluteUse = 10;
        item.Info = 2;
        item.TextArgs = TextFormatting::TextArg("count", item.QHunterCountFluteUse);
    }

    item.OnCritterUseOn.Subscribe(FluteUse);
}

const int STR_RAT_CATCHED =
    27; // Вы применили ультразвуковой гипнотизатор на мутировавшую крысу. Теперь ее можно положить себе в рюкзак. Если, конечно, она не очухается.
const int STR_EMPTY = 28;    // В свистке закончились заряды. При последнем неаккуратном применении прибор был уничтожен.
const int STR_WRONGRAT = 29; // Крыса не реагирует на воздействие гипнотизатора. Попробуйте найти менее устойчивый экземпляр, где-нибудь в Пустоши.

// Применение свистка на живой крысе: на подходящей карте заменяет крысу на предмет rat_grenade,
// тратит заряд, ведёт счётчик квеста; на чужой карте — отказ; при нуле зарядов свисток уничтожается.
[[Event]]
EventResult FluteUse(Item item, Critter cr, Critter? onCritter, Item onItem, StaticItem onScenery, int param)
{
    if (onCritter != null && !onCritter.ControlledByPlayer && onCritter.ModelNameBase == Tla::CRTYPE_RAT && onCritter.IsAlive()) {
        item.QHunterCountFluteUse -= 1;
        item.TextArgs = TextFormatting::TextArg("count", item.QHunterCountFluteUse);
        Map? map = onCritter.GetMap();
        if (map != null) {
            Location loc = map.GetLocation();
            if (loc.AutoGarbage) {
                Item rat = map.AddItem(onCritter.Hex, Content::Item::rat_grenade, 1);
                rat.SetupScript(RatGrenade::RatGrenadeInit);
                Game.DestroyCritter(onCritter);
                Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_RAT_CATCHED)));
                if (cr.ModLourenceRatsFlute == 1 && cr.ModLourenceRatsFluteCounter < 5) {
                    cr.ModLourenceRatsFluteCounter += 1;
                    if (cr.ModLourenceRatsFluteCounter == 5) {
                        cr.ModLourenceRatsFlute = 2;
                    }
                }
            }
            else {
                Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_WRONGRAT)));
            }
        }

        if (item.QHunterCountFluteUse <= 0) {
            Game.DestroyItem(item);
            Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_EMPTY)));
        }

        return EventResult::StopChain;
    }

    return EventResult::StopChain;
}

// Из диалога: ставит игроку таймаут (переменную timeoutNum), отвечающий за частоту выдачи предметов у Хьюза.
[[DialogResult]]
void SetTo(Critter player, Critter npc, any timeoutNum, any realHours)
{
    player.SetAsAny(CritterProperty(timeoutNum), Game.SynchronizedTime + Time::Hours(realHours));
    DebugLog("" + (Game.SynchronizedTime + Time::Hours(realHours)));
}

// Из диалога квеста "пляши под мою дудку": спавнит вокруг NPC до 5 крыс с приказом атаковать его, затем реплика.
[[DialogResult]]
void AwakeRats(Critter cr, Critter? npc)
{
    if (npc != null && NpcPlanes::IsNoPlanes(npc)) {
        Map? map = npc.GetMap();
        if (map != null) {
            for (int i = 0; i < 5; i++) {
                mpos hex = npc.Hex;
                if (Entrance::GetFreeHex(map, 2, hex)) {
                    mdir dir = Game.GetDirection(hex, npc.Hex);
                    Critter rat = map.AddCritter(Content::Critter::RegularRat, hex, dir);
                    rat.SetupScript(RatGrenade::RatInit);
                    NpcPlanes::AddAttackPlane(rat, 0, npc);
                }
            }

            npc.StartTimeEvent(Time::Seconds(3), Comment1);
        }
    }
}

// Реплика NPC после спавна крыс (строка 2 его диалога).
[[TimeEvent]] [[Async]]
void Comment1(Critter cr)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    Messaging::Say(cr, MsgStr::DialogTextKey(cr.DialogId, 2));
    return;
}

// Приманка Лоуренса: ключи текст-пака для трёх исходов применения.
// Неудачно выбрано место для использования приманки.
const int STR_WRONG_PLACE = 33;
// Вы открываете крышку и у вас кружится голова от ужасной вони. Вы выливаете содержимое банки на свою одежду. Теперь остается только ждать, пока
// появятся крысы.
const int STR_SUCCESS = 34;
// Фу!!! Чем это от тебя воняет, lex name??!!Ну и вонища!!!Проклятье! lex name!! Отойди от меня на другую сторону улицы. Или лучше вали куда
// подальше!Дерьмо! Кто-то навалил в штаны?Буэ... Меня сейчас вырвет! lex name, пошел вон!Что это за ужасный запах?!Что это за невыносимая
// вонь?*Зажимает ноздри пальцами*Уберите это дерьмо от меня!!
const int STR_FOO = 35;

const int ENTRY_SPAWN = 17;
const int ENTRY_MOVETO = 18;

// Приманка: подписка на использование предмета.
void LureInit(Item item, bool firstTime)
{
    item.OnCritterUse.Subscribe(LureUse);
}

// Применение приманки: только на нужной карте рядом с маркером — запускает спавн крыс и периодические реплики NPC.
[[Event]]
EventResult LureUse(Item item, Critter cr, int param)
{
    Map? map = cr.GetMap();
    if (map != null && map.ProtoId == Content::Map::q_rats_out && map.GetStaticItemsInRadius(cr.Hex, 1, Content::Item::generic_4777).length() > 0) {
        Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_SUCCESS)));
        Game.DestroyItem(item);
        // SavedDeferredCall — отложенный вызов должен переживать рестарт сервера (breadcrumb из исходника).
        Game.StartTimeEvent(Time::Seconds(10), MoveRat, map.GetLocation().Id);
        cr.ModLourenceLureActive = Game.SynchronizedTime + Time::Hours(3);
        cr.StartTimeEvent(Time::Seconds(30), Lure);
        return EventResult::StopChain;
    }

    Messaging::Info(cr, TextPackKey(TextPackName::Text, "" + (STR_WRONG_PLACE)));
    return EventResult::StopChain;
}

// Пока приманка активна — периодически заставляет случайного NPC рядом возмутиться запахом игрока.
[[TimeEvent]] [[Async]]
void Lure(Critter cr, TimeEventContext event)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    if (cr.ModLourenceLureActive > Game.SynchronizedTime) {
        Map? map = cr.GetMap();
        if (map != null) {
            Critter[] npc = map.GetCrittersInRadius(cr.Hex, 5, CritterFindType::NonDeadNpc);
            if (!npc.isEmpty()) {
                Messaging::Say(npc[Game.Random(0, npc.length() - 1)],
                               TextPackKey(TextPackName::Text, "" + (STR_FOO)),
                               "|name:" + PlayerRegistration::GetPlayerName(cr.Id));
            }
        }

        timespan delayTicks = Time::Minutes(2);
        if (delayTicks != ZERO_TIMESPAN) {
            event.Repeat(delayTicks);
        }
    }

    return;
}

// Переносит до 5 крыс с карты-источника на целевую карту, делает их бездомными и натравливает на игроков/союзников.
[[TimeEvent]]
void MoveRat(any value)
{
    Location? loc = Game.GetLocation(ident(value));
    if (loc != null) {
        Map map = loc.GetMapByIndex(1);
        Map mapTo = loc.GetMapByIndex(0);
        Critter[] rats = map.GetCritters(CritterFindType::Npc);
        Critter[] allies = map.GetCritters(CritterFindType::Any);
        if (!rats.isEmpty()) {
            for (int i = 0; i < rats.length() && i < 5; i++) {
                Critter cr = rats[i];
                mpos hex;
                Entrance::MapGetEntryCoords(mapTo, ENTRY_SPAWN, 0, hex);
                if (Entrance::GetFreeHex(mapTo, 3, hex)) {
                    cr.TransferToMap(mapTo, hex, HDIR_Random);
                    cr.IsNoHome = true;
                    cr.StartTimeEvent(Time::Seconds(30), Move);
                    for (int j = 0; j < allies.length(); j++) {
                        Critter crit = allies[j];
                        if (crit.ControlledByPlayer || crit.NpcRole == 401) {
                            NpcPlanes::AddAttackPlane(cr, 0, crit);
                            EnemyStack::AddEnemyToStack(cr, crit.Id);
                        }
                    }
                }
            }

            // SavedDeferredCall — отложенный вызов должен переживать рестарт сервера (breadcrumb из исходника).
            Game.StartTimeEvent(Time::Seconds(Game.Random(1, 3)), MoveRat, value);
        }
    }
}

// Периодически ведёт перенесённую крысу к точке выхода ENTRY_MOVETO, пока та жива и без активных планов.
[[TimeEvent]] [[Async]]
void Move(Critter cr, TimeEventContext event)
{
    if (!Sync::LockCritterWithMap(cr)) {
        return;
    }

    if (cr.IsDead()) {
        return;
    }

    if (NpcPlanes::IsNoPlanes(cr)) {
        Map? map = cr.GetMap();
        mpos hex = cr.Hex;
        if (map != null && Entrance::MapGetEntryCoords(map, ENTRY_MOVETO, 0, hex)) {
            if (Entrance::GetFreeHex(map, 15, hex)) {
                NpcPlanes::AddWalkPlane(cr, 17, hex, HDIR_Random, false, 0);
            }
        }
    }

    timespan delayTicks = Time::Seconds(30);
    if (delayTicks != ZERO_TIMESPAN) {
        event.Repeat(delayTicks);
    }
}

#endif

}
