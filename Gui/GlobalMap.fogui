//               "OnInit":
{
    {
        {
            GMPos = Sprite::Sprite("art/intrface/GM_Town/town_view_sh.png");
            GMPosMove = Sprite::Sprite("art/intrface/GlobalMap/WMAPLOC.png");
            GMTarget = Sprite::Sprite("art/intrface/GlobalMap/WMAPTARG.png");
            GMEncOn = Sprite::Sprite("art/intrface/GlobalMap/WMAPFGT1.png");
            GMEncOff = Sprite::Sprite("art/intrface/GlobalMap/WMAPFGT0.png");
            GMEncSpecialOn = Sprite::Sprite("art/intrface/GlobalMap/WMRNDEN2.png");
            GMEncSpecialOff = Sprite::Sprite("art/intrface/GlobalMap/WMRNDEN3.png");
            FogFull = Sprite::Sprite("art/intrface/black_pixel.png");
        }
    }
}
//               "OnShow": null,
//               "OnHide": null,
//               "OnAppear": null,
//               "OnDisappear": null,
//               "OnDraw":
{
    {
        {
            string text;

            auto hoveredLocation = cast<GuiScreens::GlobalMap::LocationPic>(Gui::GetHoveredObject());
            if (hoveredLocation != null) {
                text += MSG_LOCATION(STR_LOC_NAME(hoveredLocation.Location.LocPid)) + "\\n";
            }

            auto gmBase = cast<GlobalMapBase>(Parent.Parent);
            auto globalMapObjects = cast<GMObjects>(Parent);

            GlobalMapFog::DrawFog(Parent.Parent.Pos + Parent.Pos, Settings.GlobalMapZoneLength * globalMapObjects.GlobalZoom, FogFull.Id);

            if (Parent.IsMouseHit()) {
                int CoordX = globalMapObjects.NormalX2(Game.MousePos.x - Parent.Pos.x - gmBase.AbsolutePos.x);
                int CoordY = globalMapObjects.NormalY2(Game.MousePos.y - Parent.Pos.y - gmBase.AbsolutePos.y);

                string Coordinates = MSG_GAME(MsgStr::StrGlobalMapCoordInfo);
                Coordinates = Game.ReplaceText(Coordinates, "%dx", CoordX);
                Coordinates = Game.ReplaceText(Coordinates, "%dy", CoordY);
                Coordinates = Game.ReplaceText(Coordinates, "%s", "\\n");
                Coordinates = Game.ReplaceText(Coordinates, "%zx", CoordX / Settings.GlobalMapZoneLength);
                Coordinates = Game.ReplaceText(Coordinates, "%zy", CoordY / Settings.GlobalMapZoneLength);

                text += Coordinates;

                Game.DrawText(text, ipos(Game.MousePos.x + 30, Game.MousePos.y + 10), isize(200, 100), COLOR_GREEN, FONT_DEFAULT, FT_BORDERED);
            }

            auto info = GlobalmapGroup::GetCurrentGroup();
            if (info.IsMoving) {
                GMTarget.Draw(ipos(globalMapObjects.NormalX(info.ToX) + gmBase.AbsolutePos.x + Parent.Pos.x,
                                   globalMapObjects.NormalY(info.ToY) + gmBase.AbsolutePos.y + Parent.Pos.y),
                              isize(),
                              0,
                              0);

                auto group = GlobalmapGroup::GetCurrentGroup();
                if (group != null) {
                    int[] points = array<int>(group.Points);
                    for (int i = 0; i < points.length(); i = i + 3) {
                        points[i] = globalMapObjects.NormalX(points[i]) + gmBase.AbsolutePos.x + Parent.Pos.x;
                        points[i + 1] = globalMapObjects.NormalY(points[i + 1]) + gmBase.AbsolutePos.y + Parent.Pos.y;
                    }
                    Game.DrawPrimitive(RenderPrimitiveType::PointList, points);
                }
            }
        }
    }
}
